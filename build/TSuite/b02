program ExoticAutomataProcessor;

type
  { A 2D matrix layout type mapping cell generations }
  TGrid = array of array of Integer;

  { The behavioral abstraction interface mapping engine operations }
  IGridEngine = interface
    procedure Setup(w, h: Integer);
    procedure Step;
    function GetGrid: TGrid;
    procedure AsyncTicker;
    procedure Shutdown;
  end;

  { Sizing cursor structure designed to test record-field loop variables }
  TLoopCursor = record
    Y: Integer;
    X: Integer;
  end;

  { Shared base record handling thread-safe logging infrastructures }
  TBaseEngine = record
    EngineName: string;
    LogMutex: Integer;
    procedure RecursiveSyncLog(depth: Integer; const msg: string); virtual;
  end;

  { Specialized concrete record inheriting fields/methods and executing matrix shifts }
  TAutomataEngine = record
    inherit TBaseEngine; { Composition-oriented record embedding }
    Width, Height: Integer;
    Matrix: TGrid;
    IsActive: Boolean;
    BackgroundThread: Integer;
    
    procedure Setup(w, h: Integer); virtual;
    procedure Step; virtual;
    function GetGrid: TGrid; virtual;
    procedure AsyncTicker; virtual;
    procedure Shutdown; virtual;
  end;

{ Deep multi-entrant logging function demonstrating rcmutex capabilities }
procedure TBaseEngine.RecursiveSyncLog(depth: Integer; const msg: string);
var
  eng: ^TBaseEngine;
begin
  eng := myself; { }
  lock(eng^.LogMutex);
  
  if depth > 0 then
  begin
    { Re-entering a locked recursive mutex frame safely }
    eng^.RecursiveSyncLog(depth - 1, msg);
  end
  else
  begin
    writeln('[LOG][', eng^.EngineName, '] Trace marker reached: ', msg);
  end;
  
  unlock(eng^.LogMutex);
end;

procedure TAutomataEngine.Setup(w, h: Integer);
var
  eng: ^TAutomataEngine;
begin
  eng := myself; { }
  eng^.Width := w;
  eng^.Height := h;
  eng^.IsActive := false;
  
  { Multi-dimensional dynamic array memory allocation }
  SetLength(eng^.Matrix, h, w);
  
  { Initialize a recursive mutex to support multi-entrant locking chains }
  eng^.LogMutex := rcmutex();
  if eng^.LogMutex < 0 then
    writeln('CRITICAL: Recursive mutex allocation error.');
end;

function TAutomataEngine.GetGrid: TGrid;
var
  eng: ^TAutomataEngine;
begin
  eng := myself; { }
  GetGrid := eng^.Matrix;
end;

procedure TAutomataEngine.Step;
var
  eng: ^TAutomataEngine;
  nextMatrix: TGrid;
  cursor: TLoopCursor; { Base variable for the field selector loop control test }

  { Exotic Pattern: Nested helper using try-except to parse matrix bounds }
  function ComputeNeighbors(const g: TGrid; y, x: Integer): Integer;
  var
    count: Integer;
  begin
    count := 0;
    { Intentionally trigger and trap out-of-bounds faults instead of manual margin checks }
    try if g[y - 1][x]     = 1 then count += 1; except end;
    try if g[y + 1][x]     = 1 then count += 1; except end;
    try if g[y][x - 1]     = 1 then count += 1; except end;
    try if g[y][x + 1]     = 1 then count += 1; except end;
    try if g[y - 1][x - 1] = 1 then count += 1; except end;
    try if g[y - 1][x + 1] = 1 then count += 1; except end;
    try if g[y + 1][x - 1] = 1 then count += 1; except end;
    try if g[y + 1][x + 1] = 1 then count += 1; except end;
    ComputeNeighbors := count;
  end;

begin
  eng := myself; { }
  SetLength(nextMatrix, eng^.Height, eng^.Width);

  { ------------------------------------------------------------------------- }
  { EXOTIC SYNTAX: RECORD-FIELD LOOP CONTROL VARIABLE COUNTERS                }
  { ------------------------------------------------------------------------- }
  { Iterates directly using record fields on a plain base variable }
  for cursor.Y := 0 to eng^.Height - 1 do
  begin
    for cursor.X := 0 to eng^.Width - 1 do
    begin
      var activeNeighbors: Integer;
      var currentCellState: Integer;
      
      activeNeighbors := ComputeNeighbors(eng^.Matrix, cursor.Y, cursor.X);
      currentCellState := eng^.Matrix[cursor.Y][cursor.X];
      
      { ------------------------------------------------------------------------- }
      { EXOTIC SYNTAX: NESTED C-STYLE TERNARY CONDITIONAL OPERATORS               }
      { ------------------------------------------------------------------------- }
      { Evaluates Game of Life standard logic via chained ternary branches }
      nextMatrix[cursor.Y][cursor.X] := (currentCellState = 1) ? 
        ((activeNeighbors < 2) or (activeNeighbors > 3) ? 0 : 1) : 
        (activeNeighbors = 3 ? 1 : 0);
    end;
  end;
  
  eng^.Matrix := nextMatrix;
end;

procedure TAutomataEngine.AsyncTicker;
var
  eng: ^TAutomataEngine;
begin
  eng := myself; { }
  eng^.IsActive := true;
  
  { ------------------------------------------------------------------------- }
  { EXOTIC SYNTAX: INLINE THREAD SPARKING CLOSURE VIA SPAWN(PROCEDURE)         }
  { ------------------------------------------------------------------------- }
  { Spawns an anonymous thread closure capturing enclosing context pointers }
  eng^.BackgroundThread := spawn(procedure
    begin
      while eng^.IsActive do
      begin
        eng^.Step();
        { Execute a thread-safe recursive multi-entrant lock trace verification }
        eng^.RecursiveSyncLog(2, 'Background generational iteration complete.');
      end;
    end);
end;

procedure TAutomataEngine.Shutdown;
var
  eng: ^TAutomataEngine;
  tID: Integer;
begin
  eng := myself; { }
  
  lock(eng^.LogMutex);
  eng^.IsActive := false;
  unlock(eng^.LogMutex);
  
  tID := eng^.BackgroundThread;
  join tID;
  
  if eng^.LogMutex >= 0 then
  begin
    destroy(eng^.LogMutex);
  end;
end;

{ Global helper routine matching our layout interface boundary extraction requirements }
function ExtractEngineGrid(const engine: IGridEngine): TGrid;
begin
  ExtractEngineGrid := engine.GetGrid();
end;

procedure RunExoticSimulation;
var
  rawEngine: ^TAutomataEngine;
  gridInterface: IGridEngine;
begin
  new(rawEngine);
  rawEngine^.EngineName := 'ConwayMatrix_Omega';
  
  { Box target record directly into an abstract layout structure }
  gridInterface := IGridEngine(rawEngine);
  gridInterface.Setup(6, 6);
  
  { Seed a Blinker pattern configuration into center layout components }
  rawEngine^.Matrix[2][1] := 1;
  rawEngine^.Matrix[2][2] := 1;
  rawEngine^.Matrix[2][3] := 1;
  
  writeln('Simulation seed generation mapping established.');

  { Fire background closure ticker framework loop }
  gridInterface.AsyncTicker;

  { Let the background ticker own generation stepping to avoid racing Step on the same engine }

  { ------------------------------------------------------------------------- }
  { EXOTIC SYNTAX: DIRECT FUNCTIONAL CALL SELECTOR INDEXING                   }
  { ------------------------------------------------------------------------- }
  { Evaluates multi-dimensional array selectors straight against function outcomes }
  var evaluatedCenterCell: Integer;
  evaluatedCenterCell := ExtractEngineGrid(gridInterface)[2][2];

  { ------------------------------------------------------------------------- }
  { EXOTIC SYNTAX: IMPLICIT MULTI-STATEMENT CASE ROUTING SYNTAX CHECK         }
  { ------------------------------------------------------------------------- }
  { Triggers multi-statement execution branches without requiring begin-end wrappers }
  case evaluatedCenterCell of
    0: writeln('State Log: Matrix processing center cell decayed.'); writeln('Triggering fallback check.');
    1: writeln('State Log: Matrix center survived generation tick cycles.'); rawEngine^.RecursiveSyncLog(0, 'Success check confirmed.');
  end;

  { Cleanly resolve background loops before unmapping infrastructure components }
  gridInterface.Shutdown;

  { ------------------------------------------------------------------------- }
  { EXOTIC SYNTAX: INTERFACE OBJECT TYPE IDENTIFICATION CHECKING             }
  { ------------------------------------------------------------------------- }
  if gridInterface is TAutomataEngine then
  begin
    var confirmedInstance: ^TAutomataEngine;
    confirmedInstance := gridInterface as TAutomataEngine;
    writeln('Final verified operational state dump for engine: ', confirmedInstance^.EngineName);
  end;

  dispose(rawEngine);
end;

begin
  RunExoticSimulation;
end.
