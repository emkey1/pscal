#!/usr/bin/env bash
# Auto-deploy the Aether compiler to ALL benchmark claws (claw1, claw2, claw3) whenever a
# commit changes the compiler, so benchmark runs always use the current language.
# Installed into .git/hooks/post-commit by tools/install_aether_autodeploy.sh.
#
# Runs in the background (non-blocking) and best-effort per host; a down claw never fails
# the commit. Log: /tmp/aether_autodeploy.log (per-host detail: /tmp/aether_deploy_<h>.log).
# Skips commits that don't touch aether/rea/pscal-core. Disable with AETHER_AUTODEPLOY=0.
[ "${AETHER_AUTODEPLOY:-${CLAW2_AUTODEPLOY:-1}}" = "0" ] && exit 0
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
# The bench binary is built from components/{aether,rea,pscal-core} only; a gitlink bump
# of any of those (or an in-tree source change) shows the component path in diff-tree.
if git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null \
     | grep -qE '^components/(aether|pscal-core|rea)(/|$)'; then
    echo "[post-commit] aether sources changed -> deploying to claw1/claw2/claw3 (background; log: /tmp/aether_autodeploy.log)"
    nohup bash "$ROOT/tools/deploy_aether_to_claws.sh" > /tmp/aether_autodeploy.log 2>&1 &
fi
exit 0
