#!/usr/bin/env python3
"""tiny language compiler targeting the Pscal VM.

This script parses a very small language described by the grammar in the
repository's README and emits Pscal bytecode so the resulting program can be
executed by ``pscalvm``.  Only integer variables and arithmetic are supported,
which is sufficient for basic demonstrations and educational purposes.

Usage::

    python tools/tiny source.tiny output.pbc

The output file can be executed with ``pscalvm``::

    ./build/bin/pscalvm output.pbc

"""
from __future__ import annotations

import re
import struct
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import List, Optional, Tuple, Dict, Any, Set

# ---------------------------------------------------------------------------
# Opcode loading
# ---------------------------------------------------------------------------

def pscal_core_root(root: Path) -> Path:
    """The umbrella repo builds pscal-core out of ``components/pscal-core``
    (see CLAUDE.md); the opcode/version sources this tool needs to stay in
    sync with live there, not directly under the umbrella's own ``src/``."""
    return root / "components" / "pscal-core"


def load_opcodes(root: Path) -> Dict[str, int]:
    """Parse ``opcodes.def`` (the single source of truth for the opcode page
    since VM 2.0 Phase 0 item 4 -- see that file's own header comment and
    Docs/pscal_vm_manual/pscal_vm_manual_ch3.md) to recover pinned opcode
    values. Values are explicit (hex or decimal) and NOT positional, unlike
    the old plain-enum scheme this used to (incorrectly, post-Phase 1a)
    assume."""
    opdef = pscal_core_root(root) / "src" / "compiler" / "opcodes.def"
    pattern = re.compile(r"^\s*OP\s*\(\s*([A-Z0-9_]+)\s*,\s*(0[xX][0-9A-Fa-f]+|\d+)\s*,")
    opcodes: Dict[str, int] = {}
    with open(opdef, "r", encoding="utf-8") as f:
        for line in f:
            stripped = line.strip()
            if stripped.startswith("//"):
                continue
            m = pattern.match(line)
            if m:
                opcodes[m.group(1)] = int(m.group(2), 0)
    return opcodes


def load_format_version(root: Path) -> int:
    """Parse ``cache.c`` for ``PSB3_FORMAT_VERSION``. This is a container-
    format constant (rare hard-cutover epoch bumps, e.g. 1->2 for the
    global-access cache side table, 2->3 for slot-addressed globals -- see
    Docs/pscal_vm2_plan.md), distinct from the per-compile ``PSCAL_VM_VERSION``
    in ``version.h`` that ``load_vm_version`` below reads."""
    cache_c = pscal_core_root(root) / "src" / "core" / "cache.c"
    pattern = re.compile(r"#define\s+PSB3_FORMAT_VERSION\s+(\d+)")
    with open(cache_c, "r", encoding="utf-8") as f:
        for line in f:
            m = pattern.search(line)
            if m:
                return int(m.group(1))
    raise RuntimeError("Unable to determine PSB3_FORMAT_VERSION")

# VarType enum (partial). Stable, positional values (unlike OpCode, VarType
# has not been given the pinned-explicit-value treatment): TYPE_UNKNOWN=0,
# TYPE_VOID=1, TYPE_INT32(aliased TYPE_INTEGER)=2, TYPE_DOUBLE=3, TYPE_STRING=4.
TYPE_INTEGER = 2
TYPE_STRING = 4

# ---------------------------------------------------------------------------
# Lexer
# ---------------------------------------------------------------------------

TOKEN_REGEX = re.compile(
    r"\s*(?:"  # Skip leading whitespace
    r"(?P<id>[A-Za-z_][A-Za-z_0-9]*)"
    r"|(?P<num>\d+)"
    r"|(?P<assign>:=)"
    r"|(?P<op>[+\-*/<>=;()])"
    r"|(?P<unknown>.)"
    r")"
)

KEYWORDS = {
    "if", "then", "else", "end",
    "repeat", "until",
    "read", "write",
}

@dataclass
class Token:
    type: str
    value: str


def tokenize(source: str) -> List[Token]:
    # Remove comments enclosed in curly braces. Comments do not nest and may
    # span multiple lines, so we simply strip everything between a ``{`` and
    # the next ``}``.
    source = re.sub(r"\{[^}]*\}", " ", source)

    tokens: List[Token] = []
    for match in TOKEN_REGEX.finditer(source):
        if match.group("id"):
            val = match.group("id")
            typ = val.lower() if val.lower() in KEYWORDS else "IDENT"
            tokens.append(Token(typ, val))
        elif match.group("num"):
            tokens.append(Token("NUMBER", match.group("num")))
        elif match.group("assign"):
            tokens.append(Token(":=", ":="))
        elif match.group("op"):
            tokens.append(Token(match.group("op"), match.group("op")))
        elif match.group("unknown"):
            raise SyntaxError(f"Unknown token: {match.group('unknown')}")
    tokens.append(Token("EOF", ""))
    return tokens

# ---------------------------------------------------------------------------
# Parser AST definitions
# ---------------------------------------------------------------------------

@dataclass
class Node:
    pass

@dataclass
class Program(Node):
    statements: List[Node]

@dataclass
class Assign(Node):
    name: str
    expr: Node

@dataclass
class Read(Node):
    name: str

@dataclass
class Write(Node):
    expr: Optional[Node] = None

@dataclass
class If(Node):
    cond: Node
    then_branch: List[Node]
    else_branch: Optional[List[Node]]

@dataclass
class Repeat(Node):
    body: List[Node]
    cond: Node

@dataclass
class BinOp(Node):
    left: Node
    op: str
    right: Node

@dataclass
class Num(Node):
    value: int

@dataclass
class Var(Node):
    name: str

# ---------------------------------------------------------------------------
# Recursive descent parser
# ---------------------------------------------------------------------------

class Parser:
    def __init__(self, tokens: List[Token]):
        self.tokens = tokens
        self.pos = 0

    def current(self) -> Token:
        return self.tokens[self.pos]

    def consume(self, typ: str) -> Token:
        tok = self.current()
        if tok.type != typ:
            raise SyntaxError(f"Expected {typ}, got {tok.type}")
        self.pos += 1
        return tok

    def parse(self) -> Program:
        stmts = self.statement_sequence()
        self.consume("EOF")
        return Program(stmts)

    def statement_sequence(self) -> List[Node]:
        stmts = [self.statement()]
        while self.current().type == ";":
            self.consume(";")
            stmts.append(self.statement())
        return stmts

    def statement(self) -> Node:
        tok = self.current()
        if tok.type == "if":
            return self.if_statement()
        if tok.type == "repeat":
            return self.repeat_statement()
        if tok.type == "read":
            self.consume("read")
            name = self.consume("IDENT").value
            return Read(name)
        if tok.type == "write":
            self.consume("write")
            if self.current().type in {";", "until", "end", "else", "EOF"}:
                return Write(None)
            expr = self.expression()
            return Write(expr)
        if tok.type == "IDENT":
            name = self.consume("IDENT").value
            self.consume(":=")
            expr = self.expression()
            return Assign(name, expr)
        raise SyntaxError(f"Unexpected token {tok.type}")

    def if_statement(self) -> If:
        self.consume("if")
        cond = self.expression()
        self.consume("then")
        then_branch = self.statement_sequence()
        else_branch = None
        if self.current().type == "else":
            self.consume("else")
            else_branch = self.statement_sequence()
        self.consume("end")
        return If(cond, then_branch, else_branch)

    def repeat_statement(self) -> Repeat:
        self.consume("repeat")
        body = self.statement_sequence()
        self.consume("until")
        cond = self.expression()
        return Repeat(body, cond)

    def expression(self) -> Node:
        node = self.simple_expression()
        tok = self.current()
        if tok.type in ("<", "="):
            self.consume(tok.type)
            right = self.simple_expression()
            node = BinOp(node, tok.type, right)
        return node

    def simple_expression(self) -> Node:
        node = self.term()
        while self.current().type in ("+", "-"):
            op = self.current().type
            self.consume(op)
            right = self.term()
            node = BinOp(node, op, right)
        return node

    def term(self) -> Node:
        node = self.factor()
        while self.current().type in ("*", "/"):
            op = self.current().type
            self.consume(op)
            right = self.factor()
            node = BinOp(node, op, right)
        return node

    def factor(self) -> Node:
        tok = self.current()
        if tok.type == "(" :
            self.consume("(")
            node = self.expression()
            self.consume(")")
            return node
        if tok.type == "NUMBER":
            self.consume("NUMBER")
            return Num(int(tok.value))
        if tok.type == "IDENT":
            self.consume("IDENT")
            return Var(tok.value)
        raise SyntaxError(f"Unexpected token {tok.type}")

# ---------------------------------------------------------------------------
# Bytecode builder and emitter helpers
# ---------------------------------------------------------------------------

class BytecodeBuilder:
    def __init__(self, opcodes: Dict[str, int]):
        self.opcodes = opcodes
        self.code: List[int] = []
        self.lines: List[int] = []
        self.constants: List[Tuple[int, Any]] = []
        self.const_map: Dict[Tuple[int, Any], int] = {}

    def emit(self, byte: int) -> None:
        self.code.append(byte & 0xFF)
        self.lines.append(0)

    def emit_short(self, value: int) -> None:
        self.emit((value >> 8) & 0xFF)
        self.emit(value & 0xFF)

    def emit_int32(self, value: int) -> None:
        # Big-endian i32, matching opcodes.def's 'j' spec (VM 2.0 Phase 1c
        # widened jump displacements from i16 to i32 -- rides the PSB3 format
        # epoch since it changes the on-disk code-stream encoding).
        self.emit((value >> 24) & 0xFF)
        self.emit((value >> 16) & 0xFF)
        self.emit((value >> 8) & 0xFF)
        self.emit(value & 0xFF)

    def add_constant(self, ctype: int, value: Any) -> int:
        key = (ctype, value)
        if key in self.const_map:
            return self.const_map[key]
        idx = len(self.constants)
        self.constants.append((ctype, value))
        self.const_map[key] = idx
        return idx

    def emit_constant(self, value: int) -> None:
        idx = self.add_constant(TYPE_INTEGER, value)
        if idx <= 0xFF:
            self.emit(self.opcodes["CONSTANT"])
            self.emit(idx)
        else:
            self.emit(self.opcodes["CONSTANT16"])
            self.emit_short(idx)

# ---------------------------------------------------------------------------
# Compiler
# ---------------------------------------------------------------------------

class tinyCompiler:
    def __init__(self, root: Path):
        self.root = root
        self.opcodes = load_opcodes(root)
        self.builder = BytecodeBuilder(self.opcodes)
        self.vars: Set[str] = set()
        self.var_name_idx: Dict[str, int] = {}
        self.read_idx = self.builder.add_constant(TYPE_STRING, "read")
        self.write_idx = self.builder.add_constant(TYPE_STRING, "write")
        self.const_true_idx = self.builder.add_constant(TYPE_INTEGER, 1)
        self.const_false_idx = self.builder.add_constant(TYPE_INTEGER, 0)
        self.type_integer_idx = self.builder.add_constant(TYPE_STRING, "integer")

    # --- AST Traversal to collect variables ---
    def collect_vars(self, node: Node) -> None:
        if isinstance(node, Var):
            self.vars.add(node.name)
        for child in getattr(node, "__dict__", {}).values():
            if isinstance(child, list):
                for c in child:
                    if isinstance(c, Node):
                        self.collect_vars(c)
            elif isinstance(child, Node):
                self.collect_vars(child)

    # --- Top-level compile ---
    def compile(self, program: Program) -> BytecodeBuilder:
        self.collect_vars(program)
        # Emit definitions for all variables. VM 2.0 Phase 2b (plan §5.7)
        # retired DEFINE_GLOBAL/DEFINE_GLOBAL16 in favor of a single
        # DEFINE_GLOBAL_SLOT opcode carrying a u16 field: the compiler still
        # emits a constant-pool NAME index here (the load-time link step
        # rewrites it into a slot index before verification/execution), but
        # the width is now always 16 bits, so there is no size split to emit.
        for name in sorted(self.vars):
            name_idx = self.builder.add_constant(TYPE_STRING, name)
            self.var_name_idx[name] = name_idx
            self.builder.emit(self.opcodes["DEFINE_GLOBAL_SLOT"])
            self.builder.emit_short(name_idx)
            self.builder.emit(TYPE_INTEGER)
            self.builder.emit_short(self.type_integer_idx)
        # Compile statements
        for stmt in program.statements:
            self.compile_statement(stmt)

        # Ensure every program terminates with a newline for clean output
        self.builder.emit(self.opcodes["CONSTANT"])
        self.builder.emit(self.const_true_idx)
        self.builder.emit(self.opcodes["CALL_BUILTIN"])
        self.builder.emit_short(self.write_idx)
        self.builder.emit(1)
        self.builder.emit(self.opcodes["HALT"])
        return self.builder

    # --- Statement compilation ---
    def compile_statement(self, stmt: Node) -> None:
        if isinstance(stmt, Assign):
            self.compile_expression(stmt.expr)
            name_idx = self.var_name_idx[stmt.name]
            self.emit_global_addr(name_idx)
            self.builder.emit(self.opcodes["SWAP"])
            self.builder.emit(self.opcodes["SET_INDIRECT"])
        elif isinstance(stmt, Read):
            name_idx = self.var_name_idx[stmt.name]
            self.emit_global_addr(name_idx)
            self.builder.emit(self.opcodes["CALL_BUILTIN"])
            self.builder.emit_short(self.read_idx)
            self.builder.emit(1)  # argument count
        elif isinstance(stmt, Write):
            if stmt.expr is None:
                self.builder.emit(self.opcodes["CONSTANT"])
                self.builder.emit(self.const_true_idx)
                self.builder.emit(self.opcodes["CALL_BUILTIN"])
                self.builder.emit_short(self.write_idx)
                self.builder.emit(1)
            else:
                self.builder.emit(self.opcodes["CONSTANT"])
                self.builder.emit(self.const_false_idx)
                self.compile_expression(stmt.expr)
                self.builder.emit(self.opcodes["CALL_BUILTIN"])
                self.builder.emit_short(self.write_idx)
                self.builder.emit(2)
        elif isinstance(stmt, If):
            self.compile_expression(stmt.cond)
            self.builder.emit(self.opcodes["JUMP_IF_FALSE"])
            jump_to_else = len(self.builder.code)
            self.builder.emit_int32(0)
            for s in stmt.then_branch:
                self.compile_statement(s)
            if stmt.else_branch:
                self.builder.emit(self.opcodes["JUMP"])
                jump_over_else = len(self.builder.code)
                self.builder.emit_int32(0)
                offset = len(self.builder.code) - (jump_to_else + 4)
                self.patch_int32(jump_to_else, offset)
                for s in stmt.else_branch:
                    self.compile_statement(s)
                offset = len(self.builder.code) - (jump_over_else + 4)
                self.patch_int32(jump_over_else, offset)
            else:
                offset = len(self.builder.code) - (jump_to_else + 4)
                self.patch_int32(jump_to_else, offset)
        elif isinstance(stmt, Repeat):
            loop_start = len(self.builder.code)
            for s in stmt.body:
                self.compile_statement(s)
            self.compile_expression(stmt.cond)
            self.builder.emit(self.opcodes["JUMP_IF_FALSE"])
            backward = loop_start - (len(self.builder.code) + 4)
            self.builder.emit_int32(backward)
        else:
            raise NotImplementedError(f"Unhandled statement {stmt}")

    def patch_short(self, pos: int, value: int) -> None:
        self.builder.code[pos] = (value >> 8) & 0xFF
        self.builder.code[pos + 1] = value & 0xFF

    def patch_int32(self, pos: int, value: int) -> None:
        self.builder.code[pos] = (value >> 24) & 0xFF
        self.builder.code[pos + 1] = (value >> 16) & 0xFF
        self.builder.code[pos + 2] = (value >> 8) & 0xFF
        self.builder.code[pos + 3] = value & 0xFF

    def emit_global_addr(self, name_idx: int) -> None:
        # GET_GLOBAL_ADDRESS/GET_GLOBAL_ADDRESS16 -> GET_GSLOT_ADDRESS
        # (VM 2.0 Phase 2b, plan §5.7): single opcode, u16 field.
        self.builder.emit(self.opcodes["GET_GSLOT_ADDRESS"])
        self.builder.emit_short(name_idx)

    # --- Expression compilation ---
    def compile_expression(self, expr: Node) -> None:
        if isinstance(expr, Num):
            self.builder.emit_constant(expr.value)
        elif isinstance(expr, Var):
            # GET_GLOBAL/GET_GLOBAL16 -> GET_GSLOT (VM 2.0 Phase 2b, plan
            # §5.7): a plain slot-indexed load, no inline cache slot to emit
            # at all (Phase 2a's global-access cache side table exists only
            # for the retired name-addressed family; slot access needs no
            # caching -- it's already just an array index).
            name_idx = self.var_name_idx[expr.name]
            self.builder.emit(self.opcodes["GET_GSLOT"])
            self.builder.emit_short(name_idx)
        elif isinstance(expr, BinOp):
            self.compile_expression(expr.left)
            self.compile_expression(expr.right)
            opmap = {
                "+": "ADD",
                "-": "SUBTRACT",
                "*": "MULTIPLY",
                "/": "DIVIDE",
                "<": "LESS",
                "=": "EQUAL",
            }
            self.builder.emit(self.opcodes[opmap[expr.op]])
        else:
            raise NotImplementedError(f"Unhandled expression {expr}")

# ---------------------------------------------------------------------------
# Serialization -- PSB3 container (VM 2.0 plan §5.2; Docs/pscal_vm_manual/
# pscal_vm_manual_ch2.md documents the format this replicates). PSB3 is a
# hard cutover from the old PSB2 layout this used to emit directly (plan §2:
# "one format, one loader" -- there is no PSB2 reader left in the VM at all),
# so this whole section is a from-scratch reimplementation, not a patch.
# ---------------------------------------------------------------------------

PSB3_MAGIC = 0x50534233  # 'PSB3'


def psb3_fourcc(s: str) -> int:
    b = s.encode("ascii")
    return b[0] | (b[1] << 8) | (b[2] << 16) | (b[3] << 24)


PSB3_SEC_CODE = psb3_fourcc("CODE")
PSB3_SEC_LINE = psb3_fourcc("LINE")
PSB3_SEC_CONS = psb3_fourcc("CONS")
PSB3_SEC_BMAP = psb3_fourcc("BMAP")
PSB3_SEC_PROC = psb3_fourcc("PROC")
PSB3_SEC_TYPE = psb3_fourcc("TYPE")
PSB3_SECTION_ALIGN = 8

FNV1A64_OFFSET = 1469598103934665603
FNV1A64_MASK = (1 << 64) - 1


def load_vm_version(root: Path) -> int:
    """Parse ``version.h`` to obtain the VM bytecode version.

    The tiny compiler needs to embed the same version number as the VM uses
    when writing bytecode files. Previously this value was hard-coded and could
    fall out of sync with the VM, leading to warnings about "stale" bytecode.
    By loading the version dynamically we ensure the tiny frontend always
    targets the correct VM version without manual updates when the core VM
    version changes.
    """

    version_header = pscal_core_root(root) / "src" / "core" / "version.h"
    pattern = re.compile(r"#define\s+PSCAL_VM_VERSION\s+(\d+)")
    with open(version_header, "r", encoding="utf-8") as f:
        for line in f:
            m = pattern.search(line)
            if m:
                return int(m.group(1))
    raise RuntimeError("Unable to determine PSCAL_VM_VERSION")


def _put_varint(buf: bytearray, v: int) -> None:
    """Unsigned LEB128: 7 payload bits per byte, MSB = continuation."""
    if v < 0:
        raise ValueError("varint requires a non-negative value")
    while True:
        byte = v & 0x7F
        v >>= 7
        if v:
            buf.append(byte | 0x80)
        else:
            buf.append(byte)
            return


def _put_svarint(buf: bytearray, v: int) -> None:
    """Zigzag-encoded signed varint, matching cache.c's bufSVarint."""
    zigzag = ((v << 1) ^ (v >> 63)) & FNV1A64_MASK
    _put_varint(buf, zigzag)


def _put_len_prefixed(buf: bytearray, data: bytes) -> None:
    _put_varint(buf, len(data))
    buf.extend(data)


def _fnv1a64_update(h: int, data: bytes) -> int:
    for byte in data:
        h ^= byte
        h = (h * 0x100000001B3) & FNV1A64_MASK
    return h


def _write_value(buf: bytearray, ctype: int, val) -> None:
    """Mirrors cache.c's writeValue() for the two constant kinds tiny emits."""
    buf.extend(struct.pack("<I", ctype))
    if ctype == TYPE_INTEGER:
        buf.extend(struct.pack("<Q", int(val) & 0xFFFFFFFFFFFFFFFF))
    elif ctype == TYPE_STRING:
        if val is None:
            buf.append(0)
        else:
            buf.append(1)
            _put_len_prefixed(buf, val.encode("utf-8"))
    else:
        raise NotImplementedError("Unsupported constant type")


def _write_code_section(code: bytes) -> bytes:
    buf = bytearray()
    _put_varint(buf, len(code))
    _put_varint(buf, 0)  # cache_count: tiny never uses global-access caches
    buf.extend(code)
    return bytes(buf)


def _write_lines_section(line_count: int) -> bytes:
    # tiny doesn't track source lines; one run covering the whole chunk at
    # line 0 (matching the old PSB2 output's all-zero lines[] array).
    buf = bytearray()
    if line_count == 0:
        _put_varint(buf, 0)
        return bytes(buf)
    _put_varint(buf, 1)          # run_count
    _put_varint(buf, 0)          # pc_delta (first run always starts at pc 0)
    _put_svarint(buf, 0)         # line_delta (line stays 0)
    return bytes(buf)


def _write_const_section(consts: List[Tuple[int, Any]]) -> bytes:
    buf = bytearray()
    _put_varint(buf, len(consts))
    for ctype, val in consts:
        _write_value(buf, ctype, val)
    return bytes(buf)


def _write_bmap_section() -> bytes:
    # tiny emits no builtin-lowercase-map entries; an empty map's fingerprint
    # is simply the untouched FNV-1a offset basis (cache.c's
    # computeBuiltinFingerprintEntry/writeBmapSection never folds anything in
    # when builtin_map_count is 0).
    buf = bytearray()
    _put_varint(buf, 0)  # builtin_map_count
    buf.extend(struct.pack("<Q", FNV1A64_OFFSET))
    return bytes(buf)


def _write_procs_section() -> bytes:
    # tiny never emits procedures or Pascal-style const globals.
    buf = bytearray()
    _put_varint(buf, 0)  # proc_count
    _put_varint(buf, 0)  # const_sym_count
    return bytes(buf)


def _write_types_section() -> bytes:
    buf = bytearray()
    _put_varint(buf, 0)  # type_count
    return bytes(buf)


def write_bytecode(builder: BytecodeBuilder, path: Path, vm_version: int, format_version: int) -> None:
    code = bytes(builder.code)
    sections = [
        (PSB3_SEC_CODE, _write_code_section(code)),
        (PSB3_SEC_LINE, _write_lines_section(len(code))),
        (PSB3_SEC_CONS, _write_const_section(builder.constants)),
        (PSB3_SEC_BMAP, _write_bmap_section()),
        (PSB3_SEC_PROC, _write_procs_section()),
        (PSB3_SEC_TYPE, _write_types_section()),
    ]

    header = bytearray()
    header.extend(struct.pack("<I", PSB3_MAGIC))
    header.extend(struct.pack("<H", format_version))
    header.extend(struct.pack("<H", vm_version))
    header.extend(struct.pack("<I", 0))            # flags: reserved
    header.extend(struct.pack("<I", len(sections)))  # section_count

    dir_entry_size = 12  # id:u32 + offset:u32 + length:u32
    running_offset = len(header) + len(sections) * dir_entry_size
    running_offset = (running_offset + (PSB3_SECTION_ALIGN - 1)) & ~(PSB3_SECTION_ALIGN - 1)
    offsets = []
    for _sec_id, body in sections:
        offsets.append(running_offset)
        running_offset += len(body)
        running_offset = (running_offset + (PSB3_SECTION_ALIGN - 1)) & ~(PSB3_SECTION_ALIGN - 1)

    directory = bytearray()
    for (sec_id, body), offset in zip(sections, offsets):
        directory.extend(struct.pack("<III", sec_id, offset, len(body)))

    with open(path, "wb") as f:
        f.write(bytes(header))
        f.write(bytes(directory))
        written = len(header) + len(directory)
        for (_sec_id, body), offset in zip(sections, offsets):
            if written < offset:
                f.write(b"\x00" * (offset - written))
                written = offset
            f.write(body)
            written += len(body)
            aligned = (written + (PSB3_SECTION_ALIGN - 1)) & ~(PSB3_SECTION_ALIGN - 1)
            if written < aligned:
                f.write(b"\x00" * (aligned - written))
                written = aligned
        # Builtin lowercase mapping count (tiny backend does not emit metadata)
        f.write(struct.pack("<i", 0))
        # Procedure table uses the convention stored_proc_count = -(count + 1).
        # The tiny frontend never emits procedures, so we write -1 to signal
        # an empty table to match the VM loader's expectations.
        f.write(struct.pack("<i", -1))
        # Constant symbol table and type table counts (both zero for tiny)
        f.write(struct.pack("<i", 0))
        f.write(struct.pack("<i", 0))

# ---------------------------------------------------------------------------
# Main entry
# ---------------------------------------------------------------------------

def main(argv: List[str]) -> int:
    if len(argv) != 3:
        print("Usage: tiny source.tiny output.pbc", file=sys.stderr)
        return 1
    src_path = Path(argv[1])
    out_path = Path(argv[2])
    source = src_path.read_text(encoding="utf-8")
    tokens = tokenize(source)
    program = Parser(tokens).parse()
    compiler = tinyCompiler(Path(__file__).resolve().parent.parent)
    builder = compiler.compile(program)
    vm_version = load_vm_version(compiler.root)
    format_version = load_format_version(compiler.root)
    write_bytecode(builder, out_path, vm_version, format_version)
    return 0

if __name__ == "__main__":
    sys.exit(main(sys.argv))
