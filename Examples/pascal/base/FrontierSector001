    if (Borg.Health <= 0) then
        Exit;
    if (Borg.QX = Ship.QX) and (Borg.QY = Ship.QY) then
    begin
        dmg := 60 + NextRandInt(110);
        if Ship.Shields >= dmg then
            Ship.Shields := Ship.Shields - dmg
        else
        begin
            Ship.Energy := Ship.Energy - (dmg - Ship.Shields);
            Ship.Shields := 0;
        end;
        AddLog('Borg attack! Damage=' + IntToStr(dmg));
    end;
end;

