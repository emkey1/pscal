procedure SetFromGlobal(gx, gy: Integer; var qx, qy, sx, sy: Integer);
begin
    qx := ((gx - 1) div GRID_SIZE) + 1;
    sx := ((gx - 1) mod GRID_SIZE) + 1;
    qy := ((gy - 1) div GRID_SIZE) + 1;
    sy := ((gy - 1) mod GRID_SIZE) + 1;
end;

function NormalizeSpaces(const s: string): string;
var
    i: Integer;
    outS: string;
    prevSpace: Boolean;
    ch: Char;
begin
    outS := '';
    prevSpace := True;
    for i := 1 to Length(s) do
    begin
        ch := s[i];
        if (ch = ' ') or (ch = #9) then
        begin
            if (not prevSpace) then
            begin
                outS := outS + ' ';
                prevSpace := True;
            end;
        end
        else
        begin
            outS := outS + ch;
            prevSpace := False;
        end;
    end;
    if (Length(outS) > 0) and (outS[Length(outS)] = ' ') then
        RemoveLastChar(outS);
    NormalizeSpaces := outS;
end;

procedure ParseCommandLine(raw: string; var cmd, args: string);
var
    p: Integer;
begin
    UpperString(raw);
    raw := NormalizeSpaces(raw);
    p := Pos(' ', raw);
    if p = 0 then
    begin
        cmd := raw;
        args := '';
    end
    else
    begin
        cmd := Copy(raw, 1, p - 1);
        args := Copy(raw, p + 1, Length(raw) - p);
    end;
end;

procedure NormalizeCommandAlias(var cmd: string);
begin
    if (cmd = 'N') or (cmd = 'MOVE') or (cmd = 'WARP') then cmd := 'NAV'
    else if (cmd = 'SCAN') or (cmd = 'SHORT') then cmd := 'SRS'
    else if (cmd = 'LONG') or (cmd = 'GALAXY') then cmd := 'LRS'
    else if (cmd = 'PHASER') then cmd := 'PHA'
    else if (cmd = 'TORPEDO') then cmd := 'TOR'
    else if (cmd = 'SHIELD') then cmd := 'SHE'
    else if (cmd = 'TRADE') or (cmd = 'DOCK') then cmd := 'PORT'
    else if (cmd = 'MAP') then cmd := 'SRS'
    else if (cmd = 'STATUS') then cmd := 'STA'
    else if (cmd = 'EXITPOCKET') or (cmd = 'EXITP') then cmd := 'EXITP'
    else if (cmd = 'RESTORE') then cmd := 'LOAD'
    else if (cmd = '?') then cmd := 'HELP'
    else if (cmd = 'EXIT') then cmd := 'QUIT';
end;

function Parse4Ints(args: string; var a, b, c, d: Integer): Boolean;
var
    p1, p2, p3, code: Integer;
    t1, t2, t3, t4: string;
begin
    Parse4Ints := False;
    args := NormalizeSpaces(args);
    p1 := Pos(' ', args);
    if p1 = 0 then Exit;
    t1 := Copy(args, 1, p1 - 1);
    args := Copy(args, p1 + 1, Length(args) - p1);
    p2 := Pos(' ', args);
    if p2 = 0 then Exit;
    t2 := Copy(args, 1, p2 - 1);
    args := Copy(args, p2 + 1, Length(args) - p2);
    p3 := Pos(' ', args);
    if p3 = 0 then Exit;
    t3 := Copy(args, 1, p3 - 1);
    t4 := Copy(args, p3 + 1, Length(args) - p3);

    Val(t1, a, code); if code <> 0 then Exit;
    Val(t2, b, code); if code <> 0 then Exit;
    Val(t3, c, code); if code <> 0 then Exit;
    Val(t4, d, code); if code <> 0 then Exit;
    Parse4Ints := True;
end;

