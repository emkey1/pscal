end;

function NextRandInt(maxValue: Integer): Integer;
const
    PM_A = 16807;
    PM_M = 2147483647;
    PM_Q = 127773;
    PM_R = 2836;
var
    hi, lo, test: Integer;
begin
    if maxValue <= 0 then
    begin
        NextRandInt := 0;
        Exit;
    end;
    if GameSeed <= 0 then
        GameSeed := 1;
    hi := GameSeed div PM_Q;
    lo := GameSeed mod PM_Q;
    test := PM_A * lo - PM_R * hi;
    if test > 0 then
        GameSeed := test
    else
        GameSeed := test + PM_M;
    NextRandInt := GameSeed mod maxValue;
end;

procedure ClearSectorFlags;
var
    qx, qy, sx, sy, i: Integer;
begin
    for i := 1 to MAX_POCKETS do
    begin
        Pockets[i].Active := False;
        Pockets[i].EntranceQX := 0;
        Pockets[i].EntranceQY := 0;
        Pockets[i].EntranceSX := 0;
        Pockets[i].EntranceSY := 0;
        Pockets[i].FortLevel := 0;
        Pockets[i].Hull := 0;
        Pockets[i].MaxHull := 0;
        Pockets[i].StoredCredits := 0;
    end;
    for qx := 1 to GRID_SIZE do
        for qy := 1 to GRID_SIZE do
        begin
            Galaxy[qx, qy].Scanned := False;
            Galaxy[qx, qy].BorgCount := 0;
            Galaxy[qx, qy].PortCount := 0;
            Galaxy[qx, qy].GatewayCount := 0;
            for sx := 1 to GRID_SIZE do
                for sy := 1 to GRID_SIZE do
                begin
                    Galaxy[qx, qy].Sectors[sx, sy].HasBorg := False;
                    Galaxy[qx, qy].Sectors[sx, sy].HasPort := False;
                    Galaxy[qx, qy].Sectors[sx, sy].HasGateway := False;
                    Galaxy[qx, qy].Sectors[sx, sy].GatewayID := 0;
                    Galaxy[qx, qy].Sectors[sx, sy].PortInfo.Active := False;
                end;
        end;
end;

function CargoUsed: Integer;
begin
    CargoUsed := Ship.CargoBay.Ore + Ship.CargoBay.Organics + Ship.CargoBay.Equipment;
end;

function NetWorth: Integer;
var
    i: Integer;
begin
    NetWorth := Ship.Credits +
        Ship.CargoBay.Ore * 7 +
        Ship.CargoBay.Organics * 9 +
        Ship.CargoBay.Equipment * 12;
    for i := 1 to MAX_POCKETS do
        if Pockets[i].Active then
            NetWorth := NetWorth + Pockets[i].StoredCredits;
end;

function CurrentSectorHasGateway: Boolean;
begin
    CurrentSectorHasGateway := Galaxy[Ship.QX, Ship.QY].Sectors[Ship.SX, Ship.SY].HasGateway;
end;

function CurrentGatewayID: Integer;
begin
    if CurrentSectorHasGateway() then
        CurrentGatewayID := Galaxy[Ship.QX, Ship.QY].Sectors[Ship.SX, Ship.SY].GatewayID
    else
        CurrentGatewayID := 0;
end;

procedure PlaceGateways;
var
    want, placed, tries: Integer;
    qx, qy, sx, sy, id: Integer;
begin
    want := 3 + NextRandInt(3);
    if want > MAX_POCKETS then
        want := MAX_POCKETS;
    placed := 0;
    tries := 0;
    while (placed < want) and (tries < 10000) do
    begin
        tries := tries + 1;
        qx := NextRandInt(GRID_SIZE) + 1;
        qy := NextRandInt(GRID_SIZE) + 1;
        sx := NextRandInt(GRID_SIZE) + 1;
        sy := NextRandInt(GRID_SIZE) + 1;
        if (qx = 1) and (qy = 1) and (sx = 1) and (sy = 1) then
            Continue;
        if Galaxy[qx, qy].Sectors[sx, sy].HasPort then
            Continue;
        if Galaxy[qx, qy].Sectors[sx, sy].HasGateway then
            Continue;
        placed := placed + 1;
        id := placed;
        Galaxy[qx, qy].Sectors[sx, sy].HasGateway := True;
        Galaxy[qx, qy].Sectors[sx, sy].GatewayID := id;
        Galaxy[qx, qy].GatewayCount := Galaxy[qx, qy].GatewayCount + 1;
        Pockets[id].Active := True;
        Pockets[id].EntranceQX := qx;
        Pockets[id].EntranceQY := qy;
        Pockets[id].EntranceSX := sx;
        Pockets[id].EntranceSY := sy;
        Pockets[id].FortLevel := 0;
        Pockets[id].MaxHull := 900;
        Pockets[id].Hull := Pockets[id].MaxHull;
        Pockets[id].StoredCredits := 0;
    end;
end;

