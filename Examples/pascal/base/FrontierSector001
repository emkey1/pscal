procedure TickPirates;
var
    chance, loss, cargoLoss, pocketHit: Integer;
begin
    if InPocket then
    begin
        if (CurrentPocket >= 1) and (CurrentPocket <= MAX_POCKETS) and Pockets[CurrentPocket].Active then
        begin
            chance := 6 + Pockets[CurrentPocket].FortLevel * 2;
            if chance > 30 then
                chance := 30;
            if NextRandInt(100) < chance then
            begin
                pocketHit := 40 + NextRandInt(90);
                if Pockets[CurrentPocket].Hull > pocketHit then
                    Pockets[CurrentPocket].Hull := Pockets[CurrentPocket].Hull - pocketHit
                else
                    Pockets[CurrentPocket].Hull := 0;
                AddLog('Pirate raid hits pocket ' + IntToStr(CurrentPocket) + ' for ' + IntToStr(pocketHit) + ' hull.');
                if Pockets[CurrentPocket].Hull <= 0 then
                begin
                    AddLog('Pocket defense collapsed. Stored credits lost.');
                    Pockets[CurrentPocket].StoredCredits := 0;
                    Pockets[CurrentPocket].Hull := Pockets[CurrentPocket].MaxHull div 2;
                    if Pockets[CurrentPocket].Hull < 100 then
                        Pockets[CurrentPocket].Hull := 100;
                end;
            end;
        end;
        Exit;
    end;

    chance := 15;
    if NextRandInt(100) < chance then
    begin
        if CargoUsed() > 0 then
        begin
            cargoLoss := 1 + NextRandInt(3);
            while (cargoLoss > 0) and (Ship.CargoBay.Ore > 0) do
            begin
                Ship.CargoBay.Ore := Ship.CargoBay.Ore - 1;
                cargoLoss := cargoLoss - 1;
            end;
            while (cargoLoss > 0) and (Ship.CargoBay.Organics > 0) do
            begin
                Ship.CargoBay.Organics := Ship.CargoBay.Organics - 1;
                cargoLoss := cargoLoss - 1;
            end;
            while (cargoLoss > 0) and (Ship.CargoBay.Equipment > 0) do
            begin
                Ship.CargoBay.Equipment := Ship.CargoBay.Equipment - 1;
                cargoLoss := cargoLoss - 1;
            end;
            AddLog('Pirates ambush convoy. Cargo was stolen.');
        end
        else
        begin
            loss := 50 + NextRandInt(140);
            if Ship.Credits < loss then
                loss := Ship.Credits;
            Ship.Credits := Ship.Credits - loss;
            AddLog('Pirates extort you for ' + IntToStr(loss) + ' credits.');
        end;
    end;
end;

