procedure CommandFORT;
var
    spend, repair: Integer;
begin
    if not InPocket then
    begin
        AddLog('FORT is only available inside a pocket.');
        Exit;
    end;
    if (CurrentPocket < 1) or (CurrentPocket > MAX_POCKETS) or (not Pockets[CurrentPocket].Active) then
    begin
        AddLog('Pocket data unavailable.');
        Exit;
    end;
    spend := 200 + Pockets[CurrentPocket].FortLevel * 100;
    if Ship.Credits < spend then
    begin
        AddLog('Need ' + IntToStr(spend) + ' credits for next fort level.');
        Exit;
    end;
    Ship.Credits := Ship.Credits - spend;
    Pockets[CurrentPocket].StoredCredits := Pockets[CurrentPocket].StoredCredits + (spend div 4);
    Pockets[CurrentPocket].FortLevel := Pockets[CurrentPocket].FortLevel + 1;
    repair := 140 + NextRandInt(120);
    Pockets[CurrentPocket].Hull := Clamp(Pockets[CurrentPocket].Hull + repair, 0, Pockets[CurrentPocket].MaxHull);
    AddLog('Pocket ' + IntToStr(CurrentPocket) + ' fortified to L' + IntToStr(Pockets[CurrentPocket].FortLevel) + '.');
    LastTurnUsed := True;
end;

