procedure UpperString(var s: string);
var
    i: Integer;
begin
    for i := 1 to Length(s) do
        s[i] := UpCase(s[i]);
end;

function Clamp(v, lo, hi: Integer): Integer;
begin
    if v < lo then
        Clamp := lo
    else if v > hi then
        Clamp := hi
    else
        Clamp := v;
end;

function InBounds(v: Integer): Boolean;
begin
    InBounds := (v >= 1) and (v <= GRID_SIZE);
end;

function GlobalX(qx, sx: Integer): Integer;
begin
    GlobalX := (qx - 1) * GRID_SIZE + sx;
end;

function GlobalY(qy, sy: Integer): Integer;
begin
    GlobalY := (qy - 1) * GRID_SIZE + sy;
end;

function BorgDistanceToSector001: Integer;
begin
    BorgDistanceToSector001 := Abs(GlobalX(Borg.QX, Borg.SX) - 1) + Abs(GlobalY(Borg.QY, Borg.SY) - 1);
end;

procedure AddLog(msg: string);
var
    i: Integer;
begin
    for i := 1 to 4 do
        LogLines[i] := LogLines[i + 1];
    LogLines[5] := msg;
end;

procedure PrintAt(x, y: Integer; s: string);
begin
    GotoXY(x, y);
    Write(s);
end;

procedure RemoveLastChar(var s: string);
begin
    if Length(s) > 0 then
        s := Copy(s, 1, Length(s) - 1);
end;

procedure RestoreDefaultTextStyle;
begin
    TextBackground(Black);
    TextColor(LightGray);
end;

function PadLeft(s: string; w: Integer): string;
begin
    while Length(s) < w do
        s := ' ' + s;
    PadLeft := s;
end;

function PadRight(s: string; w: Integer): string;
begin
    while Length(s) < w do
        s := s + ' ';
    PadRight := s;
end;

procedure ReadCommandLine(var s: string; var interrupted: Boolean);
var
    ch, ch2, ch3: Char;
    histPos: Integer;
    i: Integer;
    escSeq: string;
    procedure RedrawInput;
    begin
        GotoXY(6, 24);
        ClrEol;
        Write(s);
    end;
    procedure LoadHistory(idx: Integer);
    begin
        if (idx >= 1) and (idx <= CmdHistoryCount) then
            s := CmdHistory[idx]
        else
            s := '';
        RedrawInput;
    end;
    procedure HistoryUp;
    begin
        if CmdHistoryCount > 0 then
        begin
            if histPos > 1 then
                histPos := histPos - 1;
            LoadHistory(histPos);
        end;
    end;
    procedure HistoryDown;
    begin
        if CmdHistoryCount > 0 then
        begin
            if histPos < CmdHistoryCount then
            begin
                histPos := histPos + 1;
                LoadHistory(histPos);
            end
            else
            begin
                histPos := CmdHistoryCount + 1;
                s := '';
                RedrawInput;
            end;
        end;
    end;
begin
    s := '';
    interrupted := False;
    histPos := CmdHistoryCount + 1;
    repeat
        ch := ReadKey;
        if ch = #3 then
        begin
            interrupted := True;
            Exit;
        end;
        if (ch = #8) or (ch = #127) then
        begin
            if Length(s) > 0 then
            begin
                RemoveLastChar(s);
                Write(#8, ' ', #8);
            end;
        end
        else if (ch = 'A') or (ch = 'B') or (ch = 'C') or (ch = 'D') then
        begin
            { Runtime-specific reversed arrow sequence observed via probe: D [ ESC }
            if KeyPressed then
            begin
                ch2 := ReadKey;
                if (ch2 = '[') and KeyPressed then
                begin
                    ch3 := ReadKey;
                    if ch3 = #27 then
                    begin
                        if ch = 'A' then
                            HistoryUp
                        else if ch = 'B' then
                            HistoryDown
                        else
                        begin
                            { Left/Right consumed intentionally }
                        end;
                    end
                    else
                    begin
                        s := s + ch + ch2 + ch3;
                        Write(ch, ch2, ch3);
                    end;
                end
                else
                begin
                    s := s + ch + ch2;
                    Write(ch, ch2);
                end;
            end
            else
            begin
                s := s + ch;
                Write(ch);
            end;
        end
        else if (ch = #13) or (ch = #10) then
        begin
            Break;
        end
        else if (ch = #0) or (ch = #224) then
        begin
            ch2 := ReadKey;
            if ch2 = #83 then
            begin
                if Length(s) > 0 then
                begin
                    RemoveLastChar(s);
                    RedrawInput;
                end;
            end
            else if ch2 = #72 then
                HistoryUp
            else if ch2 = #80 then
                HistoryDown;
        end
        else if ch = #27 then
        begin
            { Strict ANSI sequence parsing after ESC }
            ch2 := ReadKey;
            if (ch2 = '[') or (ch2 = 'O') then
            begin
                ch3 := ReadKey;
                if ch3 = 'A' then
                    HistoryUp
                else if ch3 = 'B' then
                    HistoryDown
                else if ch3 = '3' then
                begin
                    ch2 := ReadKey; { expect '~' }
                    if Length(s) > 0 then
                    begin
                        RemoveLastChar(s);
                        RedrawInput;
                    end;
                end;
            end;
        end
        else if ch = '[' then
        begin
            { Compatibility path for terminals leaking bare bracket-arrow fragments: [A [B [C [D }
            if KeyPressed then
            begin
                ch2 := ReadKey;
                if ch2 = 'A' then
                    HistoryUp
                else if ch2 = 'B' then
                    HistoryDown
                else if (ch2 = 'C') or (ch2 = 'D') then
                begin
                    { Right/Left consumed intentionally }
                end
                else if ch2 = '3' then
                begin
                    if KeyPressed then
                        ch3 := ReadKey; { consume optional '~' }
                    if Length(s) > 0 then
                    begin
                        RemoveLastChar(s);
                        RedrawInput;
                    end;
                end
                else
                begin
                    s := s + '[' + ch2;
                    Write('[', ch2);
                end;
            end
            else
            begin
                s := s + ch;
                Write(ch);
            end;
        end
        else if (ch >= ' ') then
        begin
            s := s + ch;
            Write(ch);
        end;
    until False;
    if s <> '' then
    begin
        if (CmdHistoryCount = 0) or (CmdHistory[CmdHistoryCount] <> s) then
        begin
            if CmdHistoryCount < 20 then
                CmdHistoryCount := CmdHistoryCount + 1
            else
            begin
                for i := 1 to 19 do
                    CmdHistory[i] := CmdHistory[i + 1];
            end;
            CmdHistory[CmdHistoryCount] := s;
        end;
    end;
    WriteLn;
end;

