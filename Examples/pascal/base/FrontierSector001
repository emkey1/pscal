procedure CommandSHE;
var
    amount: Integer;
begin
    if not Parse1Int(CmdArgs, amount) then
    begin
        Write('Shield transfer amount (+to shields, -to core): ');
        ReadLn(amount);
    end;
    if amount > 0 then
    begin
        if Ship.Energy < amount then
        begin
            AddLog('Insufficient core energy.');
            Exit;
        end;
        Ship.Energy := Ship.Energy - amount;
        Ship.Shields := Clamp(Ship.Shields + amount, 0, Ship.MaxShields);
    end
    else if amount < 0 then
    begin
        amount := -amount;
        if Ship.Shields < amount then
        begin
            AddLog('Insufficient shield energy.');
            Exit;
        end;
        Ship.Shields := Ship.Shields - amount;
        Ship.Energy := Clamp(Ship.Energy + amount, 0, Ship.MaxEnergy);
    end;
    AddLog('Transfer complete.');
end;

