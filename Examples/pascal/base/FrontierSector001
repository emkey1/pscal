    for xq := 1 to GRID_SIZE do
        for yq := 1 to GRID_SIZE do
            for xs := 1 to GRID_SIZE do
                for ys := 1 to GRID_SIZE do
                    if Galaxy[xq, yq].Sectors[xs, ys].HasPort then
                    begin
                        qx := xq; qy := yq; sx := xs; sy := ys;
                        FindFirstPort := True;
                        Exit;
