begin
    Galaxy[Borg.QX, Borg.QY].Sectors[Borg.SX, Borg.SY].HasBorg := True;
    Galaxy[Borg.QX, Borg.QY].BorgCount := 1;
end;

procedure RemoveBorgFromMap;
begin
    Galaxy[Borg.QX, Borg.QY].Sectors[Borg.SX, Borg.SY].HasBorg := False;
    Galaxy[Borg.QX, Borg.QY].BorgCount := 0;
end;

procedure PlaceRandomPorts;
var
    count, want, qx, qy, sx, sy, tries: Integer;
begin
    want := 4 + NextRandInt(3);
    count := 0;
    tries := 0;
    while (count < want) and (tries < 10000) do
    begin
        tries := tries + 1;
        qx := NextRandInt(GRID_SIZE) + 1;
        qy := NextRandInt(GRID_SIZE) + 1;
        sx := NextRandInt(GRID_SIZE) + 1;
        sy := NextRandInt(GRID_SIZE) + 1;
        if not Galaxy[qx, qy].Sectors[sx, sy].HasPort then
        begin
            Galaxy[qx, qy].Sectors[sx, sy].HasPort := True;
            Galaxy[qx, qy].PortCount := Galaxy[qx, qy].PortCount + 1;
            with Galaxy[qx, qy].Sectors[sx, sy].PortInfo do
            begin
                Active := True;
                PortType := (count mod 3) + 1;
                Stock.Ore := 20 + NextRandInt(50);
                Stock.Organics := 20 + NextRandInt(50);
                Stock.Equipment := 20 + NextRandInt(50);
                Credits := 400 + NextRandInt(800);
            end;
            count := count + 1;
        end;
    end;
    if count < want then
    begin
        { deterministic fallback to guarantee startup completion }
        for qx := 1 to GRID_SIZE do
            for qy := 1 to GRID_SIZE do
                for sx := 1 to GRID_SIZE do
                    for sy := 1 to GRID_SIZE do
                        if (count < want) and (not Galaxy[qx, qy].Sectors[sx, sy].HasPort) then
                        begin
                            Galaxy[qx, qy].Sectors[sx, sy].HasPort := True;
                            Galaxy[qx, qy].PortCount := Galaxy[qx, qy].PortCount + 1;
                            with Galaxy[qx, qy].Sectors[sx, sy].PortInfo do
                            begin
                                Active := True;
                                PortType := (count mod 3) + 1;
                                Stock.Ore := 20 + NextRandInt(50);
                                Stock.Organics := 20 + NextRandInt(50);
                                Stock.Equipment := 20 + NextRandInt(50);
                                Credits := 400 + NextRandInt(800);
                            end;
                            count := count + 1;
                        end;
    end;
end;

procedure InitGame;
var
    i: Integer;
begin
    if GameSeed = 0 then
        GameSeed := 13579;
    ClearSectorFlags;

    Ship.QX := 1; Ship.QY := 1; Ship.SX := 1; Ship.SY := 1;
    Ship.MaxEnergy := 1500; Ship.Energy := 1200;
