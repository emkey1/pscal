        TextColor(11);
        Write('DEMO: Press any key to continue...');
        RestoreDefaultTextStyle;
        ReadKey;
    end;
begin
    AddLog('Starting DEMO sequence...');
    AutoConfirmNav := True;
    oldCredits := Ship.Credits;

    DemoStep('DEMO step 1: refresh market scans');
    CommandSRS;
    CommandLRS;

    if FindFirstPort(tqx, tqy, tsx, tsy) then
    begin
        DemoStep('DEMO step 2: warp to first discovered port');
        CmdArgs := IntToStr(tqx) + ' ' + IntToStr(tqy) + ' ' + IntToStr(tsx) + ' ' + IntToStr(tsy);
        CommandNAV;
        EndTurn;
        DemoStep('DEMO step 3: quick trade run (buy ore x2 then sell ore x1)');
        if Ship.Credits >= 14 then
        begin
            Ship.Credits := Ship.Credits - 14;
            Ship.CargoBay.Ore := Ship.CargoBay.Ore + 2;
            AddLog('DEMO traded: bought Ore x2 for 14 credits.');
        end;
        if Ship.CargoBay.Ore > 0 then
        begin
            Ship.CargoBay.Ore := Ship.CargoBay.Ore - 1;
            Ship.Credits := Ship.Credits + 6;
            AddLog('DEMO traded: sold Ore x1 for 6 credits.');
        end;
        LastTurnUsed := True;
        EndTurn;
    end
    else
        AddLog('DEMO note: no port found (unexpected map state).');

    if FindFirstGateway(tqx, tqy, tsx, tsy) then
    begin
        DemoStep('DEMO step 4: warp to gateway and enter pocket');
        CmdArgs := IntToStr(tqx) + ' ' + IntToStr(tqy) + ' ' + IntToStr(tsx) + ' ' + IntToStr(tsy);
        CommandNAV;
        EndTurn;
        CmdArgs := '';
        CommandENTER;
        EndTurn;
        DemoStep('DEMO step 5: fortify pocket entrance');
        CommandFORT;
        EndTurn;
        DemoStep('DEMO step 6: exit pocket and continue trading lanes');
        CommandEXITPOCKET;
        EndTurn;
    end
    else
        AddLog('DEMO note: no gateway found (unexpected map state).');

    AutoConfirmNav := False;
    AddLog('DEMO sequence complete. Credits delta=' + IntToStr(Ship.Credits - oldCredits) + '.');
end;

procedure CommandSAVE;
var
    f: File;
    fn: string;
    qx, qy, sx, sy, i, j: Integer;
begin
    fn := SaveFileName();
    Assign(f, fn);
    Rewrite(f);
    if IOResult <> 0 then
    begin
        AddLog('SAVE failed: cannot open "' + fn + '" for writing.');
        Exit;
    end;

    WriteLn(f, 'TF_SAVE_V1');
    WriteLn(f, TurnCount, ' ', TurnsRemaining, ' ', GameSeed, ' ', BackgroundPulses);
    WriteLn(f, Ord(GameOver), ' ', Ord(AutoConfirmNav), ' ', Ord(InPocket), ' ', CurrentPocket);
    WriteLn(f, Ship.QX, ' ', Ship.QY, ' ', Ship.SX, ' ', Ship.SY, ' ', Ship.Energy, ' ', Ship.MaxEnergy, ' ',
            Ship.Shields, ' ', Ship.MaxShields, ' ', Ship.Torpedoes, ' ', Ship.MaxCargo, ' ', Ship.Credits);
    WriteLn(f, Ship.CargoBay.Ore, ' ', Ship.CargoBay.Organics, ' ', Ship.CargoBay.Equipment);
    WriteLn(f, Ship.PhaserFrequency);
    WriteLn(f, Borg.QX, ' ', Borg.QY, ' ', Borg.SX, ' ', Borg.SY, ' ', Borg.Health, ' ', Borg.Shields);
    WriteLn(f, Borg.AdaptedFrequency);

    for qx := 1 to GRID_SIZE do
        for qy := 1 to GRID_SIZE do
        begin
            WriteLn(f, Ord(Galaxy[qx, qy].Scanned), ' ', Galaxy[qx, qy].BorgCount, ' ', Galaxy[qx, qy].PortCount, ' ', Galaxy[qx, qy].GatewayCount);
            for sx := 1 to GRID_SIZE do
                for sy := 1 to GRID_SIZE do
                    with Galaxy[qx, qy].Sectors[sx, sy] do
                    begin
                        WriteLn(f, Ord(HasBorg), ' ', Ord(HasPort), ' ', Ord(HasGateway), ' ', GatewayID);
                        WriteLn(f, Ord(PortInfo.Active), ' ', PortInfo.PortType, ' ', PortInfo.Stock.Ore, ' ',
                                PortInfo.Stock.Organics, ' ', PortInfo.Stock.Equipment, ' ', PortInfo.Credits);
                    end;
        end;

    for i := 1 to MAX_POCKETS do
        with Pockets[i] do
            WriteLn(f, Ord(Active), ' ', EntranceQX, ' ', EntranceQY, ' ', EntranceSX, ' ', EntranceSY, ' ',
                    FortLevel, ' ', Hull, ' ', MaxHull, ' ', StoredCredits);

    WriteLn(f, CmdHistoryCount);
    for i := 1 to CmdHistoryCount do
        WriteLn(f, CmdHistory[i]);
    for i := 1 to 5 do
        WriteLn(f, LogLines[i]);
    WriteLn(f, LastSRSHeader);
    for i := 1 to 8 do
        WriteLn(f, LastSRSRows[i]);
    WriteLn(f, LastLRSHeader);
    for i := 1 to 3 do
        WriteLn(f, LastLRSRows[i]);
    Close(f);

    AddLog('Game saved to "' + fn + '".');
end;

procedure CommandLOAD;
var
    f: File;
    fn, magic: string;
    qx, qy, sx, sy, i: Integer;
    i1, i2, i3, i4, i5, i6, i7, i8, i9: Integer;
begin
    fn := SaveFileName();
    Assign(f, fn);
    Reset(f);
    if IOResult <> 0 then
    begin
        AddLog('LOAD failed: cannot open "' + fn + '".');
        Exit;
    end;

    if EOF(f) then
    begin
        Close(f);
        AddLog('LOAD failed: file is empty.');
        Exit;
    end;
    ReadLn(f, magic);
    if magic <> 'TF_SAVE_V1' then
    begin
        Close(f);
        AddLog('LOAD failed: unsupported save format.');
        Exit;
    end;

    ReadLn(f, TurnCount, TurnsRemaining, GameSeed, BackgroundPulses);
    ReadLn(f, i1, i2, i3, CurrentPocket);
    GameOver := (i1 <> 0);
    AutoConfirmNav := (i2 <> 0);
    InPocket := (i3 <> 0);
    ReadLn(f, Ship.QX, Ship.QY, Ship.SX, Ship.SY, Ship.Energy, Ship.MaxEnergy, Ship.Shields, Ship.MaxShields,
           Ship.Torpedoes, Ship.MaxCargo, Ship.Credits);
    ReadLn(f, Ship.CargoBay.Ore, Ship.CargoBay.Organics, Ship.CargoBay.Equipment);
    ReadLn(f, Ship.PhaserFrequency);
    ReadLn(f, Borg.QX, Borg.QY, Borg.SX, Borg.SY, Borg.Health, Borg.Shields);
    ReadLn(f, Borg.AdaptedFrequency);

    for qx := 1 to GRID_SIZE do
        for qy := 1 to GRID_SIZE do
        begin
            ReadLn(f, i1, Galaxy[qx, qy].BorgCount, Galaxy[qx, qy].PortCount, Galaxy[qx, qy].GatewayCount);
            Galaxy[qx, qy].Scanned := (i1 <> 0);
            for sx := 1 to GRID_SIZE do
                for sy := 1 to GRID_SIZE do
                begin
                    ReadLn(f, i1, i2, i3, Galaxy[qx, qy].Sectors[sx, sy].GatewayID);
                    Galaxy[qx, qy].Sectors[sx, sy].HasBorg := (i1 <> 0);
                    Galaxy[qx, qy].Sectors[sx, sy].HasPort := (i2 <> 0);
                    Galaxy[qx, qy].Sectors[sx, sy].HasGateway := (i3 <> 0);
                    ReadLn(f, i4, Galaxy[qx, qy].Sectors[sx, sy].PortInfo.PortType, i5, i6, i7, i8);
                    Galaxy[qx, qy].Sectors[sx, sy].PortInfo.Active := (i4 <> 0);
                    Galaxy[qx, qy].Sectors[sx, sy].PortInfo.Stock.Ore := i5;
                    Galaxy[qx, qy].Sectors[sx, sy].PortInfo.Stock.Organics := i6;
                    Galaxy[qx, qy].Sectors[sx, sy].PortInfo.Stock.Equipment := i7;
                    Galaxy[qx, qy].Sectors[sx, sy].PortInfo.Credits := i8;
                end;
        end;

    for i := 1 to MAX_POCKETS do
    begin
        ReadLn(f, i1, i2, i3, i4, i5, i6, i7, i8, i9);
        Pockets[i].Active := (i1 <> 0);
        Pockets[i].EntranceQX := i2;
        Pockets[i].EntranceQY := i3;
        Pockets[i].EntranceSX := i4;
        Pockets[i].EntranceSY := i5;
        Pockets[i].FortLevel := i6;
        Pockets[i].Hull := i7;
        Pockets[i].MaxHull := i8;
        Pockets[i].StoredCredits := i9;
    end;

    ReadLn(f, CmdHistoryCount);
    if CmdHistoryCount < 0 then CmdHistoryCount := 0;
    if CmdHistoryCount > 20 then CmdHistoryCount := 20;
    for i := 1 to CmdHistoryCount do
        ReadLn(f, CmdHistory[i]);
    for i := CmdHistoryCount + 1 to 20 do
        CmdHistory[i] := '';

    for i := 1 to 5 do
        if not EOF(f) then ReadLn(f, LogLines[i]) else LogLines[i] := '';
    Close(f);

    LastTurnUsed := False;
    CommandSRS;
    CommandLRS;
    AddLog('Game loaded from "' + fn + '".');
end;

procedure MainLoop;
var
    fn: TCommandProc;
    hasCmd: Boolean;
    interrupted: Boolean;
begin
    while not GameOver do
    begin
        RenderScreen;
        ReadCommandLine(CmdLine, interrupted);
        if interrupted then
        begin
            AddLog('Interrupted (^C). Exiting cleanly.');
            GameOver := True;
            Continue;
        end;
        ParseCommandLine(CmdLine, CmdName, CmdArgs);
        NormalizeCommandAlias(CmdName);
        LastTurnUsed := False;
        if CmdName = '' then
            Continue;
        if CmdName = 'QUIT' then
        begin
            AddLog('Quit command received.');
            GameOver := True;
            Continue;
        end;
        hasCmd := True;
        if CmdName = 'NAV' then fn := @CommandNAV
        else if CmdName = 'SRS' then fn := @CommandSRS
        else if CmdName = 'LRS' then fn := @CommandLRS
        else if CmdName = 'PHA' then fn := @CommandPHA
        else if CmdName = 'TOR' then fn := @CommandTOR
        else if CmdName = 'SHE' then fn := @CommandSHE
        else if CmdName = 'PORT' then fn := @CommandPORT
        else if CmdName = 'ENTER' then fn := @CommandENTER
        else if CmdName = 'EXITP' then fn := @CommandEXITPOCKET
        else if CmdName = 'FORT' then fn := @CommandFORT
        else if CmdName = 'SAVE' then fn := @CommandSAVE
        else if CmdName = 'LOAD' then fn := @CommandLOAD
        else if CmdName = 'SEED' then fn := @CommandSEED
        else if CmdName = 'DEMO' then fn := @CommandDEMO
        else if CmdName = 'STA' then fn := @PrintStatus
        else if CmdName = 'HELP' then fn := @CommandHelp
        else hasCmd := False;
        if not hasCmd then
            AddLog('Unknown command "' + CmdName + '". Type HELP for command list.')
        else
            fn();
        EndTurn;
    end;
end;

begin
    InitGame;
    MainLoop;
end.
