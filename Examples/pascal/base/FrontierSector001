procedure CommandSRS;
var
    sx, sy: Integer;
    cell: string;
    row: string;
begin
    Galaxy[Ship.QX, Ship.QY].Scanned := True;
    LastSRSHeader := 'SRS Q(' + IntToStr(Ship.QX) + ',' + IntToStr(Ship.QY) + ')';
    for sy := 1 to GRID_SIZE do
    begin
        row := PadLeft(IntToStr(sy), 2) + ' | ';
        for sx := 1 to GRID_SIZE do
        begin
            cell := ' . ';
            if Galaxy[Ship.QX, Ship.QY].Sectors[sx, sy].HasPort then
                cell := '(P)';
            if Galaxy[Ship.QX, Ship.QY].Sectors[sx, sy].HasGateway then
                cell := '<G>';
            if Galaxy[Ship.QX, Ship.QY].Sectors[sx, sy].HasBorg then
                cell := '[B]';
            if (sx = Ship.SX) and (sy = Ship.SY) then
                cell := '-T-';
            row := row + PadRight(cell, 4);
        end;
        LastSRSRows[sy] := row;
    end;
    AddLog('SRS updated for quadrant ' + IntToStr(Ship.QX) + ',' + IntToStr(Ship.QY) + '.');
end;

function CountEmpty(qx, qy: Integer): Integer;
var
    sx, sy, c: Integer;
begin
    c := 0;
    for sx := 1 to GRID_SIZE do
        for sy := 1 to GRID_SIZE do
            if (not Galaxy[qx, qy].Sectors[sx, sy].HasPort)
               and (not Galaxy[qx, qy].Sectors[sx, sy].HasBorg)
               and (not Galaxy[qx, qy].Sectors[sx, sy].HasGateway) then
                c := c + 1;
    CountEmpty := c;
end;

procedure CommandLRS;
var
    qx, qy, x0, x1, y0, y1: Integer;
    row: string;
begin
    x0 := Clamp(Ship.QX - 1, 1, GRID_SIZE);
    x1 := Clamp(Ship.QX + 1, 1, GRID_SIZE);
    y0 := Clamp(Ship.QY - 1, 1, GRID_SIZE);
    y1 := Clamp(Ship.QY + 1, 1, GRID_SIZE);
    LastLRSHeader := 'LRS around Q(' + IntToStr(Ship.QX) + ',' + IntToStr(Ship.QY) + ') [B/P/G/Empty]';
    for qy := 1 to 3 do
        LastLRSRows[qy] := ' ';
    for qy := y0 to y1 do
    begin
        row := '';
        for qx := x0 to x1 do
        begin
            Galaxy[qx, qy].Scanned := True;
            row := row + PadLeft(
                   IntToStr(Galaxy[qx, qy].BorgCount) +
                   IntToStr(Galaxy[qx, qy].PortCount) +
                   IntToStr(Galaxy[qx, qy].GatewayCount) +
                   IntToStr(CountEmpty(qx, qy)), 6) + ' ';
        end;
        LastLRSRows[qy - y0 + 1] := row;
    end;
    AddLog('LRS updated.');
end;

procedure CommandNAV;
var
    nqX, nqY, nsX, nsY: Integer;
    gx0, gy0, gx1, gy1, dist, cost: Integer;
    k: Char;
begin
    if InPocket then
    begin
        AddLog('Cannot WARP while inside pocket space. Use EXITP first.');
        Exit;
    end;
    if not Parse4Ints(CmdArgs, nqX, nqY, nsX, nsY) then
    begin
        Write('Destination Quadrant X Y (1..8 1..8): ');
        ReadLn(nqX, nqY);
        Write('Destination Sector X Y (1..8 1..8): ');
        ReadLn(nsX, nsY);
    end;
    if (not InBounds(nqX)) or (not InBounds(nqY)) or (not InBounds(nsX)) or (not InBounds(nsY)) then
    begin
        AddLog('Invalid coordinates.');
        Exit;
    end;
    gx0 := GlobalX(Ship.QX, Ship.SX);
    gy0 := GlobalY(Ship.QY, Ship.SY);
    gx1 := GlobalX(nqX, nsX);
    gy1 := GlobalY(nqY, nsY);
    dist := Abs(gx1 - gx0) + Abs(gy1 - gy0);
    cost := dist * 8;
    AddLog('WARP plan: distance=' + IntToStr(dist) + ', fuel cost=' + IntToStr(cost) + '. Confirm [Y/N]?');
    if not AutoConfirmNav then
    begin
        TextColor(11);
        GotoXY(1, 23);
        ClrEol;
        Write('WARP CONFIRM [Y/N]: ');
        RestoreDefaultTextStyle;
        k := UpCase(ReadKey);
        if (k <> 'Y') and (k <> #13) then
        begin
            AddLog('WARP cancelled.');
            Exit;
        end;
    end;
    if Ship.Energy < cost then
    begin
        AddLog('Insufficient energy. Needed=' + IntToStr(cost));
        Exit;
    end;
    Ship.Energy := Ship.Energy - cost;
    Ship.QX := nqX; Ship.QY := nqY; Ship.SX := nsX; Ship.SY := nsY;
    AddLog('Warp complete. Fuel cost ' + IntToStr(cost));
    LastTurnUsed := True;
    CommandSRS;
    CommandLRS;
end;

procedure BorgAttackIfLocal;
