PROCEDURE SearchNearby;
VAR
  DX, DY: Integer;
  Found: Boolean;
BEGIN
  Found := False;
  FOR DY := -1 TO 1 DO
    FOR DX := -1 TO 1 DO
      IF NOT ((DX = 0) AND (DY = 0)) THEN
        IF (Player.X + DX >= 1) AND (Player.X + DX <= MaxWidth) AND
           (Player.Y + DY >= 1) AND (Player.Y + DY <= MaxHeight) THEN
          IF Map[Player.Y + DY, Player.X + DX] = TileSecretDoor THEN
          BEGIN
            Map[Player.Y + DY, Player.X + DX] := TileDoor;
            SeenMap[Player.Y + DY, Player.X + DX] := TileDoor;
            Found := True;
          END;
  IF Found THEN
    AddMessage('You found a secret door!')
  ELSE
    AddMessage('You find nothing unusual.');
END;

PROCEDURE OpenDoor;
VAR
  DX, DY: Integer;
  TX, TY: Integer;
BEGIN
  FOR DY := -1 TO 1 DO
    FOR DX := -1 TO 1 DO
      IF ((Abs(DX) + Abs(DY)) = 1) THEN
      BEGIN
        TX := Player.X + DX;
        TY := Player.Y + DY;
        IF (TX >= 1) AND (TX <= MaxWidth) AND (TY >= 1) AND (TY <= MaxHeight) THEN
        BEGIN
          IF Map[TY, TX] = TileSecretDoor THEN
          BEGIN
            Map[TY, TX] := TileDoor;
            SeenMap[TY, TX] := TileDoor;
            AddMessage('You open a hidden door.');
            EXIT;
          END;
          IF Map[TY, TX] = TileLockedDoor THEN
          BEGIN
            IF Player.Keys > 0 THEN
            BEGIN
              DEC(Player.Keys);
              Map[TY, TX] := TileDoor;
              SeenMap[TY, TX] := TileDoor;
              AddMessage('You unlock the door.');
            END
            ELSE
              AddMessage('Door is locked. You need a key.');
            EXIT;
          END;
        END;
      END;
  AddMessage('No door to open nearby.');
END;

PROCEDURE CloseDoor;
VAR
  DX, DY: Integer;
  TX, TY: Integer;
BEGIN
  FOR DY := -1 TO 1 DO
    FOR DX := -1 TO 1 DO
      IF ((Abs(DX) + Abs(DY)) = 1) THEN
      BEGIN
        TX := Player.X + DX;
        TY := Player.Y + DY;
        IF (TX >= 1) AND (TX <= MaxWidth) AND (TY >= 1) AND (TY <= MaxHeight) THEN
        BEGIN
          IF Map[TY, TX] = TileDoor THEN
          BEGIN
            Map[TY, TX] := TileSecretDoor;
            SeenMap[TY, TX] := TileWall;
            AddMessage('You close the door.');
            EXIT;
          END;
        END;
      END;
  AddMessage('No door to close nearby.');
END;

PROCEDURE RestUntilSafe;
VAR
  Steps: Integer;
BEGIN
  Steps := 0;
  WHILE (NOT GameOver) AND (Steps < 80) DO
  BEGIN
    IF IsDangerVisible THEN
    BEGIN
      AddMessage('Rest interrupted by danger.');
      EXIT;
    END;
    IF (Player.HP >= Player.MaxHP) AND
       (Player.PoisonTurns = 0) AND (Player.SlowTurns = 0) AND
       (Player.ConfuseTurns = 0) AND (Player.BlindTurns = 0) THEN
    BEGIN
      AddMessage('You feel rested.');
      EXIT;
    END;
    EndPlayerTurn;
    IF Player.Mana < Player.MaxMana THEN
      INC(Player.Mana); { Resting while safe accelerates mana recovery. }
    INC(Steps);
    RenderMap;
    DrawHUD;
    DrawMessages;
  END;
END;

FUNCTION ConfirmQuit: Boolean;
VAR
  K: Char;
BEGIN
  AddMessage('Quit game? Y=Yes N=No');
  RenderMap;
  DrawHUD;
  DrawMessages;
  K := UpCase(ReadKey);
  ConfirmQuit := (K = 'Y');
  IF NOT ConfirmQuit THEN
    AddMessage('Quit cancelled.');
END;

PROCEDURE AutoExplore;
VAR
  Dist: ARRAY[1..MaxHeight, 1..MaxWidth] OF Integer;
  PrevX: ARRAY[1..MaxHeight, 1..MaxWidth] OF Integer;
  PrevY: ARRAY[1..MaxHeight, 1..MaxWidth] OF Integer;
  QX: ARRAY[1..(MaxWidth * MaxHeight)] OF Integer;
  QY: ARRAY[1..(MaxWidth * MaxHeight)] OF Integer;
  Head, Tail: Integer;
  R, C, NX, NY, DX, DY: Integer;
  TX, TY: Integer;
  CurX, CurY: Integer;
  Found: Boolean;
  ExploreSteps: Integer;
BEGIN
  ExploreSteps := 0;
  WHILE (ExploreSteps < 40) AND (NOT GameOver) DO
  BEGIN
    IF IsInterestingVisible THEN
    BEGIN
      AddMessage('Auto-explore halted: nearby point of interest.');
      EXIT;
    END;

    FOR R := 1 TO MaxHeight DO
      FOR C := 1 TO MaxWidth DO
      BEGIN
        Dist[R, C] := -1;
        PrevX[R, C] := 0;
        PrevY[R, C] := 0;
      END;

    Head := 1;
    Tail := 1;
    QX[1] := Player.X;
    QY[1] := Player.Y;
    Dist[Player.Y, Player.X] := 0;
    TX := 0;
    TY := 0;
    Found := False;

    WHILE Head <= Tail DO
    BEGIN
      CurX := QX[Head];
      CurY := QY[Head];
      INC(Head);

      IF (SeenMap[CurY, CurX] = TileFog) AND (Map[CurY, CurX] <> TileWall) THEN
      BEGIN
        TX := CurX;
        TY := CurY;
        Found := True;
        BREAK;
      END;

      FOR DY := -1 TO 1 DO
        FOR DX := -1 TO 1 DO
          IF NOT ((DX = 0) AND (DY = 0)) THEN
          BEGIN
            NX := CurX + DX;
            NY := CurY + DY;
            IF (NX >= 1) AND (NX <= MaxWidth) AND (NY >= 1) AND (NY <= MaxHeight) THEN
              IF (Dist[NY, NX] = -1) AND (Map[NY, NX] <> TileWall) THEN
              BEGIN
                Dist[NY, NX] := Dist[CurY, CurX] + 1;
                PrevX[NY, NX] := CurX;
                PrevY[NY, NX] := CurY;
                INC(Tail);
                QX[Tail] := NX;
                QY[Tail] := NY;
              END;
          END;
    END;

    IF NOT Found THEN
    BEGIN
      IF ExploreSteps = 0 THEN
        AddMessage('No unexplored reachable area.');
      EXIT;
    END;

    CurX := TX;
    CurY := TY;
    WHILE NOT ((PrevX[CurY, CurX] = Player.X) AND (PrevY[CurY, CurX] = Player.Y)) DO
    BEGIN
      NX := PrevX[CurY, CurX];
      NY := PrevY[CurY, CurX];
      IF (NX = 0) OR (NY = 0) THEN BREAK;
      CurX := NX;
      CurY := NY;
    END;

    PlayerMove(CurX, CurY);
    EndPlayerTurn;
    INC(ExploreSteps);
    RenderMap;
    DrawHUD;
    DrawMessages;
  END;
END;

PROCEDURE DropItem;
VAR
  K: Char;
  ItemIdx: Integer;
BEGIN
  IF GetItemAt(Player.X, Player.Y) > 0 THEN
  BEGIN
    AddMessage('Something is already on this tile.');
    EXIT;
  END;
  IF IsStairsDownAt(Player.X, Player.Y) OR IsStairsUpAt(Player.X, Player.Y) THEN
  BEGIN
    AddMessage('Cannot drop items on stairs.');
    EXIT;
  END;

  AddMessage('Drop: P=Potion H=Heal M=Map T=Teleport');
  RenderMap;
  DrawHUD;
  DrawMessages;
  K := UpCase(ReadKey);

  ItemIdx := 0;
  WHILE (ItemIdx < MaxItems) DO
  BEGIN
    INC(ItemIdx);
    IF NOT Items[ItemIdx].Active THEN BREAK;
  END;
  IF (ItemIdx < 1) OR (ItemIdx > MaxItems) OR Items[ItemIdx].Active THEN
  BEGIN
    AddMessage('No room to drop items on this floor.');
    EXIT;
  END;

  CASE K OF
    'P':
      BEGIN
        IF Player.Potions <= 0 THEN
          AddMessage('No potions to drop.')
        ELSE
        BEGIN
          DEC(Player.Potions);
          Items[ItemIdx].X := Player.X;
          Items[ItemIdx].Y := Player.Y;
          Items[ItemIdx].TypeChar := TilePotion;
          Items[ItemIdx].Value := 10;
          Items[ItemIdx].Active := True;
          AddMessage('You drop a potion.');
          EndPlayerTurn;
        END;
      END;
    'H':
      BEGIN
        IF Player.ScrollHeal <= 0 THEN
          AddMessage('No healing scrolls to drop.')
        ELSE
        BEGIN
          DEC(Player.ScrollHeal);
          Items[ItemIdx].X := Player.X;
          Items[ItemIdx].Y := Player.Y;
          Items[ItemIdx].TypeChar := TileScroll;
          Items[ItemIdx].Value := 1;
          Items[ItemIdx].Active := True;
          AddMessage('You drop a healing scroll.');
          EndPlayerTurn;
        END;
      END;
    'M':
      BEGIN
        IF Player.ScrollMap <= 0 THEN
          AddMessage('No mapping scrolls to drop.')
        ELSE
        BEGIN
          DEC(Player.ScrollMap);
          Items[ItemIdx].X := Player.X;
          Items[ItemIdx].Y := Player.Y;
          Items[ItemIdx].TypeChar := TileScroll;
          Items[ItemIdx].Value := 2;
          Items[ItemIdx].Active := True;
          AddMessage('You drop a mapping scroll.');
          EndPlayerTurn;
        END;
      END;
    'T':
      BEGIN
        IF Player.ScrollTeleport <= 0 THEN
          AddMessage('No teleport scrolls to drop.')
        ELSE
        BEGIN
          DEC(Player.ScrollTeleport);
          Items[ItemIdx].X := Player.X;
          Items[ItemIdx].Y := Player.Y;
          Items[ItemIdx].TypeChar := TileScroll;
          Items[ItemIdx].Value := 3;
          Items[ItemIdx].Active := True;
          AddMessage('You drop a teleport scroll.');
          EndPlayerTurn;
        END;
      END;
  ELSE
    AddMessage('Never mind.');
  END;
END;

PROCEDURE TeleportPlayerToFloor;
VAR
  TX, TY, Tries: Integer;
BEGIN
  Tries := 0;
  REPEAT
    TX := 2 + Random(MaxWidth - 4);
    TY := 2 + Random(MaxHeight - 4);
    INC(Tries);
  UNTIL ((Map[TY, TX] = TileFloor) AND (GetEnemyAt(TX, TY) = 0)) OR (Tries > 200);
  IF (Map[TY, TX] = TileFloor) THEN
  BEGIN
    Player.X := TX;
    Player.Y := TY;
  END;
END;

PROCEDURE GetItem;
VAR
  ItemIdx: Integer;
BEGIN
  ItemIdx := GetItemAt(Player.X, Player.Y);
  IF ItemIdx > 0 THEN
  BEGIN
    IF Items[ItemIdx].TypeChar = TilePotion THEN
    BEGIN
      IF Player.Potions < MaxInventory THEN
      BEGIN
        INC(Player.Potions);
        Items[ItemIdx].Active := False;
        AddMessage('You picked up a potion.');
      END
      ELSE
      BEGIN
        AddMessage('Inventory full.');
      END;
    END
    ELSE IF Items[ItemIdx].TypeChar = TileWeapon THEN
    BEGIN
      IF Items[ItemIdx].Value > Player.WeaponBonus THEN
      BEGIN
        Player.SpareWeaponBonus := Player.WeaponBonus;
        Player.SpareWeaponName := Player.WeaponName;
        Player.WeaponBonus := Items[ItemIdx].Value;
        Player.WeaponName := 'Blade +' + IntToStr(Items[ItemIdx].Value);
        AddMessage('You equip ' + Player.WeaponName + '.');
      END
      ELSE IF Items[ItemIdx].Value > Player.SpareWeaponBonus THEN
      BEGIN
        Player.SpareWeaponBonus := Items[ItemIdx].Value;
        Player.SpareWeaponName := 'Blade +' + IntToStr(Items[ItemIdx].Value);
        AddMessage('You stash ' + Player.SpareWeaponName + '.');
      END
      ELSE
        AddMessage('You leave the weaker weapon.');
      Items[ItemIdx].Active := False;
    END
    ELSE IF Items[ItemIdx].TypeChar = TileArmor THEN
    BEGIN
      IF Items[ItemIdx].Value > Player.ArmorBonus THEN
      BEGIN
        Player.SpareArmorBonus := Player.ArmorBonus;
        Player.SpareArmorName := Player.ArmorName;
        Player.ArmorBonus := Items[ItemIdx].Value;
        Player.ArmorName := 'Mail +' + IntToStr(Items[ItemIdx].Value);
        AddMessage('You equip ' + Player.ArmorName + '.');
      END
      ELSE IF Items[ItemIdx].Value > Player.SpareArmorBonus THEN
      BEGIN
        Player.SpareArmorBonus := Items[ItemIdx].Value;
        Player.SpareArmorName := 'Mail +' + IntToStr(Items[ItemIdx].Value);
        AddMessage('You stash ' + Player.SpareArmorName + '.');
      END
      ELSE
        AddMessage('You leave the weaker armor.');
      Items[ItemIdx].Active := False;
    END
    ELSE IF Items[ItemIdx].TypeChar = TileScroll THEN
    BEGIN
      IF Items[ItemIdx].Value = 1 THEN
      BEGIN
        INC(Player.ScrollHeal);
        AddMessage('You pick up a Scroll of Healing.');
      END
      ELSE IF Items[ItemIdx].Value = 2 THEN
      BEGIN
        INC(Player.ScrollMap);
        AddMessage('You pick up a Scroll of Mapping.');
      END
      ELSE
      BEGIN
        INC(Player.ScrollTeleport);
        AddMessage('You pick up a Scroll of Teleport.');
      END;
      Items[ItemIdx].Active := False;
    END
    ELSE IF Items[ItemIdx].TypeChar = TileAmulet THEN
    BEGIN
      IF Random(2) = 0 THEN
      BEGIN
        Player.WeaponBonus := Player.WeaponBonus + Items[ItemIdx].Value;
        AddMessage('Amulet glows! Attack rises.');
      END
      ELSE
      BEGIN
        Player.ArmorBonus := Player.ArmorBonus + Items[ItemIdx].Value;
        AddMessage('Amulet glows! Armor rises.');
      END;
      Items[ItemIdx].Active := False;
    END
    ELSE IF Items[ItemIdx].TypeChar = TileKey THEN
    BEGIN
      INC(Player.Keys);
      Items[ItemIdx].Active := False;
      AddMessage('You pick up a key.');
    END
    ELSE
    BEGIN
      AddMessage('Nothing else to pick up here.');
    END;
  END
  ELSE
  BEGIN
    AddMessage('Nothing here to pick up.');
  END;
END;

{ --- Main Loop --- }

PROCEDURE InitGame;
VAR
  I, J: Integer;
BEGIN
  Randomize;
  GameSeed := Random(2147483646) + 1;
  Depth := 1;
  TurnCount := 0;
  GameOver := False;
  RunIgnoreDepth := 0;
  RunIgnoreItemX := 0;
  RunIgnoreItemY := 0;
  SpawnBudget := 0;
  SpawnCooldown := 0;
  ClearMessageLog;
  FOR I := 1 TO MaxDungeonDepth DO
    Levels[I].Generated := False;

  ClearSeenMap;
  
  { Init Player }
  Player.X := 1;
  Player.Y := 1;
  Player.HP := 50;
  Player.MaxHP := 50;
  Player.Attack := 5;
  Player.Defense := 2;
  Player.Gold := 0;
  Player.Level := 1;
  Player.XP := 0;
  Player.Potions := 2;
  Player.Mana := 12;
  Player.MaxMana := 12;
  Player.ScrollHeal := 0;
  Player.ScrollMap := 0;
  Player.ScrollTeleport := 0;
  Player.Keys := 0;
  Player.PoisonTurns := 0;
  Player.SlowTurns := 0;
  Player.HasteTurns := 0;
  Player.ConfuseTurns := 0;
  Player.BlindTurns := 0;
  Player.DetectTurns := 0;
  Player.WeaponBonus := 0;
  Player.ArmorBonus := 0;
  Player.WeaponName := 'Fists';
  Player.ArmorName := 'Clothes';
  Player.SpareWeaponBonus := 0;
  Player.SpareArmorBonus := 0;
  Player.SpareWeaponName := 'None';
  Player.SpareArmorName := 'None';
  
  EnterLevel(1, 2, 2);
  
  ClearScreen;
  WriteLn('Welcome to the Dungeon!');
  WriteLn('Find the stairs (>) to descend.');
  IF SaveExists THEN
    WriteLn('Press R now to load ', SaveFileName, '.');
  WriteLn('Press any key to start...');
  Key := ReadKey;
  IF UpCase(Key) = 'R' THEN
    LoadGame
  ELSE
    ClearScreen;
END;

BEGIN
  InitGame;
  
  WHILE NOT GameOver DO
  BEGIN
    RenderMap;
    DrawHUD;
    DrawMessages;

    { Block for input }
    Key := ReadKey;

    CASE Key OF
      'y': BEGIN PlayerMove(Player.X - 1, Player.Y - 1); EndPlayerTurn; END;
      'u': BEGIN PlayerMove(Player.X + 1, Player.Y - 1); EndPlayerTurn; END;
      'h': BEGIN PlayerMove(Player.X - 1, Player.Y); EndPlayerTurn; END;
      'j': BEGIN PlayerMove(Player.X, Player.Y + 1); EndPlayerTurn; END;
      'k': BEGIN PlayerMove(Player.X, Player.Y - 1); EndPlayerTurn; END;
      'l': BEGIN PlayerMove(Player.X + 1, Player.Y); EndPlayerTurn; END;
      'b': BEGIN PlayerMove(Player.X - 1, Player.Y + 1); EndPlayerTurn; END;
      'n': BEGIN PlayerMove(Player.X + 1, Player.Y + 1); EndPlayerTurn; END;
      'Y': RunDirection(-1, -1);
      'U': RunDirection(1, -1);
      'H': RunDirection(-1, 0);
      'J': RunDirection(0, 1);
      'K': RunDirection(0, -1);
      'L': RunDirection(1, 0);
      'B': RunDirection(-1, 1);
      'N': RunDirection(1, 1);
      '.': BEGIN AddMessage('You wait.'); EndPlayerTurn; END;
      'g', 'G', ',': BEGIN GetItem; EndPlayerTurn; END;
      '>':
        BEGIN
          IF IsStairsDownAt(Player.X, Player.Y) THEN
          BEGIN
            NextLevel;
            EndPlayerTurn;
          END
          ELSE
            AddMessage('No stairs down here.');
        END;
      '<':
        BEGIN
          IF IsStairsUpAt(Player.X, Player.Y) THEN
          BEGIN
            IF Depth > 1 THEN
            BEGIN
              EnterLevel(Depth - 1, Levels[Depth].EntryX, Levels[Depth].EntryY);
              AddMessage('You climb to the previous level.');
              EndPlayerTurn;
            END
            ELSE
              AddMessage('These stairs lead to the surface.');
          END
          ELSE
            AddMessage('No stairs up here.');
        END;
      'i', 'I': ShowInventory;
      'w', 'W': SwapEquipment;
      '?': ShowHelp;
      'd', 'D': DropItem;
      'f', 'F': BEGIN SearchNearby; EndPlayerTurn; END;
      'o', 'O': BEGIN OpenDoor; EndPlayerTurn; END;
      'c', 'C': BEGIN CloseDoor; EndPlayerTurn; END;
      'e', 'E': ShowEquipment;
      'a', 'A':
        BEGIN
          { Attack adjacent enemy }
          FOR I := 1 TO MaxEnemies DO
            IF Enemies[I].Active THEN
              IF (Abs(Enemies[I].X - Player.X) + Abs(Enemies[I].Y - Player.Y)) = 1 THEN
              BEGIN
                CombatRound(I);
                BREAK;
              END;
          EndPlayerTurn;
        END;
      'p', 'P': BEGIN UsePotion; EndPlayerTurn; END;
      'z', 'Z': UseScroll;
      'm', 'M': CastSpell;
      'v', 'V': RestUntilSafe;
      'x', 'X': AutoExplore;
      's', 'S': SaveGame;
      'r', 'R': LoadGame;
      'q', 'Q': GameOver := ConfirmQuit;
    END;
  END;
  
  WriteLn;
  WriteLn('Game Over. Final Score: ', Player.Gold);
END.
