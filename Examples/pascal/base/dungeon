FUNCTION IsStairsDownAt(X, Y: Integer): Boolean; FORWARD;
FUNCTION IsStairsUpAt(X, Y: Integer): Boolean; FORWARD;

{ --- Helper Procedures --- }

PROCEDURE ClearScreen;
BEGIN
  { Full terminal clear + home to avoid stale artifacts outside ClrScr window. }
  Write(#27, '[2J');
  Write(#27, '[3J');
  Write(#27, '[H');
  ClrScr;
  TextColor(White);
  GotoXY(1, 1);
END;

FUNCTION FitLine(S: String): String;
BEGIN
  IF Length(S) > ViewWidth THEN
    S := Copy(S, 1, ViewWidth);
  WHILE Length(S) < ViewWidth DO
    S := S + ' ';
  FitLine := S;
END;

PROCEDURE WriteScreenLine(Y: Integer; S: String);
BEGIN
  GotoXY(1, Y);
  Write(FitLine(S));
END;

PROCEDURE ClearMessageLog;
VAR
  I: Integer;
BEGIN
  FOR I := 1 TO MessageLines DO
    MessageLog[I] := '';
END;

PROCEDURE ClearSeenMap;
VAR
  I, J: Integer;
BEGIN
  FOR I := 1 TO MaxHeight DO
    FOR J := 1 TO MaxWidth DO
      SeenMap[I, J] := TileFog;
END;

PROCEDURE RevealCurrentMap;
VAR
  R, C: Integer;
BEGIN
  FOR R := 1 TO MaxHeight DO
    FOR C := 1 TO MaxWidth DO
      SeenMap[R, C] := Map[R, C];
END;

PROCEDURE CopyMap(VAR Dest: TMap; VAR Src: TMap);
VAR
  R, C: Integer;
BEGIN
  FOR R := 1 TO MaxHeight DO
    FOR C := 1 TO MaxWidth DO
      Dest[R, C] := Src[R, C];
END;

PROCEDURE CopyEnemiesToLevel(LevelNum: Integer);
VAR
  I: Integer;
BEGIN
  FOR I := 1 TO MaxEnemies DO
    Levels[LevelNum].Enemies[I] := Enemies[I];
END;

PROCEDURE CopyEnemiesFromLevel(LevelNum: Integer);
VAR
  I: Integer;
BEGIN
  FOR I := 1 TO MaxEnemies DO
    Enemies[I] := Levels[LevelNum].Enemies[I];
END;

PROCEDURE CopyItemsToLevel(LevelNum: Integer);
VAR
  I: Integer;
BEGIN
  FOR I := 1 TO MaxItems DO
    Levels[LevelNum].Items[I] := Items[I];
END;

PROCEDURE CopyItemsFromLevel(LevelNum: Integer);
VAR
  I: Integer;
BEGIN
  FOR I := 1 TO MaxItems DO
    Items[I] := Levels[LevelNum].Items[I];
END;

PROCEDURE SetGenSeed(S: LongInt);
BEGIN
  GenSeed := S;
  IF GenSeed < 1 THEN
    GenSeed := 1;
END;

FUNCTION NextGenRandInt: LongInt;
BEGIN
  GenSeed := (GenSeed * 1103515245 + 12345) MOD 2147483647;
  IF GenSeed < 0 THEN
    GenSeed := -GenSeed;
  NextGenRandInt := GenSeed;
END;

FUNCTION GenRand(MaxN: Integer): Integer;
BEGIN
  IF MaxN <= 0 THEN
    GenRand := 0
  ELSE
    GenRand := NextGenRandInt MOD MaxN;
END;

FUNCTION GetThemeByDepth(LevelDepth: Integer): Integer;
BEGIN
  IF LevelDepth <= 4 THEN
    GetThemeByDepth := ThemeCaves
  ELSE IF LevelDepth <= 8 THEN
    GetThemeByDepth := ThemeRuins
  ELSE
    GetThemeByDepth := ThemeCrypt;
END;

FUNCTION GetThemeName(LevelDepth: Integer): String;
VAR
  Theme: Integer;
BEGIN
  Theme := GetThemeByDepth(LevelDepth);
  IF Theme = ThemeCaves THEN
    GetThemeName := 'Caves'
  ELSE IF Theme = ThemeRuins THEN
    GetThemeName := 'Ruins'
  ELSE
    GetThemeName := 'Crypt';
END;

PROCEDURE AddStatusSuffix(VAR S: String; LabelText: String; Turns: Integer);
BEGIN
  IF Turns > 0 THEN
    S := S + ' ' + LabelText + ':' + IntToStr(Turns);
END;

PROCEDURE TickPlayerStatus;
BEGIN
  IF Player.PoisonTurns > 0 THEN
  BEGIN
    DEC(Player.PoisonTurns);
    DEC(Player.HP);
    IF Player.HP <= 0 THEN
    BEGIN
      GameOver := True;
      AddMessage('You succumb to poison.');
      EXIT;
    END;
  END;
  IF Player.SlowTurns > 0 THEN DEC(Player.SlowTurns);
  IF Player.HasteTurns > 0 THEN DEC(Player.HasteTurns);
  IF Player.ConfuseTurns > 0 THEN DEC(Player.ConfuseTurns);
  IF Player.BlindTurns > 0 THEN DEC(Player.BlindTurns);
  IF Player.DetectTurns > 0 THEN DEC(Player.DetectTurns);
END;

PROCEDURE AddMessage(S: String);
VAR
  I: Integer;
BEGIN
  FOR I := 1 TO MessageLines - 1 DO
    MessageLog[I] := MessageLog[I + 1];
  MessageLog[MessageLines] := S;
END;

PROCEDURE DrawMessages;
VAR
  I: Integer;
BEGIN
  FOR I := 1 TO MessageLines DO
    WriteScreenLine(MessageTop + I - 1, MessageLog[I]);
END;

PROCEDURE GotoXYSafe(X, Y: Integer);
BEGIN
  IF (X >= 1) AND (X <= ViewWidth) AND (Y >= 1) AND (Y <= ScreenHeight) THEN
    GotoXY(X, Y);
END;

PROCEDURE WriteCharSafe(X, Y: Integer; C: Char);
BEGIN
  IF (X >= 1) AND (X <= ViewWidth) AND (Y >= 1) AND (Y <= ScreenHeight) THEN
  BEGIN
    GotoXY(X, Y);
    Write(C);
  END;
END;

PROCEDURE ColorText(X, Y: Integer; C: Char; FGColor: Byte);
BEGIN
  IF (X >= 1) AND (X <= ViewWidth) AND (Y >= 1) AND (Y <= ScreenHeight) THEN
  BEGIN
    GotoXY(X, Y);
    TextColor(FGColor);
    Write(C);
    TextColor(White); { Reset to white }
  END;
END;

PROCEDURE ColorTextGlyph(X, Y: Integer; S: String; FGColor: Byte);
BEGIN
  IF (X >= 1) AND (X <= ViewWidth) AND (Y >= 1) AND (Y <= ScreenHeight) THEN
  BEGIN
    GotoXY(X, Y);
    TextColor(FGColor);
    Write(S);
    TextColor(White);
  END;
END;

{ --- Map Generation --- }

PROCEDURE InitMap;
VAR
  I, J: Integer;
BEGIN
  FOR I := 1 TO MaxHeight DO
    FOR J := 1 TO MaxWidth DO
      Map[I, J] := TileWall;
END;

PROCEDURE PlaceRoom(X, Y, W, H: Integer);
VAR
  I, J: Integer;
BEGIN
  FOR I := Y TO Y + H - 1 DO
    FOR J := X TO X + W - 1 DO
      IF (I >= 1) AND (I <= MaxHeight) AND (J >= 1) AND (J <= MaxWidth) THEN
        Map[I, J] := TileFloor;
END;

PROCEDURE ConnectRooms(X1, Y1, X2, Y2: Integer);
VAR
  X, Y: Integer;
BEGIN
  { Horizontal corridor }
  X := X1;
  WHILE X <> X2 DO
  BEGIN
    IF (Y1 >= 1) AND (Y1 <= MaxHeight) AND (X >= 1) AND (X <= MaxWidth) THEN
      Map[Y1, X] := TileFloor;
    IF X < X2 THEN INC(X) ELSE DEC(X);
  END;
  
  { Vertical corridor }
  Y := Y1;
  WHILE Y <> Y2 DO
  BEGIN
    IF (Y >= 1) AND (Y <= MaxHeight) AND (X2 >= 1) AND (X2 <= MaxWidth) THEN
      Map[Y, X2] := TileFloor;
    IF Y < Y2 THEN INC(Y) ELSE DEC(Y);
  END;
END;

PROCEDURE PlaceVaultWithSecretDoor;
VAR
  Tries: Integer;
  DoorX, DoorY: Integer;
  InX, InY: Integer;
  VX, VY, VW, VH: Integer;
  R, C: Integer;
  Overlap: Boolean;
BEGIN
  Tries := 0;
  WHILE Tries < 120 DO
  BEGIN
    INC(Tries);
    DoorX := 3 + GenRand(MaxWidth - 6);
    DoorY := 3 + GenRand(MaxHeight - 6);

    IF Map[DoorY, DoorX] <> TileWall THEN
      CONTINUE;

    { Look for a wall tile separating reachable floor from solid rock. }
    IF (Map[DoorY, DoorX - 1] = TileFloor) AND (Map[DoorY, DoorX + 1] = TileWall) THEN
    BEGIN
      InX := DoorX + 1; InY := DoorY;
      VW := 3 + GenRand(3); VH := 3 + GenRand(3);
      VX := InX; VY := InY - (VH DIV 2);
    END
    ELSE IF (Map[DoorY, DoorX + 1] = TileFloor) AND (Map[DoorY, DoorX - 1] = TileWall) THEN
    BEGIN
      InX := DoorX - 1; InY := DoorY;
      VW := 3 + GenRand(3); VH := 3 + GenRand(3);
      VX := InX - VW + 1; VY := InY - (VH DIV 2);
    END
    ELSE IF (Map[DoorY - 1, DoorX] = TileFloor) AND (Map[DoorY + 1, DoorX] = TileWall) THEN
    BEGIN
      InX := DoorX; InY := DoorY + 1;
      VW := 3 + GenRand(3); VH := 3 + GenRand(3);
      VX := InX - (VW DIV 2); VY := InY;
    END
    ELSE IF (Map[DoorY + 1, DoorX] = TileFloor) AND (Map[DoorY - 1, DoorX] = TileWall) THEN
    BEGIN
      InX := DoorX; InY := DoorY - 1;
      VW := 3 + GenRand(3); VH := 3 + GenRand(3);
      VX := InX - (VW DIV 2); VY := InY - VH + 1;
    END
    ELSE
      CONTINUE;

    IF (VX < 2) OR (VY < 2) OR (VX + VW - 1 > MaxWidth - 1) OR (VY + VH - 1 > MaxHeight - 1) THEN
      CONTINUE;

    Overlap := False;
    FOR R := VY TO VY + VH - 1 DO
      FOR C := VX TO VX + VW - 1 DO
        IF Map[R, C] = TileFloor THEN
          Overlap := True;
    IF Overlap THEN
      CONTINUE;

    PlaceRoom(VX, VY, VW, VH);
    IF GenRand(100) < 45 THEN
      Map[DoorY, DoorX] := TileLockedDoor
    ELSE
      Map[DoorY, DoorX] := TileSecretDoor;
    EXIT;
  END;
END;

PROCEDURE DecorateRoom(X, Y, W, H, Theme: Integer);
VAR
  Style: Integer;
  R, C: Integer;
  MidX, MidY: Integer;
BEGIN
  IF (W < 5) OR (H < 5) THEN
    EXIT;
  Style := GenRand(4);
  MidX := X + (W DIV 2);
  MidY := Y + (H DIV 2);

  CASE Style OF
    0:
      BEGIN
        { Pillars with a different feel by theme. }
        FOR R := Y + 1 TO Y + H - 2 DO
          FOR C := X + 1 TO X + W - 2 DO
            IF ((R - Y) MOD 2 = 0) AND ((C - X) MOD 3 = 0) THEN
            BEGIN
              IF Theme = ThemeRuins THEN
                Map[R, C] := TileDoor
              ELSE
                Map[R, C] := TileWall;
            END;
      END;
    1:
      BEGIN
        { Cross hall room. }
        FOR C := X + 1 TO X + W - 2 DO
          Map[MidY, C] := TileFloor;
        FOR R := Y + 1 TO Y + H - 2 DO
          Map[R, MidX] := TileFloor;
      END;
    2:
      BEGIN
        { Inner ring with four openings. }
        FOR C := X + 1 TO X + W - 2 DO
        BEGIN
          Map[Y + 1, C] := TileWall;
          Map[Y + H - 2, C] := TileWall;
        END;
        FOR R := Y + 1 TO Y + H - 2 DO
        BEGIN
          Map[R, X + 1] := TileWall;
          Map[R, X + W - 2] := TileWall;
        END;
        Map[Y + 1, MidX] := TileFloor;
        Map[Y + H - 2, MidX] := TileFloor;
        Map[MidY, X + 1] := TileFloor;
        Map[MidY, X + W - 2] := TileFloor;
      END;
    3:
      BEGIN
        { Diagonal rubble strip. }
        C := X + 1;
        FOR R := Y + 1 TO Y + H - 2 DO
        BEGIN
          IF (C >= X + 1) AND (C <= X + W - 2) THEN
            Map[R, C] := TileWall;
          INC(C);
        END;
      END;
  END;
END;

PROCEDURE GenerateDungeon;
VAR
  Rooms: ARRAY[1..MaxRooms] OF RECORD X, Y, W, H: Integer; END;
  I, J, K: Integer;
  RX, RY, RW, RH: Integer;
  Connected: Boolean;
BEGIN
  InitMap;
  
  { Generate Random Rooms }
  FOR I := 1 TO MaxRooms DO
  BEGIN
    REPEAT
      RW := 4 + GenRand(6); { Width 4-9 }
      RH := 4 + GenRand(6); { Height 4-9 }
      RX := 2 + GenRand(MaxWidth - RW - 2);
      RY := 2 + GenRand(MaxHeight - RH - 2);
      Connected := False;
      
      { Check overlap with existing rooms }
      FOR J := 1 TO I - 1 DO
      BEGIN
        IF (RX < Rooms[J].X + Rooms[J].W + 1) AND
           (RX + RW + 1 > Rooms[J].X) AND
           (RY < Rooms[J].Y + Rooms[J].H + 1) AND
           (RY + RH + 1 > Rooms[J].Y) THEN
          Connected := True;
      END;
    UNTIL NOT Connected;
    
    Rooms[I].X := RX;
    Rooms[I].Y := RY;
    Rooms[I].W := RW;
    Rooms[I].H := RH;
    
    PlaceRoom(RX, RY, RW, RH);
    DecorateRoom(RX, RY, RW, RH, GetThemeByDepth(Depth));
  END;
  
  { Connect Rooms }
  FOR I := 1 TO MaxRooms - 1 DO
  BEGIN
    ConnectRooms(
      Rooms[I].X + (Rooms[I].W DIV 2), 
      Rooms[I].Y + (Rooms[I].H DIV 2),
      Rooms[I+1].X + (Rooms[I+1].W DIV 2), 
      Rooms[I+1].Y + (Rooms[I+1].H DIV 2)
    );
  END;

  { Add optional side vaults sealed by secret doors. }
  FOR I := 1 TO 1 + (Depth DIV 6) DO
    PlaceVaultWithSecretDoor;
END;

{ --- Entity Management --- }

FUNCTION IsWall(X, Y: Integer): Boolean;
BEGIN
  IF (X < 1) OR (X > MaxWidth) OR (Y < 1) OR (Y > MaxHeight) THEN
    IsWall := True
  ELSE
    IsWall := (Map[Y, X] = TileWall) OR (Map[Y, X] = TileSecretDoor) OR (Map[Y, X] = TileLockedDoor);
END;

FUNCTION IsDoor(X, Y: Integer): Boolean;
BEGIN
  IF (X < 1) OR (X > MaxWidth) OR (Y < 1) OR (Y > MaxHeight) THEN
    IsDoor := False
  ELSE
    IsDoor := (Map[Y, X] = TileDoor) OR (Map[Y, X] = TileLockedDoor);
END;

FUNCTION HasLockedDoorOnMap: Boolean;
VAR
  R, C: Integer;
BEGIN
  FOR R := 1 TO MaxHeight DO
    FOR C := 1 TO MaxWidth DO
      IF Map[R, C] = TileLockedDoor THEN
      BEGIN
        HasLockedDoorOnMap := True;
        EXIT;
      END;
  HasLockedDoorOnMap := False;
END;

FUNCTION HasLineOfSight(X1, Y1, X2, Y2: Integer): Boolean;
VAR
  DX, DY: Integer;
  SX, SY: Integer;
  Err, E2: Integer;
  X, Y: Integer;
BEGIN
  X := X1;
  Y := Y1;
  DX := Abs(X2 - X1);
  DY := Abs(Y2 - Y1);
  IF X1 < X2 THEN SX := 1 ELSE SX := -1;
  IF Y1 < Y2 THEN SY := 1 ELSE SY := -1;
  Err := DX - DY;

  WHILE (X <> X2) OR (Y <> Y2) DO
  BEGIN
    E2 := Err * 2;
    IF E2 > -DY THEN
    BEGIN
      Err := Err - DY;
      X := X + SX;
    END;
    IF E2 < DX THEN
    BEGIN
      Err := Err + DX;
      Y := Y + SY;
    END;

    IF (X = X2) AND (Y = Y2) THEN
    BEGIN
      HasLineOfSight := True;
      EXIT;
    END;

    IF IsWall(X, Y) THEN
    BEGIN
      HasLineOfSight := False;
      EXIT;
    END;
  END;
  HasLineOfSight := True;
END;

FUNCTION GetEnemyAt(X, Y: Integer): Integer;
VAR
  I: Integer;
BEGIN
  GetEnemyAt := 0;
  FOR I := 1 TO MaxEnemies DO
    IF Enemies[I].Active AND (Enemies[I].X = X) AND (Enemies[I].Y = Y) THEN
    BEGIN
      GetEnemyAt := I;
      EXIT;
    END;
END;

FUNCTION GetItemAt(X, Y: Integer): Integer;
VAR
  I: Integer;
BEGIN
  GetItemAt := 0;
  FOR I := 1 TO MaxItems DO
    IF Items[I].Active AND (Items[I].X = X) AND (Items[I].Y = Y) THEN
    BEGIN
      GetItemAt := I;
      EXIT;
    END;
END;

FUNCTION IsItemBlockedCell(X, Y: Integer): Boolean;
VAR
  K: Integer;
BEGIN
  IsItemBlockedCell := False;
  IF (Player.X = X) AND (Player.Y = Y) THEN
  BEGIN
    IsItemBlockedCell := True;
    EXIT;
  END;
  FOR K := 1 TO MaxItems DO
    IF Items[K].Active AND (Items[K].X = X) AND (Items[K].Y = Y) THEN
    BEGIN
      IsItemBlockedCell := True;
      EXIT;
    END;
END;

FUNCTION IsAdjacentToSecretDoor(X, Y: Integer): Boolean;
BEGIN
  IsAdjacentToSecretDoor := False;
  IF (X > 1) AND (Map[Y, X - 1] = TileSecretDoor) THEN IsAdjacentToSecretDoor := True;
  IF (X < MaxWidth) AND (Map[Y, X + 1] = TileSecretDoor) THEN IsAdjacentToSecretDoor := True;
  IF (Y > 1) AND (Map[Y - 1, X] = TileSecretDoor) THEN IsAdjacentToSecretDoor := True;
  IF (Y < MaxHeight) AND (Map[Y + 1, X] = TileSecretDoor) THEN IsAdjacentToSecretDoor := True;
END;

FUNCTION CountActiveEnemies: Integer;
VAR
  K: Integer;
BEGIN
  CountActiveEnemies := 0;
  FOR K := 1 TO MaxEnemies DO
    IF Enemies[K].Active THEN
      INC(CountActiveEnemies);
END;

FUNCTION IsDangerVisible: Boolean;
VAR
  K, Dist, SightRange: Integer;
BEGIN
  IF Player.BlindTurns > 0 THEN
    SightRange := 2
  ELSE
    SightRange := 8;
  FOR K := 1 TO MaxEnemies DO
    IF Enemies[K].Active THEN
    BEGIN
      Dist := Abs(Enemies[K].X - Player.X) + Abs(Enemies[K].Y - Player.Y);
      IF (Dist <= SightRange) AND HasLineOfSight(Player.X, Player.Y, Enemies[K].X, Enemies[K].Y) THEN
      BEGIN
        IsDangerVisible := True;
        EXIT;
      END;
    END;
  IsDangerVisible := False;
END;

FUNCTION IsInterestingVisible: Boolean;
VAR
  K, Dist, SightRange: Integer;
BEGIN
  IF IsDangerVisible THEN
  BEGIN
    IsInterestingVisible := True;
    EXIT;
  END;
  IF Player.BlindTurns > 0 THEN
    SightRange := 2
  ELSE
    SightRange := 8;
  FOR K := 1 TO MaxItems DO
    IF Items[K].Active THEN
    BEGIN
      Dist := Abs(Items[K].X - Player.X) + Abs(Items[K].Y - Player.Y);
      IF (Dist <= SightRange) AND HasLineOfSight(Player.X, Player.Y, Items[K].X, Items[K].Y) THEN
      BEGIN
        IsInterestingVisible := True;
        EXIT;
      END;
    END;
  IsInterestingVisible := IsStairsDownAt(Player.X, Player.Y) OR IsStairsUpAt(Player.X, Player.Y);
END;

PROCEDURE SpawnEnemies;
VAR
  I, X, Y, Count, Theme: Integer;
  TargetCount: Integer;
  Tier, ThemeRoll: Integer;
  Names: ARRAY[1..8] OF String[15];
BEGIN
  Theme := GetThemeByDepth(Depth);
  IF Theme = ThemeCaves THEN
  BEGIN
    Names[1] := 'Bat';
    Names[2] := 'Rat';
    Names[3] := 'Goblin';
    Names[4] := 'Orc';
    Names[5] := 'Troll';
    Names[6] := 'Warg';
    Names[7] := 'Ogre';
    Names[8] := 'Wyvern';
  END
  ELSE IF Theme = ThemeRuins THEN
  BEGIN
    Names[1] := 'Bandit';
    Names[2] := 'Goblin';
    Names[3] := 'Orc';
    Names[4] := 'Adept';
    Names[5] := 'Troll';
    Names[6] := 'Sentinel';
    Names[7] := 'Vampire';
    Names[8] := 'Dragon';
  END
  ELSE
  BEGIN
    Names[1] := 'Rat';
    Names[2] := 'Skeleton';
    Names[3] := 'Ghoul';
    Names[4] := 'Wraith';
    Names[5] := 'Vampire';
    Names[6] := 'Lich';
    Names[7] := 'Dread';
    Names[8] := 'Ancient';
  END;
  
  Count := 0;
  TargetCount := 8 + Depth * 3;
  IF TargetCount > MaxEnemies THEN
    TargetCount := MaxEnemies;
  FOR I := 1 TO MaxEnemies DO
    Enemies[I].Active := False;
    
  WHILE Count < TargetCount DO
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    
    IF (Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y) THEN
    BEGIN
      { Don't spawn on player }
      IF (X <> Player.X) OR (Y <> Player.Y) THEN
      BEGIN
        INC(Count);
        Enemies[Count].X := X;
        Enemies[Count].Y := Y;
        Enemies[Count].Active := True;
        
