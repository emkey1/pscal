PROCEDURE AutoExplore; FORWARD;
PROCEDURE SearchNearby; FORWARD;
PROCEDURE SaveCurrentLevelState; FORWARD;
PROCEDURE LoadLevelState(LevelNum: Integer); FORWARD;
