PROCEDURE SpawnItems;
VAR
  I, X, Y, Count, Theme: Integer;
  ScrollCap, AmuletCap: Integer;
  BonusTries: Integer;
BEGIN
  Theme := GetThemeByDepth(Depth);
  ScrollCap := 14;
  AmuletCap := 15;
  IF Theme = ThemeRuins THEN
    ScrollCap := 15
  ELSE IF Theme = ThemeCrypt THEN
    ScrollCap := 13;
  IF Theme = ThemeCrypt THEN
    AmuletCap := 16;

  Count := 0;
  FOR I := 1 TO MaxItems DO
    Items[I].Active := False;

  { Guarantee at least one key when this level has locked doors. }
  IF HasLockedDoorOnMap THEN
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    WHILE NOT ((Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y)) DO
    BEGIN
      X := 2 + GenRand(MaxWidth - 4);
      Y := 2 + GenRand(MaxHeight - 4);
    END;
    INC(Count);
    Items[Count].X := X;
    Items[Count].Y := Y;
    Items[Count].TypeChar := TileKey;
    Items[Count].Value := 1;
    Items[Count].Active := True;
  END;
    
  { Spawn Gold }
  WHILE Count < 5 DO
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    IF (Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y) THEN
    BEGIN
      INC(Count);
      Items[Count].X := X;
      Items[Count].Y := Y;
      Items[Count].TypeChar := TileGold;
      Items[Count].Value := 10 + GenRand(20);
      Items[Count].Active := True;
    END;
  END;
  
  { Spawn Potions }
  WHILE Count < 8 DO
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    IF (Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y) THEN
    BEGIN
      INC(Count);
      Items[Count].X := X;
      Items[Count].Y := Y;
      Items[Count].TypeChar := TilePotion;
      Items[Count].Value := 10;
      Items[Count].Active := True;
    END;
  END;

  { Spawn Weapons }
  WHILE Count < 10 DO
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    IF (Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y) THEN
    BEGIN
      INC(Count);
      Items[Count].X := X;
      Items[Count].Y := Y;
      Items[Count].TypeChar := TileWeapon;
      IF Theme = ThemeCaves THEN
        Items[Count].Value := 1 + GenRand(2) + (Depth DIV 3)
      ELSE
        Items[Count].Value := 1 + GenRand(3) + (Depth DIV 2);
      Items[Count].Active := True;
    END;
  END;

  { Spawn Armor }
  WHILE Count < 11 DO
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    IF (Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y) THEN
    BEGIN
      INC(Count);
      Items[Count].X := X;
      Items[Count].Y := Y;
      Items[Count].TypeChar := TileArmor;
      IF Theme = ThemeCaves THEN
        Items[Count].Value := 1 + GenRand(3) + (Depth DIV 2)
      ELSE IF Theme = ThemeCrypt THEN
        Items[Count].Value := 2 + GenRand(3) + (Depth DIV 2)
      ELSE
        Items[Count].Value := 1 + GenRand(2) + (Depth DIV 3);
      Items[Count].Active := True;
    END;
  END;

  { Spawn Scrolls (Value as subtype: 1=Healing, 2=Mapping, 3=Teleport) }
  WHILE Count < ScrollCap DO
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    IF (Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y) THEN
    BEGIN
      INC(Count);
      Items[Count].X := X;
      Items[Count].Y := Y;
      Items[Count].TypeChar := TileScroll;
      IF Theme = ThemeCaves THEN
        Items[Count].Value := 1 + GenRand(2) { less teleport in caves }
      ELSE
        Items[Count].Value := 1 + GenRand(3);
      Items[Count].Active := True;
    END;
  END;

  { Spawn Amulets (small permanent bonuses) }
  WHILE Count < AmuletCap DO
  BEGIN
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    IF (Map[Y, X] = TileFloor) AND NOT IsWall(X, Y) AND NOT IsItemBlockedCell(X, Y) THEN
    BEGIN
      INC(Count);
      Items[Count].X := X;
      Items[Count].Y := Y;
      Items[Count].TypeChar := TileAmulet;
      IF Theme = ThemeCrypt THEN
        Items[Count].Value := 2 + GenRand(2)
      ELSE
        Items[Count].Value := 1 + GenRand(2);
      Items[Count].Active := True;
    END;
  END;

  { Vault reward bias: secret side rooms tend to have one extra premium drop. }
  BonusTries := 0;
  WHILE (Count < MaxItems) AND (BonusTries < 80) DO
  BEGIN
    INC(BonusTries);
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    IF (Map[Y, X] = TileFloor) AND IsAdjacentToSecretDoor(X, Y) AND
       (GetItemAt(X, Y) = 0) AND (GetEnemyAt(X, Y) = 0) THEN
    BEGIN
      INC(Count);
      Items[Count].X := X;
      Items[Count].Y := Y;
      IF GenRand(100) < 45 THEN
      BEGIN
        Items[Count].TypeChar := TileScroll;
        Items[Count].Value := 1 + GenRand(3); { heal/map/tele }
      END
      ELSE IF GenRand(100) < 70 THEN
      BEGIN
        Items[Count].TypeChar := TileWeapon;
        Items[Count].Value := 2 + GenRand(4) + (Depth DIV 2);
      END
      ELSE
      BEGIN
        Items[Count].TypeChar := TileArmor;
        Items[Count].Value := 2 + GenRand(4) + (Depth DIV 2);
      END;
      Items[Count].Active := True;
      BREAK;
    END;
  END;

END;

FUNCTION Sign(Value: Integer): Integer;
BEGIN
  IF Value < 0 THEN
    Sign := -1
  ELSE IF Value > 0 THEN
    Sign := 1
  ELSE
    Sign := 0;
END;

FUNCTION IsPassable(X, Y: Integer): Boolean;
BEGIN
  IsPassable := NOT IsWall(X, Y);
END;

FUNCTION ShouldStopRunAtCrossCorridor(X, Y, DX, DY: Integer): Boolean;
VAR
  Side1Open, Side2Open: Boolean;
BEGIN
  ShouldStopRunAtCrossCorridor := False;

  { Cardinal running: stop when a perpendicular branch is immediately adjacent. }
  IF (DX <> 0) AND (DY = 0) THEN
  BEGIN
    Side1Open := IsPassable(X, Y - 1);
    Side2Open := IsPassable(X, Y + 1);
    ShouldStopRunAtCrossCorridor := Side1Open OR Side2Open;
    EXIT;
  END;
  IF (DY <> 0) AND (DX = 0) THEN
  BEGIN
    Side1Open := IsPassable(X - 1, Y);
    Side2Open := IsPassable(X + 1, Y);
    ShouldStopRunAtCrossCorridor := Side1Open OR Side2Open;
    EXIT;
  END;
END;

FUNCTION IsNarrowCorridorTileForRun(X, Y, DX, DY: Integer): Boolean;
BEGIN
  IsNarrowCorridorTileForRun := False;
  IF (DX <> 0) AND (DY = 0) THEN
  BEGIN
    { Horizontal corridor: side walls present, path continues left/right. }
    IF (NOT IsPassable(X, Y - 1)) AND (NOT IsPassable(X, Y + 1)) AND
       (IsPassable(X - 1, Y) OR IsPassable(X + 1, Y)) THEN
      IsNarrowCorridorTileForRun := True;
  END
  ELSE IF (DY <> 0) AND (DX = 0) THEN
  BEGIN
    { Vertical corridor: side walls present, path continues up/down. }
    IF (NOT IsPassable(X - 1, Y)) AND (NOT IsPassable(X + 1, Y)) AND
       (IsPassable(X, Y - 1) OR IsPassable(X, Y + 1)) THEN
      IsNarrowCorridorTileForRun := True;
  END;
END;

FUNCTION CanEnemyMoveTo(EnemyIdx, NewX, NewY: Integer): Boolean;
VAR
  OtherEnemy: Integer;
BEGIN
  CanEnemyMoveTo := False;
  IF NOT IsPassable(NewX, NewY) THEN EXIT;
  IF (NewX = Player.X) AND (NewY = Player.Y) THEN EXIT;

  FOR OtherEnemy := 1 TO MaxEnemies DO
    IF Enemies[OtherEnemy].Active AND (OtherEnemy <> EnemyIdx) AND
       (Enemies[OtherEnemy].X = NewX) AND (Enemies[OtherEnemy].Y = NewY) THEN
      EXIT;

  CanEnemyMoveTo := True;
END;

PROCEDURE EnemyAttackPlayer(EnemyIdx: Integer);
VAR
  EnemyDmg: Integer;
  HitChance: Integer;
  HitRoll: Integer;
  CritRoll: Integer;
BEGIN
  HitChance := 72 + (Depth DIV 2) - (Player.Defense + Player.ArmorBonus);
  IF HitChance < 35 THEN HitChance := 35;
  IF HitChance > 95 THEN HitChance := 95;
  HitRoll := GenRand(100);
  IF HitRoll >= HitChance THEN
  BEGIN
    AddMessage(Enemies[EnemyIdx].Name + ' misses you [melee].');
    EXIT;
  END;

  EnemyDmg := Enemies[EnemyIdx].Damage - ((Player.Defense + Player.ArmorBonus) DIV 2);
  IF EnemyDmg < 1 THEN EnemyDmg := 1;
  CritRoll := GenRand(100);
  IF CritRoll < 8 THEN
  BEGIN
    EnemyDmg := EnemyDmg + (EnemyDmg DIV 2) + 1;
    AddMessage(Enemies[EnemyIdx].Name + ' lands a critical hit [melee]!');
  END;
  Player.HP := Player.HP - EnemyDmg;
  AddMessage(Enemies[EnemyIdx].Name + ' hits you for ' + IntToStr(EnemyDmg) + ' [physical].');
  IF Enemies[EnemyIdx].Glyph = 'W' THEN
  BEGIN
    IF GenRand(100) < 20 THEN
    BEGIN
      Player.BlindTurns := Player.BlindTurns + 4;
      AddMessage('Darkness blinds you!');
    END;
  END
  ELSE IF (Enemies[EnemyIdx].Glyph = 'V') OR (Enemies[EnemyIdx].Glyph = 'D') THEN
  BEGIN
    IF GenRand(100) < 20 THEN
    BEGIN
      Player.ConfuseTurns := Player.ConfuseTurns + 4;
      AddMessage('Your mind reels in confusion!');
    END;
  END
  ELSE IF (Enemies[EnemyIdx].Glyph = 's') OR (Enemies[EnemyIdx].Glyph = 'L') THEN
  BEGIN
    IF GenRand(100) < 20 THEN
    BEGIN
      Player.SlowTurns := Player.SlowTurns + 4;
      AddMessage('You feel sluggish.');
    END;
  END
  ELSE IF (Enemies[EnemyIdx].Glyph = 'g') OR (Enemies[EnemyIdx].Glyph = 'o') THEN
  BEGIN
    IF GenRand(100) < 15 THEN
    BEGIN
      Player.PoisonTurns := Player.PoisonTurns + 5;
      AddMessage('You are poisoned!');
    END;
  END;
  IF Player.HP <= 0 THEN
  BEGIN
    GameOver := True;
    AddMessage('YOU HAVE DIED.');
  END;
END;

PROCEDURE EnemyCastSpellAtPlayer(EnemyIdx: Integer);
VAR
  SpellDmg: Integer;
BEGIN
  SpellDmg := 3 + (Depth DIV 2) + GenRand(4);
  SpellDmg := SpellDmg - ((Player.Defense + Player.ArmorBonus) DIV 4);
  IF SpellDmg < 1 THEN SpellDmg := 1;
  Player.HP := Player.HP - SpellDmg;
  AddMessage(Enemies[EnemyIdx].Name + ' casts a bolt for ' + IntToStr(SpellDmg) + ' [arcane].');
  IF Player.HP <= 0 THEN
  BEGIN
    GameOver := True;
    AddMessage('YOU HAVE DIED.');
  END;
END;

PROCEDURE MonstersTakeTurn;
VAR
  EnemyIdx: Integer;
  AllyIdx: Integer;
  Actions: Integer;
  DX, DY: Integer;
  StepX, StepY: Integer;
  Dist: Integer;
  TryX, TryY: Integer;
  AllyDist: Integer;
  EngageRange: Integer;
  PackAssist: Boolean;
  Fleeing: Boolean;
  IsCaster: Boolean;
BEGIN
  FOR EnemyIdx := 1 TO MaxEnemies DO
  BEGIN
    IF NOT Enemies[EnemyIdx].Active THEN
      CONTINUE;

    Enemies[EnemyIdx].Energy := Enemies[EnemyIdx].Energy + Enemies[EnemyIdx].Speed;
    Actions := 0;
    WHILE Enemies[EnemyIdx].Energy >= 100 DO
    BEGIN
      Enemies[EnemyIdx].Energy := Enemies[EnemyIdx].Energy - 100;
      INC(Actions);
      IF Actions > 2 THEN BREAK;

      DX := Player.X - Enemies[EnemyIdx].X;
      DY := Player.Y - Enemies[EnemyIdx].Y;
      Dist := Abs(DX) + Abs(DY);
      EngageRange := 8;
      PackAssist := False;
      Fleeing := (Enemies[EnemyIdx].HP * 100 <= Enemies[EnemyIdx].MaxHP * 35);
      IsCaster := (Enemies[EnemyIdx].Glyph = 'A') OR (Enemies[EnemyIdx].Glyph = 'L') OR
                  (Enemies[EnemyIdx].Glyph = 'V') OR (Enemies[EnemyIdx].Glyph = 'D');

      { Pack behavior: if an ally is already near the player, this enemy joins. }
      FOR AllyIdx := 1 TO MaxEnemies DO
        IF Enemies[AllyIdx].Active AND (AllyIdx <> EnemyIdx) THEN
        BEGIN
          AllyDist := Abs(Enemies[AllyIdx].X - Player.X) + Abs(Enemies[AllyIdx].Y - Player.Y);
          IF AllyDist <= 4 THEN
          BEGIN
            PackAssist := True;
            BREAK;
          END;
        END;
      IF PackAssist THEN
        EngageRange := 12;

      IF Dist <= 1 THEN
      BEGIN
        EnemyAttackPlayer(EnemyIdx);
        IF GameOver THEN EXIT;
        CONTINUE;
      END;

      IF IsCaster AND
         (Dist <= 6) AND HasLineOfSight(Enemies[EnemyIdx].X, Enemies[EnemyIdx].Y, Player.X, Player.Y) AND
         (GenRand(100) < 45) THEN
      BEGIN
        EnemyCastSpellAtPlayer(EnemyIdx);
        IF GameOver THEN EXIT;
        CONTINUE;
      END;

      IF IsCaster AND (Dist <= 2) THEN
      BEGIN
        { Casters prefer spacing: kite when a melee threat is too close. }
        StepX := -Sign(DX);
        StepY := -Sign(DY);
        TryX := Enemies[EnemyIdx].X + StepX;
        TryY := Enemies[EnemyIdx].Y + StepY;
        IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
        BEGIN
          Enemies[EnemyIdx].X := TryX;
          Enemies[EnemyIdx].Y := TryY;
          CONTINUE;
        END;
      END;

      IF Fleeing THEN
      BEGIN
        { Wounded enemies try to open distance instead of closing in. }
        StepX := -Sign(DX);
        StepY := -Sign(DY);
        TryX := Enemies[EnemyIdx].X + StepX;
        TryY := Enemies[EnemyIdx].Y + StepY;
        IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
        BEGIN
          Enemies[EnemyIdx].X := TryX;
          Enemies[EnemyIdx].Y := TryY;
        END
        ELSE
        BEGIN
          TryX := Enemies[EnemyIdx].X - Sign(DX);
          TryY := Enemies[EnemyIdx].Y;
          IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
            Enemies[EnemyIdx].X := TryX
          ELSE
          BEGIN
            TryX := Enemies[EnemyIdx].X;
            TryY := Enemies[EnemyIdx].Y - Sign(DY);
            IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
              Enemies[EnemyIdx].Y := TryY;
          END;
        END;
      END
      { Angband-like behavior: nearby monsters pursue, distant monsters may wander. }
      ELSE IF Dist <= EngageRange THEN
      BEGIN
        StepX := Sign(DX);
        StepY := Sign(DY);

        TryX := Enemies[EnemyIdx].X + StepX;
        TryY := Enemies[EnemyIdx].Y + StepY;
        IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
        BEGIN
          Enemies[EnemyIdx].X := TryX;
          Enemies[EnemyIdx].Y := TryY;
        END
        ELSE
        BEGIN
          TryX := Enemies[EnemyIdx].X + StepX;
          TryY := Enemies[EnemyIdx].Y;
          IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
            Enemies[EnemyIdx].X := TryX
          ELSE
          BEGIN
            TryX := Enemies[EnemyIdx].X;
            TryY := Enemies[EnemyIdx].Y + StepY;
            IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
              Enemies[EnemyIdx].Y := TryY;
          END;
        END;
      END
      ELSE
      BEGIN
        IF GenRand(100) < 30 THEN
        BEGIN
          TryX := Enemies[EnemyIdx].X + (GenRand(3) - 1);
          TryY := Enemies[EnemyIdx].Y + (GenRand(3) - 1);
          IF CanEnemyMoveTo(EnemyIdx, TryX, TryY) THEN
          BEGIN
            Enemies[EnemyIdx].X := TryX;
            Enemies[EnemyIdx].Y := TryY;
          END;
        END;
      END;
    END;
  END;
END;

PROCEDURE TrySpawnMonster;
VAR
  Slot, X, Y, TryCount, Theme, Tier: Integer;
BEGIN
  IF SpawnBudget <= 0 THEN EXIT;
  IF SpawnCooldown > 0 THEN EXIT;
  IF CountActiveEnemies >= MaxEnemies THEN EXIT;

  Slot := 0;
  FOR X := 1 TO MaxEnemies DO
    IF NOT Enemies[X].Active THEN
    BEGIN
      Slot := X;
      BREAK;
    END;
  IF Slot = 0 THEN EXIT;

  TryCount := 0;
  REPEAT
    X := 2 + GenRand(MaxWidth - 4);
    Y := 2 + GenRand(MaxHeight - 4);
    INC(TryCount);
  UNTIL ((Map[Y, X] = TileFloor) AND (GetEnemyAt(X, Y) = 0) AND (GetItemAt(X, Y) = 0) AND
         ((Abs(X - Player.X) + Abs(Y - Player.Y)) >= 10)) OR (TryCount > 80);
  IF TryCount > 80 THEN EXIT;

  Theme := GetThemeByDepth(Depth);
  Tier := Depth + GenRand(2);
  IF Tier < 1 THEN Tier := 1;
  IF Tier > 8 THEN Tier := 8;

  Enemies[Slot].Active := True;
  Enemies[Slot].X := X;
  Enemies[Slot].Y := Y;
  Enemies[Slot].Energy := 0;

  CASE Tier OF
    1: BEGIN Enemies[Slot].Name := 'Rat'; Enemies[Slot].Glyph := 'r'; Enemies[Slot].MaxHP := 12; Enemies[Slot].Damage := 3; Enemies[Slot].Speed := 110; Enemies[Slot].Color := Brown; Enemies[Slot].ResistPhysical := 0; Enemies[Slot].ResistMagic := 0; END;
    2: BEGIN Enemies[Slot].Name := 'Goblin'; Enemies[Slot].Glyph := 'g'; Enemies[Slot].MaxHP := 20; Enemies[Slot].Damage := 4; Enemies[Slot].Speed := 105; Enemies[Slot].Color := LightGreen; Enemies[Slot].ResistPhysical := 5; Enemies[Slot].ResistMagic := 0; END;
    3: BEGIN Enemies[Slot].Name := 'Skeleton'; Enemies[Slot].Glyph := 's'; Enemies[Slot].MaxHP := 30; Enemies[Slot].Damage := 6; Enemies[Slot].Speed := 95; Enemies[Slot].Color := White; Enemies[Slot].ResistPhysical := 15; Enemies[Slot].ResistMagic := 10; END;
    4: BEGIN Enemies[Slot].Name := 'Orc'; Enemies[Slot].Glyph := 'o'; Enemies[Slot].MaxHP := 40; Enemies[Slot].Damage := 7; Enemies[Slot].Speed := 100; Enemies[Slot].Color := LightRed; Enemies[Slot].ResistPhysical := 10; Enemies[Slot].ResistMagic := 15; END;
    5: BEGIN Enemies[Slot].Name := 'Troll'; Enemies[Slot].Glyph := 'T'; Enemies[Slot].MaxHP := 50; Enemies[Slot].Damage := 9; Enemies[Slot].Speed := 85; Enemies[Slot].Color := Green; Enemies[Slot].ResistPhysical := 20; Enemies[Slot].ResistMagic := 10; END;
    6: BEGIN Enemies[Slot].Name := 'Wraith'; Enemies[Slot].Glyph := 'W'; Enemies[Slot].MaxHP := 52; Enemies[Slot].Damage := 10; Enemies[Slot].Speed := 115; Enemies[Slot].Color := LightGray; Enemies[Slot].ResistPhysical := 10; Enemies[Slot].ResistMagic := 30; END;
    7: BEGIN Enemies[Slot].Name := 'Vampire'; Enemies[Slot].Glyph := 'V'; Enemies[Slot].MaxHP := 62; Enemies[Slot].Damage := 12; Enemies[Slot].Speed := 110; Enemies[Slot].Color := Magenta; Enemies[Slot].ResistPhysical := 20; Enemies[Slot].ResistMagic := 35; END;
  ELSE
    BEGIN Enemies[Slot].Name := 'Dragon'; Enemies[Slot].Glyph := 'D'; Enemies[Slot].MaxHP := 74; Enemies[Slot].Damage := 15; Enemies[Slot].Speed := 95; Enemies[Slot].Color := LightRed; Enemies[Slot].ResistPhysical := 30; Enemies[Slot].ResistMagic := 40; END;
  END;
  IF Theme = ThemeCrypt THEN
    Enemies[Slot].Color := LightGray;
  Enemies[Slot].HP := Enemies[Slot].MaxHP;

  DEC(SpawnBudget);
  SpawnCooldown := 8 + GenRand(7);
  AddMessage('You hear distant footsteps...');
END;

PROCEDURE EndPlayerTurn;
VAR
  MonsterTurns: Integer;
BEGIN
  INC(TurnCount);
  TickPlayerStatus;
  IF GameOver THEN EXIT;

  MonsterTurns := 1;
  IF Player.SlowTurns > 0 THEN
    MonsterTurns := 2
  ELSE IF (Player.HasteTurns > 0) AND ((TurnCount MOD 2) = 1) THEN
    MonsterTurns := 0;

  WHILE MonsterTurns > 0 DO
  BEGIN
    MonstersTakeTurn;
    DEC(MonsterTurns);
    IF GameOver THEN EXIT;
  END;
  IF SpawnCooldown > 0 THEN DEC(SpawnCooldown);
  TrySpawnMonster;

  { Slow passive regeneration gives a roguelike resting rhythm. }
  IF (TurnCount MOD 8 = 0) AND (Player.HP < Player.MaxHP) THEN
    INC(Player.HP);
  IF (TurnCount MOD 6 = 0) AND (Player.Mana < Player.MaxMana) THEN
    INC(Player.Mana);
END;

FUNCTION IsStairsDownAt(X, Y: Integer): Boolean;
BEGIN
  IsStairsDownAt := (X >= 1) AND (X <= MaxWidth) AND (Y >= 1) AND (Y <= MaxHeight) AND
                    (Map[Y, X] = TileStairsDown);
END;

FUNCTION IsStairsUpAt(X, Y: Integer): Boolean;
BEGIN
  IsStairsUpAt := (X >= 1) AND (X <= MaxWidth) AND (Y >= 1) AND (Y <= MaxHeight) AND
                  (Map[Y, X] = TileStairsUp);
END;

PROCEDURE SaveCurrentLevelState;
BEGIN
  IF (Depth < 1) OR (Depth > MaxDungeonDepth) THEN
    EXIT;
  Levels[Depth].Generated := True;
  CopyMap(Levels[Depth].Map, Map);
  CopyMap(Levels[Depth].SeenMap, SeenMap);
  CopyEnemiesToLevel(Depth);
  CopyItemsToLevel(Depth);
  Levels[Depth].SpawnBudget := SpawnBudget;
  Levels[Depth].SpawnCooldown := SpawnCooldown;
END;

PROCEDURE LoadLevelState(LevelNum: Integer);
BEGIN
  CopyMap(Map, Levels[LevelNum].Map);
  CopyMap(SeenMap, Levels[LevelNum].SeenMap);
  CopyEnemiesFromLevel(LevelNum);
  CopyItemsFromLevel(LevelNum);
  SpawnBudget := Levels[LevelNum].SpawnBudget;
  SpawnCooldown := Levels[LevelNum].SpawnCooldown;
END;

PROCEDURE PlaceStairsDownForCurrentLevel;
VAR
  SX, SY: Integer;
BEGIN
  REPEAT
    SX := 2 + GenRand(MaxWidth - 4);
    SY := 2 + GenRand(MaxHeight - 4);
  UNTIL (Map[SY, SX] = TileFloor);
  Map[SY, SX] := TileStairsDown;
  Levels[Depth].DownX := SX;
  Levels[Depth].DownY := SY;
END;

PROCEDURE EnterLevel(NewDepth, EntryX, EntryY: Integer);
BEGIN
  IF (NewDepth < 1) OR (NewDepth > MaxDungeonDepth) THEN
  BEGIN
    AddMessage('You cannot go that way.');
    EXIT;
  END;

  IF (Depth >= 1) AND (Depth <= MaxDungeonDepth) AND Levels[Depth].Generated AND (NewDepth <> Depth) THEN
    SaveCurrentLevelState;
  Depth := NewDepth;

  IF Levels[Depth].Generated THEN
  BEGIN
    LoadLevelState(Depth)
  END
  ELSE
  BEGIN
    SetGenSeed(GameSeed + (Depth * 8191));
    GenerateDungeon;
    ClearSeenMap;
    SpawnEnemies;
    SpawnItems;
    Levels[Depth].EntryX := EntryX;
    Levels[Depth].EntryY := EntryY;
    IF (EntryX >= 1) AND (EntryX <= MaxWidth) AND (EntryY >= 1) AND (EntryY <= MaxHeight) AND
       (Map[EntryY, EntryX] <> TileWall) THEN
      Map[EntryY, EntryX] := TileStairsUp;
    PlaceStairsDownForCurrentLevel;
    SpawnBudget := 6 + (Depth DIV 2);
    IF SpawnBudget > 20 THEN SpawnBudget := 20;
    SpawnCooldown := 6 + GenRand(6);
    Levels[Depth].Generated := True;
    SaveCurrentLevelState;
    AddMessage('You enter the ' + GetThemeName(Depth) + '.');
  END;

  Player.X := EntryX;
  Player.Y := EntryY;
  IF (Player.X < 1) OR (Player.X > MaxWidth) OR (Player.Y < 1) OR (Player.Y > MaxHeight) OR
     (Map[Player.Y, Player.X] = TileWall) THEN
  BEGIN
    Player.X := 2;
    Player.Y := 2;
    WHILE Map[Player.Y, Player.X] = TileWall DO
    BEGIN
      INC(Player.Y);
      IF Player.Y > MaxHeight THEN
      BEGIN
        Player.Y := 2;
        INC(Player.X);
      END;
    END;
  END;
END;

{ --- Rendering --- }

PROCEDURE RenderMap;
VAR
  I, J: Integer;
  Ex, Ey: Integer;
  Dist: Integer;
  ViewTop: Integer;
  ViewLeft: Integer;
  MapY: Integer;
  MapX: Integer;
  ScreenY: Integer;
  ScreenX: Integer;
  SightRange: Integer;
BEGIN
  IF Player.BlindTurns > 0 THEN
    SightRange := 2
  ELSE
    SightRange := 8;
  ViewLeft := Player.X - (ViewWidth DIV 2);
  IF ViewLeft < 1 THEN
    ViewLeft := 1;
  IF ViewLeft > MaxWidth - ViewWidth + 1 THEN
    ViewLeft := MaxWidth - ViewWidth + 1;

  ViewTop := Player.Y - (MapHeightView DIV 2);
  IF ViewTop < 1 THEN
    ViewTop := 1;
  IF ViewTop > MaxHeight - MapHeightView + 1 THEN
    ViewTop := MaxHeight - MapHeightView + 1;

  FOR ScreenY := MapTop TO MapTop + MapHeightView - 1 DO
  BEGIN
    MapY := ViewTop + (ScreenY - MapTop);
    FOR ScreenX := 1 TO ViewWidth DO
    BEGIN
      MapX := ViewLeft + (ScreenX - 1);
      { Calculate Distance from Player }
      Ex := MapX - Player.X;
      Ey := MapY - Player.Y;
      Dist := Abs(Ex) + Abs(Ey);
      
      { Update Seen Map (Fog of War) }
      IF (Dist <= SightRange) AND HasLineOfSight(Player.X, Player.Y, MapX, MapY) THEN
        SeenMap[MapY, MapX] := Map[MapY, MapX];
        
      { Draw Tile }
      IF (MapX = Player.X) AND (MapY = Player.Y) THEN
      BEGIN
        ColorTextGlyph(ScreenX, ScreenY, GlyphPlayer, LightGreen);
      END
      ELSE IF SeenMap[MapY, MapX] <> TileFog THEN
      BEGIN
        CASE SeenMap[MapY, MapX] OF
          TileWall: ColorTextGlyph(ScreenX, ScreenY, GlyphWall, DarkGray);
          TileSecretDoor: ColorTextGlyph(ScreenX, ScreenY, GlyphWall, DarkGray);
          TileDoor: ColorTextGlyph(ScreenX, ScreenY, GlyphDoor, Brown);
          TileLockedDoor: ColorTextGlyph(ScreenX, ScreenY, GlyphLockedDoor, LightRed);
          TileFloor: ColorTextGlyph(ScreenX, ScreenY, GlyphFloor, DarkGray);
          TileStairsDown: ColorTextGlyph(ScreenX, ScreenY, GlyphStairsDown, Yellow);
          TileStairsUp: ColorTextGlyph(ScreenX, ScreenY, GlyphStairsUp, LightCyan);
          TileWeapon: ColorTextGlyph(ScreenX, ScreenY, GlyphWeapon, LightCyan);
          TileArmor: ColorTextGlyph(ScreenX, ScreenY, GlyphArmor, LightBlue);
          TileScroll: ColorTextGlyph(ScreenX, ScreenY, GlyphScroll, LightMagenta);
          TileAmulet: ColorTextGlyph(ScreenX, ScreenY, GlyphAmulet, LightGreen);
          TileKey: ColorTextGlyph(ScreenX, ScreenY, GlyphKey, Yellow);
          ELSE
            ColorText(ScreenX, ScreenY, SeenMap[MapY, MapX], White);
        END;
      END
      ELSE
      BEGIN
        { Unseen area: keep black or clear }
        GotoXY(ScreenX, ScreenY);
        Write(' ');
      END;
    END;
  END;
    
  { Draw Enemies and Items on top of map if visible }
  FOR I := 1 TO MaxEnemies DO
    IF Enemies[I].Active THEN
    BEGIN
      Ex := Enemies[I].X - Player.X;
      Ey := Enemies[I].Y - Player.Y;
      ScreenY := MapTop + (Enemies[I].Y - ViewTop);
      ScreenX := Enemies[I].X - ViewLeft + 1;
      IF (Abs(Ex) <= SightRange) AND (Abs(Ey) <= SightRange) AND
         HasLineOfSight(Player.X, Player.Y, Enemies[I].X, Enemies[I].Y) AND
         (ScreenX >= 1) AND (ScreenX <= ViewWidth) AND
         (ScreenY >= MapTop) AND (ScreenY < MapTop + MapHeightView) THEN
        ColorText(ScreenX, ScreenY, Enemies[I].Glyph, Enemies[I].Color);
      IF (Player.DetectTurns > 0) AND
         (ScreenX >= 1) AND (ScreenX <= ViewWidth) AND
         (ScreenY >= MapTop) AND (ScreenY < MapTop + MapHeightView) THEN
      BEGIN
        IF NOT ((Abs(Ex) <= SightRange) AND (Abs(Ey) <= SightRange) AND
                HasLineOfSight(Player.X, Player.Y, Enemies[I].X, Enemies[I].Y)) THEN
          ColorText(ScreenX, ScreenY, Enemies[I].Glyph, LightMagenta);
      END;
    END;
        
  FOR I := 1 TO MaxItems DO
    IF Items[I].Active THEN
    BEGIN
      Ex := Items[I].X - Player.X;
      Ey := Items[I].Y - Player.Y;
      ScreenY := MapTop + (Items[I].Y - ViewTop);
      ScreenX := Items[I].X - ViewLeft + 1;
      IF (Abs(Ex) <= SightRange) AND (Abs(Ey) <= SightRange) AND
         HasLineOfSight(Player.X, Player.Y, Items[I].X, Items[I].Y) AND
         ((Items[I].X <> Player.X) OR (Items[I].Y <> Player.Y)) AND
         (GetEnemyAt(Items[I].X, Items[I].Y) = 0) AND
         (ScreenX >= 1) AND (ScreenX <= ViewWidth) AND
         (ScreenY >= MapTop) AND (ScreenY < MapTop + MapHeightView) THEN
      BEGIN
        CASE Items[I].TypeChar OF
          TileGold: ColorText(ScreenX, ScreenY, Items[I].TypeChar, Yellow);
          TilePotion: ColorText(ScreenX, ScreenY, Items[I].TypeChar, LightMagenta);
          TileWeapon: ColorTextGlyph(ScreenX, ScreenY, GlyphWeapon, LightCyan);
          TileArmor: ColorTextGlyph(ScreenX, ScreenY, GlyphArmor, LightBlue);
          TileScroll: ColorTextGlyph(ScreenX, ScreenY, GlyphScroll, LightMagenta);
          TileAmulet: ColorTextGlyph(ScreenX, ScreenY, GlyphAmulet, LightGreen);
          TileKey: ColorTextGlyph(ScreenX, ScreenY, GlyphKey, Yellow);
          TileStairsDown: ColorTextGlyph(ScreenX, ScreenY, GlyphStairsDown, Yellow);
          ELSE
            ColorText(ScreenX, ScreenY, Items[I].TypeChar, White);
        END;
      END;
    END;
END;

PROCEDURE DrawHUD;
VAR
  Line1, Line2: String[255];
BEGIN
  Line1 := 'DEPTH: ' + IntToStr(Depth) +
           '  HP: ' + IntToStr(Player.HP) + '/' + IntToStr(Player.MaxHP) +
           '  LVL: ' + IntToStr(Player.Level) +
           '  GOLD: ' + IntToStr(Player.Gold) +
           '  THEME: ' + GetThemeName(Depth);
  Line2 := 'Potions: ' + IntToStr(Player.Potions) + '  XP: ' + IntToStr(Player.XP) +
           '  Scr: ' + IntToStr(Player.ScrollHeal + Player.ScrollMap + Player.ScrollTeleport) +
           '  Key: ' + IntToStr(Player.Keys) +
           '  ATK: ' + IntToStr(Player.Attack + Player.WeaponBonus) +
           '  AR: ' + IntToStr(Player.Defense + Player.ArmorBonus) +
           '  MP: ' + IntToStr(Player.Mana) + '/' + IntToStr(Player.MaxMana) +
           '  TURN: ' + IntToStr(TurnCount);
  AddStatusSuffix(Line2, 'Poi', Player.PoisonTurns);
  AddStatusSuffix(Line2, 'Slo', Player.SlowTurns);
  AddStatusSuffix(Line2, 'Has', Player.HasteTurns);
  AddStatusSuffix(Line2, 'Con', Player.ConfuseTurns);
  AddStatusSuffix(Line2, 'Bli', Player.BlindTurns);
  AddStatusSuffix(Line2, 'Det', Player.DetectTurns);
  WriteScreenLine(1, Line1);
  WriteScreenLine(2, Line2);
  WriteScreenLine(ControlsRow, 'Controls: hjkl+yubn move, HJKL+YUBN run, v rest, x explore, ? help');
END;

{ --- Game Logic --- }

PROCEDURE PlayerMove(NewX, NewY: Integer);
VAR
  EnemyIdx: Integer;
  ItemIdx: Integer;
BEGIN
  IF (Player.ConfuseTurns > 0) AND (GenRand(100) < 50) THEN
  BEGIN
    NewX := Player.X + (GenRand(3) - 1);
    NewY := Player.Y + (GenRand(3) - 1);
    AddMessage('You stumble in confusion.');
  END;

  ItemIdx := GetItemAt(NewX, NewY);
  IF IsWall(NewX, NewY) THEN
  BEGIN
    AddMessage('You bump into a wall.');
    EXIT;
  END;
  
  EnemyIdx := GetEnemyAt(NewX, NewY);
  IF EnemyIdx > 0 THEN
  BEGIN
    { Attack Enemy }
    CombatRound(EnemyIdx);
    EXIT;
  END;
  
  IF ItemIdx > 0 THEN
  BEGIN
    { Auto-pickup logic can be here, or wait for 'G' }
    { Let's make it auto-pickup gold, require 'G' for potions/items }
    IF Items[ItemIdx].TypeChar = TileGold THEN
    BEGIN
      Player.Gold := Player.Gold + Items[ItemIdx].Value;
      Items[ItemIdx].Active := False;
      AddMessage('You picked up ' + IntToStr(Items[ItemIdx].Value) + ' gold.');
    END;
  END;
  
  Player.X := NewX;
  Player.Y := NewY;
  
END;

PROCEDURE RunDirection(DX, DY: Integer);
VAR
  NextX, NextY: Integer;
  EnemyIdx, ItemIdx: Integer;
  Dist: Integer;
  CorridorWatch: Boolean;
BEGIN
  IF Depth <> RunIgnoreDepth THEN
  BEGIN
    RunIgnoreDepth := 0;
    RunIgnoreItemX := 0;
    RunIgnoreItemY := 0;
  END;
  CorridorWatch := IsNarrowCorridorTileForRun(Player.X, Player.Y, DX, DY);

  WHILE NOT GameOver DO
  BEGIN
    IF CorridorWatch AND ShouldStopRunAtCrossCorridor(Player.X, Player.Y, DX, DY) THEN
      EXIT;

    { Stop running if anything interesting becomes visible nearby. }
    FOR EnemyIdx := 1 TO MaxEnemies DO
      IF Enemies[EnemyIdx].Active THEN
      BEGIN
        Dist := Abs(Enemies[EnemyIdx].X - Player.X) + Abs(Enemies[EnemyIdx].Y - Player.Y);
        IF (Dist <= 8) AND HasLineOfSight(Player.X, Player.Y, Enemies[EnemyIdx].X, Enemies[EnemyIdx].Y) THEN
          EXIT;
      END;
    FOR ItemIdx := 1 TO MaxItems DO
      IF Items[ItemIdx].Active THEN
      BEGIN
        Dist := Abs(Items[ItemIdx].X - Player.X) + Abs(Items[ItemIdx].Y - Player.Y);
        IF (Dist <= 8) AND HasLineOfSight(Player.X, Player.Y, Items[ItemIdx].X, Items[ItemIdx].Y) THEN
        BEGIN
          IF NOT ((Depth = RunIgnoreDepth) AND
                  (Items[ItemIdx].X = RunIgnoreItemX) AND
                  (Items[ItemIdx].Y = RunIgnoreItemY)) THEN
          BEGIN
            RunIgnoreDepth := Depth;
            RunIgnoreItemX := Items[ItemIdx].X;
            RunIgnoreItemY := Items[ItemIdx].Y;
            EXIT;
          END;
        END;
      END;
    IF IsStairsDownAt(Player.X, Player.Y) OR IsStairsUpAt(Player.X, Player.Y) THEN
      EXIT;

    NextX := Player.X + DX;
    NextY := Player.Y + DY;
    IF IsWall(NextX, NextY) OR IsDoor(NextX, NextY) THEN
      EXIT;

    IF GetEnemyAt(NextX, NextY) > 0 THEN
    BEGIN
      PlayerMove(NextX, NextY);
      EndPlayerTurn;
      EXIT;
    END;

    PlayerMove(NextX, NextY);
    EndPlayerTurn;
    IF GetItemAt(Player.X, Player.Y) > 0 THEN
    BEGIN
      RunIgnoreDepth := 0;
      RunIgnoreItemX := 0;
      RunIgnoreItemY := 0;
      RenderMap;
      DrawHUD;
      DrawMessages;
      EXIT;
    END;

    IF (Depth = RunIgnoreDepth) AND (Player.X = RunIgnoreItemX) AND (Player.Y = RunIgnoreItemY) THEN
    BEGIN
      RunIgnoreDepth := 0;
      RunIgnoreItemX := 0;
      RunIgnoreItemY := 0;
    END;
    CorridorWatch := IsNarrowCorridorTileForRun(Player.X, Player.Y, DX, DY);
    RenderMap;
    DrawHUD;
    DrawMessages;
  END;
END;

PROCEDURE CombatRound(EnemyIdx: Integer);
VAR
  PlayerDmg, EnemyDmg: Integer;
  HitChance: Integer;
  HitRoll: Integer;
  CritRoll: Integer;
  ResistPct: Integer;
BEGIN
  { Player attacks }
  IF (Player.BlindTurns > 0) AND (GenRand(100) < 35) THEN
  BEGIN
    AddMessage('You miss in the darkness.');
    EXIT;
  END;
  IF (Player.ConfuseTurns > 0) AND (GenRand(100) < 30) THEN
  BEGIN
    AddMessage('You swing wildly and miss.');
    EXIT;
  END;
  HitChance := 75 + (Player.Level * 2) + (Player.WeaponBonus * 2) - Depth;
  IF HitChance < 40 THEN HitChance := 40;
  IF HitChance > 97 THEN HitChance := 97;
  HitRoll := GenRand(100);
  IF HitRoll >= HitChance THEN
  BEGIN
    AddMessage('You miss ' + Enemies[EnemyIdx].Name + ' [physical].');
    EXIT;
  END;
  PlayerDmg := Player.Attack + Player.WeaponBonus + Random(3);
  CritRoll := GenRand(100);
  IF CritRoll < 12 THEN
  BEGIN
    PlayerDmg := PlayerDmg + (PlayerDmg DIV 2) + 1;
    AddMessage('Critical hit [physical]!');
  END;
  ResistPct := Enemies[EnemyIdx].ResistPhysical;
  IF ResistPct > 0 THEN
  BEGIN
    PlayerDmg := (PlayerDmg * (100 - ResistPct)) DIV 100;
    IF PlayerDmg < 1 THEN PlayerDmg := 1;
    AddMessage(Enemies[EnemyIdx].Name + ' resists physical damage.');
  END;
  Enemies[EnemyIdx].HP := Enemies[EnemyIdx].HP - PlayerDmg;
  AddMessage('You hit ' + Enemies[EnemyIdx].Name + ' for ' + IntToStr(PlayerDmg) + ' [physical].');
  
  IF Enemies[EnemyIdx].HP <= 0 THEN
  BEGIN
    AddMessage(Enemies[EnemyIdx].Name + ' dies!');
    Enemies[EnemyIdx].Active := False;
    Player.XP := Player.XP + 10;
    CheckLevelUp;
  END
  ELSE
  BEGIN
    { Enemy attacks back }
    EnemyDmg := Enemies[EnemyIdx].Damage - ((Player.Defense + Player.ArmorBonus) DIV 2);
    IF EnemyDmg < 1 THEN EnemyDmg := 1;
    Player.HP := Player.HP - EnemyDmg;
    AddMessage(Enemies[EnemyIdx].Name + ' hits you for ' + IntToStr(EnemyDmg) + ' [physical].');
    
    IF Player.HP <= 0 THEN
    BEGIN
      GameOver := True;
      AddMessage('YOU HAVE DIED.');
    END;
  END;
END;

PROCEDURE CheckLevelUp;
BEGIN
  IF Player.XP >= Player.Level * 100 THEN
  BEGIN
    INC(Player.Level);
    Player.MaxHP := Player.MaxHP + 10;
    Player.HP := Player.MaxHP;
    Player.Attack := Player.Attack + 2;
    Player.Defense := Player.Defense + 1;
    Player.MaxMana := Player.MaxMana + 3;
    Player.Mana := Player.MaxMana;
    AddMessage('LEVEL UP! You are now level ' + IntToStr(Player.Level) + '.');
  END;
END;

PROCEDURE NextLevel;
BEGIN
  ClearScreen;
  AddMessage('You descend deeper into the dungeon...');
  Delay(1000);
  EnterLevel(Depth + 1, Player.X, Player.Y);
END;

FUNCTION SaveExists: Boolean;
VAR
  F: Text;
BEGIN
  Assign(F, SaveFileName);
  {$I-}
  Reset(F);
  {$I+}
  IF IOResult = 0 THEN
  BEGIN
    Close(F);
    SaveExists := True;
  END
  ELSE
    SaveExists := False;
END;

PROCEDURE SaveGame;
VAR
  F: Text;
  L, R, C: Integer;
  Row: String[255];
  EnemyNameOut: String[15];
BEGIN
  SaveCurrentLevelState;
  Assign(F, SaveFileName);
  Rewrite(F);

  WriteLn(F, 'DUNGEON_SAVE_V12');
  WriteLn(F, MaxWidth, ' ', MaxHeight);
  WriteLn(F, GameSeed);
  WriteLn(F, Depth);
  WriteLn(F, TurnCount);
  WriteLn(F, Player.X, ' ', Player.Y, ' ', Player.HP, ' ', Player.MaxHP, ' ',
             Player.Attack, ' ', Player.Defense, ' ', Player.Gold, ' ',
             Player.Level, ' ', Player.XP, ' ', Player.Potions);
  WriteLn(F, Player.Mana, ' ', Player.MaxMana);
  WriteLn(F, Player.ScrollHeal, ' ', Player.ScrollMap, ' ', Player.ScrollTeleport, ' ', Player.Keys);
  WriteLn(F, Player.PoisonTurns, ' ', Player.SlowTurns, ' ', Player.HasteTurns, ' ',
             Player.ConfuseTurns, ' ', Player.BlindTurns, ' ', Player.DetectTurns);
  WriteLn(F, Player.WeaponBonus, ' ', Player.ArmorBonus, ' ',
             Player.SpareWeaponBonus, ' ', Player.SpareArmorBonus);
  WriteLn(F, Player.WeaponName);
  WriteLn(F, Player.ArmorName);
  WriteLn(F, Player.SpareWeaponName);
  WriteLn(F, Player.SpareArmorName);
  WriteLn(F, Ord(GameOver));

  FOR L := 1 TO MaxDungeonDepth DO
  BEGIN
    WriteLn(F, Ord(Levels[L].Generated), ' ', Levels[L].EntryX, ' ', Levels[L].EntryY, ' ',
               Levels[L].DownX, ' ', Levels[L].DownY, ' ', Levels[L].SpawnBudget, ' ', Levels[L].SpawnCooldown);
    IF Levels[L].Generated THEN
    BEGIN
      FOR R := 1 TO MaxHeight DO
      BEGIN
        Row := '';
        FOR C := 1 TO MaxWidth DO
          Row := Row + Levels[L].Map[R, C];
        WriteLn(F, Row);
      END;

      FOR R := 1 TO MaxHeight DO
      BEGIN
        Row := '';
        FOR C := 1 TO MaxWidth DO
          Row := Row + Levels[L].SeenMap[R, C];
        WriteLn(F, Row);
      END;

      FOR R := 1 TO MaxEnemies DO
      BEGIN
        EnemyNameOut := Levels[L].Enemies[R].Name;
        IF Length(EnemyNameOut) = 0 THEN
          EnemyNameOut := '-';
        WriteLn(F, Levels[L].Enemies[R].X, ' ', Levels[L].Enemies[R].Y, ' ',
                   Levels[L].Enemies[R].HP, ' ', Levels[L].Enemies[R].MaxHP, ' ',
                   Levels[L].Enemies[R].Damage, ' ', Levels[L].Enemies[R].Glyph, ' ',
                   Levels[L].Enemies[R].Speed, ' ', Levels[L].Enemies[R].Energy, ' ',
                   Levels[L].Enemies[R].Color, ' ',
                   Levels[L].Enemies[R].ResistPhysical, ' ', Levels[L].Enemies[R].ResistMagic, ' ',
                   Ord(Levels[L].Enemies[R].Active), ' ',
                   EnemyNameOut);
      END;

      FOR R := 1 TO MaxItems DO
        WriteLn(F, Levels[L].Items[R].X, ' ', Levels[L].Items[R].Y, ' ',
                   Levels[L].Items[R].TypeChar, ' ', Levels[L].Items[R].Value, ' ',
                   Ord(Levels[L].Items[R].Active));
    END;
  END;

  Close(F);
  AddMessage('Game saved to ' + SaveFileName + '.');
END;

PROCEDURE LoadGame;
VAR
  F: Text;
  L, R, C: Integer;
  Row: String[255];
  Magic: String;
  SaveVersion: Integer;
  SaveWidth, SaveHeight: Integer;
  ActiveFlag: Integer;
BEGIN
  IF NOT SaveExists THEN
  BEGIN
    AddMessage('No save file found.');
    EXIT;
  END;

  Assign(F, SaveFileName);
  Reset(F);

  ReadLn(F, Magic);
  SaveVersion := 0;
  IF Magic = 'DUNGEON_SAVE_V12' THEN
    SaveVersion := 12;

  IF SaveVersion = 0 THEN
  BEGIN
    Close(F);
    AddMessage('Unsupported save version. Supported: V12.');
    EXIT;
  END;

  ReadLn(F, SaveWidth, SaveHeight);
  IF (SaveWidth <> MaxWidth) OR (SaveHeight <> MaxHeight) THEN
  BEGIN
    Close(F);
    AddMessage('Save map size mismatch. Delete old save and start a new run.');
    EXIT;
  END;

  ReadLn(F, GameSeed);
  ReadLn(F, Depth);
  ReadLn(F, TurnCount);
  ReadLn(F, Player.X, Player.Y, Player.HP, Player.MaxHP, Player.Attack,
         Player.Defense, Player.Gold, Player.Level, Player.XP, Player.Potions);
  ReadLn(F, Player.Mana, Player.MaxMana);
  ReadLn(F, Player.ScrollHeal, Player.ScrollMap, Player.ScrollTeleport, Player.Keys);
  ReadLn(F, Player.PoisonTurns, Player.SlowTurns, Player.HasteTurns,
         Player.ConfuseTurns, Player.BlindTurns, Player.DetectTurns);
  ReadLn(F, Player.WeaponBonus, Player.ArmorBonus, Player.SpareWeaponBonus, Player.SpareArmorBonus);
  ReadLn(F, Player.WeaponName);
  ReadLn(F, Player.ArmorName);
  ReadLn(F, Player.SpareWeaponName);
  ReadLn(F, Player.SpareArmorName);
  ReadLn(F, ActiveFlag);
  GameOver := ActiveFlag <> 0;

  FOR L := 1 TO MaxDungeonDepth DO
  BEGIN
    ReadLn(F, ActiveFlag, Levels[L].EntryX, Levels[L].EntryY, Levels[L].DownX, Levels[L].DownY,
           Levels[L].SpawnBudget, Levels[L].SpawnCooldown);
    Levels[L].Generated := ActiveFlag <> 0;
    IF Levels[L].Generated THEN
    BEGIN
      FOR R := 1 TO MaxHeight DO
      BEGIN
        ReadLn(F, Row);
        FOR C := 1 TO MaxWidth DO
          IF C <= Length(Row) THEN
            Levels[L].Map[R, C] := Row[C]
          ELSE
            Levels[L].Map[R, C] := TileWall;
      END;

      FOR R := 1 TO MaxHeight DO
      BEGIN
        ReadLn(F, Row);
        FOR C := 1 TO MaxWidth DO
          IF C <= Length(Row) THEN
            Levels[L].SeenMap[R, C] := Row[C]
          ELSE
            Levels[L].SeenMap[R, C] := TileFog;
      END;

      FOR R := 1 TO MaxEnemies DO
      BEGIN
        ReadLn(F, Levels[L].Enemies[R].X, Levels[L].Enemies[R].Y, Levels[L].Enemies[R].HP,
               Levels[L].Enemies[R].MaxHP, Levels[L].Enemies[R].Damage, Levels[L].Enemies[R].Glyph,
               Levels[L].Enemies[R].Speed, Levels[L].Enemies[R].Energy, Levels[L].Enemies[R].Color,
               Levels[L].Enemies[R].ResistPhysical, Levels[L].Enemies[R].ResistMagic,
               ActiveFlag, Levels[L].Enemies[R].Name);
        IF Levels[L].Enemies[R].Name = '-' THEN
          Levels[L].Enemies[R].Name := '';
        Levels[L].Enemies[R].Active := ActiveFlag <> 0;
      END;

      FOR R := 1 TO MaxItems DO
      BEGIN
        ReadLn(F, Levels[L].Items[R].X, Levels[L].Items[R].Y, Levels[L].Items[R].TypeChar,
               Levels[L].Items[R].Value, ActiveFlag);
        Levels[L].Items[R].Active := ActiveFlag <> 0;
      END;
    END;
  END;

  Close(F);
  IF (Depth >= 1) AND (Depth <= MaxDungeonDepth) AND Levels[Depth].Generated THEN
    LoadLevelState(Depth);
  ClearScreen;
  AddMessage('Game loaded from ' + SaveFileName + '.');
END;

PROCEDURE UsePotion;
BEGIN
  IF Player.Potions > 0 THEN
  BEGIN
    IF Player.HP >= Player.MaxHP THEN
    BEGIN
      AddMessage('You are already at full health.');
    END
    ELSE
    BEGIN
      DEC(Player.Potions);
      Player.HP := Player.MaxHP;
      Player.PoisonTurns := 0;
      Player.ConfuseTurns := 0;
      Player.BlindTurns := 0;
      AddMessage('You drink a potion and feel refreshed.');
    END;
  END
  ELSE
  BEGIN
    AddMessage('You have no potions!');
  END;
END;

PROCEDURE UseScroll;
VAR
  K: Char;
BEGIN
  AddMessage('Use scroll: H=Heal M=Map T=Teleport');
  RenderMap;
  DrawHUD;
  DrawMessages;
  K := UpCase(ReadKey);
  CASE K OF
    'H':
      BEGIN
        IF Player.ScrollHeal <= 0 THEN
          AddMessage('No healing scrolls.')
        ELSE
        BEGIN
          DEC(Player.ScrollHeal);
          IF Player.HP < Player.MaxHP THEN
          BEGIN
            Player.HP := Player.HP + 20;
            IF Player.HP > Player.MaxHP THEN Player.HP := Player.MaxHP;
          END;
          AddMessage('You read a Scroll of Healing.');
          EndPlayerTurn;
        END;
      END;
    'M':
      BEGIN
        IF Player.ScrollMap <= 0 THEN
          AddMessage('No mapping scrolls.')
        ELSE
        BEGIN
          DEC(Player.ScrollMap);
          RevealCurrentMap;
          AddMessage('You read a Scroll of Mapping.');
          EndPlayerTurn;
        END;
      END;
    'T':
      BEGIN
        IF Player.ScrollTeleport <= 0 THEN
          AddMessage('No teleport scrolls.')
        ELSE
        BEGIN
          DEC(Player.ScrollTeleport);
          TeleportPlayerToFloor;
          Player.HasteTurns := Player.HasteTurns + 4;
          AddMessage('You read a Scroll of Teleport.');
          EndPlayerTurn;
        END;
      END;
  ELSE
    AddMessage('Never mind.');
  END;
END;

PROCEDURE CastSpell;
VAR
  K: Char;
  Cost: Integer;
  EnemyIdx, KIdx: Integer;
  BestDist, Dist: Integer;
  Dmg: Integer;
  ResistPct: Integer;
BEGIN
  AddMessage('Cast: B=Bolt(3) H=Heal(4) D=Detect(2) P=Phase(5) C=Cure(4) S=Haste(4)');
  RenderMap;
  DrawHUD;
  DrawMessages;
  K := UpCase(ReadKey);

  IF K = 'B' THEN Cost := 3
  ELSE IF K = 'H' THEN Cost := 4
  ELSE IF K = 'D' THEN Cost := 2
  ELSE IF K = 'P' THEN Cost := 5
  ELSE IF K = 'C' THEN Cost := 4
  ELSE IF K = 'S' THEN Cost := 4
  ELSE
  BEGIN
    AddMessage('Never mind.');
    EXIT;
  END;

  IF Player.Mana < Cost THEN
  BEGIN
    AddMessage('Not enough mana.');
    EXIT;
  END;

  IF K = 'B' THEN
  BEGIN
    EnemyIdx := 0;
    BestDist := 9999;
    FOR KIdx := 1 TO MaxEnemies DO
      IF Enemies[KIdx].Active THEN
      BEGIN
        Dist := Abs(Enemies[KIdx].X - Player.X) + Abs(Enemies[KIdx].Y - Player.Y);
        IF (Dist <= 7) AND HasLineOfSight(Player.X, Player.Y, Enemies[KIdx].X, Enemies[KIdx].Y) THEN
          IF Dist < BestDist THEN
          BEGIN
            BestDist := Dist;
            EnemyIdx := KIdx;
          END;
      END;
    IF EnemyIdx = 0 THEN
    BEGIN
      AddMessage('No target in sight for Magic Bolt.');
      EXIT;
    END;
    DEC(Player.Mana, Cost);
    Dmg := 6 + (Player.Level DIV 2) + GenRand(6);
    ResistPct := Enemies[EnemyIdx].ResistMagic;
    IF ResistPct > 0 THEN
    BEGIN
      Dmg := (Dmg * (100 - ResistPct)) DIV 100;
      IF Dmg < 1 THEN Dmg := 1;
      AddMessage(Enemies[EnemyIdx].Name + ' resists magic.');
    END;
    Enemies[EnemyIdx].HP := Enemies[EnemyIdx].HP - Dmg;
    AddMessage('Magic Bolt hits ' + Enemies[EnemyIdx].Name + ' for ' + IntToStr(Dmg) + ' [arcane].');
    IF Enemies[EnemyIdx].HP <= 0 THEN
    BEGIN
      Enemies[EnemyIdx].Active := False;
      Player.XP := Player.XP + 12;
      AddMessage(Enemies[EnemyIdx].Name + ' is destroyed.');
      CheckLevelUp;
    END;
    EndPlayerTurn;
    EXIT;
  END;

  IF K = 'H' THEN
  BEGIN
    DEC(Player.Mana, Cost);
    Dmg := 12 + GenRand(10) + Player.Level;
    Player.HP := Player.HP + Dmg;
    IF Player.HP > Player.MaxHP THEN Player.HP := Player.MaxHP;
    AddMessage('You cast Heal and recover ' + IntToStr(Dmg) + ' HP [holy].');
    EndPlayerTurn;
    EXIT;
  END;

  IF K = 'D' THEN
  BEGIN
    DEC(Player.Mana, Cost);
    Player.DetectTurns := 24;
    AddMessage('You sense hostile minds nearby.');
    EndPlayerTurn;
    EXIT;
  END;

  IF K = 'P' THEN
  BEGIN
    DEC(Player.Mana, Cost);
    TeleportPlayerToFloor;
    AddMessage('You bend space and step through.');
    EndPlayerTurn;
    EXIT;
  END;

  IF K = 'C' THEN
  BEGIN
    DEC(Player.Mana, Cost);
    Player.PoisonTurns := 0;
    Player.SlowTurns := 0;
    Player.ConfuseTurns := 0;
    Player.BlindTurns := 0;
    AddMessage('You cast Cure and purge afflictions.');
    EndPlayerTurn;
    EXIT;
  END;

  IF K = 'S' THEN
  BEGIN
    DEC(Player.Mana, Cost);
    Player.SlowTurns := 0;
    Player.HasteTurns := Player.HasteTurns + 10;
    AddMessage('You cast Haste and quicken your step.');
    EndPlayerTurn;
    EXIT;
  END;
END;

