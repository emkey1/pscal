#!/usr/bin/env pascal
{
  PASCAL  DUNGEON CRAWLER
  ---------------------------------
  This program creates a random dungeon, allows movement, combat, and item pickup.
  It uses standard CRT graphics and text mode.

  Controls:
    HJKL YUBN         : Move
    .                 : Wait a turn
    G ,               : Get / Equip item
    E                 : Show equipment
    >                 : Descend stairs (on stair tile)
    A                 : Attack (if enemy adjacent)
    P                 : Use Potion
    R                 : Load
    Q                 : Quit
}

PROGRAM DungeonCrawler;

USES CRT, DOS;

CONST
  MaxWidth = 120;
  MaxHeight = 50;
  ViewWidth = 80;
  ScreenHeight = 25;
  HUDLines = 2;
  ControlsRow = 22;
  MessageTop = 23;
  MessageLines = 3;
  MapTop = 3;
  MapHeightView = 19;
  MaxRooms = 15;
  MaxEnemies = 20;
  MaxItems = 16;
  MaxInventory = 10;
  MaxDungeonDepth = 32;
  
  TileWall = '#';
  TileFloor = '.';
  TileDoor = '+';
  TileLockedDoor = '*';
  TileSecretDoor = ':';
  TilePlayer = '@';
  TileEnemy = 'E';
  TileGold = '$';
  TilePotion = '!';
  TileWeapon = ')';
  TileArmor = '[';
  TileScroll = '?';
  TileAmulet = '"';
  TileKey = '=';
  TileStairsDown = '>';
  TileStairsUp = '<';
  TileFog = ' ';
  SaveFileName = 'dungeon.sav';
  ThemeCrypt = 1;
  ThemeCaves = 2;
  ThemeRuins = 3;
  GlyphWall = '▓';
  GlyphFloor = '·';
  GlyphPlayer = '☺';
  GlyphDoor = '╬';
  GlyphLockedDoor = '✦';
  GlyphStairsDown = '▼';
  GlyphStairsUp = '▲';
  GlyphWeapon = '⚔';
  GlyphArmor = '⛨';
  GlyphScroll = '§';
  GlyphAmulet = '☼';
  GlyphKey = '⌂';

TYPE
  TCoord = RECORD
    X, Y: Integer;
  END;

  TEnemy = RECORD
    X, Y: Integer;
    HP: Integer;
    MaxHP: Integer;
    Damage: Integer;
    Name: String[15];
    Glyph: Char;
    Speed: Integer; { 100 is normal speed }
    Energy: Integer;
    Color: Byte;
    ResistPhysical: Integer; { 0..90 percent }
    ResistMagic: Integer;    { 0..90 percent }
    Active: Boolean;
  END;

  TItem = RECORD
    X, Y: Integer;
    TypeChar: Char;
    Value: Integer;
    Active: Boolean;
  END;

  TPlayer = RECORD
    X, Y: Integer;
    HP: Integer;
    MaxHP: Integer;
    Attack: Integer;
    Defense: Integer;
    Gold: Integer;
    Level: Integer;
    XP: Integer;
    Potions: Integer;
    ScrollHeal: Integer;
    ScrollMap: Integer;
    ScrollTeleport: Integer;
    Keys: Integer;
    WeaponBonus: Integer;
    ArmorBonus: Integer;
    WeaponName: String[20];
    ArmorName: String[20];
    SpareWeaponBonus: Integer;
    SpareArmorBonus: Integer;
    SpareWeaponName: String[20];
    SpareArmorName: String[20];
    Mana: Integer;
    MaxMana: Integer;
    PoisonTurns: Integer;
    SlowTurns: Integer;
    HasteTurns: Integer;
    ConfuseTurns: Integer;
    BlindTurns: Integer;
    DetectTurns: Integer;
  END;

  TMap = ARRAY[1..MaxHeight, 1..MaxWidth] OF Char;

  TLevelState = RECORD
    Generated: Boolean;
    Map: TMap;
    SeenMap: TMap;
    Enemies: ARRAY[1..MaxEnemies] OF TEnemy;
    Items: ARRAY[1..MaxItems] OF TItem;
    EntryX, EntryY: Integer;
    DownX, DownY: Integer;
    SpawnBudget: Integer;
    SpawnCooldown: Integer;
  END;


VAR
  Map: TMap;
  SeenMap: TMap; { Fog of War tracking }
  Enemies: ARRAY[1..MaxEnemies] OF TEnemy;
  Items: ARRAY[1..MaxItems] OF TItem;
  Player: TPlayer;
  
  GameOver: Boolean;
  Depth: Integer;
  
  Key: Char;
  MoveX, MoveY: Integer;
  I: Integer;
  TurnCount: Integer;
  GameSeed: LongInt;
  GenSeed: LongInt;
  RunIgnoreDepth: Integer;
  RunIgnoreItemX: Integer;
  RunIgnoreItemY: Integer;
  MessageLog: ARRAY[1..MessageLines] OF String[255];
  Levels: ARRAY[1..MaxDungeonDepth] OF TLevelState;
  SpawnBudget: Integer;
  SpawnCooldown: Integer;

{ --- Forward declarations --- }
