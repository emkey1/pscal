               ELSE Enemies[Count].Glyph := 's';
               Enemies[Count].MaxHP := 28;
               Enemies[Count].Damage := 6;
               Enemies[Count].Speed := 90;
               IF Theme = ThemeCaves THEN Enemies[Count].Color := LightGreen
               ELSE Enemies[Count].Color := White;
               Enemies[Count].ResistPhysical := 15;
               Enemies[Count].ResistMagic := 10;
             END;
          4: BEGIN
               Enemies[Count].Name := Names[4];
               IF Theme = ThemeRuins THEN Enemies[Count].Glyph := 'A'
               ELSE IF Theme = ThemeCrypt THEN Enemies[Count].Glyph := 'W'
               ELSE Enemies[Count].Glyph := 'o';
               Enemies[Count].MaxHP := 36;
               Enemies[Count].Damage := 7;
               Enemies[Count].Speed := 100;
               IF Theme = ThemeCrypt THEN Enemies[Count].Color := LightGray
               ELSE Enemies[Count].Color := LightRed;
               Enemies[Count].ResistPhysical := 10;
               Enemies[Count].ResistMagic := 15;
             END;
          5: BEGIN
               Enemies[Count].Name := Names[5];
               IF Theme = ThemeCrypt THEN Enemies[Count].Glyph := 'V'
               ELSE Enemies[Count].Glyph := 'T';
               Enemies[Count].MaxHP := 48;
               Enemies[Count].Damage := 9;
               Enemies[Count].Speed := 85;
               IF Theme = ThemeCrypt THEN Enemies[Count].Color := Magenta
               ELSE Enemies[Count].Color := Green;
               Enemies[Count].ResistPhysical := 20;
               Enemies[Count].ResistMagic := 10;
             END;
          6: BEGIN
               Enemies[Count].Name := Names[6];
               IF Theme = ThemeCaves THEN Enemies[Count].Glyph := 'w'
               ELSE IF Theme = ThemeRuins THEN Enemies[Count].Glyph := 'S'
               ELSE Enemies[Count].Glyph := 'L';
               Enemies[Count].MaxHP := 44;
               Enemies[Count].Damage := 10;
               Enemies[Count].Speed := 115;
               IF Theme = ThemeCaves THEN Enemies[Count].Color := Brown
               ELSE Enemies[Count].Color := LightGray;
               Enemies[Count].ResistPhysical := 10;
               Enemies[Count].ResistMagic := 30;
             END;
          7: BEGIN
               Enemies[Count].Name := Names[7];
               IF Theme = ThemeCrypt THEN Enemies[Count].Glyph := 'D'
               ELSE Enemies[Count].Glyph := 'V';
               Enemies[Count].MaxHP := 58;
               Enemies[Count].Damage := 12;
               Enemies[Count].Speed := 110;
               IF Theme = ThemeCrypt THEN Enemies[Count].Color := LightMagenta
               ELSE Enemies[Count].Color := Magenta;
               Enemies[Count].ResistPhysical := 20;
               Enemies[Count].ResistMagic := 35;
