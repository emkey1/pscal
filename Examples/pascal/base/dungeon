               Enemies[Count].Speed := 105;
               IF Theme = ThemeCrypt THEN Enemies[Count].Color := LightGray
               ELSE Enemies[Count].Color := LightGreen;
               Enemies[Count].ResistPhysical := 5;
               Enemies[Count].ResistMagic := 0;
             END;
          3: BEGIN
