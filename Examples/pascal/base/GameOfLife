            ClearGrid(grid);
            grid[0, 24] := Alive;
            grid[1, 22] := Alive;
            grid[1, 24] := Alive;
            grid[2, 12] := Alive;
            grid[2, 13] := Alive;
            grid[2, 20] := Alive;
            grid[2, 21] := Alive;
            grid[2, 34] := Alive;
            grid[2, 35] := Alive;
            grid[3, 11] := Alive;
