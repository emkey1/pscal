            for i := 0 to High(grid) do
              for j := 0 to cols - 1 do
                if Random(10) < 2 then grid[i, j] := Alive;
          end;
        '5': // Glider 
          begin
            ClearGrid(grid);
            grid[1, 2] := Alive;
            grid[2, 3] := Alive;
            grid[3, 1] := Alive;
            grid[3, 2] := Alive;
            grid[3, 3] := Alive;
          end;
        '6': // Gosper Glider Gun 
