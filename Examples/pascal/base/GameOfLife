program GameOfLife;

// Conway's Game of Life - PSCAL Pascal Variant 

type
  CellState = (Dead, Alive);

  GridType = array of array of CellState;

  PatternType = record
    name: String;
    cells: array of array of Byte; // 1=alive, 0=dead 
    offsetX, offsetY: Integer;
  end;

  // For pattern definitions 
  Point = record
    x, y: Integer;
  end;

var
  grid: GridType;
  rows, cols: Integer;
  generation: LongInt;
  speed: Word; // in ms 
  autoPause: Boolean;
  paused, running: Boolean;

procedure InitializeGrid(var g: GridType; r, c: Integer);
var
  i, j: Integer;
begin
  SetLength(g, r);
  for i := 0 to High(g) do
    SetLength(g[i], c);

  // Initialize all cells dead 
  for i := 0 to High(g) do
    for j := 0 to c - 1 do
      g[i, j] := Dead;
end;

procedure ClearGrid(var g: GridType);
var
  i, j: Integer;
begin
  for i := 0 to High(g) do
    for j := 0 to cols - 1 do
      g[i, j] := Dead;
end;

function CountNeighbors(const g: GridType; r, c: Integer): Byte;
var
  count: Byte;
  dr, dc: ShortInt;
  nr, nc: Integer;
begin
  count := 0;

  for dr := -1 to 1 do
    for dc := -1 to 1 do
      if (dr <> 0) or (dc <> 0) then
      begin
        nr := r + dr;
        nc := c + dc;

        // Wrapping edges 
        if nr < 0 then nr := High(g);
        if nr > High(g) then nr := 0;
        if nc < 0 then nc := cols - 1;
        if nc > cols - 1 then nc := 0;

        if g[nr, nc] = Alive then
          Inc(count);
      end;

  CountNeighbors := count;
end;

procedure NextGeneration(var g: GridType);
var
  newGen: GridType;
  i, j: Integer;
  neighbors: Byte;

begin
  // Create new generation grid 
  SetLength(newGen, Length(g));
  for i := 0 to High(newGen) do
    SetLength(newGen[i], cols);

  // Apply rules 
  for i := 0 to High(g) do
    for j := 0 to cols - 1 do
      begin
        neighbors := CountNeighbors(g, i, j);

        case g[i, j] of
          Dead:
            if neighbors = 3 then newGen[i, j] := Alive else newGen[i, j] := Dead;
          Alive:
            if (neighbors < 2) or (neighbors > 3) then newGen[i, j] := Dead else newGen[i, j] := Alive;
        end;
      end;

  // Replace grid 
  g := newGen;
end;

procedure DrawGrid(const g: GridType);
var
  i, j: Integer;
begin
  Writeln(#13#10'Generation: ', generation, '  Speed: ', speed, 'ms');
  Writeln('+', StringOfChar('-', cols), '+');

  for i := 0 to High(g) do
    begin
      Write('|');
      for j := 0 to cols - 1 do
        if g[i, j] = Alive then
          Write(#219)  // Solid block 
        else
          Write(' ');
      Writeln('|');
    end;

  Writeln('+', StringOfChar('-', cols), '+');
end;

procedure ToggleCell(var g: GridType; r, c: Integer);
begin
  if (r >= 0) and (r <= High(g)) and (c >= 0) and (c < cols) then
    if g[r, c] = Dead then
      g[r, c] := Alive
    else
      g[r, c] := Dead;
end;

procedure DrawMenu;
begin
  Write(#13#10, ' [1] Start/Pause         [2] Next Step');
  Write(#13#10, ' [3] Clear Grid          [4] Randomize');
  Write(#13#10, ' [5] Glider              [6] Gosper Gun');
  Write(#13#10, ' [7] Speed Up            [8] Slow Down');
  Write(#13#10, ' [9] Save Pattern        [0] Load Pattern');
  Write(#13#10, ' [E] Edit Mode           [Q] Quit');
end;

procedure RunSimulation;
var
  key: Char;
  startTick, elapsed: LongInt;
  i, j: Integer;
  r, c: Integer;
  filename, cellStr: String;

begin
  running := true;
  autoPause := false;

  while running do
    begin
      ClrScr;
      GotoXY(1, 1);
      DrawGrid(grid);
      DrawMenu;
      
      if not paused then
        begin
          startTick := GetTickCount; // Platform-specific, fallback to random for portability 
          
          NextGeneration(grid);
          Inc(generation);

          elapsed := GetTickCount - startTick;
          if speed > elapsed then
            Delay(speed - elapsed);
        end;

      key := UpCase(ReadKey);

      case key of
        '1': paused := not paused;
        '2':
          begin
            NextGeneration(grid);
            Inc(generation);
          end;
        '3': 
          begin
            ClearGrid(grid);
            generation := 0;
          end;
        '4': 
