            // Implementation omitted for brevity 
          end;
        '0': // Load 
          begin
            Writeln('Filename? ');
            Readln(filename);
            // Implementation omitted for brevity 
          end;
        'E': 
          begin
            Writeln('Edit mode: click coordinates (e.g., A5)');
            Write('Cell: ');
            Readln(cellStr);
            if ParseCoordinate(cellStr, r, c) then
              ToggleCell(grid, r, c);
          end;
        'Q': running := false;
      end;

      Delay(10); // Prevent console flicker 
    end;
end;

procedure FindOscillators(const g: GridType; maxGen: LongInt);
var
  history: array of GridType;
  i, j, k, gen: LongInt;
  found: Boolean;

begin
  Writeln('Analyzing for oscillators up to generation ', maxGen);
  
  // Store current state
  SetLength(history, 1);
  history[0] := CloneGrid(g);

  for gen := 1 to maxGen do
    begin
      NextGeneration(grid);
      
      // Compare current grid with all store 
      found := false;
      for k := 0 to High(history) do
        begin
          if CompareGrids(grid, history[k]) then
            begin
              Writeln('Found oscillator of period ', gen - k, ' at generation ', gen);
              found := true;
              break;
            end;
        end;

      if not found then
        begin
          j := Length(history);
          SetLength(history, j + 1);
          history[j] := CloneGrid(grid);
        end;
    end;

  Writeln('Analysis complete.');
end;

function CloneGrid(const src: GridType): GridType;
var
  i: Integer;
begin
  SetLength(Result, Length(src));
  for i := 0 to High(src) do
    begin
      SetLength(Result[i], cols);
      Move(src[i][0], Result[i][0], cols * SizeOf(CellState));
    end;
end;

function CompareGrids(const a, b: GridType): Boolean;
var
  i, j: Integer;
begin
  Result := (Length(a) = Length(b));
  if not Result then Exit;

  for i := 0 to High(a) do
    for j := 0 to cols - 1 do
      if a[i, j] <> b[i, j] then Exit(false);

  Result := true;
end;

function ParseCoordinate(coordStr: String; var r, c: Integer): Boolean;
var
  ch: Char;
  code: Integer;
begin
  ParseCoordinate := false;

  if Length(coordStr) < 2 then Exit(false);

  ch := UpCase(coordStr[1]);
  if (ch < 'A') or (ch > 'Z') then Exit(false);
  
  r := ord(ch) - ord('A');

  Val(Copy(coordStr, 2), c, code);
  ParseCoordinate := (code = 0) and (c >= 0) and (c < cols);
end;

