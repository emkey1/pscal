#!/usr/bin/env pascal
program Checkers;

{ PSCAL Pascal variant - Turbo Pascal compatible + dynamic arrays/exceptions }

type
  BoardType = array[1..8, 1..8] of ShortInt;
  MoveType = record
    fromRow, fromCol, toRow, toCol: Integer;
    capturedRow, capturedCol: Integer; { For multi-jump tracking }
  end;
  BoardStateHistory = array[1..512] of Integer;

var
  board: BoardType;
  gameOver, humanVsComputer: Boolean;
  moveCount: Integer;
  mainChoice: String;

procedure ClearScreen; inline;
begin
  ClrScr;
end;

function IsOdd(x: Integer): Boolean; inline;
begin
  IsOdd := Odd(x);
end;

function EmptyMove: MoveType; inline;
begin
  EmptyMove.fromRow := 0;
  EmptyMove.fromCol := 0;
  EmptyMove.toRow := 0;
  EmptyMove.toCol := 0;
  EmptyMove.capturedRow := 0;
  EmptyMove.capturedCol := 0;
end;

procedure InitializeBoard(var b: BoardType);
var
  r, c: Integer;
begin
  for r := 1 to 8 do
    for c := 1 to 8 do
      b[r, c] := 0;

  for r := 1 to 3 do
    for c := 1 to 8 do
      if IsOdd(r + c) then
        b[r, c] := 1; { PLAYER1 }

  for r := 6 to 8 do
    for c := 1 to 8 do
      if IsOdd(r + c) then
        b[r, c] := -1; { PLAYER2 }
end;

function GetPieceChar(piece: ShortInt): Char;
begin
  case piece of
    1:     GetPieceChar := 'o'; { Player1 regular }
   -1:     GetPieceChar := 'x'; { Player2 regular }
    2:     GetPieceChar := 'O'; { Player1 king }
   -2:     GetPieceChar := 'X'; { Player2 king }
    else  GetPieceChar := '.';
  end;
end;

function BoardStateHash(var b: BoardType; playerToMove: ShortInt): Integer;
const
  BoardHashMod = 400000003;
var
  r, c: Integer;
  hashValue: Integer;
begin
  if playerToMove = 1 then
    hashValue := 1
  else
    hashValue := 2;

  for r := 1 to 8 do
    for c := 1 to 8 do
      hashValue := (hashValue * 5 + b[r, c] + 3) mod BoardHashMod;

  BoardStateHash := hashValue;
end;

procedure RememberBoardState(var history: BoardStateHistory; var historyCount: Integer;
                             stateHash: Integer);
var
  i: Integer;
begin
  if historyCount < 512 then
    Inc(historyCount)
  else
  begin
    for i := 1 to 511 do
      history[i] := history[i + 1];
  end;

  history[historyCount] := stateHash;
end;

function CountBoardState(var history: BoardStateHistory; historyCount: Integer;
                         stateHash: Integer): Integer;
var
  i: Integer;
begin
  CountBoardState := 0;
  for i := 1 to historyCount do
    if history[i] = stateHash then
      Inc(CountBoardState);
end;

procedure DrawBoard(const b: BoardType);
var
  r, c: Integer;
begin
  ClearScreen;

  Write('  ');
  for c := 1 to 8 do
    Write(c:4);
  Writeln;
  
  Writeln('   +', StringOfChar('-', 8 * 4 - 1), '+');

  for r := 1 to 8 do
  begin
    Write(Chr(ord('A') + r - 1):2, ' |');
    
    for c := 1 to 8 do
      Write(' ', GetPieceChar(b[r, c]), ' |');
      
    Writeln;
    if r < 8 then
      Writeln('   +', StringOfChar('-', 8 * 4 - 1), '+');
  end;

  Writeln('   +', StringOfChar('-', 8 * 4 - 1), '+');
end;

function IsValidPos(r, c: Integer): Boolean; inline;
begin
  IsValidPos := (r >= 1) and (r <= 8) and (c >= 1) and (c <= 8);
end;

function IsPiece(b: BoardType; r, c: Integer): Boolean; inline;
begin
  if not IsValidPos(r, c) then Exit(false);
  IsPiece := (b[r, c] <> 0);
end;

function IsKing(b: BoardType; r, c: Integer): Boolean; inline;
begin
  if not IsValidPos(r, c) then Exit(false);
  IsKing := (Abs(b[r, c]) > 1);
end;

procedure CreateKing(var b: BoardType; r, c: Integer);
begin
  if not IsValidPos(r, c) then Exit;
  
  if (r = 8) and (b[r, c] = 1) then
    b[r, c] := 2  { Player1 becomes king }
  else if (r = 1) and (b[r, c] = -1) then
    b[r, c] := -2 { Player2 becomes king }
end;

procedure MovePiece(var b: BoardType; fromR, fromC, toR, toC: Integer);
var
  tempPiece: ShortInt;
begin
  if not (IsValidPos(fromR, fromC) and IsValidPos(toR, toC)) then Exit;
  
  tempPiece := b[fromR, fromC];
  b[toR, toC] := tempPiece;

  if (toR = 8) and (tempPiece = 1) then
    b[toR, toC] := 2
  else if (toR = 1) and (tempPiece = -1) then
    b[toR, toC] := -2;

  b[fromR, fromC] := 0;
end;

procedure RemovePiece(var b: BoardType; r, c: Integer);
begin
  if IsValidPos(r, c) then 
    b[r, c] := 0;
end;

type
  MoveArray = array of MoveType; { Dynamic array per spec }

procedure CloneBoard(var src: BoardType; var dest: BoardType);
var
  r, c: Integer;
begin
  for r := 1 to 8 do
    for c := 1 to 8 do
      dest[r, c] := src[r, c];
end;

function GetAllMoves(var b: BoardType; player: ShortInt): MoveArray;
var
  moves: MoveArray;
  idx: Integer;
  r, c, dr, dc, mr, mc, tr, tc, tr2, tc2: Integer;
  pieceVal: ShortInt;
  isKingPiece: Boolean;
var
  hasCaptures: Boolean;
begin
  SetLength(moves, 0);
  
  hasCaptures := false;
  for r := 1 to 8 do
    for c := 1 to 8 do
      if (not hasCaptures) and (b[r, c] * player > 0) then
      begin
        pieceVal := b[r, c];
        isKingPiece := Abs(pieceVal) > 1;
        for dr := -1 to 1 do
          for dc := -1 to 1 do
            if (not hasCaptures) and (dr <> 0) and (dc <> 0) and
               (isKingPiece or
                ((pieceVal > 0) and (dr = 1)) or
                ((pieceVal < 0) and (dr = -1))) then
            begin
              mr := r + dr; mc := c + dc;
              tr2 := r + 2 * dr; tc2 := c + 2 * dc;

              if IsValidPos(mr, mc) and IsValidPos(tr2, tc2) then
                if (b[mr, mc] * player < 0) and (b[tr2, tc2] = 0) then
                  hasCaptures := true;
            end;
      end;

  for r := 1 to 8 do
    for c := 1 to 8 do
      if b[r, c] * player > 0 then
      begin
        pieceVal := b[r, c];
        isKingPiece := Abs(pieceVal) > 1;
        for dr := -1 to 1 do
          for dc := -1 to 1 do
            if (dr <> 0) and (dc <> 0) and
               (isKingPiece or
                ((pieceVal > 0) and (dr = 1)) or
                ((pieceVal < 0) and (dr = -1))) then
            begin
              tr := r + dr;
              tc := c + dc;
              
              if IsValidPos(tr, tc) then
              begin
                if b[tr, tc] = 0 then
                begin
                  { Simple move }
                  if not hasCaptures then
                  begin
                    idx := Length(moves);
                    SetLength(moves, idx + 1);
                    with moves[idx] do
                    begin
                      fromRow := r; 
                      fromCol := c;
                      toRow := tr; 
                      toCol := tc;
                      capturedRow := 0; 
                      capturedCol := 0;
                    end;
                  end;
                end
                else if (b[tr, tc] * player < 0) then
                begin
                  tr := r + 2 * dr;
                  tc := c + 2 * dc;
                  if IsValidPos(tr, tc) and (b[tr, tc] = 0) then
                  begin
                    idx := Length(moves);
                    SetLength(moves, idx + 1);
                    with moves[idx] do
                    begin
                      fromRow := r; 
                      fromCol := c;
                      toRow := tr; 
                      toCol := tc;
                      capturedRow := r + dr; 
                      capturedCol := c + dc;
                    end;
                  end;
                end;
              end;
            end;
      end;

  GetAllMoves := moves;
end;

function ExecuteMove(var b: BoardType; m: MoveType): Boolean;
begin
  if (m.fromRow < 1) or (m.fromRow > 8) or 
     (m.fromCol < 1) or (m.fromCol > 8) or
     (m.toRow < 1) or (m.toRow > 8) or 
     (m.toCol < 1) or (m.toCol > 8) then
    Exit(false);
    
  MovePiece(b, m.fromRow, m.fromCol, m.toRow, m.toCol);

  if (m.capturedRow > 0) and (m.capturedCol > 0) then
    RemovePiece(b, m.capturedRow, m.capturedCol);

  ExecuteMove := true;
end;

function IsCaptureMove(m: MoveType): Boolean; inline;
begin
  IsCaptureMove := (m.capturedRow > 0) and (m.capturedCol > 0);
end;

function HasAnyMove(var b: BoardType; player: ShortInt): Boolean;
var
  moves: MoveArray;
begin
  try
    moves := GetAllMoves(b, player);
    HasAnyMove := (Length(moves) > 0);
  except
    HasAnyMove := false;
  end;
end;

function EvaluateBoard(var b: BoardType; player: ShortInt): Integer;
var
  r, c: Integer;
begin
  EvaluateBoard := 0;
  
  for r := 1 to 8 do
    for c := 1 to 8 do
      case b[r, c] of
         1: EvaluateBoard := EvaluateBoard - 5;
        -1: EvaluateBoard := EvaluateBoard + 5;
         2: EvaluateBoard := EvaluateBoard - 8;
        -2: EvaluateBoard := EvaluateBoard + 8;
      end;

  if player = 1 then
    EvaluateBoard := -EvaluateBoard;
end;

function MinimaxAlphaBeta(var b: BoardType; depth: Byte; player: ShortInt;
                          alpha, beta: Integer): Integer;
var
  best, value: Integer;
  moves: MoveArray;
  i: Integer;
  tempBoard: BoardType;

  function MinimaxRec(var b2: BoardType; d: Byte; p: ShortInt;
                      l_alpha, l_beta: Integer): Integer;
  var
    bestVal: Integer;
    childMoves: MoveArray;
    idx2: Integer;
  begin
    if (d = 0) or not HasAnyMove(b2, p) then
      Exit(EvaluateBoard(b2, -p));

    childMoves := GetAllMoves(b2, p);
    
    if (Length(childMoves) = 0) then
      Exit(EvaluateBoard(b2, -p));
    
    if (p > 0) then
      bestVal := l_alpha
    else 
      bestVal := l_beta;

    for idx2 := 0 to High(childMoves) do
    begin
      CloneBoard(b2, tempBoard);
      ExecuteMove(tempBoard, childMoves[idx2]);
      
      value := MinimaxRec(tempBoard, d - 1, -p, l_alpha, l_beta);

      if p > 0 then
      begin
        if value > bestVal then
          bestVal := value;
      end
      else if value < bestVal then
        bestVal := value;

      { Alpha-beta pruning }
      if (p > 0) then
        l_alpha := Max(l_alpha, bestVal)
      else
        l_beta := Min(l_beta, bestVal);
        
      if l_beta <= l_alpha then Break;
    end;

    MinimaxRec := bestVal;
  end;
  
var
  dummy: Integer;
begin
  try
    moves := GetAllMoves(b, player);
    
    if (Length(moves) = 0) then
      Exit(EvaluateBoard(b, player));
      
    best := (player > 0) ? -10000 : 10000;

    for i := 0 to High(moves) do
    begin
      CloneBoard(b, tempBoard);
      ExecuteMove(tempBoard, moves[i]);
      
      value := MinimaxRec(tempBoard, depth - 1, -player, alpha, beta);

      if (player > 0) then
        if value > best then
          best := value
      else
        if value < best then
          best := value;
    end;

    MinimaxAlphaBeta := best;
  except
    Exit(EvaluateBoard(b, player));
  end;
end;

function GetBestMove(var b: BoardType; player: ShortInt; depth: Byte): MoveType;
var
  moves: MoveArray;
  bestValue, value: Integer;
  i, bestIdx: Integer;
  tempBoard: BoardType;

begin
  try
    moves := GetAllMoves(b, player);
    
    if (Length(moves) = 0) then
      Exit(EmptyMove); { Empty move }

    bestValue := (player > 0) ? -10000 : 10000;
    bestIdx := -1;

    for i := 0 to High(moves) do
    begin
      CloneBoard(b, tempBoard);
      ExecuteMove(tempBoard, moves[i]);
      
      value := MinimaxAlphaBeta(tempBoard, depth - 1, -player, 
                                  (player > 0) ? -10000 : 10000,
                                  (player > 0) ? 10000 : -10000);

      if (player > 0) then
        if value > bestValue then
        begin
          bestValue := value;
          bestIdx := i;
        end
      else
        if value < bestValue then
        begin
          bestValue := value;
          bestIdx := i;
        end;
    end;

    if (bestIdx >= 0) then
      GetBestMove := moves[bestIdx]
    else 
      GetBestMove := moves[0];
      
  except
    { Fallback: return first available move }
    try
      moves := GetAllMoves(b, player);
      if (Length(moves) > 0) then
        GetBestMove := moves[0]
      else
        GetBestMove := EmptyMove;
    except
      GetBestMove := EmptyMove;
    end;
  end;
end;

function ParseCoordinate(coordStr: String; var r, c: Integer): Boolean;
var
  ch: Char;
begin
  if Length(coordStr) <> 2 then
    Exit(false);

  ch := UpCase(coordStr[1]);
  if (ch < 'A') or (ch > 'H') then
    Exit(false);

  r := ord(ch) - ord('A') + 1;

  ch := coordStr[2];
  if (ch < '1') or (ch > '8') then
    ParseCoordinate := false
  else
  begin
    c := ord(ch) - ord('0');
    ParseCoordinate := true;
  end;
end;

function CheckWin(var b: BoardType): ShortInt; { returns winner (1=player1, -1=player2) }
var
  p1Pieces, p2Pieces: Integer;
  r, c: Integer;

begin
  p1Pieces := 0; 
  p2Pieces := 0;
  
  for r := 1 to 8 do
    for c := 1 to 8 do
      if b[r, c] > 0 then 
        Inc(p1Pieces)
      else if b[r, c] < 0 then
        Inc(p2Pieces);

  if (p1Pieces = 0) or not HasAnyMove(b, 1) then
    Exit(-1); { Player2 wins }
    
  if (p2Pieces = 0) or not HasAnyMove(b, -1) then
    Exit(1); { Player1 wins }
    
  Exit(0);
end;

procedure PauseForComputerTurn;
var
  ch: Char;
begin
  Writeln('');
  Write('Press any key for next computer move...');
  repeat 
    ch := ReadKey; 
  until ch <> #0;
  
  Writeln('');
end;

procedure PlayGame(humanVsComputer: Boolean);
var
  currentPlayer, winner: ShortInt;
  m, tempMove: MoveType;
  validMoves: MoveArray;
  moveStr1, moveStr2: String;
  boardHistory: BoardStateHistory;
  stateHash: Integer;
  openingIdx: Integer;
  fromR, fromC, toR, toC: Integer;
  historyCount, i: Integer;
  drawByRepetition: Boolean;

begin
  Randomize;
  currentPlayer := 1;
  winner := 0;
  historyCount := 0;
  drawByRepetition := false;

  InitializeBoard(board);
  moveCount := 0;
  
  repeat
    DrawBoard(board);

    if not humanVsComputer then
    begin
      stateHash := BoardStateHash(board, currentPlayer);
      RememberBoardState(boardHistory, historyCount, stateHash);
      if CountBoardState(boardHistory, historyCount, stateHash) >= 3 then
      begin
        drawByRepetition := true;
        break;
      end;
    end;
    
    if currentPlayer = 1 then
      Writeln(#10, 'Turn: Player O (lowercase o/O)')
    else
      Writeln(#10, 'Turn: Player X (lowercase x/X)');
    
    if (not humanVsComputer) or (currentPlayer = -1) then
    begin
      PauseForComputerTurn;
      
      if humanVsComputer then
        m := GetBestMove(board, currentPlayer, 4) { Increased depth for better AI }
      else if moveCount < 2 then
      begin
        validMoves := GetAllMoves(board, currentPlayer);
        if Length(validMoves) > 0 then
        begin
          openingIdx := (Random(Length(validMoves)) + GetTicks()) mod Length(validMoves);
          m := validMoves[openingIdx];
        end
        else
          m := EmptyMove;
      end
      else
        m := GetBestMove(board, currentPlayer, 3);
      
      if (m.fromRow = 0) then
        break;
        
      if currentPlayer = 1 then
        Writeln('Computer O move: ',
                Chr(ord('A') + m.fromRow - 1), m.fromCol, ' -> ',
                Chr(ord('A') + m.toRow - 1), m.toCol)
      else
        Writeln('Computer X move: ',
                Chr(ord('A') + m.fromRow - 1), m.fromCol, ' -> ',
                Chr(ord('A') + m.toRow - 1), m.toCol);
              
      ExecuteMove(board, m);
      
      if IsCaptureMove(m) then
        if currentPlayer = 1 then
          Writeln('Computer O made a capture!')
        else
          Writeln('Computer X made a capture!');
    end
    else if (currentPlayer = 1) then
    begin
      repeat
        repeat
          Write('Enter move from (e.g., A3, or Q to quit): ');
          Readln(moveStr1);
          if moveStr1 = '' then moveStr1 := ' ';
          if UpCase(moveStr1[1]) = 'Q' then
            Exit;
            
        until ParseCoordinate(moveStr1, fromR, fromC);

        repeat
          Write('To (e.g., B4, or Q to quit): ');
          Readln(moveStr2);
          if moveStr2 = '' then moveStr2 := ' ';
          if UpCase(moveStr2[1]) = 'Q' then
            Exit;
            
        until ParseCoordinate(moveStr2, toR, toC);

        { Validate and execute move }
        try
          m := EmptyMove;
          validMoves := GetAllMoves(board, currentPlayer);
          for i := 0 to High(validMoves) do
          begin
            tempMove := validMoves[i];
            
            if (tempMove.fromRow = fromR) and 
               (tempMove.fromCol = fromC) and
               (tempMove.toRow = toR) and 
               (tempMove.toCol = toC) then
            begin
              m := tempMove;
              break;
            end;
          end;

          if (m.fromRow = 0) then
            raise 'Invalid move';

          ExecuteMove(board, m);
          
          if IsCaptureMove(m) then
            Writeln('You made a capture!');
        except
          Writeln('Invalid move. Please try again.');
          m := EmptyMove;
        end;
      until m.fromRow <> 0;
    end;

    winner := CheckWin(board);
    
    if (winner <> 0) then
      break;
      
    currentPlayer := -currentPlayer;
    Inc(moveCount);
  until false;

  DrawBoard(board);
  
  if winner = 1 then
    Writeln(#10, 'Player O (lowercase o/O) wins!')
  else if winner = -1 then
    Writeln(#10, 'Player X (lowercase x/X) wins!')
  else if drawByRepetition then
    Writeln(#10, 'Draw by repetition!')
  else 
    Writeln(#10, 'Game Over!');
end;

procedure ShowMenu;
var
  choice: String;
begin
  repeat
    ClearScreen;
    Writeln('CHECKERS GAME');
    Writeln('===============');
    Writeln('1. Human vs Computer');
    Writeln('2. Computer vs Computer (AI vs AI)');
    Writeln('Q. Quit');
    
    Write('Choose an option (1-2 or Q): ');
    Readln(choice);
    if choice = '' then choice := ' ';
  until (UpCase(choice[1]) in ['1', '2', 'Q']);

  case UpCase(choice[1]) of
    '1': PlayGame(true);
    '2': PlayGame(false);
  end;
end;

begin
  repeat
    ShowMenu;
    
    Write('Play again? (Y/N): ');
    Readln(mainChoice);
    if mainChoice = '' then mainChoice := ' ';
  until UpCase(mainChoice[1]) = 'N';
  
  Writeln('Thanks for playing Checkers!');
end.
