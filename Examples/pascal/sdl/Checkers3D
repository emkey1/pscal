    height := 1;
  aspect := width / height;
  GLViewport(0, 0, width, height);
  GLMatrixMode('projection');
  GLLoadIdentity();
  GLPerspective(VIEW_FOV, aspect, NEAR_CLIP, FAR_CLIP);
  GLMatrixMode('modelview');
  GLClearDepth(1.0);
  GLDepthTest(true);
  GLDisable('lighting');
  GLDisable('cull_face');
end;

