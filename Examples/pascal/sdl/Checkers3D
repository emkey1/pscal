procedure PlayGame(humanVsComputer: Boolean);
var
  currentPlayer, winner: ShortInt;
  m: MoveType;
  aiMove: SearchMoveType;
  aiMoves: SearchMoveArray;
  boardHistory: array[1..512] of Integer;
  stateHash, historyCount: Integer;
  drawByRepetition: Boolean;
  i: Integer;
  aiDepth: Integer;
  keyCode: Integer;
  humanTurnLog: String;
  pieceBeforeMove: ShortInt;
  nextBoard: BoardType;
  foundMove: Boolean;

  procedure ActivateCursorSquare;
  var
    moveIndex: Integer;
  begin
    foundMove := false;

    if board[cursorRow, cursorCol] * currentPlayer > 0 then
    begin
      selectedPiece.row := cursorRow;
      selectedPiece.col := cursorCol;
      selectedPiece.validMoves := GetMovesForPiece(board, currentPlayer, cursorRow, cursorCol, false);
      Exit;
    end;

    if selectedPiece.row <= 0 then
      Exit;

    for moveIndex := 0 to High(selectedPiece.validMoves) do
      if (selectedPiece.validMoves[moveIndex].toRow = cursorRow) and
         (selectedPiece.validMoves[moveIndex].toCol = cursorCol) then
      begin
        m := selectedPiece.validMoves[moveIndex];
        foundMove := true;
        Break;
      end;

    if not foundMove then
      Exit;

    pieceBeforeMove := board[m.fromRow, m.fromCol];
    if ExecuteMove(board, m) then
      AppendHumanTurnMove(humanTurnLog, m)
    else
    begin
      ClearMove(m);
      Exit;
    end;

    Inc(moveCount);

    cursorRow := m.toRow;
    cursorCol := m.toCol;

    if HasMove(m) and
       (WouldPromote(pieceBeforeMove, m.toRow) or
        (not IsCaptureMove(m)) or
        (not ContinueCaptureIfNeeded(board, currentPlayer, m.toRow, m.toCol))) then
    begin
      LogTurnMove(currentPlayer, humanTurnLog);
      humanTurnLog := '';
      currentPlayer := -currentPlayer;
      RecordBoardState(board, currentPlayer, boardHistory, historyCount, stateHash, drawByRepetition);
      ResetSelection;
    end;
  end;

begin
  Randomize;
  currentPlayer := 1;
  winner := 0;
  historyCount := 0;
  drawByRepetition := false;
  
  { Initialize the Transposition Table }
  for i := 0 to TT_SIZE - 1 do
  begin
    TransTable[i].hash := 0;
    TransTable[i].depth := 0;
    TransTable[i].score := 0;
  end;

  InitializeBoard(board);
  moveCount := 0;
  humanTurnLog := '';
  cursorRow := 6;
  cursorCol := 1;
  boardYawAngle := BOARD_YAW_DEFAULT;
  ResetSelection;
  RecordBoardState(board, currentPlayer, boardHistory, historyCount, stateHash, drawByRepetition);
  
  InitGraph(WINDOW_WIDTH, WINDOW_HEIGHT, 'SDL Checkers 3D');
  SetupProjection(WINDOW_WIDTH, WINDOW_HEIGHT);
  InitFonts;
  PrintControls(humanVsComputer);
  
  running := true;
  
  repeat
    GraphLoop(0);
    if QuitRequested then
    begin
      exitProgramRequested := true;
      break;
    end;

    DrawBoard();

    keyCode := PollKeyAny();
    while keyCode <> 0 do
    begin
      case keyCode of
        27, Ord('q'), Ord('Q'):
          running := false;
        Ord('z'), Ord('Z'):
          boardYawAngle := boardYawAngle - BOARD_ROTATE_STEP;
        Ord('x'), Ord('X'):
          boardYawAngle := boardYawAngle + BOARD_ROTATE_STEP;
      end;

      if humanVsComputer and (currentPlayer = 1) then
      begin
        case keyCode of
          Ord('i'), Ord('I'):
            if cursorRow > 1 then Dec(cursorRow);
          Ord('k'), Ord('K'):
            if cursorRow < 8 then Inc(cursorRow);
          Ord('j'), Ord('J'):
            if cursorCol > 1 then Dec(cursorCol);
          Ord('l'), Ord('L'):
            if cursorCol < 8 then Inc(cursorCol);
          Ord('c'), Ord('C'):
            begin
              humanTurnLog := '';
              ResetSelection;
            end;
          13, 32:
            ActivateCursorSquare;
        end;
      end;

      keyCode := PollKeyAny();
    end;

    { Computer opponent }
    if (not humanVsComputer) or (currentPlayer = -1) then
      begin
        GraphLoop(500);
        if QuitRequested then
        begin
          exitProgramRequested := true;
          break;
        end;

        if humanVsComputer then
          aiDepth := 4
        else if moveCount < 2 then
          aiDepth := 0
        else
          aiDepth := 3;
        if humanVsComputer then
          aiMove := GetBestMove(board, currentPlayer, 4)
        else if moveCount < 2 then
          begin
            aiMoves := GenerateAllSearchMoves(board, currentPlayer);
            if Length(aiMoves) > 0 then
              aiMove := aiMoves[(Random(Length(aiMoves)) + GetTicks()) mod Length(aiMoves)]
            else
              ClearSearchMove(aiMove);
          end
        else
          aiMove := GetBestMove(board, currentPlayer, 3);
        
        if HasSearchMove(aiMove) then
          begin
            ApplySearchMove(board, aiMove, nextBoard);
            CloneBoard(nextBoard, board);

            Inc(moveCount);
            cursorRow := SearchMoveEndRow(aiMove);
            cursorCol := SearchMoveEndCol(aiMove);
            ResetSelection;

            LogTurnMove(currentPlayer, SearchMoveToText(aiMove));
            currentPlayer := -currentPlayer;
            RecordBoardState(board, currentPlayer, boardHistory, historyCount, stateHash, drawByRepetition);
          end
        else
          break;
      end;

    { Check win condition }
    winner := CheckWin(board);
    
    if (winner <> 0) then
      begin
        DrawBoard();
        if winner = 1 then
          Writeln('Player O wins!')
        else
          Writeln('Player X wins!');
          
          GraphLoop(3000);
          if QuitRequested then
            exitProgramRequested := true;
          break;
      end;

    if drawByRepetition then
      begin
        DrawBoard();
        Writeln('Draw by repetition!');
        GraphLoop(3000);
        if QuitRequested then
          exitProgramRequested := true;
        break;
      end;

    { Check for draw }
    if not HasAnyMove(board, currentPlayer) then
      begin
        DrawBoard();
        Writeln('No moves left - draw!');
        
        GraphLoop(3000);
        if QuitRequested then
          exitProgramRequested := true;
        break;
      end;

    { Continue loop }
    GraphLoop(16);

  until not running;

  CloseGraph();
end;

