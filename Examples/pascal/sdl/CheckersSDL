procedure PlayGame(humanVsComputer: Boolean);
var
  currentPlayer, winner: ShortInt;
  m: MoveType;
  aiMove: SearchMoveType;
  validMoves: MoveArray;
  aiMoves: SearchMoveArray;
  boardHistory: array[1..512] of Integer;
  stateHash, historyCount: Integer;
  drawByRepetition: Boolean;
  x, y, buttons: Integer;
  prevButtons: Integer;
  r, c, i: Integer;
  aiDepth: Integer;
  modeLabel, turnLabel, ruleLabel: String;
  humanTurnLog: String;
  pieceBeforeMove: ShortInt;
  nextBoard: BoardType;

begin
  Randomize;
  currentPlayer := 1;
  winner := 0;
  historyCount := 0;
  drawByRepetition := false;
  
  { Initialize the Transposition Table }
  for i := 0 to TT_SIZE - 1 do
  begin
    TransTable[i].hash := 0;
    TransTable[i].depth := 0;
    TransTable[i].score := 0;
  end;

  InitializeBoard(board);
  moveCount := 0;
  humanTurnLog := '';
  prevButtons := 0;
  selectedPiece.row := 0;
  selectedPiece.col := 0;
  SetLength(selectedPiece.validMoves, 0);
  RecordBoardState(board, currentPlayer, boardHistory, historyCount, stateHash, drawByRepetition);
  
  { Set up SDL }
  InitGraph(WINDOW_WIDTH, WINDOW_HEIGHT, 'SDL Checkers');
  InitFonts;
  
  running := true;
  
  repeat
    GraphLoop(0);
    if QuitRequested then
    begin
      exitProgramRequested := true;
      break;
    end;

    DrawBoard();
    
    { Update status bar }
    if humanVsComputer then
      modeLabel := 'Human vs Computer'
    else
      modeLabel := 'AI vs AI';

    if currentPlayer = 1 then
      turnLabel := 'O'
    else
      turnLabel := 'X';

    if forcedCapturesEnabled then
      ruleLabel := 'Forced captures: ON'
    else
      ruleLabel := 'Forced captures: OFF';

    DrawMessage('Checkers - ' + modeLabel, 10, 490);
    DrawMessage('Turn: ' + turnLabel, 250, 490);
    DrawMessage(ruleLabel, 360, 490);

    { Handle input }
    if humanVsComputer then
    begin
      if pollkey() then
      begin
        case readkey() of
          'q', 'Q': running := false;
          #13: { Enter to confirm move }
            begin
              if (selectedPiece.row > 0) and 
                 (Length(selectedPiece.validMoves) > 0) then
                begin
                  m := selectedPiece.validMoves[0];
                  pieceBeforeMove := board[m.fromRow, m.fromCol];
                  
                  if ExecuteMove(board, m) then
                    AppendHumanTurnMove(humanTurnLog, m)
                  else
                    ClearMove(m);
                  
                  if HasMove(m) and IsCaptureMove(m) then
                    DrawMessage('Capture made!', 300, 470);

                  if HasMove(m) then
                    Inc(moveCount);

                  if HasMove(m) and
                     (WouldPromote(pieceBeforeMove, m.toRow) or
                     (not IsCaptureMove(m)) or
                     (not ContinueCaptureIfNeeded(board, currentPlayer, m.toRow, m.toCol))) then
                  begin
                    LogTurnMove(currentPlayer, humanTurnLog);
                    humanTurnLog := '';
                    { Switch turns }
                    currentPlayer := -currentPlayer;
                    RecordBoardState(board, currentPlayer, boardHistory, historyCount, stateHash, drawByRepetition);

                    selectedPiece.row := 0;
                    selectedPiece.col := 0;
                    SetLength(selectedPiece.validMoves, 0);
                  end;
                end;
            end;
        end;
      end;
    end
    else
      GraphLoop(0);

    { Computer opponent }
    if (not humanVsComputer) or (currentPlayer = -1) then
      begin
        GraphLoop(500);
        if QuitRequested then
        begin
          exitProgramRequested := true;
          break;
        end;

        if humanVsComputer then
          aiDepth := 4
        else if moveCount < 2 then
          aiDepth := 0
        else
          aiDepth := 3;
        if humanVsComputer then
          aiMove := GetBestMove(board, currentPlayer, 4)
        else if moveCount < 2 then
          begin
            aiMoves := GenerateAllSearchMoves(board, currentPlayer);
            if Length(aiMoves) > 0 then
              aiMove := aiMoves[(Random(Length(aiMoves)) + GetTicks()) mod Length(aiMoves)]
            else
              ClearSearchMove(aiMove);
          end
        else
          aiMove := GetBestMove(board, currentPlayer, 3);
        
        if HasSearchMove(aiMove) then
          begin
            ApplySearchMove(board, aiMove, nextBoard);
            CloneBoard(nextBoard, board);
            
            if aiMove.captureCount > 0 then
              DrawMessage('Computer capture!', 280, 470);

            Inc(moveCount);

            selectedPiece.row := 0;
            selectedPiece.col := 0;
            SetLength(selectedPiece.validMoves, 0);

            LogTurnMove(currentPlayer, SearchMoveToText(aiMove));
            { Switch turns }
            currentPlayer := -currentPlayer;
            RecordBoardState(board, currentPlayer, boardHistory, historyCount, stateHash, drawByRepetition);
          end
        else
          break;
      end;

    { Mouse selection }
    GetMouseState(x, y, buttons);
    
    if ((buttons and 1) <> 0) and ((prevButtons and 1) = 0) then
      begin
        { Convert screen coords to board coords }
        r := (y - BOARD_OFFSET_Y) div CELL_SIZE + 1;
        c := (x - BOARD_OFFSET_X) div CELL_SIZE + 1;

        { Only allow selecting own pieces }
        if (r >= 1) and (r <= 8) and (c >= 1) and (c <= 8) then
          if board[r, c] * currentPlayer > 0 then
            begin
              selectedPiece.row := r;
              selectedPiece.col := c;

              { Get valid moves for this piece }
              selectedPiece.validMoves := GetMovesForPiece(board, currentPlayer, r, c, false);

              DrawBoard();
            end
          else if (selectedPiece.row > 0) then
            begin
              { Try to move selected piece }
              for i := 0 to High(selectedPiece.validMoves) do
                if (selectedPiece.validMoves[i].toRow = r) and 
                   (selectedPiece.validMoves[i].toCol = c) then
                  begin
                    m := selectedPiece.validMoves[i];
                    pieceBeforeMove := board[m.fromRow, m.fromCol];
                    
                    if ExecuteMove(board, m) then
                      AppendHumanTurnMove(humanTurnLog, m)
                    else
                      ClearMove(m);
                    
                    if HasMove(m) and IsCaptureMove(m) then
                      DrawMessage('Capture made!', 300, 470);
                      
                    if HasMove(m) then
                      Inc(moveCount);

                    if HasMove(m) and
                       (WouldPromote(pieceBeforeMove, m.toRow) or
                       (not IsCaptureMove(m)) or
                       (not ContinueCaptureIfNeeded(board, currentPlayer, m.toRow, m.toCol))) then
                    begin
                      LogTurnMove(currentPlayer, humanTurnLog);
                      humanTurnLog := '';
                      { Switch turns }
                      currentPlayer := -currentPlayer;
                      RecordBoardState(board, currentPlayer, boardHistory, historyCount, stateHash, drawByRepetition);

                      selectedPiece.row := 0;
                      selectedPiece.col := 0;
                      SetLength(selectedPiece.validMoves, 0);
                    end;
                    
                    break;
                  end;
            end;
      end;

    prevButtons := buttons;

    { Check win condition }
    winner := CheckWin(board);
    
    if (winner <> 0) then
      begin
        DrawBoard();
        
        if winner = 1 then
          DrawMessage('Player O wins!', 280, 250)
        else
          DrawMessage('Player X wins!', 280, 250);
          
          GraphLoop(3000);
          if QuitRequested then
            exitProgramRequested := true;
          break;
      end;

    if drawByRepetition then
      begin
        DrawBoard();
        DrawMessage('Draw by repetition!', 255, 250);
        GraphLoop(3000);
        if QuitRequested then
          exitProgramRequested := true;
        break;
      end;

    { Check for draw }
    if not HasAnyMove(board, currentPlayer) then
      begin
        DrawBoard();
        
        DrawMessage('No moves left - draw!', 260, 250);
        
        GraphLoop(3000);
        if QuitRequested then
          exitProgramRequested := true;
        break;
      end;

    { Continue loop }
    GraphLoop(16);

  until not running;

  if textReady then
    QuitTextSystem;
  CloseGraph();
end;

procedure ShowMenu;
var
  choice: String;

begin
  repeat
    ClrScr();
    
    Writeln('CHECKERS - SDL EDITION');
    Writeln('======================');
    Writeln('1. Human vs Computer');
    Writeln('2. AI vs AI (Computer Battle)');
    if forcedCapturesEnabled then
      Writeln('3. Forced Captures: ON')
    else
      Writeln('3. Forced Captures: OFF');
    Writeln('Q. Quit');
    
    Write('Choose an option: ');
    Readln(choice);
    if choice = '' then choice := ' ';
    if choice[1] = '3' then
      forcedCapturesEnabled := not forcedCapturesEnabled;
  until (UpCase(choice[1]) in ['1', '2', 'Q']);

  case UpCase(choice[1]) of
    '1': PlayGame(true);
    '2': PlayGame(false);
    'Q': exitProgramRequested := true;
  end;
end;

begin
  var mainChoice: String;
  forcedCapturesEnabled := false;
  exitProgramRequested := false;
  repeat
    ShowMenu();
    if exitProgramRequested then
      break;
    
    Write('Play again? (Y/N): ');
    Readln(mainChoice);
    if mainChoice = '' then mainChoice := ' ';
  until UpCase(mainChoice[1]) = 'N';
  
  Writeln('Thanks for playing Checkers!');
end.
