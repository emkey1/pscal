fn main() -> Void {
    if !has_toon() {
        fx {
            writeln("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"name\":\"Aether\",\"answer\":42,\"enabled\":true}");
    let root: ToonNode = toon_root(doc);

    fx {
        println("name = ", toon_get_text(root, "name"));
        println("answer = ", toon_get_int(root, "answer"));
        println("enabled = ", toon_get_bool(root, "enabled"));
    }

    toon_close(doc);
    ret;
}
