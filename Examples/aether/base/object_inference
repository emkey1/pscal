type Counter {
    value: Int;

    fn current() -> Int {
        ret self.value;
    }

    fn ready() -> Bool {
        ret self.value >= 42;
    }
}

fn main() -> Void {
    let counter = new Counter();
    counter.value = 42;
    let value = counter.current();
    let isReady = counter.ready();

    fx {
        println(value);
        println(isReady);
    }
    ret;
}
