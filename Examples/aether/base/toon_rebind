fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"user\":{\"name\":\"Ada\",\"role\":\"admin\"}}");
    let current: ToonNode = toon_root(doc);
    current = toon_key(current, "user");

    fx {
        println("name = ", toon_get_text(current, "name"));
        println("role = ", toon_get_text(current, "role"));
    }

    toon_close(doc);
    ret;
}
