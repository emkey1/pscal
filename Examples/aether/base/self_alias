type Point {
    x: Int;
    y: Int;

    fn sum() -> Int {
        ret self.x + self.y;
    }

    fn shifted(dx: Int, dy: Int) -> Int {
        ret (self.x + dx) + (self.y + dy);
    }
}

fn main() -> Void {
    let point: Point = Point { x: 20, y: 22 };

    fx {
        writeln("point sum = ", point.sum());
        writeln("shifted = ", point.shifted(1, -1));
    }
    ret;
}
