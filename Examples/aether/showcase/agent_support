mod AgentSupport {
    export const PayloadPath = "Examples/aether/showcase/agent_payload.json";
    export const ReviewScore = 70;
    export const ReadyScore = 90;
    export const DefaultScore = 72;

    @pure
    export fn classify(score: Int) -> Text {
        if score >= ReadyScore {
            ret "ready";
        }
        if score >= ReviewScore {
            ret "review";
        }
        ret "blocked";
    }

    @pre score >= 0
    @post result >= 1
    export fn priority(score: Int) -> Int {
        if score >= ReadyScore {
            ret 3;
        }
        if score >= ReviewScore {
            ret 2;
        }
        ret 1;
    }
}
