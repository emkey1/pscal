// 302_inventory_018
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Cable: 1 x $32.53 = $32.53 LOW
// expect: Spring: 24 x $10.00 = $240.00
// expect: Plate: 20 x $14.94 = $298.80
// expect: Rod: 4 x $9.50 = $38.00 LOW
// expect: Bolt: 37 x $31.98 = $1183.26
// expect: Washer: 7 x $12.61 = $88.27 LOW
// expect: Screw: 8 x $39.69 = $317.52 LOW
// expect: Nut: 7 x $11.83 = $82.81 LOW
// expect: Clamp: 23 x $32.17 = $739.91
// expect: Hinge: 29 x $21.55 = $624.95
// expect: Pump: 1 x $36.27 = $36.27 LOW
// expect: Bracket: 25 x $12.73 = $318.25
// expect: grand total: $4000.57
// expect: low-stock items: 6

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Cable", "Spring", "Plate", "Rod", "Bolt", "Washer", "Screw", "Nut", "Clamp", "Hinge", "Pump", "Bracket"];
    let qtys: Int[] = [1, 24, 20, 4, 37, 7, 8, 7, 23, 29, 1, 25];
    let prices: Real[] = [32.53, 10.00, 14.94, 9.50, 31.98, 12.61, 39.69, 11.83, 32.17, 21.55, 36.27, 12.73];
    let threshold: Int = 10;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
