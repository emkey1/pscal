@pure
@pre n >= 0
// Factorial of 0 is 1, otherwise positive
@post result >= 1 || n == 0
fn calculateFactorial(n: Int) -> Int {
    if n == 0 {
        ret 1;
    }
    let res: Int = 1;
    loop i in 1..n+1 { // Range is half-open, so n+1 makes n inclusive
        res = res * i;
    }
    ret res;
}

fn main() -> Void {
    let num1: Int = 5;
    let fact1: Int = calculateFactorial(num1);

    let num2: Int = 0;
    let fact2: Int = calculateFactorial(num2);

    fx {
        println("Factorial of ", num1, " is ", fact1);
        println("Factorial of ", num2, " is ", fact2);
    }
    ret;
}