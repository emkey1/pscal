// 310_ledger_002
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Withdraw $176.00: $100.00
// expect: Deposit $265.00: $365.00
// expect: Withdraw $24.00: $341.00
// expect: Interest 5%: $358.05
// expect: Deposit $24.00: $382.05
// expect: Withdraw $58.00: $324.05
// expect: Withdraw $206.00: $118.05
// expect: Withdraw $139.00: $118.05
// expect: Withdraw $228.00: $118.05

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 176.0);
    fx { println("Withdraw $176.00: $", balance:0:2); }
    balance = deposit(balance, 265.0);
    fx { println("Deposit $265.00: $", balance:0:2); }
    balance = withdraw(balance, 24.0);
    fx { println("Withdraw $24.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 24.0);
    fx { println("Deposit $24.00: $", balance:0:2); }
    balance = withdraw(balance, 58.0);
    fx { println("Withdraw $58.00: $", balance:0:2); }
    balance = withdraw(balance, 206.0);
    fx { println("Withdraw $206.00: $", balance:0:2); }
    balance = withdraw(balance, 139.0);
    fx { println("Withdraw $139.00: $", balance:0:2); }
    balance = withdraw(balance, 228.0);
    fx { println("Withdraw $228.00: $", balance:0:2); }
    ret;
}
