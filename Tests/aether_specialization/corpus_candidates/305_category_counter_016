// 305_category_counter_016
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: pea [veg]
// expect: item 1: pea [veg]
// expect: item 2: beef [meat]
// expect: item 3: ham [meat]
// expect: item 4: rye [grain]
// expect: item 5: beef [meat]
// expect: item 6: corn [veg]
// expect: item 7: lamb [meat]
// expect: item 8: pork [meat]
// expect: item 9: pea [veg]
// expect: item 10: barley [grain]
// expect: item 11: wheat [grain]
// expect: item 12: wheat [grain]
// expect: item 13: kale [veg]
// expect: veg: 5
// expect: meat: 5
// expect: grain: 4
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["pea", "pea", "beef", "ham", "rye", "beef", "corn", "lamb", "pork", "pea", "barley", "wheat", "wheat", "kale"];
    let tags: Text[] = ["veg", "veg", "meat", "meat", "grain", "meat", "veg", "meat", "meat", "veg", "grain", "grain", "grain", "veg"];
    let cats: Text[] = ["veg", "meat", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
