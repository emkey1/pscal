// 306_recursion_007
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(6, 7) = 279936
// expect: digit_sum(389829) = 39
// expect: count_digits(4438011) = 7
// expect: sum_to(39) = 780
// expect: reverse_int(1337400) = 47331

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(6, 7);
    let ds: Int = digitSum(389829);
    let cd: Int = countDigits(4438011);
    let st: Int = sumTo(39);
    let ri: Int = reverseInt(1337400, 0);
    fx {
        println("power(6, 7) = ", pw);
        println("digit_sum(389829) = ", ds);
        println("count_digits(4438011) = ", cd);
        println("sum_to(39) = ", st);
        println("reverse_int(1337400) = ", ri);
    }
    ret;
}
