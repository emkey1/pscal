// 302_inventory_024
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Gear: 35 x $7.03 = $246.05
// expect: Spring: 39 x $0.95 = $37.05
// expect: Pump: 25 x $16.53 = $413.25
// expect: Rod: 38 x $31.42 = $1193.96
// expect: Bearing: 8 x $35.32 = $282.56
// expect: Hinge: 27 x $28.70 = $774.90
// expect: Clamp: 31 x $4.60 = $142.60
// expect: Bracket: 5 x $4.43 = $22.15 LOW
// expect: Plate: 26 x $28.84 = $749.84
// expect: Bolt: 9 x $11.47 = $103.23
// expect: grand total: $3965.59
// expect: low-stock items: 1

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Gear", "Spring", "Pump", "Rod", "Bearing", "Hinge", "Clamp", "Bracket", "Plate", "Bolt"];
    let qtys: Int[] = [35, 39, 25, 38, 8, 27, 31, 5, 26, 9];
    let prices: Real[] = [7.03, 0.95, 16.53, 31.42, 35.32, 28.70, 4.60, 4.43, 28.84, 11.47];
    let threshold: Int = 8;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
