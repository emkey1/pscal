// 300_ledger_033
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Withdraw $244.00: $256.00
// expect: Interest 1%: $258.56
// expect: Withdraw $128.00: $130.56
// expect: Deposit $202.00: $332.56
// expect: Deposit $94.00: $426.56
// expect: Deposit $90.00: $516.56
// expect: Withdraw $40.00: $476.56
// expect: Deposit $208.00: $684.56
// expect: Deposit $265.00: $949.56

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 244.0);
    fx { println("Withdraw $244.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 128.0);
    fx { println("Withdraw $128.00: $", balance:0:2); }
    balance = deposit(balance, 202.0);
    fx { println("Deposit $202.00: $", balance:0:2); }
    balance = deposit(balance, 94.0);
    fx { println("Deposit $94.00: $", balance:0:2); }
    balance = deposit(balance, 90.0);
    fx { println("Deposit $90.00: $", balance:0:2); }
    balance = withdraw(balance, 40.0);
    fx { println("Withdraw $40.00: $", balance:0:2); }
    balance = deposit(balance, 208.0);
    fx { println("Deposit $208.00: $", balance:0:2); }
    balance = deposit(balance, 265.0);
    fx { println("Deposit $265.00: $", balance:0:2); }
    ret;
}
