// 315_category_counter_011
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: wheat [grain]
// expect: item 1: plum [fruit]
// expect: item 2: apple [fruit]
// expect: item 3: fig [fruit]
// expect: item 4: beef [meat]
// expect: item 5: oat [grain]
// expect: item 6: rice [grain]
// expect: item 7: barley [grain]
// expect: item 8: pear [fruit]
// expect: item 9: apple [fruit]
// expect: item 10: ham [meat]
// expect: item 11: lime [fruit]
// expect: item 12: rice [grain]
// expect: grain: 5
// expect: fruit: 6
// expect: meat: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["wheat", "plum", "apple", "fig", "beef", "oat", "rice", "barley", "pear", "apple", "ham", "lime", "rice"];
    let tags: Text[] = ["grain", "fruit", "fruit", "fruit", "meat", "grain", "grain", "grain", "fruit", "fruit", "meat", "fruit", "grain"];
    let cats: Text[] = ["grain", "fruit", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
