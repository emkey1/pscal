// 302_inventory_022
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Spring: 13 x $39.80 = $517.40
// expect: Clamp: 36 x $29.53 = $1063.08
// expect: Washer: 21 x $20.36 = $427.56
// expect: Valve: 26 x $32.81 = $853.06
// expect: Bearing: 1 x $17.34 = $17.34 LOW
// expect: Seal: 40 x $25.89 = $1035.60
// expect: Gear: 0 x $29.26 = $0.00 LOW
// expect: Rod: 19 x $28.94 = $549.86
// expect: Hinge: 14 x $8.26 = $115.64
// expect: Bolt: 32 x $9.85 = $315.20
// expect: Plate: 34 x $12.07 = $410.38
// expect: Cable: 13 x $34.78 = $452.14
// expect: grand total: $5757.26
// expect: low-stock items: 2

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Spring", "Clamp", "Washer", "Valve", "Bearing", "Seal", "Gear", "Rod", "Hinge", "Bolt", "Plate", "Cable"];
    let qtys: Int[] = [13, 36, 21, 26, 1, 40, 0, 19, 14, 32, 34, 13];
    let prices: Real[] = [39.80, 29.53, 20.36, 32.81, 17.34, 25.89, 29.26, 28.94, 8.26, 9.85, 12.07, 34.78];
    let threshold: Int = 10;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
