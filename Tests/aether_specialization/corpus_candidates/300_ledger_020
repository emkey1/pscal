// 300_ledger_020
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Withdraw $217.00: $100.00
// expect: Withdraw $161.00: $100.00
// expect: Withdraw $147.00: $100.00
// expect: Deposit $276.00: $376.00
// expect: Withdraw $167.00: $209.00
// expect: Interest 1%: $211.09
// expect: Withdraw $33.00: $178.09
// expect: Withdraw $263.00: $178.09

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 217.0);
    fx { println("Withdraw $217.00: $", balance:0:2); }
    balance = withdraw(balance, 161.0);
    fx { println("Withdraw $161.00: $", balance:0:2); }
    balance = withdraw(balance, 147.0);
    fx { println("Withdraw $147.00: $", balance:0:2); }
    balance = deposit(balance, 276.0);
    fx { println("Deposit $276.00: $", balance:0:2); }
    balance = withdraw(balance, 167.0);
    fx { println("Withdraw $167.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 33.0);
    fx { println("Withdraw $33.00: $", balance:0:2); }
    balance = withdraw(balance, 263.0);
    fx { println("Withdraw $263.00: $", balance:0:2); }
    ret;
}
