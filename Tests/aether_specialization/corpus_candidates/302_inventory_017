// 302_inventory_017
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Nut: 21 x $25.68 = $539.28
// expect: Hinge: 10 x $11.13 = $111.30
// expect: Rod: 7 x $18.48 = $129.36 LOW
// expect: Plate: 30 x $37.27 = $1118.10
// expect: Bracket: 20 x $38.54 = $770.80
// expect: Seal: 26 x $11.37 = $295.62
// expect: Bolt: 6 x $8.14 = $48.84 LOW
// expect: Cable: 3 x $4.92 = $14.76 LOW
// expect: Pump: 0 x $24.16 = $0.00 LOW
// expect: Washer: 16 x $2.95 = $47.20
// expect: Valve: 34 x $14.92 = $507.28
// expect: Screw: 11 x $19.23 = $211.53
// expect: grand total: $3794.07
// expect: low-stock items: 4

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Nut", "Hinge", "Rod", "Plate", "Bracket", "Seal", "Bolt", "Cable", "Pump", "Washer", "Valve", "Screw"];
    let qtys: Int[] = [21, 10, 7, 30, 20, 26, 6, 3, 0, 16, 34, 11];
    let prices: Real[] = [25.68, 11.13, 18.48, 37.27, 38.54, 11.37, 8.14, 4.92, 24.16, 2.95, 14.92, 19.23];
    let threshold: Int = 10;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
