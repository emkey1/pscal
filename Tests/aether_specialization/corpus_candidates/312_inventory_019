// 312_inventory_019
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Hinge: 9 x $30.80 = $277.20
// expect: Bearing: 2 x $30.92 = $61.84 LOW
// expect: Rod: 22 x $9.01 = $198.22
// expect: Gear: 10 x $19.84 = $198.40
// expect: Seal: 24 x $25.90 = $621.60
// expect: Nut: 1 x $34.78 = $34.78 LOW
// expect: Plate: 30 x $28.46 = $853.80
// expect: Screw: 22 x $12.33 = $271.26
// expect: Pump: 24 x $14.64 = $351.36
// expect: Cable: 8 x $7.25 = $58.00
// expect: Spring: 37 x $12.64 = $467.68
// expect: Bracket: 18 x $35.78 = $644.04
// expect: grand total: $4038.18
// expect: low-stock items: 2

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Hinge", "Bearing", "Rod", "Gear", "Seal", "Nut", "Plate", "Screw", "Pump", "Cable", "Spring", "Bracket"];
    let qtys: Int[] = [9, 2, 22, 10, 24, 1, 30, 22, 24, 8, 37, 18];
    let prices: Real[] = [30.80, 30.92, 9.01, 19.84, 25.90, 34.78, 28.46, 12.33, 14.64, 7.25, 12.64, 35.78];
    let threshold: Int = 5;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
