// 310_ledger_017
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Withdraw $108.00: $142.00
// expect: Deposit $289.00: $431.00
// expect: Withdraw $146.00: $285.00
// expect: Interest 2%: $290.70
// expect: Deposit $65.00: $355.70
// expect: Withdraw $83.00: $272.70
// expect: Withdraw $97.00: $175.70
// expect: Deposit $127.00: $302.70

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 108.0);
    fx { println("Withdraw $108.00: $", balance:0:2); }
    balance = deposit(balance, 289.0);
    fx { println("Deposit $289.00: $", balance:0:2); }
    balance = withdraw(balance, 146.0);
    fx { println("Withdraw $146.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 65.0);
    fx { println("Deposit $65.00: $", balance:0:2); }
    balance = withdraw(balance, 83.0);
    fx { println("Withdraw $83.00: $", balance:0:2); }
    balance = withdraw(balance, 97.0);
    fx { println("Withdraw $97.00: $", balance:0:2); }
    balance = deposit(balance, 127.0);
    fx { println("Deposit $127.00: $", balance:0:2); }
    ret;
}
