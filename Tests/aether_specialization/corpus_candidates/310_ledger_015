fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 135.0);
    fx { println("Withdraw $135.00: $", balance:0:2); }
    balance = withdraw(balance, 281.0);
    fx { println("Withdraw $281.00: $", balance:0:2); }
    balance = deposit(balance, 281.0);
    fx { println("Deposit $281.00: $", balance:0:2); }
    balance = deposit(balance, 63.0);
    fx { println("Deposit $63.00: $", balance:0:2); }
    balance = withdraw(balance, 300.0);
    fx { println("Withdraw $300.00: $", balance:0:2); }
    balance = deposit(balance, 35.0);
    fx { println("Deposit $35.00: $", balance:0:2); }
    balance = deposit(balance, 139.0);
    fx { println("Deposit $139.00: $", balance:0:2); }
    balance = deposit(balance, 36.0);
    fx { println("Deposit $36.00: $", balance:0:2); }
    balance = deposit(balance, 246.0);
    fx { println("Deposit $246.00: $", balance:0:2); }
    balance = withdraw(balance, 269.0);
    fx { println("Withdraw $269.00: $", balance:0:2); }
    ret;
}
