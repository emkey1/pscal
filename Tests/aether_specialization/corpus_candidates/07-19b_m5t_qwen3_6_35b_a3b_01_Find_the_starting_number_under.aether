fn main() -> Void {
    let max_steps: Int = 0;
    let max_start: Int = 0;

    loop start in 1..100 {
        let n: Int = start;
        let steps: Int = 0;

        loop {
            if n == 1 { break; }
            if n % 2 == 0 {
                n = n / 2;
            } else {
                n = n * 3 + 1;
            }
            steps = steps + 1;
        }

        if steps > max_steps {
            max_steps = steps;
            max_start = start;
        }
    }

    fx {
        println("Longest Collatz under 100 starts at ", max_start, " with ", max_steps, " steps.");
    }
    ret;
}