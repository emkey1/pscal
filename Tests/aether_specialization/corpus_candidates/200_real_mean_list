// real_mean_list
// A displayed average binds Real, so sum / n is real division.
// expect: average = 78.75
fn main() -> Void {
    let xs: Int[] = [73, 88, 90, 64];
    let n: Int = length(xs);
    let sum: Int = 0;
    loop i in 0..n {
        sum = sum + xs[i];
    }
    let average: Real = sum / n;
    fx { println("average = ", average:0:2); }
    ret;
}
