@pure
fn classify(score: Int) -> Text {
    if score >= 90 {
        ret "excellent";
    }
    if score >= 70 {
        ret "good";
    }
    ret "needs work";
}

fn main() -> Void {
    if !has_toon() {
        fx { println("yyjson unavailable"); }
        ret;
    }

    let doc: ToonDoc = toon_parse("[{\"name\":\"Alice\",\"score\":95},{\"name\":\"Bob\",\"score\":76},{\"name\":\"Charlie\",\"score\":42}]");
    let root: ToonNode = toon_root(doc);
    let excellent: Int = 0;
    let good: Int = 0;
    let needsWork: Int = 0;

    loop i in 0..toon_len(root) {
        let user: ToonNode = toon_at(root, i);
        let name: Text = toon_get_text(user, "name");
        let score: Int = toon_get_int_or(user, "score", 0);
        let status: Text = classify(score);

        fx {
            println(name, ": ", score, " -> ", status);
        }

        if status == "excellent" {
            excellent = excellent + 1;
        } else if status == "good" {
            good = good + 1;
        } else {
            needsWork = needsWork + 1;
        }
    }

    fx {
        println("Summary: excellent=", excellent, ", good=", good, ", needs work=", needsWork);
    }

    toon_close(doc);
    ret;
}