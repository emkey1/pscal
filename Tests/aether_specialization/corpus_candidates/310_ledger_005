// 310_ledger_005
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Interest 1%: $505.00
// expect: Deposit $44.00: $549.00
// expect: Deposit $138.00: $687.00
// expect: Deposit $239.00: $926.00
// expect: Withdraw $268.00: $658.00
// expect: Withdraw $106.00: $552.00
// expect: Deposit $139.00: $691.00
// expect: Withdraw $123.00: $568.00
// expect: Withdraw $245.00: $323.00
// expect: Withdraw $190.00: $133.00

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 44.0);
    fx { println("Deposit $44.00: $", balance:0:2); }
    balance = deposit(balance, 138.0);
    fx { println("Deposit $138.00: $", balance:0:2); }
    balance = deposit(balance, 239.0);
    fx { println("Deposit $239.00: $", balance:0:2); }
    balance = withdraw(balance, 268.0);
    fx { println("Withdraw $268.00: $", balance:0:2); }
    balance = withdraw(balance, 106.0);
    fx { println("Withdraw $106.00: $", balance:0:2); }
    balance = deposit(balance, 139.0);
    fx { println("Deposit $139.00: $", balance:0:2); }
    balance = withdraw(balance, 123.0);
    fx { println("Withdraw $123.00: $", balance:0:2); }
    balance = withdraw(balance, 245.0);
    fx { println("Withdraw $245.00: $", balance:0:2); }
    balance = withdraw(balance, 190.0);
    fx { println("Withdraw $190.00: $", balance:0:2); }
    ret;
}
