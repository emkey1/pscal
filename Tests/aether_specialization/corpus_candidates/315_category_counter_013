// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: milk [dairy]
// expect: item 1: rye [grain]
// expect: item 2: pea [veg]
// expect: item 3: butter [dairy]
// expect: item 4: cream [dairy]
// expect: item 5: leek [veg]
// expect: item 6: oat [grain]
// expect: item 7: milk [dairy]
// expect: item 8: cream [dairy]
// expect: item 9: kale [veg]
// expect: item 10: yogurt [dairy]
// expect: item 11: oat [grain]
// expect: dairy: 6
// expect: grain: 3
// expect: veg: 3
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["milk", "rye", "pea", "butter", "cream", "leek", "oat", "milk", "cream", "kale", "yogurt", "oat"];
    let tags: Text[] = ["dairy", "grain", "veg", "dairy", "dairy", "veg", "grain", "dairy", "dairy", "veg", "dairy", "grain"];
    let cats: Text[] = ["dairy", "grain", "veg"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
