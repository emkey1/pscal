// Vigenère Cipher - uses a keyword to shift letters
fn vigenereEncrypt(text: Text, key: Text) -> Text {
    let result: Text = "";
    let keyLen: Int = string_len(key);
    let keyIndex: Int = 0;
    loop i in 0..string_len(text) {
        let ch: Text = copy(text, i + 1, 1);
        let code: Int = ord(ch);
        if (code >= ord("A") && code <= ord("Z")) || (code >= ord("a") && code <= ord("z")) {
            let keyChar: Text = copy(key, (keyIndex % keyLen) + 1, 1);
            let shift: Int = ord(keyChar) - ord("a");
            if code >= ord("A") && code <= ord("Z") {
                result = result + chr(((code - ord("A") + shift) % 26) + ord("A"));
            } else {
                result = result + chr(((code - ord("a") + shift) % 26) + ord("a"));
            }
            keyIndex = keyIndex + 1;
        } else {
            result = result + ch;
        }
    }
    ret result;
}

fn vigenereDecrypt(text: Text, key: Text) -> Text {
    let result: Text = "";
    let keyLen: Int = string_len(key);
    let keyIndex: Int = 0;
    loop i in 0..string_len(text) {
        let ch: Text = copy(text, i + 1, 1);
        let code: Int = ord(ch);
        if (code >= ord("A") && code <= ord("Z")) || (code >= ord("a") && code <= ord("z")) {
            let keyChar: Text = copy(key, (keyIndex % keyLen) + 1, 1);
            let shift: Int = ord(keyChar) - ord("a");
            if code >= ord("A") && code <= ord("Z") {
                result = result + chr(((code - ord("A") - shift + 26) % 26) + ord("A"));
            } else {
                result = result + chr(((code - ord("a") - shift + 26) % 26) + ord("a"));
            }
            keyIndex = keyIndex + 1;
        } else {
            result = result + ch;
        }
    }
    ret result;
}

fn main() -> Void {
    fx {
        let message: Text = "Attack at dawn";
        let key: Text = "lemon";
        let encrypted: Text = vigenereEncrypt(message, key);
        let decrypted: Text = vigenereDecrypt(encrypted, key);
        println("Original: ", message);
        println("Encrypted: ", encrypted);
        println("Decrypted: ", decrypted);
    }
    ret;
}
