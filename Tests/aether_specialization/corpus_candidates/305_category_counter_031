// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: rye [grain]
// expect: item 1: wheat [grain]
// expect: item 2: wheat [grain]
// expect: item 3: rice [grain]
// expect: item 4: corn [veg]
// expect: item 5: cream [dairy]
// expect: item 6: wheat [grain]
// expect: item 7: oat [grain]
// expect: item 8: yogurt [dairy]
// expect: item 9: kale [veg]
// expect: item 10: barley [grain]
// expect: item 11: duck [meat]
// expect: item 12: milk [dairy]
// expect: item 13: pea [veg]
// expect: grain: 7
// expect: veg: 3
// expect: dairy: 3
// expect: meat: 1
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["rye", "wheat", "wheat", "rice", "corn", "cream", "wheat", "oat", "yogurt", "kale", "barley", "duck", "milk", "pea"];
    let tags: Text[] = ["grain", "grain", "grain", "grain", "veg", "dairy", "grain", "grain", "dairy", "veg", "grain", "meat", "dairy", "veg"];
    let cats: Text[] = ["grain", "veg", "dairy", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
