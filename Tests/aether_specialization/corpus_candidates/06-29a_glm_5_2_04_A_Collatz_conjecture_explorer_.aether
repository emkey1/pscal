@pure
fn collatzLength(n: Int) -> Int {
    let len: Int = 1;
    let current: Int = n;
    loop current > 1 {
        if current % 2 == 0 {
            current = current / 2;
        } else {
            current = 3 * current + 1;
        }
        len = len + 1;
    }
    ret len;
}

fn main() -> Void {
    let limit: Int = 30;
    let lengths: Int[] = [];
    let maxLen: Int = 0;

    loop i in 0..limit {
        let n: Int = i + 1;
        let len: Int = collatzLength(n);
        lengths = lengths + [len];
        if len > maxLen {
            maxLen = len;
        }
    }

    fx {
        println("Collatz sequence lengths for n = 1..", limit);
        println("");
        loop i in 0..length(lengths) {
            let n: Int = i + 1;
            let len: Int = lengths[i];
            let bar: Text = stringofchar("#", len);
            println(n, ": ", bar);
        }
        println("");
        println("Longest sequence: ", maxLen, " steps");
    }
    ret;
}