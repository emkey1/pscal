// 315_category_counter_022
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: yogurt [dairy]
// expect: item 1: corn [veg]
// expect: item 2: butter [dairy]
// expect: item 3: pear [fruit]
// expect: item 4: wheat [grain]
// expect: item 5: wheat [grain]
// expect: item 6: milk [dairy]
// expect: item 7: wheat [grain]
// expect: dairy: 3
// expect: veg: 1
// expect: fruit: 1
// expect: grain: 3
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["yogurt", "corn", "butter", "pear", "wheat", "wheat", "milk", "wheat"];
    let tags: Text[] = ["dairy", "veg", "dairy", "fruit", "grain", "grain", "dairy", "grain"];
    let cats: Text[] = ["dairy", "veg", "fruit", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
