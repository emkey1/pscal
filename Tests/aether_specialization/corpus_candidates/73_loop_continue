// e3_continue  (wishlist 4)
// Skips even indices with continue; sums the odd values 1+3+5+7+9.
// expect: sum of odds 0..10 = 25

fn main() -> Void {
    let sum: Int = 0;
    loop i in 0..10 {
        if i % 2 == 0 {
            continue;
        }
        sum = sum + i;
    }
    fx {
        println("sum of odds 0..10 = ", sum);
    }
    ret;
}
