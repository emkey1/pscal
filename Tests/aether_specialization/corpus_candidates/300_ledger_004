// 300_ledger_004
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Interest 5%: $262.50
// expect: Withdraw $270.00: $262.50
// expect: Withdraw $117.00: $145.50
// expect: Deposit $41.00: $186.50
// expect: Withdraw $87.00: $99.50
// expect: Interest 2%: $101.49
// expect: Deposit $130.00: $231.49
// expect: Withdraw $83.00: $148.49

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 270.0);
    fx { println("Withdraw $270.00: $", balance:0:2); }
    balance = withdraw(balance, 117.0);
    fx { println("Withdraw $117.00: $", balance:0:2); }
    balance = deposit(balance, 41.0);
    fx { println("Deposit $41.00: $", balance:0:2); }
    balance = withdraw(balance, 87.0);
    fx { println("Withdraw $87.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 130.0);
    fx { println("Deposit $130.00: $", balance:0:2); }
    balance = withdraw(balance, 83.0);
    fx { println("Withdraw $83.00: $", balance:0:2); }
    ret;
}
