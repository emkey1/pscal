// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Deposit $58.00: $308.00
// expect: Deposit $62.00: $370.00
// expect: Deposit $14.00: $384.00
// expect: Withdraw $254.00: $130.00
// expect: Interest 5%: $136.50
// expect: Withdraw $255.00: $136.50
// expect: Withdraw $143.00: $136.50
// expect: Withdraw $296.00: $136.50
// expect: Withdraw $48.00: $88.50
// expect: Withdraw $47.00: $41.50
// expect: Withdraw $139.00: $41.50

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 58.0);
    fx { println("Deposit $58.00: $", balance:0:2); }
    balance = deposit(balance, 62.0);
    fx { println("Deposit $62.00: $", balance:0:2); }
    balance = deposit(balance, 14.0);
    fx { println("Deposit $14.00: $", balance:0:2); }
    balance = withdraw(balance, 254.0);
    fx { println("Withdraw $254.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 255.0);
    fx { println("Withdraw $255.00: $", balance:0:2); }
    balance = withdraw(balance, 143.0);
    fx { println("Withdraw $143.00: $", balance:0:2); }
    balance = withdraw(balance, 296.0);
    fx { println("Withdraw $296.00: $", balance:0:2); }
    balance = withdraw(balance, 48.0);
    fx { println("Withdraw $48.00: $", balance:0:2); }
    balance = withdraw(balance, 47.0);
    fx { println("Withdraw $47.00: $", balance:0:2); }
    balance = withdraw(balance, 139.0);
    fx { println("Withdraw $139.00: $", balance:0:2); }
    ret;
}
