// 305_category_counter_012
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: fig [fruit]
// expect: item 1: cream [dairy]
// expect: item 2: fig [fruit]
// expect: item 3: milk [dairy]
// expect: item 4: apple [fruit]
// expect: item 5: oat [grain]
// expect: item 6: cheese [dairy]
// expect: item 7: oat [grain]
// expect: item 8: rye [grain]
// expect: item 9: cream [dairy]
// expect: item 10: lime [fruit]
// expect: item 11: barley [grain]
// expect: fruit: 4
// expect: dairy: 4
// expect: grain: 4
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["fig", "cream", "fig", "milk", "apple", "oat", "cheese", "oat", "rye", "cream", "lime", "barley"];
    let tags: Text[] = ["fruit", "dairy", "fruit", "dairy", "fruit", "grain", "dairy", "grain", "grain", "dairy", "fruit", "grain"];
    let cats: Text[] = ["fruit", "dairy", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
