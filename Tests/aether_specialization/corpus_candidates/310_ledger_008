// 310_ledger_008
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Interest 1%: $101.00
// expect: Interest 5%: $106.05
// expect: Deposit $186.00: $292.05
// expect: Interest 5%: $306.65
// expect: Deposit $192.00: $498.65
// expect: Withdraw $210.00: $288.65
// expect: Deposit $110.00: $398.65
// expect: Withdraw $130.00: $268.65
// expect: Deposit $114.00: $382.65
// expect: Interest 5%: $401.79
// expect: Deposit $56.00: $457.79

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 186.0);
    fx { println("Deposit $186.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 192.0);
    fx { println("Deposit $192.00: $", balance:0:2); }
    balance = withdraw(balance, 210.0);
    fx { println("Withdraw $210.00: $", balance:0:2); }
    balance = deposit(balance, 110.0);
    fx { println("Deposit $110.00: $", balance:0:2); }
    balance = withdraw(balance, 130.0);
    fx { println("Withdraw $130.00: $", balance:0:2); }
    balance = deposit(balance, 114.0);
    fx { println("Deposit $114.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 56.0);
    fx { println("Deposit $56.00: $", balance:0:2); }
    ret;
}
