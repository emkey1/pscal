// Kolakoski sequence (OEIS A000002): the only sequence over {1,2} that
// is its own run-length encoding. Seed with [1,2,2], then read the
// sequence's own earlier entries as instructions for how many times to
// repeat the next alternating value. Whether 1s and 2s each occur with
// limiting density exactly 1/2 remains an open conjecture.

fn main() -> Void {
    let n: Int = 30;
    let seq: Int[] = [1, 2, 2];
    let i: Int = 2;

    loop length(seq) < n {
        let last: Int = seq[length(seq) - 1];
        let nextVal: Int = 1;
        if last == 1 {
            nextVal = 2;
        }
        let runLength: Int = seq[i];
        let r: Int = 0;
        loop r < runLength {
            seq = seq + [nextVal];
            r = r + 1;
        }
        i = i + 1;
    }

    fx {
        println("Kolakoski sequence, a(1)..a(", n, "):");
        loop k in 0..n {
            print(seq[k], " ");
        }
        println("");
        println("Conjectured -- unproven -- that both digits occur with density 1/2.");
    }
    ret;
}
