fn main() -> Void {
    let numerator: Int = 7;
    let denominator: Int = 3;

    let ratio: Real = numerator * 1.0 / denominator;

    fx {
        println("Ratio (default): ", ratio);
        println("Ratio (prec=2): ", ratio:0:2);
        println("Ratio (padded): ", ratio:10:4);
    }
    ret;
}
