// 300_ledger_001
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Interest 1%: $101.00
// expect: Withdraw $203.00: $101.00
// expect: Withdraw $218.00: $101.00
// expect: Withdraw $298.00: $101.00
// expect: Withdraw $215.00: $101.00
// expect: Withdraw $111.00: $101.00
// expect: Withdraw $35.00: $66.00
// expect: Deposit $262.00: $328.00
// expect: Withdraw $106.00: $222.00

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 203.0);
    fx { println("Withdraw $203.00: $", balance:0:2); }
    balance = withdraw(balance, 218.0);
    fx { println("Withdraw $218.00: $", balance:0:2); }
    balance = withdraw(balance, 298.0);
    fx { println("Withdraw $298.00: $", balance:0:2); }
    balance = withdraw(balance, 215.0);
    fx { println("Withdraw $215.00: $", balance:0:2); }
    balance = withdraw(balance, 111.0);
    fx { println("Withdraw $111.00: $", balance:0:2); }
    balance = withdraw(balance, 35.0);
    fx { println("Withdraw $35.00: $", balance:0:2); }
    balance = deposit(balance, 262.0);
    fx { println("Deposit $262.00: $", balance:0:2); }
    balance = withdraw(balance, 106.0);
    fx { println("Withdraw $106.00: $", balance:0:2); }
    ret;
}
