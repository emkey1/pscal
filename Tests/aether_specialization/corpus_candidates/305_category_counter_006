// 305_category_counter_006
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: beef [meat]
// expect: item 1: pear [fruit]
// expect: item 2: cream [dairy]
// expect: item 3: cheese [dairy]
// expect: item 4: lamb [meat]
// expect: item 5: lime [fruit]
// expect: item 6: cheese [dairy]
// expect: item 7: butter [dairy]
// expect: meat: 2
// expect: fruit: 2
// expect: dairy: 4
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["beef", "pear", "cream", "cheese", "lamb", "lime", "cheese", "butter"];
    let tags: Text[] = ["meat", "fruit", "dairy", "dairy", "meat", "fruit", "dairy", "dairy"];
    let cats: Text[] = ["meat", "fruit", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
