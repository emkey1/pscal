// 305_category_counter_025
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: pear [fruit]
// expect: item 1: duck [meat]
// expect: item 2: cream [dairy]
// expect: item 3: fig [fruit]
// expect: item 4: plum [fruit]
// expect: item 5: apple [fruit]
// expect: item 6: milk [dairy]
// expect: item 7: milk [dairy]
// expect: item 8: leek [veg]
// expect: fruit: 4
// expect: meat: 1
// expect: dairy: 3
// expect: veg: 1
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["pear", "duck", "cream", "fig", "plum", "apple", "milk", "milk", "leek"];
    let tags: Text[] = ["fruit", "meat", "dairy", "fruit", "fruit", "fruit", "dairy", "dairy", "veg"];
    let cats: Text[] = ["fruit", "meat", "dairy", "veg"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
