// 305_category_counter_027
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: wheat [grain]
// expect: item 1: pear [fruit]
// expect: item 2: rice [grain]
// expect: item 3: barley [grain]
// expect: item 4: barley [grain]
// expect: item 5: yogurt [dairy]
// expect: item 6: oat [grain]
// expect: item 7: pear [fruit]
// expect: item 8: yogurt [dairy]
// expect: item 9: apple [fruit]
// expect: item 10: rice [grain]
// expect: item 11: cream [dairy]
// expect: item 12: barley [grain]
// expect: item 13: cheese [dairy]
// expect: grain: 7
// expect: fruit: 3
// expect: dairy: 4
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["wheat", "pear", "rice", "barley", "barley", "yogurt", "oat", "pear", "yogurt", "apple", "rice", "cream", "barley", "cheese"];
    let tags: Text[] = ["grain", "fruit", "grain", "grain", "grain", "dairy", "grain", "fruit", "dairy", "fruit", "grain", "dairy", "grain", "dairy"];
    let cats: Text[] = ["grain", "fruit", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
