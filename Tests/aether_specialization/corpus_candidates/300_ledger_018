// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Withdraw $122.00: $128.00
// expect: Withdraw $172.00: $128.00
// expect: Deposit $105.00: $233.00
// expect: Interest 5%: $244.65
// expect: Withdraw $120.00: $124.65
// expect: Withdraw $67.00: $57.65
// expect: Interest 5%: $60.53
// expect: Withdraw $285.00: $60.53
// expect: Withdraw $84.00: $60.53
// expect: Withdraw $36.00: $24.53
// expect: Withdraw $229.00: $24.53

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 122.0);
    fx { println("Withdraw $122.00: $", balance:0:2); }
    balance = withdraw(balance, 172.0);
    fx { println("Withdraw $172.00: $", balance:0:2); }
    balance = deposit(balance, 105.0);
    fx { println("Deposit $105.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 120.0);
    fx { println("Withdraw $120.00: $", balance:0:2); }
    balance = withdraw(balance, 67.0);
    fx { println("Withdraw $67.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 285.0);
    fx { println("Withdraw $285.00: $", balance:0:2); }
    balance = withdraw(balance, 84.0);
    fx { println("Withdraw $84.00: $", balance:0:2); }
    balance = withdraw(balance, 36.0);
    fx { println("Withdraw $36.00: $", balance:0:2); }
    balance = withdraw(balance, 229.0);
    fx { println("Withdraw $229.00: $", balance:0:2); }
    ret;
}
