// 305_category_counter_003
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: leek [veg]
// expect: item 1: barley [grain]
// expect: item 2: rye [grain]
// expect: item 3: rice [grain]
// expect: item 4: pork [meat]
// expect: item 5: bean [veg]
// expect: item 6: corn [veg]
// expect: item 7: kale [veg]
// expect: item 8: beef [meat]
// expect: item 9: rye [grain]
// expect: veg: 4
// expect: grain: 4
// expect: meat: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["leek", "barley", "rye", "rice", "pork", "bean", "corn", "kale", "beef", "rye"];
    let tags: Text[] = ["veg", "grain", "grain", "grain", "meat", "veg", "veg", "veg", "meat", "grain"];
    let cats: Text[] = ["veg", "grain", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
