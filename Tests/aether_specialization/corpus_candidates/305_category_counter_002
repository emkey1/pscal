// 305_category_counter_002
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: pork [meat]
// expect: item 1: duck [meat]
// expect: item 2: lime [fruit]
// expect: item 3: oat [grain]
// expect: item 4: ham [meat]
// expect: item 5: lamb [meat]
// expect: item 6: wheat [grain]
// expect: item 7: apple [fruit]
// expect: item 8: rye [grain]
// expect: item 9: pear [fruit]
// expect: item 10: beef [meat]
// expect: item 11: oat [grain]
// expect: item 12: apple [fruit]
// expect: meat: 5
// expect: fruit: 4
// expect: grain: 4
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["pork", "duck", "lime", "oat", "ham", "lamb", "wheat", "apple", "rye", "pear", "beef", "oat", "apple"];
    let tags: Text[] = ["meat", "meat", "fruit", "grain", "meat", "meat", "grain", "fruit", "grain", "fruit", "meat", "grain", "fruit"];
    let cats: Text[] = ["meat", "fruit", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
