// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Withdraw $91.00: $159.00
// expect: Deposit $244.00: $403.00
// expect: Deposit $118.00: $521.00
// expect: Deposit $194.00: $715.00
// expect: Deposit $167.00: $882.00
// expect: Deposit $76.00: $958.00
// expect: Withdraw $143.00: $815.00
// expect: Interest 1%: $823.15
// expect: Withdraw $29.00: $794.15
// expect: Withdraw $145.00: $649.15
// expect: Deposit $138.00: $787.15
// expect: Deposit $32.00: $819.15

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 91.0);
    fx { println("Withdraw $91.00: $", balance:0:2); }
    balance = deposit(balance, 244.0);
    fx { println("Deposit $244.00: $", balance:0:2); }
    balance = deposit(balance, 118.0);
    fx { println("Deposit $118.00: $", balance:0:2); }
    balance = deposit(balance, 194.0);
    fx { println("Deposit $194.00: $", balance:0:2); }
    balance = deposit(balance, 167.0);
    fx { println("Deposit $167.00: $", balance:0:2); }
    balance = deposit(balance, 76.0);
    fx { println("Deposit $76.00: $", balance:0:2); }
    balance = withdraw(balance, 143.0);
    fx { println("Withdraw $143.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 29.0);
    fx { println("Withdraw $29.00: $", balance:0:2); }
    balance = withdraw(balance, 145.0);
    fx { println("Withdraw $145.00: $", balance:0:2); }
    balance = deposit(balance, 138.0);
    fx { println("Deposit $138.00: $", balance:0:2); }
    balance = deposit(balance, 32.0);
    fx { println("Deposit $32.00: $", balance:0:2); }
    ret;
}
