@pure
fn find_status(score: Int) -> Text {
    if score >= 90 {
        ret "A";
    }
    if score >= 80 {
        ret "B";
    }
    if score >= 70 {
        ret "C";
    }
    ret "F";
}

fn main() -> Void {
    let user_score: Int = 85;
    let grade: Text = find_status(user_score);

    fx {
        println("User score: ", user_score, " -> Grade: ", grade);
    }
    ret;
}
