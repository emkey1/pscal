// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: apple [fruit]
// expect: item 1: rice [grain]
// expect: item 2: rye [grain]
// expect: item 3: fig [fruit]
// expect: item 4: ham [meat]
// expect: item 5: kale [veg]
// expect: item 6: leek [veg]
// expect: item 7: leek [veg]
// expect: item 8: oat [grain]
// expect: item 9: apple [fruit]
// expect: item 10: lamb [meat]
// expect: item 11: corn [veg]
// expect: item 12: lamb [meat]
// expect: item 13: pork [meat]
// expect: fruit: 3
// expect: grain: 3
// expect: meat: 4
// expect: veg: 4
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["apple", "rice", "rye", "fig", "ham", "kale", "leek", "leek", "oat", "apple", "lamb", "corn", "lamb", "pork"];
    let tags: Text[] = ["fruit", "grain", "grain", "fruit", "meat", "veg", "veg", "veg", "grain", "fruit", "meat", "veg", "meat", "meat"];
    let cats: Text[] = ["fruit", "grain", "meat", "veg"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
