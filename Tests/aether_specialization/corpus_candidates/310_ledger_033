// 310_ledger_033
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Deposit $99.00: $599.00
// expect: Withdraw $154.00: $445.00
// expect: Withdraw $242.00: $203.00
// expect: Deposit $16.00: $219.00
// expect: Interest 2%: $223.38
// expect: Deposit $173.00: $396.38
// expect: Withdraw $295.00: $101.38
// expect: Deposit $111.00: $212.38

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 99.0);
    fx { println("Deposit $99.00: $", balance:0:2); }
    balance = withdraw(balance, 154.0);
    fx { println("Withdraw $154.00: $", balance:0:2); }
    balance = withdraw(balance, 242.0);
    fx { println("Withdraw $242.00: $", balance:0:2); }
    balance = deposit(balance, 16.0);
    fx { println("Deposit $16.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 173.0);
    fx { println("Deposit $173.00: $", balance:0:2); }
    balance = withdraw(balance, 295.0);
    fx { println("Withdraw $295.00: $", balance:0:2); }
    balance = deposit(balance, 111.0);
    fx { println("Deposit $111.00: $", balance:0:2); }
    ret;
}
