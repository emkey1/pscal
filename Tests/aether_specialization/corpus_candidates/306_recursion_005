// 306_recursion_005
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(5, 7) = 78125
// expect: digit_sum(289898) = 44
// expect: count_digits(8713116) = 7
// expect: sum_to(8) = 36
// expect: reverse_int(122977) = 779221

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(5, 7);
    let ds: Int = digitSum(289898);
    let cd: Int = countDigits(8713116);
    let st: Int = sumTo(8);
    let ri: Int = reverseInt(122977, 0);
    fx {
        println("power(5, 7) = ", pw);
        println("digit_sum(289898) = ", ds);
        println("count_digits(8713116) = ", cd);
        println("sum_to(8) = ", st);
        println("reverse_int(122977) = ", ri);
    }
    ret;
}
