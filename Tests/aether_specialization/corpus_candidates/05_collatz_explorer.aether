fn collatzLength(n: Int) -> Int {
    let steps: Int = 0;
    let current: Int = n;
    loop current != 1 {
        if current % 2 == 0 {
            current = current / 2;
        } else {
            current = current * 3 + 1;
        }
        steps = steps + 1;
    }
    ret steps;
}

fn main() -> Void {
    let limit: Int = 100;
    let longestStart: Int = 1;
    let longestLen: Int = 0;

    fx { println("Collatz sequences for 1..", limit, ":"); }

    loop n in 1..limit + 1 {
        let len: Int = collatzLength(n);
        if len > longestLen {
            longestLen = len;
            longestStart = n;
        }
        if n <= 10 {
            fx { println("  n=", n, " steps=", len); }
        }
    }

    fx {
        println("");
        println("Longest chain: n=", longestStart, " with ", longestLen, " steps");
    }
    ret;
}
