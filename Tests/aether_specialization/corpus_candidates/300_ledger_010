// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Interest 1%: $505.00
// expect: Withdraw $220.00: $285.00
// expect: Withdraw $94.00: $191.00
// expect: Deposit $114.00: $305.00
// expect: Deposit $271.00: $576.00
// expect: Withdraw $192.00: $384.00
// expect: Interest 5%: $403.20
// expect: Withdraw $210.00: $193.20
// expect: Withdraw $198.00: $193.20
// expect: Withdraw $17.00: $176.20
// expect: Withdraw $292.00: $176.20
// expect: Withdraw $85.00: $91.20

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 220.0);
    fx { println("Withdraw $220.00: $", balance:0:2); }
    balance = withdraw(balance, 94.0);
    fx { println("Withdraw $94.00: $", balance:0:2); }
    balance = deposit(balance, 114.0);
    fx { println("Deposit $114.00: $", balance:0:2); }
    balance = deposit(balance, 271.0);
    fx { println("Deposit $271.00: $", balance:0:2); }
    balance = withdraw(balance, 192.0);
    fx { println("Withdraw $192.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 210.0);
    fx { println("Withdraw $210.00: $", balance:0:2); }
    balance = withdraw(balance, 198.0);
    fx { println("Withdraw $198.00: $", balance:0:2); }
    balance = withdraw(balance, 17.0);
    fx { println("Withdraw $17.00: $", balance:0:2); }
    balance = withdraw(balance, 292.0);
    fx { println("Withdraw $292.00: $", balance:0:2); }
    balance = withdraw(balance, 85.0);
    fx { println("Withdraw $85.00: $", balance:0:2); }
    ret;
}
