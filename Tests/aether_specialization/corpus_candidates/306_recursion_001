// 306_recursion_001
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(2, 8) = 256
// expect: digit_sum(337269) = 30
// expect: count_digits(6231102) = 7
// expect: sum_to(13) = 91
// expect: reverse_int(6231161) = 1611326

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(2, 8);
    let ds: Int = digitSum(337269);
    let cd: Int = countDigits(6231102);
    let st: Int = sumTo(13);
    let ri: Int = reverseInt(6231161, 0);
    fx {
        println("power(2, 8) = ", pw);
        println("digit_sum(337269) = ", ds);
        println("count_digits(6231102) = ", cd);
        println("sum_to(13) = ", st);
        println("reverse_int(6231161) = ", ri);
    }
    ret;
}
