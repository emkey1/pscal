// 305_category_counter_001
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: corn [veg]
// expect: item 1: plum [fruit]
// expect: item 2: fig [fruit]
// expect: item 3: pea [veg]
// expect: item 4: cream [dairy]
// expect: item 5: milk [dairy]
// expect: item 6: milk [dairy]
// expect: item 7: leek [veg]
// expect: item 8: milk [dairy]
// expect: item 9: ham [meat]
// expect: item 10: plum [fruit]
// expect: item 11: cream [dairy]
// expect: item 12: milk [dairy]
// expect: veg: 3
// expect: fruit: 3
// expect: dairy: 6
// expect: meat: 1
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["corn", "plum", "fig", "pea", "cream", "milk", "milk", "leek", "milk", "ham", "plum", "cream", "milk"];
    let tags: Text[] = ["veg", "fruit", "fruit", "veg", "dairy", "dairy", "dairy", "veg", "dairy", "meat", "fruit", "dairy", "dairy"];
    let cats: Text[] = ["veg", "fruit", "dairy", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
