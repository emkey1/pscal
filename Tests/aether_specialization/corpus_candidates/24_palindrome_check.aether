@pure
fn is_palindrome(s: Text) -> Bool {
    let reversed: Text = "";
    let i: Int = string_len(s);
    loop i >= 1 {
        reversed = reversed + s[i];
        i = i - 1;
    }
    ret s == reversed;
}

fn main() -> Void {
    let str: Text = "radar";
    fx {
        println(str, " is palindrome: ", is_palindrome(str));
    }
    ret;
}
