@pure
@pre n > 0
@post result >= 0
fn collatz_steps(n: Int) -> Int {
    let steps: Int = 0;
    let current: Int = n;
    loop current > 1 {
        if current % 2 == 0 {
            current = current / 2;
        } else {
            current = 3 * current + 1;
        }
        steps = steps + 1;
    }
    ret steps;
}

fn main() -> Void {
    let steps: Int = collatz_steps(12);
    fx {
        println("Collatz steps for 12: ", steps);
    }
    ret;
}