// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Deposit $39.00: $289.00
// expect: Deposit $255.00: $544.00
// expect: Deposit $215.00: $759.00
// expect: Deposit $76.00: $835.00
// expect: Withdraw $200.00: $635.00
// expect: Withdraw $44.00: $591.00
// expect: Withdraw $158.00: $433.00
// expect: Interest 2%: $441.66
// expect: Deposit $164.00: $605.66
// expect: Deposit $42.00: $647.66
// expect: Deposit $14.00: $661.66
// expect: Deposit $108.00: $769.66

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 39.0);
    fx { println("Deposit $39.00: $", balance:0:2); }
    balance = deposit(balance, 255.0);
    fx { println("Deposit $255.00: $", balance:0:2); }
    balance = deposit(balance, 215.0);
    fx { println("Deposit $215.00: $", balance:0:2); }
    balance = deposit(balance, 76.0);
    fx { println("Deposit $76.00: $", balance:0:2); }
    balance = withdraw(balance, 200.0);
    fx { println("Withdraw $200.00: $", balance:0:2); }
    balance = withdraw(balance, 44.0);
    fx { println("Withdraw $44.00: $", balance:0:2); }
    balance = withdraw(balance, 158.0);
    fx { println("Withdraw $158.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 164.0);
    fx { println("Deposit $164.00: $", balance:0:2); }
    balance = deposit(balance, 42.0);
    fx { println("Deposit $42.00: $", balance:0:2); }
    balance = deposit(balance, 14.0);
    fx { println("Deposit $14.00: $", balance:0:2); }
    balance = deposit(balance, 108.0);
    fx { println("Deposit $108.00: $", balance:0:2); }
    ret;
}
