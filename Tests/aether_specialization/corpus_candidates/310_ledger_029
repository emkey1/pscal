// 310_ledger_029
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Deposit $181.00: $681.00
// expect: Deposit $233.00: $914.00
// expect: Deposit $278.00: $1192.00
// expect: Deposit $257.00: $1449.00
// expect: Withdraw $164.00: $1285.00
// expect: Interest 1%: $1297.85
// expect: Deposit $248.00: $1545.85
// expect: Interest 1%: $1561.31
// expect: Deposit $66.00: $1627.31
// expect: Interest 5%: $1708.67

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 181.0);
    fx { println("Deposit $181.00: $", balance:0:2); }
    balance = deposit(balance, 233.0);
    fx { println("Deposit $233.00: $", balance:0:2); }
    balance = deposit(balance, 278.0);
    fx { println("Deposit $278.00: $", balance:0:2); }
    balance = deposit(balance, 257.0);
    fx { println("Deposit $257.00: $", balance:0:2); }
    balance = withdraw(balance, 164.0);
    fx { println("Withdraw $164.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 248.0);
    fx { println("Deposit $248.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 66.0);
    fx { println("Deposit $66.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    ret;
}
