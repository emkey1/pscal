// 315_category_counter_029
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: lamb [meat]
// expect: item 1: ham [meat]
// expect: item 2: fig [fruit]
// expect: item 3: corn [veg]
// expect: item 4: pea [veg]
// expect: item 5: fig [fruit]
// expect: item 6: pea [veg]
// expect: item 7: bean [veg]
// expect: item 8: corn [veg]
// expect: item 9: fig [fruit]
// expect: item 10: plum [fruit]
// expect: meat: 2
// expect: fruit: 4
// expect: veg: 5
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["lamb", "ham", "fig", "corn", "pea", "fig", "pea", "bean", "corn", "fig", "plum"];
    let tags: Text[] = ["meat", "meat", "fruit", "veg", "veg", "fruit", "veg", "veg", "veg", "fruit", "fruit"];
    let cats: Text[] = ["meat", "fruit", "veg"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
