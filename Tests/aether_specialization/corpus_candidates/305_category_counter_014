// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: cream [dairy]
// expect: item 1: beef [meat]
// expect: item 2: rye [grain]
// expect: item 3: wheat [grain]
// expect: item 4: wheat [grain]
// expect: item 5: lamb [meat]
// expect: item 6: rye [grain]
// expect: item 7: wheat [grain]
// expect: item 8: wheat [grain]
// expect: item 9: yogurt [dairy]
// expect: item 10: rice [grain]
// expect: item 11: cream [dairy]
// expect: item 12: ham [meat]
// expect: item 13: ham [meat]
// expect: dairy: 3
// expect: meat: 4
// expect: grain: 7
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["cream", "beef", "rye", "wheat", "wheat", "lamb", "rye", "wheat", "wheat", "yogurt", "rice", "cream", "ham", "ham"];
    let tags: Text[] = ["dairy", "meat", "grain", "grain", "grain", "meat", "grain", "grain", "grain", "dairy", "grain", "dairy", "meat", "meat"];
    let cats: Text[] = ["dairy", "meat", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
