type Counter {
    value: Int;

    fn bump() -> Int {
        self.value = self.value + 1;
        ret self.value;
    }

    fn reset() -> Void {
        self.value = 0;
        ret;
    }
}

fn main() -> Void {
    let counter: Counter = new Counter();
    fx {
        println("start = ", counter.value);
    }

    loop i in 0..3 { let now: Int = counter.bump(); fx { println("bumped to ", now); } }

    counter.reset();

    fx {
        println("after reset = ", counter.value);
    }

    ret;
}