// 305_category_counter_015
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: pea [veg]
// expect: item 1: corn [veg]
// expect: item 2: apple [fruit]
// expect: item 3: fig [fruit]
// expect: item 4: fig [fruit]
// expect: item 5: wheat [grain]
// expect: item 6: oat [grain]
// expect: item 7: barley [grain]
// expect: item 8: rye [grain]
// expect: item 9: fig [fruit]
// expect: item 10: oat [grain]
// expect: item 11: pear [fruit]
// expect: veg: 2
// expect: fruit: 5
// expect: grain: 5
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["pea", "corn", "apple", "fig", "fig", "wheat", "oat", "barley", "rye", "fig", "oat", "pear"];
    let tags: Text[] = ["veg", "veg", "fruit", "fruit", "fruit", "grain", "grain", "grain", "grain", "fruit", "grain", "fruit"];
    let cats: Text[] = ["veg", "fruit", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
