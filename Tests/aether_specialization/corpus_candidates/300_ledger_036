// 300_ledger_036
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Withdraw $29.00: $221.00
// expect: Deposit $244.00: $465.00
// expect: Deposit $192.00: $657.00
// expect: Deposit $63.00: $720.00
// expect: Withdraw $144.00: $576.00
// expect: Interest 2%: $587.52
// expect: Interest 1%: $593.40
// expect: Withdraw $76.00: $517.40

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 29.0);
    fx { println("Withdraw $29.00: $", balance:0:2); }
    balance = deposit(balance, 244.0);
    fx { println("Deposit $244.00: $", balance:0:2); }
    balance = deposit(balance, 192.0);
    fx { println("Deposit $192.00: $", balance:0:2); }
    balance = deposit(balance, 63.0);
    fx { println("Deposit $63.00: $", balance:0:2); }
    balance = withdraw(balance, 144.0);
    fx { println("Withdraw $144.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 76.0);
    fx { println("Withdraw $76.00: $", balance:0:2); }
    ret;
}
