// 302_inventory_007
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Rod: 20 x $32.58 = $651.60
// expect: Hinge: 30 x $25.93 = $777.90
// expect: Pump: 1 x $12.58 = $12.58 LOW
// expect: Valve: 12 x $39.91 = $478.92
// expect: Gear: 6 x $2.73 = $16.38 LOW
// expect: Nut: 23 x $32.65 = $750.95
// expect: Cable: 35 x $36.92 = $1292.20
// expect: Clamp: 29 x $29.50 = $855.50
// expect: Seal: 9 x $35.38 = $318.42 LOW
// expect: Washer: 26 x $35.89 = $933.14
// expect: Bolt: 14 x $39.91 = $558.74
// expect: grand total: $6646.33
// expect: low-stock items: 3

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Rod", "Hinge", "Pump", "Valve", "Gear", "Nut", "Cable", "Clamp", "Seal", "Washer", "Bolt"];
    let qtys: Int[] = [20, 30, 1, 12, 6, 23, 35, 29, 9, 26, 14];
    let prices: Real[] = [32.58, 25.93, 12.58, 39.91, 2.73, 32.65, 36.92, 29.50, 35.38, 35.89, 39.91];
    let threshold: Int = 10;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
