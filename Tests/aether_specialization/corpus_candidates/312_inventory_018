// 312_inventory_018
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Nut: 11 x $9.41 = $103.51
// expect: Washer: 15 x $9.12 = $136.80
// expect: Bolt: 31 x $39.57 = $1226.67
// expect: Bearing: 3 x $21.64 = $64.92 LOW
// expect: Pump: 33 x $39.57 = $1305.81
// expect: Cable: 5 x $37.23 = $186.15 LOW
// expect: Gear: 2 x $36.17 = $72.34 LOW
// expect: Plate: 32 x $33.03 = $1056.96
// expect: Rod: 2 x $25.55 = $51.10 LOW
// expect: grand total: $4204.26
// expect: low-stock items: 4

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Nut", "Washer", "Bolt", "Bearing", "Pump", "Cable", "Gear", "Plate", "Rod"];
    let qtys: Int[] = [11, 15, 31, 3, 33, 5, 2, 32, 2];
    let prices: Real[] = [9.41, 9.12, 39.57, 21.64, 39.57, 37.23, 36.17, 33.03, 25.55];
    let threshold: Int = 8;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
