// 315_category_counter_026
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: ham [meat]
// expect: item 1: corn [veg]
// expect: item 2: kale [veg]
// expect: item 3: pork [meat]
// expect: item 4: ham [meat]
// expect: item 5: ham [meat]
// expect: item 6: oat [grain]
// expect: item 7: milk [dairy]
// expect: item 8: duck [meat]
// expect: item 9: duck [meat]
// expect: item 10: cream [dairy]
// expect: item 11: wheat [grain]
// expect: item 12: beef [meat]
// expect: item 13: lamb [meat]
// expect: meat: 8
// expect: veg: 2
// expect: grain: 2
// expect: dairy: 2
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["ham", "corn", "kale", "pork", "ham", "ham", "oat", "milk", "duck", "duck", "cream", "wheat", "beef", "lamb"];
    let tags: Text[] = ["meat", "veg", "veg", "meat", "meat", "meat", "grain", "dairy", "meat", "meat", "dairy", "grain", "meat", "meat"];
    let cats: Text[] = ["meat", "veg", "grain", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
