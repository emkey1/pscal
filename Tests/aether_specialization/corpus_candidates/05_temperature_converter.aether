@pure
fn celsiusToFahrenheit(c: Real) -> Real {
    ret c * 9.0 / 5.0 + 32.0;
}

@pure
fn celsiusToKelvin(c: Real) -> Real {
    ret c + 273.15;
}

@pure
fn fahrenheitToCelsius(f: Real) -> Real {
    ret (f - 32.0) * 5.0 / 9.0;
}

@pure
fn kelvinToCelsius(k: Real) -> Real {
    ret k - 273.15;
}

@pure
fn kelvinToFahrenheit(k: Real) -> Real {
    ret celsiusToFahrenheit(kelvinToCelsius(k));
}

@pure
fn fahrenheitToKelvin(f: Real) -> Real {
    ret celsiusToKelvin(fahrenheitToCelsius(f));
}

fn main() -> Void {
    let celsius: Real = 25.0;

    let fahrenheit: Real = celsiusToFahrenheit(celsius);
    let kelvin: Real = celsiusToKelvin(celsius);

    fx {
        println(celsius:0:2, " C = ", fahrenheit:0:2, " F");
        println(celsius:0:2, " C = ", kelvin:0:2, " K");
    }

    let fahrenheit2: Real = 98.6;
    let celsius2: Real = fahrenheitToCelsius(fahrenheit2);
    let kelvin2: Real = fahrenheitToKelvin(fahrenheit2);

    fx {
        println(fahrenheit2:0:2, " F = ", celsius2:0:2, " C");
        println(fahrenheit2:0:2, " F = ", kelvin2:0:2, " K");
    }
    ret;
}
