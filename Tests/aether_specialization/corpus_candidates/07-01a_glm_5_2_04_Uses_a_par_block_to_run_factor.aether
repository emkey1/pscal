type Result {
    value: Int;
}

fn compute_factorial(out: Result, n: Int) -> Void {
    let acc: Int = 1;
    loop i in 1..n+1 {
        acc = acc * i;
    }
    out.value = acc;
    ret;
}

fn compute_fibonacci(out: Result, n: Int) -> Void {
    if n <= 1 {
        out.value = n;
        ret;
    }
    let a: Int = 0;
    let b: Int = 1;
    loop i in 2..n+1 {
        let temp: Int = a + b;
        a = b;
        b = temp;
    }
    out.value = b;
    ret;
}

fn main() -> Void {
    let fact_res: Result = new Result();
    let fib_res: Result = new Result();
    
    par {
        compute_factorial(fact_res, 10);
        compute_fibonacci(fib_res, 10);
    }
    
    fx {
        println("Factorial(10) = ", fact_res.value);
        println("Fibonacci(10) = ", fib_res.value);
    }
    ret;
}