// 305_category_counter_029
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: pear [fruit]
// expect: item 1: barley [grain]
// expect: item 2: wheat [grain]
// expect: item 3: wheat [grain]
// expect: item 4: lamb [meat]
// expect: item 5: pork [meat]
// expect: item 6: rice [grain]
// expect: item 7: plum [fruit]
// expect: fruit: 2
// expect: grain: 4
// expect: meat: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["pear", "barley", "wheat", "wheat", "lamb", "pork", "rice", "plum"];
    let tags: Text[] = ["fruit", "grain", "grain", "grain", "meat", "meat", "grain", "fruit"];
    let cats: Text[] = ["fruit", "grain", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
