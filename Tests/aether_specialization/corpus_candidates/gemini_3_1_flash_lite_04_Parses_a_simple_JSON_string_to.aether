fn main() -> Void {
    if !has_toon() {
        ret;
    }
    let doc: ToonDoc = toon_parse("{\"id\": 101, \"active\": true}");
    let root: ToonNode = toon_root(doc);
    let id: Int = toon_get_int_or(root, "id", 0);
    let active: Bool = toon_get_bool(root, "active");
    fx {
        println("ID: ", id, " Active: ", active);
    }
    toon_close(doc);
    ret;
}