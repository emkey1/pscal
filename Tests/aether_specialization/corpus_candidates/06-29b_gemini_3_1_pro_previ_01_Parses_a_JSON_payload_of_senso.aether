fn main() -> Void {
    if !has_toon() {
        fx { println("TOON unavailable"); }
        ret;
    }

    let payload: Text = "{\"sensors\":[{\"id\":\"A1\",\"temp\":22.5},{\"id\":\"A2\",\"temp\":89.1},{\"id\":\"A3\",\"temp\":21.0}]}";
    let doc: ToonDoc = toon_parse(payload);
    let root: ToonNode = toon_root(doc);
    let sensors: ToonNode = toon_key(root, "sensors");

    let totalTemp: Real = 0.0;
    let count: Int = toon_len(sensors);
    let anomalies: Int = 0;

    loop i in 0..count {
        let sensor: ToonNode = toon_at(sensors, i);
        let temp: Real = toon_get_real_or(sensor, "temp", 0.0);
        totalTemp = totalTemp + temp;

        if temp > 50.0 {
            anomalies = anomalies + 1;
            let id: Text = toon_get_text_or(sensor, "id", "UNK");
            fx { 
                println("Anomaly detected on sensor ", id, ": ", temp:0:1, "C"); 
            }
        }
    }

    if count > 0 {
        let avg: Real = totalTemp / (count * 1.0);
        fx { 
            println("Average temp: ", avg:0:2, "C across ", count, " sensors."); 
        }
    }

    fx { 
        println("Total anomalies: ", anomalies); 
    }

    toon_close(doc);
    ret;
}