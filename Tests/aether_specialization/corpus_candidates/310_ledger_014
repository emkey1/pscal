// 310_ledger_014
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Withdraw $298.00: $202.00
// expect: Deposit $232.00: $434.00
// expect: Withdraw $124.00: $310.00
// expect: Deposit $241.00: $551.00
// expect: Withdraw $152.00: $399.00
// expect: Interest 5%: $418.95
// expect: Interest 1%: $423.14
// expect: Deposit $28.00: $451.14

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 298.0);
    fx { println("Withdraw $298.00: $", balance:0:2); }
    balance = deposit(balance, 232.0);
    fx { println("Deposit $232.00: $", balance:0:2); }
    balance = withdraw(balance, 124.0);
    fx { println("Withdraw $124.00: $", balance:0:2); }
    balance = deposit(balance, 241.0);
    fx { println("Deposit $241.00: $", balance:0:2); }
    balance = withdraw(balance, 152.0);
    fx { println("Withdraw $152.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 28.0);
    fx { println("Deposit $28.00: $", balance:0:2); }
    ret;
}
