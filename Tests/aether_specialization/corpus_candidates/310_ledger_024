// 310_ledger_024
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Withdraw $120.00: $130.00
// expect: Withdraw $257.00: $130.00
// expect: Withdraw $77.00: $53.00
// expect: Withdraw $42.00: $11.00
// expect: Interest 1%: $11.11
// expect: Deposit $219.00: $230.11
// expect: Deposit $104.00: $334.11
// expect: Withdraw $232.00: $102.11
// expect: Deposit $134.00: $236.11
// expect: Withdraw $113.00: $123.11

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 120.0);
    fx { println("Withdraw $120.00: $", balance:0:2); }
    balance = withdraw(balance, 257.0);
    fx { println("Withdraw $257.00: $", balance:0:2); }
    balance = withdraw(balance, 77.0);
    fx { println("Withdraw $77.00: $", balance:0:2); }
    balance = withdraw(balance, 42.0);
    fx { println("Withdraw $42.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 219.0);
    fx { println("Deposit $219.00: $", balance:0:2); }
    balance = deposit(balance, 104.0);
    fx { println("Deposit $104.00: $", balance:0:2); }
    balance = withdraw(balance, 232.0);
    fx { println("Withdraw $232.00: $", balance:0:2); }
    balance = deposit(balance, 134.0);
    fx { println("Deposit $134.00: $", balance:0:2); }
    balance = withdraw(balance, 113.0);
    fx { println("Withdraw $113.00: $", balance:0:2); }
    ret;
}
