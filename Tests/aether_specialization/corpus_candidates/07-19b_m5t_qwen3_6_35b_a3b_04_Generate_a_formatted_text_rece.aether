fn main() -> Void {
    let items: Text[] = ["Apple", "Banana", "Cherry"];
    let prices: Real[] = [1.50, 2.00, 0.75];
    let quantities: Int[] = [3, 2, 1];
    let tax_rate: Real = 0.08;

    let subtotal: Real = 0.0;

    fx {
        println("--- RECEIPT ---");
        println("Item", "  ", "Price", "  ", "Qty", "  ", "Total");
    }

    loop i in 0..length(items) {
        let line_total: Real = prices[i] * quantities[i];
        subtotal = subtotal + line_total;

        fx {
            println(items[i], "  ", prices[i]:0:2, "  ", quantities[i], "  ", line_total:0:2);
        }
    }

    let tax: Real = subtotal * tax_rate;
    let total: Real = subtotal + tax;

    fx {
        println("              ---------");
        println("Subtotal:     ", subtotal:0:2);
        println("Tax (8%):     ", tax:0:2);
        println("Total:        ", total:0:2);
        println("--- --------- ---");
    }
    ret;
}