// 310_ledger_020
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Deposit $197.00: $697.00
// expect: Withdraw $296.00: $401.00
// expect: Interest 5%: $421.05
// expect: Deposit $235.00: $656.05
// expect: Deposit $43.00: $699.05
// expect: Withdraw $164.00: $535.05
// expect: Withdraw $226.00: $309.05
// expect: Deposit $253.00: $562.05
// expect: Withdraw $109.00: $453.05
// expect: Deposit $44.00: $497.05

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 197.0);
    fx { println("Deposit $197.00: $", balance:0:2); }
    balance = withdraw(balance, 296.0);
    fx { println("Withdraw $296.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 235.0);
    fx { println("Deposit $235.00: $", balance:0:2); }
    balance = deposit(balance, 43.0);
    fx { println("Deposit $43.00: $", balance:0:2); }
    balance = withdraw(balance, 164.0);
    fx { println("Withdraw $164.00: $", balance:0:2); }
    balance = withdraw(balance, 226.0);
    fx { println("Withdraw $226.00: $", balance:0:2); }
    balance = deposit(balance, 253.0);
    fx { println("Deposit $253.00: $", balance:0:2); }
    balance = withdraw(balance, 109.0);
    fx { println("Withdraw $109.00: $", balance:0:2); }
    balance = deposit(balance, 44.0);
    fx { println("Deposit $44.00: $", balance:0:2); }
    ret;
}
