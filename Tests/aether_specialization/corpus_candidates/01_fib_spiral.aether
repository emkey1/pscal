@pure
fn fib(n: Int) -> Int {
    if n <= 1 {
        ret n;
    }
    let a: Int = 0;
    let b: Int = 1;
    loop i in 2..n {
        let temp: Int = a + b;
        a = b;
        b = temp;
    }
    ret b;
}

@pure
fn make_row(n: Int, val: Int) -> Text {
    let spaces: Int = n - val;
    let row: Text = "";
    loop i in 0..spaces {
        row = row + " ";
    }
    row = row + "*";
    ret row;
}

fn main() -> Void {
    let limit: Int = 10;
    fx {
        println("Fibonacci Spiral (first 10):");
        println("----------------------------");
    }
    loop i in 0..limit {
        let val: Int = fib(i);
        let line: Text = make_row(limit, val);
        fx {
            println(line);
        }
    }
    fx {
        println("----------------------------");
        println("Done.");
    }
    ret;
}
