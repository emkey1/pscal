// 315_category_counter_005
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: lime [fruit]
// expect: item 1: ham [meat]
// expect: item 2: cream [dairy]
// expect: item 3: plum [fruit]
// expect: item 4: fig [fruit]
// expect: item 5: plum [fruit]
// expect: item 6: milk [dairy]
// expect: item 7: beef [meat]
// expect: item 8: lamb [meat]
// expect: item 9: pear [fruit]
// expect: fruit: 5
// expect: meat: 3
// expect: dairy: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["lime", "ham", "cream", "plum", "fig", "plum", "milk", "beef", "lamb", "pear"];
    let tags: Text[] = ["fruit", "meat", "dairy", "fruit", "fruit", "fruit", "dairy", "meat", "meat", "fruit"];
    let cats: Text[] = ["fruit", "meat", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
