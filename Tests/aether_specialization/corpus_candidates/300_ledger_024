// 300_ledger_024
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Interest 2%: $102.00
// expect: Interest 5%: $107.10
// expect: Deposit $272.00: $379.10
// expect: Deposit $198.00: $577.10
// expect: Deposit $59.00: $636.10
// expect: Withdraw $81.00: $555.10
// expect: Withdraw $62.00: $493.10
// expect: Withdraw $233.00: $260.10
// expect: Withdraw $278.00: $260.10
// expect: Interest 2%: $265.30
// expect: Withdraw $55.00: $210.30

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 272.0);
    fx { println("Deposit $272.00: $", balance:0:2); }
    balance = deposit(balance, 198.0);
    fx { println("Deposit $198.00: $", balance:0:2); }
    balance = deposit(balance, 59.0);
    fx { println("Deposit $59.00: $", balance:0:2); }
    balance = withdraw(balance, 81.0);
    fx { println("Withdraw $81.00: $", balance:0:2); }
    balance = withdraw(balance, 62.0);
    fx { println("Withdraw $62.00: $", balance:0:2); }
    balance = withdraw(balance, 233.0);
    fx { println("Withdraw $233.00: $", balance:0:2); }
    balance = withdraw(balance, 278.0);
    fx { println("Withdraw $278.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 55.0);
    fx { println("Withdraw $55.00: $", balance:0:2); }
    ret;
}
