// 302_inventory_016
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Nut: 8 x $31.45 = $251.60
// expect: Valve: 33 x $9.61 = $317.13
// expect: Bearing: 29 x $23.48 = $680.92
// expect: Gear: 8 x $7.74 = $61.92
// expect: Bracket: 10 x $36.04 = $360.40
// expect: Seal: 30 x $2.68 = $80.40
// expect: Spring: 3 x $5.89 = $17.67 LOW
// expect: Pump: 16 x $27.01 = $432.16
// expect: Cable: 30 x $7.19 = $215.70
// expect: Bolt: 14 x $31.20 = $436.80
// expect: Plate: 5 x $26.49 = $132.45
// expect: grand total: $2987.15
// expect: low-stock items: 1

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Nut", "Valve", "Bearing", "Gear", "Bracket", "Seal", "Spring", "Pump", "Cable", "Bolt", "Plate"];
    let qtys: Int[] = [8, 33, 29, 8, 10, 30, 3, 16, 30, 14, 5];
    let prices: Real[] = [31.45, 9.61, 23.48, 7.74, 36.04, 2.68, 5.89, 27.01, 7.19, 31.20, 26.49];
    let threshold: Int = 5;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
