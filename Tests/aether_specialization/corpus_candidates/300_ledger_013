    balance = withdraw(balance, 104.0);
    fx { println("Withdraw $104.00: $", balance:0:2); }
    balance = withdraw(balance, 23.0);
    fx { println("Withdraw $23.00: $", balance:0:2); }
    balance = deposit(balance, 38.0);
