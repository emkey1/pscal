// I Ching Hexagrams (Fuxi binary order)
// Each of the 64 hexagrams is a stack of six pictographic lines read
// from bottom to top. In Fuxi's arrangement, hexagram 0 is all broken
// (yin) lines, hexagram 63 is all solid (yang) lines, and the ordering
// is exactly binary counting -- making this the oldest known binary
// number representation, predating Leibniz by almost five millennia.

@pure
fn hexagramLines(value: Int) -> Text[] {
    let lines: Text[] = [];
    let v: Int = value;
    let i: Int = 0;
    loop i < 6 {
        if (v & 1) != 0 {
            lines = lines + ["━━━"];      // yang, unbroken line
        } else {
            lines = lines + ["━ ━"];      // yin, broken line
        }
        v = v >> 1;
        i = i + 1;
    }
    ret lines;
}

fn displayHexagram(value: Int) -> Void {
    let lines: Text[] = hexagramLines(value);
    fx {
        print("Hexagram ", value);
        if value < 10 {
            print("  ");
        } else {
            print(" ");
        }
        print("(");
        let j: Int = 5;
        loop j >= 0 {
            if ((value >> j) & 1) != 0 {
                print("1");
            } else {
                print("0");
            }
            j = j - 1;
        }
        println("):");
        let k: Int = 5;
        loop k >= 0 {
            println("    ", lines[k]);
            k = k - 1;
        }
        println("");
    }
    ret;
}

fn main() -> Void {
    fx {
        println("I Ching hexagrams in Fuxi binary order:");
        println("(bottom line = least significant bit)");
        println("");
    }
    loop h in 0..8 {
        displayHexagram(h);
    }
    fx {
        println("...");
    }
    loop h in 60..64 {
        displayHexagram(h);
    }
    fx {
        println("All 64 hexagrams form a complete 6-bit binary system.");
        println("Fuxi order == binary 0-63. Leibniz 1703, after seeing");
        println("the diagrams, wrote 'Explication de l'Arithmetique");
        println("Binaire' citing the I Ching as independent discovery.");
    }
    ret;
}
