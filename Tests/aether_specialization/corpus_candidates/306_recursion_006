// 306_recursion_006
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(4, 9) = 262144
// expect: digit_sum(28561) = 22
// expect: count_digits(6571539) = 7
// expect: sum_to(5) = 15
// expect: reverse_int(2243558) = 8553422

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(4, 9);
    let ds: Int = digitSum(28561);
    let cd: Int = countDigits(6571539);
    let st: Int = sumTo(5);
    let ri: Int = reverseInt(2243558, 0);
    fx {
        println("power(4, 9) = ", pw);
        println("digit_sum(28561) = ", ds);
        println("count_digits(6571539) = ", cd);
        println("sum_to(5) = ", st);
        println("reverse_int(2243558) = ", ri);
    }
    ret;
}
