// 31_toon_guarded_nested
// Concepts: _or protects only the final lookup; guard intermediate nodes
// with toon_has_key before descending
// expect: row 1: OK
// expect: row 2: EMPTY

fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("[{\"id\":1,\"meta\":{\"code\":\"OK\"}},{\"id\":2}]");
    let root: ToonNode = toon_root(doc);

    loop i in 0..toon_len(root) {
        let row: ToonNode = toon_at(root, i);
        let id: Int = toon_get_int(row, "id");
        let code: Text = "EMPTY";
        if toon_has_key(row, "meta") {
            let meta: ToonNode = toon_key(row, "meta");
            code = toon_get_text_or(meta, "code", "EMPTY");
        }
        fx {
            println("row ", id, ": ", code);
        }
    }

    toon_close(doc);
    ret;
}
