// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Interest 2%: $102.00
// expect: Deposit $210.00: $312.00
// expect: Withdraw $44.00: $268.00
// expect: Withdraw $190.00: $78.00
// expect: Deposit $38.00: $116.00
// expect: Withdraw $257.00: $116.00
// expect: Withdraw $202.00: $116.00
// expect: Deposit $87.00: $203.00
// expect: Deposit $242.00: $445.00
// expect: Interest 1%: $449.45
// expect: Interest 1%: $453.94

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 210.0);
    fx { println("Deposit $210.00: $", balance:0:2); }
    balance = withdraw(balance, 44.0);
    fx { println("Withdraw $44.00: $", balance:0:2); }
    balance = withdraw(balance, 190.0);
    fx { println("Withdraw $190.00: $", balance:0:2); }
    balance = deposit(balance, 38.0);
    fx { println("Deposit $38.00: $", balance:0:2); }
    balance = withdraw(balance, 257.0);
    fx { println("Withdraw $257.00: $", balance:0:2); }
    balance = withdraw(balance, 202.0);
    fx { println("Withdraw $202.00: $", balance:0:2); }
    balance = deposit(balance, 87.0);
    fx { println("Deposit $87.00: $", balance:0:2); }
    balance = deposit(balance, 242.0);
    fx { println("Deposit $242.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    ret;
}
