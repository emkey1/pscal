fn find_min(arr: Int[]) -> Int {
    let min: Int = arr[0];
    loop i in 1..length(arr) {
        if arr[i] < min {
            min = arr[i];
        }
    }
    ret min;
}

fn main() -> Void {
    let nums: Int[] = [5, 2, 8, 12, 3];
    fx {
        println("Min value: ", find_min(nums));
    }
    ret;
}
