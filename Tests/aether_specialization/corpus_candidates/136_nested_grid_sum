// 136_nested_grid_sum
// Concepts: nested range loops with accumulation across both dimensions
fn main() -> Void {
    let total: Int = 0;
    loop r in 1..3 {
        loop c in 1..3 {
            total = total + r * c;
            fx {
                println("cell ", r, ",", c, " = ", r * c);
            }
        }
    }
    fx {
        println("grid total = ", total);
    }
    ret;
}
