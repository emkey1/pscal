fn main() -> Void {
    if !has_toon() {
        fx { println("yyjson unavailable"); }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"users\":[{\"name\":\"Alice\",\"score\":95},{\"name\":\"Bob\",\"score\":72}]}");
    let root: ToonNode = toon_root(doc);
    let users: ToonNode = toon_key(root, "users");

    loop i in 0..toon_len(users) {
        let user: ToonNode = toon_at(users, i);
        let name: Text = toon_get_text(user, "name");
        let score: Int = toon_get_int_or(user, "score", 0);

        fx {
            println("Name: ", name, ", Score: ", score);
        }
    }

    toon_close(doc);
    ret;
}