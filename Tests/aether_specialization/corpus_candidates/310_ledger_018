// 310_ledger_018
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Withdraw $25.00: $75.00
// expect: Withdraw $204.00: $75.00
// expect: Interest 5%: $78.75
// expect: Withdraw $69.00: $9.75
// expect: Interest 2%: $9.95
// expect: Interest 1%: $10.04
// expect: Withdraw $263.00: $10.04
// expect: Interest 5%: $10.55
// expect: Interest 5%: $11.07
// expect: Interest 5%: $11.63
// expect: Interest 1%: $11.74
// expect: Interest 2%: $11.98

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 25.0);
    fx { println("Withdraw $25.00: $", balance:0:2); }
    balance = withdraw(balance, 204.0);
    fx { println("Withdraw $204.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 69.0);
    fx { println("Withdraw $69.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 263.0);
    fx { println("Withdraw $263.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    ret;
}
