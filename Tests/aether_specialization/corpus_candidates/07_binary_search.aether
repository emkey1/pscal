@pre isSorted(arr)
@post result == -1 || arr[result] == target
fn binarySearch(arr: Int[], target: Int) -> Int {
    let lo: Int = 0;
    let hi: Int = length(arr) - 1;
    loop lo <= hi {
        let mid: Int = lo + (hi - lo) / 2;
        if arr[mid] == target {
            ret mid;
        }
        if arr[mid] < target {
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    ret -1;
}

@pure
fn isSorted(arr: Int[]) -> Bool {
    loop i in 1..length(arr) {
        if arr[i] < arr[i - 1] {
            ret false;
        }
    }
    ret true;
}

fn main() -> Void {
    let data: Int[] = [2, 5, 8, 12, 16, 23, 38, 42, 56, 72, 91];
    let targets: Int[] = [23, 50, 2, 91, 1];

    fx {
        print("Array: ");
        loop i in 0..length(data) {
            print(data[i], " ");
        }
        println("");
    }

    loop i in 0..length(targets) {
        let t: Int = targets[i];
        let idx: Int = binarySearch(data, t);
        if idx >= 0 {
            fx { println("Found ", t, " at index ", idx); }
        } else {
            fx { println(t, " not found"); }
        }
    }
    ret;
}
