// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Deposit $62.00: $562.00
// expect: Deposit $82.00: $644.00
// expect: Interest 5%: $676.20
// expect: Interest 5%: $710.01
// expect: Deposit $15.00: $725.01
// expect: Withdraw $177.00: $548.01
// expect: Deposit $258.00: $806.01
// expect: Deposit $30.00: $836.01
// expect: Deposit $62.00: $898.01
// expect: Interest 2%: $915.97
// expect: Deposit $59.00: $974.97

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 62.0);
    fx { println("Deposit $62.00: $", balance:0:2); }
    balance = deposit(balance, 82.0);
    fx { println("Deposit $82.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 15.0);
    fx { println("Deposit $15.00: $", balance:0:2); }
    balance = withdraw(balance, 177.0);
    fx { println("Withdraw $177.00: $", balance:0:2); }
    balance = deposit(balance, 258.0);
    fx { println("Deposit $258.00: $", balance:0:2); }
    balance = deposit(balance, 30.0);
    fx { println("Deposit $30.00: $", balance:0:2); }
    balance = deposit(balance, 62.0);
    fx { println("Deposit $62.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 59.0);
    fx { println("Deposit $59.00: $", balance:0:2); }
    ret;
}
