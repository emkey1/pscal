// 305_category_counter_007
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: cheese [dairy]
// expect: item 1: leek [veg]
// expect: item 2: barley [grain]
// expect: item 3: kale [veg]
// expect: item 4: lamb [meat]
// expect: item 5: kale [veg]
// expect: item 6: pea [veg]
// expect: item 7: duck [meat]
// expect: item 8: duck [meat]
// expect: item 9: bean [veg]
// expect: item 10: lamb [meat]
// expect: item 11: barley [grain]
// expect: item 12: wheat [grain]
// expect: dairy: 1
// expect: veg: 5
// expect: grain: 3
// expect: meat: 4
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["cheese", "leek", "barley", "kale", "lamb", "kale", "pea", "duck", "duck", "bean", "lamb", "barley", "wheat"];
    let tags: Text[] = ["dairy", "veg", "grain", "veg", "meat", "veg", "veg", "meat", "meat", "veg", "meat", "grain", "grain"];
    let cats: Text[] = ["dairy", "veg", "grain", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
