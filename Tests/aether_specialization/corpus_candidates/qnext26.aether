fn main() -> Void {
    let scores: Int[] = [10, 20];
    
    scores = scores + [30];
    scores = scores + [40];

    let target: Int = 1;
    
    if target >= 0 && target < length(scores) {
        scores[target] = 99;
    }

    fx {
        println("Scores after update:");
        loop i in 0..length(scores) {
            println("  [", i, "]: ", scores[i]);
        }
    }
    ret;
}
