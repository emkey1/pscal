// 305_category_counter_013
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: rice [grain]
// expect: item 1: rye [grain]
// expect: item 2: rice [grain]
// expect: item 3: leek [veg]
// expect: item 4: oat [grain]
// expect: item 5: pork [meat]
// expect: item 6: oat [grain]
// expect: item 7: ham [meat]
// expect: item 8: duck [meat]
// expect: item 9: pork [meat]
// expect: grain: 5
// expect: veg: 1
// expect: meat: 4
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["rice", "rye", "rice", "leek", "oat", "pork", "oat", "ham", "duck", "pork"];
    let tags: Text[] = ["grain", "grain", "grain", "veg", "grain", "meat", "grain", "meat", "meat", "meat"];
    let cats: Text[] = ["grain", "veg", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
