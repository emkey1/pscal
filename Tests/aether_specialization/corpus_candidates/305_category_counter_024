// 305_category_counter_024
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: kale [veg]
// expect: item 1: duck [meat]
// expect: item 2: yogurt [dairy]
// expect: item 3: beef [meat]
// expect: item 4: beef [meat]
// expect: item 5: duck [meat]
// expect: item 6: yogurt [dairy]
// expect: item 7: corn [veg]
// expect: item 8: lamb [meat]
// expect: veg: 2
// expect: meat: 5
// expect: dairy: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["kale", "duck", "yogurt", "beef", "beef", "duck", "yogurt", "corn", "lamb"];
    let tags: Text[] = ["veg", "meat", "dairy", "meat", "meat", "meat", "dairy", "veg", "meat"];
    let cats: Text[] = ["veg", "meat", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
