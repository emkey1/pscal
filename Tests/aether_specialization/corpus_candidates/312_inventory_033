// 312_inventory_033
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Gear: 18 x $35.78 = $644.04
// expect: Valve: 38 x $10.18 = $386.84
// expect: Cable: 1 x $33.38 = $33.38 LOW
// expect: Spring: 8 x $9.03 = $72.24 LOW
// expect: Screw: 13 x $32.38 = $420.94
// expect: Hinge: 38 x $32.06 = $1218.28
// expect: Washer: 32 x $30.37 = $971.84
// expect: Plate: 30 x $13.02 = $390.60
// expect: Nut: 3 x $7.59 = $22.77 LOW
// expect: Rod: 18 x $9.75 = $175.50
// expect: grand total: $4336.43
// expect: low-stock items: 3

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Gear", "Valve", "Cable", "Spring", "Screw", "Hinge", "Washer", "Plate", "Nut", "Rod"];
    let qtys: Int[] = [18, 38, 1, 8, 13, 38, 32, 30, 3, 18];
    let prices: Real[] = [35.78, 10.18, 33.38, 9.03, 32.38, 32.06, 30.37, 13.02, 7.59, 9.75];
    let threshold: Int = 10;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
