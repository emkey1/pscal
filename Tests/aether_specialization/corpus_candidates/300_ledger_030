// 300_ledger_030
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Withdraw $90.00: $10.00
// expect: Withdraw $106.00: $10.00
// expect: Interest 2%: $10.20
// expect: Interest 5%: $10.71
// expect: Interest 2%: $10.92
// expect: Withdraw $239.00: $10.92
// expect: Withdraw $106.00: $10.92
// expect: Deposit $85.00: $95.92
// expect: Deposit $163.00: $258.92
// expect: Interest 2%: $264.10
// expect: Withdraw $155.00: $109.10

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 90.0);
    fx { println("Withdraw $90.00: $", balance:0:2); }
    balance = withdraw(balance, 106.0);
    fx { println("Withdraw $106.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 239.0);
    fx { println("Withdraw $239.00: $", balance:0:2); }
    balance = withdraw(balance, 106.0);
    fx { println("Withdraw $106.00: $", balance:0:2); }
    balance = deposit(balance, 85.0);
    fx { println("Deposit $85.00: $", balance:0:2); }
    balance = deposit(balance, 163.0);
    fx { println("Deposit $163.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 155.0);
    fx { println("Withdraw $155.00: $", balance:0:2); }
    ret;
}
