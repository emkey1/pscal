// expect: Starting balance: $100.00
// expect: Deposit $297.00: $397.00
// expect: Withdraw $289.00: $108.00
// expect: Withdraw $129.00: $108.00
// expect: Withdraw $44.00: $64.00
// expect: Withdraw $267.00: $64.00
// expect: Deposit $122.00: $186.00
// expect: Deposit $162.00: $348.00
// expect: Withdraw $19.00: $329.00
// expect: Deposit $185.00: $514.00
// expect: Deposit $76.00: $590.00
// expect: Interest 1%: $595.90
// expect: Deposit $24.00: $619.90

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 297.0);
    fx { println("Deposit $297.00: $", balance:0:2); }
    balance = withdraw(balance, 289.0);
    fx { println("Withdraw $289.00: $", balance:0:2); }
    balance = withdraw(balance, 129.0);
    fx { println("Withdraw $129.00: $", balance:0:2); }
    balance = withdraw(balance, 44.0);
    fx { println("Withdraw $44.00: $", balance:0:2); }
    balance = withdraw(balance, 267.0);
    fx { println("Withdraw $267.00: $", balance:0:2); }
    balance = deposit(balance, 122.0);
    fx { println("Deposit $122.00: $", balance:0:2); }
    balance = deposit(balance, 162.0);
    fx { println("Deposit $162.00: $", balance:0:2); }
    balance = withdraw(balance, 19.0);
    fx { println("Withdraw $19.00: $", balance:0:2); }
    balance = deposit(balance, 185.0);
    fx { println("Deposit $185.00: $", balance:0:2); }
    balance = deposit(balance, 76.0);
    fx { println("Deposit $76.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 24.0);
    fx { println("Deposit $24.00: $", balance:0:2); }
    ret;
}
