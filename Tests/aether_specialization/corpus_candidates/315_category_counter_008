// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: rice [grain]
// expect: item 1: lime [fruit]
// expect: item 2: rice [grain]
// expect: item 3: apple [fruit]
// expect: item 4: lime [fruit]
// expect: item 5: yogurt [dairy]
// expect: item 6: rye [grain]
// expect: item 7: cheese [dairy]
// expect: item 8: lime [fruit]
// expect: item 9: oat [grain]
// expect: item 10: butter [dairy]
// expect: item 11: rye [grain]
// expect: item 12: milk [dairy]
// expect: item 13: cream [dairy]
// expect: grain: 5
// expect: fruit: 4
// expect: dairy: 5
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["rice", "lime", "rice", "apple", "lime", "yogurt", "rye", "cheese", "lime", "oat", "butter", "rye", "milk", "cream"];
    let tags: Text[] = ["grain", "fruit", "grain", "fruit", "fruit", "dairy", "grain", "dairy", "fruit", "grain", "dairy", "grain", "dairy", "dairy"];
    let cats: Text[] = ["grain", "fruit", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
