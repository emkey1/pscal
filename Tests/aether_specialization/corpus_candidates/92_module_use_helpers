    let scores: Int[] = [95, 68, 72];
    loop i in 0..length(scores) {
        let s: Int = scores[i];
        fx {
            println(s, " pass=", isPass(s), " band=", band(s));
        }
    }
    fx {
        println("pass mark = ", PassMark);
    }
    ret;
}
