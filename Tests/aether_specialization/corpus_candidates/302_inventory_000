// 302_inventory_000
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Bracket: 11 x $17.76 = $195.36
// expect: Nut: 34 x $12.14 = $412.76
// expect: Spring: 13 x $31.78 = $413.14
// expect: Plate: 13 x $30.09 = $391.17
// expect: Screw: 32 x $23.09 = $738.88
// expect: Clamp: 20 x $15.43 = $308.60
// expect: Washer: 38 x $16.18 = $614.84
// expect: Pump: 39 x $9.50 = $370.50
// expect: Rod: 40 x $31.36 = $1254.40
// expect: Seal: 27 x $27.49 = $742.23
// expect: grand total: $5441.88
// expect: low-stock items: 0

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Bracket", "Nut", "Spring", "Plate", "Screw", "Clamp", "Washer", "Pump", "Rod", "Seal"];
    let qtys: Int[] = [11, 34, 13, 13, 32, 20, 38, 39, 40, 27];
    let prices: Real[] = [17.76, 12.14, 31.78, 30.09, 23.09, 15.43, 16.18, 9.50, 31.36, 27.49];
    let threshold: Int = 8;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
