@pure
fn eval(expr: Text) -> Real {
    // Very basic parser for "number operator number"
    let parts: Text[] = split(expr, " ");
    if length(parts) != 3 {
        ret 0.0;
    }
    let a: Real = parse_float(parts[0]);
    let op: Text = parts[1];
    let b: Real = parse_float(parts[2]);
    
    if op == "+" {
        ret a + b;
    } else if op == "-" {
        ret a - b;
    } else if op == "*" {
        ret a * b;
    } else if op == "/" {
        if b != 0.0 {
            ret a / b;
        }
        ret 0.0;
    }
    ret 0.0;
}

fn main() -> Void {
    fx {
        println("3 + 4 = ", eval("3 + 4"):0:2);
        println("10 / 2 = ", eval("10 / 2"):0:2);
        println("5 * 6 = ", eval("5 * 6"):0:2);
    }
    ret;
}