// 305_category_counter_020
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: duck [meat]
// expect: item 1: lime [fruit]
// expect: item 2: leek [veg]
// expect: item 3: lime [fruit]
// expect: item 4: bean [veg]
// expect: item 5: fig [fruit]
// expect: item 6: pear [fruit]
// expect: item 7: pork [meat]
// expect: item 8: bean [veg]
// expect: item 9: pea [veg]
// expect: item 10: fig [fruit]
// expect: item 11: bean [veg]
// expect: item 12: plum [fruit]
// expect: meat: 2
// expect: fruit: 6
// expect: veg: 5
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["duck", "lime", "leek", "lime", "bean", "fig", "pear", "pork", "bean", "pea", "fig", "bean", "plum"];
    let tags: Text[] = ["meat", "fruit", "veg", "fruit", "veg", "fruit", "fruit", "meat", "veg", "veg", "fruit", "veg", "fruit"];
    let cats: Text[] = ["meat", "fruit", "veg"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
