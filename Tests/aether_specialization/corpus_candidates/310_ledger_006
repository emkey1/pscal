// expect: Starting balance: $250.00
// expect: Deposit $294.00: $544.00
// expect: Withdraw $266.00: $278.00
// expect: Withdraw $44.00: $234.00
// expect: Withdraw $101.00: $133.00
// expect: Withdraw $45.00: $88.00
// expect: Withdraw $224.00: $88.00
// expect: Withdraw $161.00: $88.00
// expect: Deposit $136.00: $224.00

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 294.0);
    fx { println("Deposit $294.00: $", balance:0:2); }
    balance = withdraw(balance, 266.0);
    fx { println("Withdraw $266.00: $", balance:0:2); }
    balance = withdraw(balance, 44.0);
    fx { println("Withdraw $44.00: $", balance:0:2); }
    balance = withdraw(balance, 101.0);
    fx { println("Withdraw $101.00: $", balance:0:2); }
    balance = withdraw(balance, 45.0);
    fx { println("Withdraw $45.00: $", balance:0:2); }
    balance = withdraw(balance, 224.0);
    fx { println("Withdraw $224.00: $", balance:0:2); }
    balance = withdraw(balance, 161.0);
    fx { println("Withdraw $161.00: $", balance:0:2); }
    balance = deposit(balance, 136.0);
    fx { println("Deposit $136.00: $", balance:0:2); }
    ret;
}
