// 315_category_counter_014
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: oat [grain]
// expect: item 1: wheat [grain]
// expect: item 2: oat [grain]
// expect: item 3: pear [fruit]
// expect: item 4: barley [grain]
// expect: item 5: rye [grain]
// expect: item 6: rye [grain]
// expect: item 7: bean [veg]
// expect: item 8: corn [veg]
// expect: item 9: oat [grain]
// expect: item 10: plum [fruit]
// expect: grain: 7
// expect: fruit: 2
// expect: veg: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["oat", "wheat", "oat", "pear", "barley", "rye", "rye", "bean", "corn", "oat", "plum"];
    let tags: Text[] = ["grain", "grain", "grain", "fruit", "grain", "grain", "grain", "veg", "veg", "grain", "fruit"];
    let cats: Text[] = ["grain", "fruit", "veg"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
