// 305_category_counter_028
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: yogurt [dairy]
// expect: item 1: kale [veg]
// expect: item 2: rice [grain]
// expect: item 3: corn [veg]
// expect: item 4: barley [grain]
// expect: item 5: cream [dairy]
// expect: item 6: rice [grain]
// expect: item 7: rye [grain]
// expect: item 8: bean [veg]
// expect: item 9: kale [veg]
// expect: dairy: 2
// expect: veg: 4
// expect: grain: 4
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["yogurt", "kale", "rice", "corn", "barley", "cream", "rice", "rye", "bean", "kale"];
    let tags: Text[] = ["dairy", "veg", "grain", "veg", "grain", "dairy", "grain", "grain", "veg", "veg"];
    let cats: Text[] = ["dairy", "veg", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
