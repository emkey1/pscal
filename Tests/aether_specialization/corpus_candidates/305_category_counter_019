// 305_category_counter_019
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: beef [meat]
// expect: item 1: cheese [dairy]
// expect: item 2: milk [dairy]
// expect: item 3: cream [dairy]
// expect: item 4: ham [meat]
// expect: item 5: beef [meat]
// expect: item 6: duck [meat]
// expect: item 7: duck [meat]
// expect: item 8: pork [meat]
// expect: item 9: lamb [meat]
// expect: item 10: beef [meat]
// expect: item 11: barley [grain]
// expect: meat: 8
// expect: dairy: 3
// expect: grain: 1
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["beef", "cheese", "milk", "cream", "ham", "beef", "duck", "duck", "pork", "lamb", "beef", "barley"];
    let tags: Text[] = ["meat", "dairy", "dairy", "dairy", "meat", "meat", "meat", "meat", "meat", "meat", "meat", "grain"];
    let cats: Text[] = ["meat", "dairy", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
