// 312_inventory_031
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Screw: 7 x $23.18 = $162.26 LOW
// expect: Spring: 26 x $17.89 = $465.14
// expect: Rod: 29 x $6.36 = $184.44
// expect: Nut: 33 x $14.96 = $493.68
// expect: Cable: 38 x $20.33 = $772.54
// expect: Hinge: 32 x $30.11 = $963.52
// expect: Bracket: 6 x $26.65 = $159.90 LOW
// expect: Bolt: 0 x $29.39 = $0.00 LOW
// expect: Washer: 35 x $19.37 = $677.95
// expect: Pump: 37 x $34.89 = $1290.93
// expect: Clamp: 8 x $27.75 = $222.00 LOW
// expect: grand total: $5392.36
// expect: low-stock items: 4

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Screw", "Spring", "Rod", "Nut", "Cable", "Hinge", "Bracket", "Bolt", "Washer", "Pump", "Clamp"];
    let qtys: Int[] = [7, 26, 29, 33, 38, 32, 6, 0, 35, 37, 8];
    let prices: Real[] = [23.18, 17.89, 6.36, 14.96, 20.33, 30.11, 26.65, 29.39, 19.37, 34.89, 27.75];
    let threshold: Int = 10;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
