// 306_recursion_004
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(3, 7) = 2187
// expect: digit_sum(119706) = 24
// expect: count_digits(3971983) = 7
// expect: sum_to(17) = 153
// expect: reverse_int(3580745) = 5470853

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(3, 7);
    let ds: Int = digitSum(119706);
    let cd: Int = countDigits(3971983);
    let st: Int = sumTo(17);
    let ri: Int = reverseInt(3580745, 0);
    fx {
        println("power(3, 7) = ", pw);
        println("digit_sum(119706) = ", ds);
        println("count_digits(3971983) = ", cd);
        println("sum_to(17) = ", st);
        println("reverse_int(3580745) = ", ri);
    }
    ret;
}
