// 306_recursion_008
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(4, 8) = 65536
// expect: digit_sum(306708) = 24
// expect: count_digits(8601520) = 7
// expect: sum_to(23) = 276
// expect: reverse_int(7552151) = 1512557

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(4, 8);
    let ds: Int = digitSum(306708);
    let cd: Int = countDigits(8601520);
    let st: Int = sumTo(23);
    let ri: Int = reverseInt(7552151, 0);
    fx {
        println("power(4, 8) = ", pw);
        println("digit_sum(306708) = ", ds);
        println("count_digits(8601520) = ", cd);
        println("sum_to(23) = ", st);
        println("reverse_int(7552151) = ", ri);
    }
    ret;
}
