@pre low <= high
@post result.0 >= low && result.0 <= high
@post result.1 == (value < low || value > high)
fn clampFlag(value: Int, low: Int, high: Int) -> (Int, Bool) {
    if value < low {
        ret (low, true);
    }
    if value > high {
        ret (high, true);
    }
    ret (value, false);
}

fn main() -> Void {
    let (value1, changed1) = clampFlag(150, 0, 100);
    let (value2, changed2) = clampFlag(42, 0, 100);
    fx {
        println("150 => ", value1, " / ", changed1);
        println("42 => ", value2, " / ", changed2);
    }
    ret;
}
