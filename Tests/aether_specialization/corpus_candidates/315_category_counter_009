// 315_category_counter_009
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: corn [veg]
// expect: item 1: barley [grain]
// expect: item 2: oat [grain]
// expect: item 3: rye [grain]
// expect: item 4: leek [veg]
// expect: item 5: cheese [dairy]
// expect: item 6: kale [veg]
// expect: item 7: duck [meat]
// expect: item 8: ham [meat]
// expect: item 9: pork [meat]
// expect: veg: 3
// expect: grain: 3
// expect: dairy: 1
// expect: meat: 3
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["corn", "barley", "oat", "rye", "leek", "cheese", "kale", "duck", "ham", "pork"];
    let tags: Text[] = ["veg", "grain", "grain", "grain", "veg", "dairy", "veg", "meat", "meat", "meat"];
    let cats: Text[] = ["veg", "grain", "dairy", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
