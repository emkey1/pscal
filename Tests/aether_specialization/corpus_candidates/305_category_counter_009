// 305_category_counter_009
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: apple [fruit]
// expect: item 1: plum [fruit]
// expect: item 2: fig [fruit]
// expect: item 3: pear [fruit]
// expect: item 4: lime [fruit]
// expect: item 5: bean [veg]
// expect: item 6: pea [veg]
// expect: item 7: rice [grain]
// expect: item 8: barley [grain]
// expect: item 9: pea [veg]
// expect: item 10: wheat [grain]
// expect: item 11: bean [veg]
// expect: item 12: corn [veg]
// expect: fruit: 5
// expect: veg: 5
// expect: grain: 3
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["apple", "plum", "fig", "pear", "lime", "bean", "pea", "rice", "barley", "pea", "wheat", "bean", "corn"];
    let tags: Text[] = ["fruit", "fruit", "fruit", "fruit", "fruit", "veg", "veg", "grain", "grain", "veg", "grain", "veg", "veg"];
    let cats: Text[] = ["fruit", "veg", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
