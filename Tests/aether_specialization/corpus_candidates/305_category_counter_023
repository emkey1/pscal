// 305_category_counter_023
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: wheat [grain]
// expect: item 1: duck [meat]
// expect: item 2: pork [meat]
// expect: item 3: lime [fruit]
// expect: item 4: butter [dairy]
// expect: item 5: pear [fruit]
// expect: item 6: rice [grain]
// expect: item 7: cheese [dairy]
// expect: item 8: ham [meat]
// expect: item 9: pear [fruit]
// expect: item 10: pear [fruit]
// expect: item 11: rye [grain]
// expect: item 12: ham [meat]
// expect: grain: 3
// expect: meat: 4
// expect: fruit: 4
// expect: dairy: 2
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["wheat", "duck", "pork", "lime", "butter", "pear", "rice", "cheese", "ham", "pear", "pear", "rye", "ham"];
    let tags: Text[] = ["grain", "meat", "meat", "fruit", "dairy", "fruit", "grain", "dairy", "meat", "fruit", "fruit", "grain", "meat"];
    let cats: Text[] = ["grain", "meat", "fruit", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
