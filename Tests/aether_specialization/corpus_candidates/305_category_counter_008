// 305_category_counter_008
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: butter [dairy]
// expect: item 1: rye [grain]
// expect: item 2: milk [dairy]
// expect: item 3: cream [dairy]
// expect: item 4: oat [grain]
// expect: item 5: butter [dairy]
// expect: item 6: barley [grain]
// expect: item 7: pea [veg]
// expect: item 8: pea [veg]
// expect: item 9: corn [veg]
// expect: item 10: oat [grain]
// expect: item 11: barley [grain]
// expect: item 12: oat [grain]
// expect: dairy: 4
// expect: grain: 6
// expect: veg: 3
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["butter", "rye", "milk", "cream", "oat", "butter", "barley", "pea", "pea", "corn", "oat", "barley", "oat"];
    let tags: Text[] = ["dairy", "grain", "dairy", "dairy", "grain", "dairy", "grain", "veg", "veg", "veg", "grain", "grain", "grain"];
    let cats: Text[] = ["dairy", "grain", "veg"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
