type Sensor {
    label: Text;
    active: Bool;
    samples: Int[];
}

fn record_value(self: Sensor, reading: Int) -> Void {
    if self.active {
        self.samples = self.samples + [reading];
        fx {
            println("Captured ", reading, " on ", self.label);
        }
    } else {
        fx { println("Sensor ", self.label, " is offline; skipping."); }
    }
    ret;
}

fn main() -> Void {
    let probe: Sensor = new Sensor();
    probe.label = "Thermal_04";
    probe.active = true;

    probe.record_value(68);
    probe.record_value(71);

    probe.active = false;
    probe.record_value(95);

    fx {
        println("Total stored samples: ", length(probe.samples));
    }
    ret;
}
