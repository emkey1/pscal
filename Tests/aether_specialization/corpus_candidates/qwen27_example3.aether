@cost 50ops
fn batch_transform(values: Int[]) -> Int {
    let total: Int = 0;
    let count: Int = length(values);
    
    loop i in 0..count {
        total = total + (values[i] * 3);
    }
    
    ret total;
}

fn main() -> Void {
    let dataset: Int[] = [10, 25, 40, 60, 80];
    
    fx {
        println("Executing budgeted transformation...");
    }

    let result: Int = batch_transform(dataset);

    fx {
        println("Result: ", result, " (completed within ops budget)");
    }
    ret;
}
