// 310_ledger_027
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Interest 2%: $102.00
// expect: Deposit $122.00: $224.00
// expect: Deposit $285.00: $509.00
// expect: Interest 1%: $514.09
// expect: Withdraw $203.00: $311.09
// expect: Withdraw $183.00: $128.09
// expect: Interest 2%: $130.65
// expect: Deposit $19.00: $149.65
// expect: Interest 1%: $151.15
// expect: Withdraw $102.00: $49.15

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 122.0);
    fx { println("Deposit $122.00: $", balance:0:2); }
    balance = deposit(balance, 285.0);
    fx { println("Deposit $285.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 203.0);
    fx { println("Withdraw $203.00: $", balance:0:2); }
    balance = withdraw(balance, 183.0);
    fx { println("Withdraw $183.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 19.0);
    fx { println("Deposit $19.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 102.0);
    fx { println("Withdraw $102.00: $", balance:0:2); }
    ret;
}
