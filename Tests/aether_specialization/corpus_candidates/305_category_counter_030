// 305_category_counter_030
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: oat [grain]
// expect: item 1: barley [grain]
// expect: item 2: bean [veg]
// expect: item 3: cream [dairy]
// expect: item 4: cream [dairy]
// expect: item 5: corn [veg]
// expect: item 6: leek [veg]
// expect: item 7: oat [grain]
// expect: item 8: pea [veg]
// expect: item 9: cheese [dairy]
// expect: item 10: cheese [dairy]
// expect: item 11: butter [dairy]
// expect: grain: 3
// expect: veg: 4
// expect: dairy: 5
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["oat", "barley", "bean", "cream", "cream", "corn", "leek", "oat", "pea", "cheese", "cheese", "butter"];
    let tags: Text[] = ["grain", "grain", "veg", "dairy", "dairy", "veg", "veg", "grain", "veg", "dairy", "dairy", "dairy"];
    let cats: Text[] = ["grain", "veg", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
