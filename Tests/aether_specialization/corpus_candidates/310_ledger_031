// 310_ledger_031
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Deposit $285.00: $385.00
// expect: Deposit $241.00: $626.00
// expect: Interest 2%: $638.52
// expect: Withdraw $282.00: $356.52
// expect: Interest 1%: $360.09
// expect: Withdraw $119.00: $241.09
// expect: Withdraw $281.00: $241.09
// expect: Withdraw $150.00: $91.09
// expect: Interest 5%: $95.64
// expect: Deposit $96.00: $191.64
// expect: Deposit $37.00: $228.64
// expect: Withdraw $270.00: $228.64

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 285.0);
    fx { println("Deposit $285.00: $", balance:0:2); }
    balance = deposit(balance, 241.0);
    fx { println("Deposit $241.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 282.0);
    fx { println("Withdraw $282.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 119.0);
    fx { println("Withdraw $119.00: $", balance:0:2); }
    balance = withdraw(balance, 281.0);
    fx { println("Withdraw $281.00: $", balance:0:2); }
    balance = withdraw(balance, 150.0);
    fx { println("Withdraw $150.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 96.0);
    fx { println("Deposit $96.00: $", balance:0:2); }
    balance = deposit(balance, 37.0);
    fx { println("Deposit $37.00: $", balance:0:2); }
    balance = withdraw(balance, 270.0);
    fx { println("Withdraw $270.00: $", balance:0:2); }
    ret;
}
