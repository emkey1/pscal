// 315_category_counter_033
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: yogurt [dairy]
// expect: item 1: milk [dairy]
// expect: item 2: milk [dairy]
// expect: item 3: milk [dairy]
// expect: item 4: pea [veg]
// expect: item 5: corn [veg]
// expect: item 6: cheese [dairy]
// expect: item 7: bean [veg]
// expect: item 8: pork [meat]
// expect: item 9: cream [dairy]
// expect: item 10: cream [dairy]
// expect: dairy: 7
// expect: veg: 3
// expect: meat: 1
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["yogurt", "milk", "milk", "milk", "pea", "corn", "cheese", "bean", "pork", "cream", "cream"];
    let tags: Text[] = ["dairy", "dairy", "dairy", "dairy", "veg", "veg", "dairy", "veg", "meat", "dairy", "dairy"];
    let cats: Text[] = ["dairy", "veg", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
