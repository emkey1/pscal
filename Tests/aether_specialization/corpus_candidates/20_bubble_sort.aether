fn bubble_sort(arr: Int[]) -> Int[] {
    let swapped: Bool = true;
    loop swapped {
        swapped = false;
        loop i in 0..(length(arr) - 1) {
            if arr[i] > arr[i + 1] {
                let temp: Int = arr[i];
                arr[i] = arr[i + 1];
                arr[i + 1] = temp;
                swapped = true;
            }
        }
    }
    ret arr;
}

fn main() -> Void {
    let nums: Int[] = [64, 34, 25, 12, 22, 11, 90];
    let sorted: Int[] = bubble_sort(nums);
    fx {
        print("Sorted array: ");
        loop i in 0..length(sorted) {
            print(sorted[i], " ");
        }
        println("");
    }
    ret;
}
