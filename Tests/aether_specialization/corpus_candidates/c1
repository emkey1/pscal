use "helpers"; // Assuming 'helpers' module exists for common utilities like DefaultScore

// --- Type Definition ---
type JobSummary {
    name: Text;
    score: Int;
    status: Text;
    priority: Int;

    fn isReady() -> Bool {
        ret self.priority == 3;
    }
}

// --- Pure Helper Function with Contract ---
@pure
@pre score >= 0
@post result >= 0
fn normalizeScore(score: Int) -> Int {
    if score > 100 {
        ret 100;
    }
    ret score;
}

// --- Pure Helper Function for Classification ---
@pure
fn classify(score: Int) -> Text {
    if score >= 90 {
        ret "ready";
    }
    ret "review";
}


fn main() -> Void {
    // 1. Setup structured data (Simulating parsing a payload)
    let job_data_json = "{\"name\":\"Data Extraction Task\",\"score\":95,\"priority\":3}";
    let doc = toon_parse(job_data_json);
    let root = toon_root(doc);

    // 2. Extract typed fields from TOON structure
    let name: Text = toon_get_text(root, "name");
    let rawScore: Int = toon_get_int(root, "score");
    let priority_val: Int = toon_get_int(root, "priority");

    // 3. Apply pure logic and contracts
    let normalized_score = normalizeScore(rawScore);
    let job_status = classify(normalized_score);
    let is_ready = JobSummary { priority: priority_val }.isReady(); // Example of method call inference/construction

    // 4. Output visible effects inside fx block
    fx {
        println("--- Job Analysis Report ---");
        println("Job Name: ", name);
        println("Raw Score: ", rawScore);
        println("Normalized Score: ", normalized_score);
        println("Status: ", job_status);
        println("Is Ready: ", is_ready);
    }

    // 5. Cleanup and exit
    toon_close(doc);
    ret;
}

