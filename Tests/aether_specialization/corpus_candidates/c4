// --- Type Definition: Stateful Object ---
type Inventory {
    current_stock: Int;
    max_capacity: Int;

    fn add_item(amount: Int) -> Int {
        if self.current_stock + amount > self.max_capacity {
            ret self.current_stock;
        }
        self.current_stock = self.current_stock + amount;
        ret self.current_stock;
    }

    fn get_status() -> Text {
        if self.current_stock >= self.max_capacity {
            ret "FULL";
        } else if self.current_stock > 0 {
            ret "IN_STOCK";
        } else {
            ret "EMPTY";
        }
    }
}

@pre initial_stock >= 0
@post final_stock >= 0
fn process_inventory(initial_stock: Int, items_to_add: Int) -> Int {
    let inventory = new Inventory();
    inventory.current_stock = initial_stock;
    inventory.max_capacity = 50;
    let final_stock = inventory.add_item(items_to_add);
    ret final_stock;
}

fn main() -> Void {
    const STARTING_STOCK: Int = 10;
    const ADDITION_AMOUNT: Int = 25;
    let result = process_inventory(STARTING_STOCK, ADDITION_AMOUNT);
    fx {
        println("--- Inventory Operation ---");
        println("Initial Stock: ", STARTING_STOCK);
        println("Items Added: ", ADDITION_AMOUNT);
        println("Final Stock: ", result);
        let inventory = new Inventory();
        inventory.current_stock = result;
        inventory.max_capacity = 50;
        println("Current Status: ", inventory.get_status());
    }
    ret;
}
