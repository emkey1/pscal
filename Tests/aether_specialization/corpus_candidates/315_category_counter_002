// 315_category_counter_002
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: beef [meat]
// expect: item 1: beef [meat]
// expect: item 2: cream [dairy]
// expect: item 3: plum [fruit]
// expect: item 4: duck [meat]
// expect: item 5: milk [dairy]
// expect: item 6: apple [fruit]
// expect: item 7: beef [meat]
// expect: meat: 4
// expect: dairy: 2
// expect: fruit: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["beef", "beef", "cream", "plum", "duck", "milk", "apple", "beef"];
    let tags: Text[] = ["meat", "meat", "dairy", "fruit", "meat", "dairy", "fruit", "meat"];
    let cats: Text[] = ["meat", "dairy", "fruit"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
