// 315_category_counter_001
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: kale [veg]
// expect: item 1: lamb [meat]
// expect: item 2: lime [fruit]
// expect: item 3: pea [veg]
// expect: item 4: ham [meat]
// expect: item 5: beef [meat]
// expect: item 6: plum [fruit]
// expect: item 7: wheat [grain]
// expect: item 8: lime [fruit]
// expect: veg: 2
// expect: meat: 3
// expect: fruit: 3
// expect: grain: 1
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["kale", "lamb", "lime", "pea", "ham", "beef", "plum", "wheat", "lime"];
    let tags: Text[] = ["veg", "meat", "fruit", "veg", "meat", "meat", "fruit", "grain", "fruit"];
    let cats: Text[] = ["veg", "meat", "fruit", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
