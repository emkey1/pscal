// 305_category_counter_011
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: cheese [dairy]
// expect: item 1: pea [veg]
// expect: item 2: barley [grain]
// expect: item 3: yogurt [dairy]
// expect: item 4: cheese [dairy]
// expect: item 5: bean [veg]
// expect: item 6: rice [grain]
// expect: item 7: corn [veg]
// expect: item 8: pork [meat]
// expect: item 9: bean [veg]
// expect: item 10: milk [dairy]
// expect: item 11: rice [grain]
// expect: item 12: lamb [meat]
// expect: item 13: cheese [dairy]
// expect: dairy: 5
// expect: veg: 4
// expect: grain: 3
// expect: meat: 2
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["cheese", "pea", "barley", "yogurt", "cheese", "bean", "rice", "corn", "pork", "bean", "milk", "rice", "lamb", "cheese"];
    let tags: Text[] = ["dairy", "veg", "grain", "dairy", "dairy", "veg", "grain", "veg", "meat", "veg", "dairy", "grain", "meat", "dairy"];
    let cats: Text[] = ["dairy", "veg", "grain", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
