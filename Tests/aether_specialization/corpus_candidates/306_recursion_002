// 306_recursion_002
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(6, 9) = 10077696
// expect: digit_sum(545161) = 22
// expect: count_digits(426827) = 6
// expect: sum_to(9) = 45
// expect: reverse_int(9733450) = 543379

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(6, 9);
    let ds: Int = digitSum(545161);
    let cd: Int = countDigits(426827);
    let st: Int = sumTo(9);
    let ri: Int = reverseInt(9733450, 0);
    fx {
        println("power(6, 9) = ", pw);
        println("digit_sum(545161) = ", ds);
        println("count_digits(426827) = ", cd);
        println("sum_to(9) = ", st);
        println("reverse_int(9733450) = ", ri);
    }
    ret;
}
