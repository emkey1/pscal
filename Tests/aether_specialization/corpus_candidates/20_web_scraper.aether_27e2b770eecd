fn fetch_url(url: Text) -> Text {
    let body: Text = "";
    fx {
        let session: Int = httpsession();
        let out: MStream = mstreamcreate();
        let status: Int = httprequest(session, "GET", url, "", out);
        if status == 200 {
            body = mstreambuffer(out);
        }
        mstreamfree(out);
        httpclose(session);
    }
    ret body;
}

fn extract_links(html: Text) -> Text[] {
    let links: Text[] = [];
    let remaining: Text = html;
    loop true {
        let marker_pos: Int = pos("<a href=\"", remaining);
        if marker_pos == 0 {
            break;
        }
        let after_marker: Text = copy(remaining, marker_pos + 9, string_len(remaining) - (marker_pos + 9) + 1);
        let end_pos: Int = pos("\"", after_marker);
        if end_pos == 0 {
            break;
        }
        let link: Text = copy(after_marker, 1, end_pos - 1);
        links = links + [link];
        remaining = copy(after_marker, end_pos + 1, string_len(after_marker) - end_pos);
    }
    ret links;
}

fn main() -> Void {
    let url: Text = "http://example.com";
    let html: Text = fetch_url(url);
    let links: Text[] = extract_links(html);
    fx {
        print("Links found: ");
        loop i in 0..length(links) {
            print(links[i], " ");
        }
        println("");
    }
    ret;
}
