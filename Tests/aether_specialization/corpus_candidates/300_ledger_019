// 300_ledger_019
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Deposit $133.00: $233.00
// expect: Withdraw $286.00: $233.00
// expect: Interest 1%: $235.33
// expect: Interest 2%: $240.04
// expect: Withdraw $208.00: $32.04
// expect: Deposit $125.00: $157.04
// expect: Deposit $189.00: $346.04
// expect: Withdraw $104.00: $242.04
// expect: Interest 2%: $246.88
// expect: Interest 5%: $259.22

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 133.0);
    fx { println("Deposit $133.00: $", balance:0:2); }
    balance = withdraw(balance, 286.0);
    fx { println("Withdraw $286.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 208.0);
    fx { println("Withdraw $208.00: $", balance:0:2); }
    balance = deposit(balance, 125.0);
    fx { println("Deposit $125.00: $", balance:0:2); }
    balance = deposit(balance, 189.0);
    fx { println("Deposit $189.00: $", balance:0:2); }
    balance = withdraw(balance, 104.0);
    fx { println("Withdraw $104.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    ret;
}
