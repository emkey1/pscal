// 306_recursion_012
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(5, 4) = 625
// expect: digit_sum(628498) = 37
// expect: count_digits(2902517) = 7
// expect: sum_to(16) = 136
// expect: reverse_int(1622441) = 1442261

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(5, 4);
    let ds: Int = digitSum(628498);
    let cd: Int = countDigits(2902517);
    let st: Int = sumTo(16);
    let ri: Int = reverseInt(1622441, 0);
    fx {
        println("power(5, 4) = ", pw);
        println("digit_sum(628498) = ", ds);
        println("count_digits(2902517) = ", cd);
        println("sum_to(16) = ", st);
        println("reverse_int(1622441) = ", ri);
    }
    ret;
}
