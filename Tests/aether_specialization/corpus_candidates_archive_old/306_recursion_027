// 306_recursion_027
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(5, 7) = 78125
// expect: digit_sum(548593) = 34
// expect: count_digits(517302) = 6
// expect: sum_to(31) = 496
// expect: reverse_int(3833085) = 5803383

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(5, 7);
    let ds: Int = digitSum(548593);
    let cd: Int = countDigits(517302);
    let st: Int = sumTo(31);
    let ri: Int = reverseInt(3833085, 0);
    fx {
        println("power(5, 7) = ", pw);
        println("digit_sum(548593) = ", ds);
        println("count_digits(517302) = ", cd);
        println("sum_to(31) = ", st);
        println("reverse_int(3833085) = ", ri);
    }
    ret;
}
