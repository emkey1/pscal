// 310_ledger_007
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Withdraw $264.00: $100.00
// expect: Withdraw $152.00: $100.00
// expect: Withdraw $246.00: $100.00
// expect: Deposit $236.00: $336.00
// expect: Interest 1%: $339.36
// expect: Withdraw $93.00: $246.36
// expect: Withdraw $248.00: $246.36
// expect: Deposit $257.00: $503.36
// expect: Deposit $107.00: $610.36

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 264.0);
    fx { println("Withdraw $264.00: $", balance:0:2); }
    balance = withdraw(balance, 152.0);
    fx { println("Withdraw $152.00: $", balance:0:2); }
    balance = withdraw(balance, 246.0);
    fx { println("Withdraw $246.00: $", balance:0:2); }
    balance = deposit(balance, 236.0);
    fx { println("Deposit $236.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 93.0);
    fx { println("Withdraw $93.00: $", balance:0:2); }
    balance = withdraw(balance, 248.0);
    fx { println("Withdraw $248.00: $", balance:0:2); }
    balance = deposit(balance, 257.0);
    fx { println("Deposit $257.00: $", balance:0:2); }
    balance = deposit(balance, 107.0);
    fx { println("Deposit $107.00: $", balance:0:2); }
    ret;
}
