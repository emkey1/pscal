// 315_category_counter_015
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: leek [veg]
// expect: item 1: corn [veg]
// expect: item 2: corn [veg]
// expect: item 3: leek [veg]
// expect: item 4: bean [veg]
// expect: item 5: duck [meat]
// expect: item 6: wheat [grain]
// expect: item 7: lamb [meat]
// expect: item 8: corn [veg]
// expect: veg: 6
// expect: meat: 2
// expect: grain: 1
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["leek", "corn", "corn", "leek", "bean", "duck", "wheat", "lamb", "corn"];
    let tags: Text[] = ["veg", "veg", "veg", "veg", "veg", "meat", "grain", "meat", "veg"];
    let cats: Text[] = ["veg", "meat", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
