// 306_recursion_021
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(5, 5) = 3125
// expect: digit_sum(646549) = 34
// expect: count_digits(2059134) = 7
// expect: sum_to(37) = 703
// expect: reverse_int(4989884) = 4889894

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(5, 5);
    let ds: Int = digitSum(646549);
    let cd: Int = countDigits(2059134);
    let st: Int = sumTo(37);
    let ri: Int = reverseInt(4989884, 0);
    fx {
        println("power(5, 5) = ", pw);
        println("digit_sum(646549) = ", ds);
        println("count_digits(2059134) = ", cd);
        println("sum_to(37) = ", st);
        println("reverse_int(4989884) = ", ri);
    }
    ret;
}
