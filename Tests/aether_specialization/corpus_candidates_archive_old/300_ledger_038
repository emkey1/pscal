// 300_ledger_038
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Deposit $73.00: $173.00
// expect: Deposit $34.00: $207.00
// expect: Withdraw $249.00: $207.00
// expect: Withdraw $30.00: $177.00
// expect: Deposit $157.00: $334.00
// expect: Deposit $56.00: $390.00
// expect: Interest 5%: $409.50
// expect: Deposit $268.00: $677.50

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 73.0);
    fx { println("Deposit $73.00: $", balance:0:2); }
    balance = deposit(balance, 34.0);
    fx { println("Deposit $34.00: $", balance:0:2); }
    balance = withdraw(balance, 249.0);
    fx { println("Withdraw $249.00: $", balance:0:2); }
    balance = withdraw(balance, 30.0);
    fx { println("Withdraw $30.00: $", balance:0:2); }
    balance = deposit(balance, 157.0);
    fx { println("Deposit $157.00: $", balance:0:2); }
    balance = deposit(balance, 56.0);
    fx { println("Deposit $56.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 268.0);
    fx { println("Deposit $268.00: $", balance:0:2); }
    ret;
}
