// 315_category_counter_027
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: milk [dairy]
// expect: item 1: lamb [meat]
// expect: item 2: leek [veg]
// expect: item 3: milk [dairy]
// expect: item 4: corn [veg]
// expect: item 5: milk [dairy]
// expect: item 6: pea [veg]
// expect: item 7: corn [veg]
// expect: item 8: beef [meat]
// expect: item 9: yogurt [dairy]
// expect: item 10: oat [grain]
// expect: item 11: kale [veg]
// expect: dairy: 4
// expect: meat: 2
// expect: veg: 5
// expect: grain: 1
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["milk", "lamb", "leek", "milk", "corn", "milk", "pea", "corn", "beef", "yogurt", "oat", "kale"];
    let tags: Text[] = ["dairy", "meat", "veg", "dairy", "veg", "dairy", "veg", "veg", "meat", "dairy", "grain", "veg"];
    let cats: Text[] = ["dairy", "meat", "veg", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
