// 306_recursion_019
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(2, 5) = 32
// expect: digit_sum(662109) = 24
// expect: count_digits(5730294) = 7
// expect: sum_to(37) = 703
// expect: reverse_int(1469244) = 4429641

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(2, 5);
    let ds: Int = digitSum(662109);
    let cd: Int = countDigits(5730294);
    let st: Int = sumTo(37);
    let ri: Int = reverseInt(1469244, 0);
    fx {
        println("power(2, 5) = ", pw);
        println("digit_sum(662109) = ", ds);
        println("count_digits(5730294) = ", cd);
        println("sum_to(37) = ", st);
        println("reverse_int(1469244) = ", ri);
    }
    ret;
}
