// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Withdraw $296.00: $250.00
// expect: Deposit $42.00: $292.00
// expect: Deposit $262.00: $554.00
// expect: Deposit $279.00: $833.00
// expect: Interest 2%: $849.66
// expect: Withdraw $212.00: $637.66
// expect: Withdraw $265.00: $372.66
// expect: Deposit $147.00: $519.66
// expect: Deposit $195.00: $714.66
// expect: Deposit $180.00: $894.66
// expect: Deposit $133.00: $1027.66

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 296.0);
    fx { println("Withdraw $296.00: $", balance:0:2); }
    balance = deposit(balance, 42.0);
    fx { println("Deposit $42.00: $", balance:0:2); }
    balance = deposit(balance, 262.0);
    fx { println("Deposit $262.00: $", balance:0:2); }
    balance = deposit(balance, 279.0);
    fx { println("Deposit $279.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 212.0);
    fx { println("Withdraw $212.00: $", balance:0:2); }
    balance = withdraw(balance, 265.0);
    fx { println("Withdraw $265.00: $", balance:0:2); }
    balance = deposit(balance, 147.0);
    fx { println("Deposit $147.00: $", balance:0:2); }
    balance = deposit(balance, 195.0);
    fx { println("Deposit $195.00: $", balance:0:2); }
    balance = deposit(balance, 180.0);
    fx { println("Deposit $180.00: $", balance:0:2); }
    balance = deposit(balance, 133.0);
    fx { println("Deposit $133.00: $", balance:0:2); }
    ret;
}
