// 310_ledger_028
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Withdraw $201.00: $49.00
// expect: Interest 1%: $49.49
// expect: Interest 2%: $50.48
// expect: Deposit $153.00: $203.48
// expect: Deposit $289.00: $492.48
// expect: Withdraw $198.00: $294.48
// expect: Withdraw $21.00: $273.48
// expect: Interest 1%: $276.21
// expect: Withdraw $37.00: $239.21
// expect: Deposit $250.00: $489.21

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 201.0);
    fx { println("Withdraw $201.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 153.0);
    fx { println("Deposit $153.00: $", balance:0:2); }
    balance = deposit(balance, 289.0);
    fx { println("Deposit $289.00: $", balance:0:2); }
    balance = withdraw(balance, 198.0);
    fx { println("Withdraw $198.00: $", balance:0:2); }
    balance = withdraw(balance, 21.0);
    fx { println("Withdraw $21.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 37.0);
    fx { println("Withdraw $37.00: $", balance:0:2); }
    balance = deposit(balance, 250.0);
    fx { println("Deposit $250.00: $", balance:0:2); }
    ret;
}
