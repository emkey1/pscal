// 315_category_counter_025
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: apple [fruit]
// expect: item 1: pear [fruit]
// expect: item 2: duck [meat]
// expect: item 3: leek [veg]
// expect: item 4: cheese [dairy]
// expect: item 5: milk [dairy]
// expect: item 6: butter [dairy]
// expect: item 7: beef [meat]
// expect: item 8: kale [veg]
// expect: item 9: fig [fruit]
// expect: item 10: butter [dairy]
// expect: item 11: cream [dairy]
// expect: item 12: pear [fruit]
// expect: fruit: 4
// expect: meat: 2
// expect: veg: 2
// expect: dairy: 5
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["apple", "pear", "duck", "leek", "cheese", "milk", "butter", "beef", "kale", "fig", "butter", "cream", "pear"];
    let tags: Text[] = ["fruit", "fruit", "meat", "veg", "dairy", "dairy", "dairy", "meat", "veg", "fruit", "dairy", "dairy", "fruit"];
    let cats: Text[] = ["fruit", "meat", "veg", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
