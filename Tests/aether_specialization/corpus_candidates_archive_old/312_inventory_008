// 312_inventory_008
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Pump: 26 x $28.98 = $753.48
// expect: Washer: 20 x $32.77 = $655.40
// expect: Nut: 29 x $5.81 = $168.49
// expect: Clamp: 23 x $8.94 = $205.62
// expect: Rod: 22 x $28.20 = $620.40
// expect: Bracket: 25 x $21.90 = $547.50
// expect: Plate: 24 x $5.63 = $135.12
// expect: Bearing: 20 x $20.39 = $407.80
// expect: Spring: 25 x $28.89 = $722.25
// expect: grand total: $4216.06
// expect: low-stock items: 0

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Pump", "Washer", "Nut", "Clamp", "Rod", "Bracket", "Plate", "Bearing", "Spring"];
    let qtys: Int[] = [26, 20, 29, 23, 22, 25, 24, 20, 25];
    let prices: Real[] = [28.98, 32.77, 5.81, 8.94, 28.20, 21.90, 5.63, 20.39, 28.89];
    let threshold: Int = 8;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
