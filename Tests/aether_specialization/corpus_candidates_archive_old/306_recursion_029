// 306_recursion_029
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(4, 6) = 4096
// expect: digit_sum(552518) = 26
// expect: count_digits(9614518) = 7
// expect: sum_to(6) = 21
// expect: reverse_int(3140360) = 630413

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(4, 6);
    let ds: Int = digitSum(552518);
    let cd: Int = countDigits(9614518);
    let st: Int = sumTo(6);
    let ri: Int = reverseInt(3140360, 0);
    fx {
        println("power(4, 6) = ", pw);
        println("digit_sum(552518) = ", ds);
        println("count_digits(9614518) = ", cd);
        println("sum_to(6) = ", st);
        println("reverse_int(3140360) = ", ri);
    }
    ret;
}
