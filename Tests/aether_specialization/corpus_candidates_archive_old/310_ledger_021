// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Deposit $180.00: $430.00
// expect: Deposit $86.00: $516.00
// expect: Deposit $139.00: $655.00
// expect: Withdraw $11.00: $644.00
// expect: Deposit $24.00: $668.00
// expect: Interest 1%: $674.68
// expect: Deposit $191.00: $865.68
// expect: Withdraw $159.00: $706.68
// expect: Withdraw $229.00: $477.68
// expect: Deposit $241.00: $718.68
// expect: Interest 5%: $754.61
// expect: Deposit $98.00: $852.61

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 180.0);
    fx { println("Deposit $180.00: $", balance:0:2); }
    balance = deposit(balance, 86.0);
    fx { println("Deposit $86.00: $", balance:0:2); }
    balance = deposit(balance, 139.0);
    fx { println("Deposit $139.00: $", balance:0:2); }
    balance = withdraw(balance, 11.0);
    fx { println("Withdraw $11.00: $", balance:0:2); }
    balance = deposit(balance, 24.0);
    fx { println("Deposit $24.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 191.0);
    fx { println("Deposit $191.00: $", balance:0:2); }
    balance = withdraw(balance, 159.0);
    fx { println("Withdraw $159.00: $", balance:0:2); }
    balance = withdraw(balance, 229.0);
    fx { println("Withdraw $229.00: $", balance:0:2); }
    balance = deposit(balance, 241.0);
    fx { println("Deposit $241.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 98.0);
    fx { println("Deposit $98.00: $", balance:0:2); }
    ret;
}
