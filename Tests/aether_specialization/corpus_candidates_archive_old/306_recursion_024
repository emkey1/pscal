// 306_recursion_024
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(6, 6) = 46656
// expect: digit_sum(151434) = 18
// expect: count_digits(1740880) = 7
// expect: sum_to(7) = 28
// expect: reverse_int(2884942) = 2494882

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(6, 6);
    let ds: Int = digitSum(151434);
    let cd: Int = countDigits(1740880);
    let st: Int = sumTo(7);
    let ri: Int = reverseInt(2884942, 0);
    fx {
        println("power(6, 6) = ", pw);
        println("digit_sum(151434) = ", ds);
        println("count_digits(1740880) = ", cd);
        println("sum_to(7) = ", st);
        println("reverse_int(2884942) = ", ri);
    }
    ret;
}
