// 306_recursion_025
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(6, 4) = 1296
// expect: digit_sum(158903) = 26
// expect: count_digits(1483983) = 7
// expect: sum_to(11) = 66
// expect: reverse_int(9157825) = 5287519

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(6, 4);
    let ds: Int = digitSum(158903);
    let cd: Int = countDigits(1483983);
    let st: Int = sumTo(11);
    let ri: Int = reverseInt(9157825, 0);
    fx {
        println("power(6, 4) = ", pw);
        println("digit_sum(158903) = ", ds);
        println("count_digits(1483983) = ", cd);
        println("sum_to(11) = ", st);
        println("reverse_int(9157825) = ", ri);
    }
    ret;
}
