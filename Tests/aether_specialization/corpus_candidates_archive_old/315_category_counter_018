// 315_category_counter_018
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: rice [grain]
// expect: item 1: corn [veg]
// expect: item 2: cheese [dairy]
// expect: item 3: lamb [meat]
// expect: item 4: kale [veg]
// expect: item 5: corn [veg]
// expect: item 6: bean [veg]
// expect: item 7: cheese [dairy]
// expect: grain: 1
// expect: veg: 4
// expect: dairy: 2
// expect: meat: 1
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["rice", "corn", "cheese", "lamb", "kale", "corn", "bean", "cheese"];
    let tags: Text[] = ["grain", "veg", "dairy", "meat", "veg", "veg", "veg", "dairy"];
    let cats: Text[] = ["grain", "veg", "dairy", "meat"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
