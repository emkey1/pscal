// 315_category_counter_030
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: pear [fruit]
// expect: item 1: corn [veg]
// expect: item 2: cream [dairy]
// expect: item 3: cheese [dairy]
// expect: item 4: pea [veg]
// expect: item 5: milk [dairy]
// expect: item 6: oat [grain]
// expect: item 7: wheat [grain]
// expect: item 8: fig [fruit]
// expect: fruit: 2
// expect: veg: 2
// expect: dairy: 3
// expect: grain: 2
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["pear", "corn", "cream", "cheese", "pea", "milk", "oat", "wheat", "fig"];
    let tags: Text[] = ["fruit", "veg", "dairy", "dairy", "veg", "dairy", "grain", "grain", "fruit"];
    let cats: Text[] = ["fruit", "veg", "dairy", "grain"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
