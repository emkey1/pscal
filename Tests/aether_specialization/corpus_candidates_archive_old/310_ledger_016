// expect: Starting balance: $100.00
// expect: Withdraw $248.00: $100.00
// expect: Interest 2%: $102.00
// expect: Withdraw $274.00: $102.00
// expect: Deposit $248.00: $350.00
// expect: Deposit $283.00: $633.00
// expect: Deposit $192.00: $825.00
// expect: Deposit $299.00: $1124.00
// expect: Interest 2%: $1146.48
// expect: Deposit $202.00: $1348.48
// expect: Withdraw $217.00: $1131.48
// expect: Withdraw $239.00: $892.48

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 248.0);
    fx { println("Withdraw $248.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 274.0);
    fx { println("Withdraw $274.00: $", balance:0:2); }
    balance = deposit(balance, 248.0);
    fx { println("Deposit $248.00: $", balance:0:2); }
    balance = deposit(balance, 283.0);
    fx { println("Deposit $283.00: $", balance:0:2); }
    balance = deposit(balance, 192.0);
    fx { println("Deposit $192.00: $", balance:0:2); }
    balance = deposit(balance, 299.0);
    fx { println("Deposit $299.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = deposit(balance, 202.0);
    fx { println("Deposit $202.00: $", balance:0:2); }
    balance = withdraw(balance, 217.0);
    fx { println("Withdraw $217.00: $", balance:0:2); }
    balance = withdraw(balance, 239.0);
    fx { println("Withdraw $239.00: $", balance:0:2); }
    ret;
}
