// 308_searching_027
// Concepts: linear search returning first matching index or -1, find-min-index scan, binary search over a sorted Int[] (lo/hi/mid bisection), present and absent targets
// expect: array: 71 60 15 4 35 5 7 5
// expect: sorted: 10 17 29 31 55 83 85 93
// expect: index_of(95) = -1
// expect: min_index = 3
// expect: min_value = 4
// expect: binary_search(27) = -1

fn indexOf(xs: Int[], target: Int) -> Int {
    let n: Int = length(xs);
    loop i in 0..n {
        if xs[i] == target { ret i; }
    }
    ret -1;
}

fn minIndex(xs: Int[]) -> Int {
    let m: Int = 0;
    let n: Int = length(xs);
    loop i in 1..n {
        if xs[i] < xs[m] { m = i; }
    }
    ret m;
}

fn binarySearch(xs: Int[], target: Int) -> Int {
    let lo: Int = 0;
    let hi: Int = length(xs) - 1;
    loop lo <= hi {
        let mid: Int = (lo + hi) / 2;
        if xs[mid] == target { ret mid; }
        if xs[mid] < target { lo = mid + 1; }
        if xs[mid] > target { hi = mid - 1; }
    }
    ret -1;
}

fn joinInts(xs: Int[]) -> Text {
    let out: Text = "";
    let n: Int = length(xs);
    loop i in 0..n {
        if i > 0 { out = out + " "; }
        out = out + int_to_text(xs[i]);
    }
    ret out;
}

fn main() -> Void {
    let xs: Int[] = [71, 60, 15, 4, 35, 5, 7, 5];
    let sorted: Int[] = [10, 17, 29, 31, 55, 83, 85, 93];
    let ltgt: Int = 95;
    let btgt: Int = 27;
    let lin: Int = indexOf(xs, ltgt);
    let mi: Int = minIndex(xs);
    let bin: Int = binarySearch(sorted, btgt);
    fx {
        println("array: ", joinInts(xs));
        println("sorted: ", joinInts(sorted));
        println("index_of(", ltgt, ") = ", lin);
        println("min_index = ", mi);
        println("min_value = ", xs[mi]);
        println("binary_search(", btgt, ") = ", bin);
    }
    ret;
}
