// 300_ledger_012
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Deposit $116.00: $366.00
// expect: Withdraw $186.00: $180.00
// expect: Deposit $231.00: $411.00
// expect: Withdraw $111.00: $300.00
// expect: Withdraw $235.00: $65.00
// expect: Withdraw $214.00: $65.00
// expect: Withdraw $63.00: $2.00
// expect: Withdraw $124.00: $2.00
// expect: Interest 2%: $2.04

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 116.0);
    fx { println("Deposit $116.00: $", balance:0:2); }
    balance = withdraw(balance, 186.0);
    fx { println("Withdraw $186.00: $", balance:0:2); }
    balance = deposit(balance, 231.0);
    fx { println("Deposit $231.00: $", balance:0:2); }
    balance = withdraw(balance, 111.0);
    fx { println("Withdraw $111.00: $", balance:0:2); }
    balance = withdraw(balance, 235.0);
    fx { println("Withdraw $235.00: $", balance:0:2); }
    balance = withdraw(balance, 214.0);
    fx { println("Withdraw $214.00: $", balance:0:2); }
    balance = withdraw(balance, 63.0);
    fx { println("Withdraw $63.00: $", balance:0:2); }
    balance = withdraw(balance, 124.0);
    fx { println("Withdraw $124.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    ret;
}
