// 306_recursion_010
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(2, 7) = 128
// expect: digit_sum(998226) = 36
// expect: count_digits(5460588) = 7
// expect: sum_to(33) = 561
// expect: reverse_int(5258142) = 2418525

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(2, 7);
    let ds: Int = digitSum(998226);
    let cd: Int = countDigits(5460588);
    let st: Int = sumTo(33);
    let ri: Int = reverseInt(5258142, 0);
    fx {
        println("power(2, 7) = ", pw);
        println("digit_sum(998226) = ", ds);
        println("count_digits(5460588) = ", cd);
        println("sum_to(33) = ", st);
        println("reverse_int(5258142) = ", ri);
    }
    ret;
}
