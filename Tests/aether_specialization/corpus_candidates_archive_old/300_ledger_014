// expect: Starting balance: $500.00
// expect: Deposit $27.00: $527.00
// expect: Withdraw $98.00: $429.00
// expect: Withdraw $272.00: $157.00
// expect: Withdraw $223.00: $157.00
// expect: Withdraw $62.00: $95.00
// expect: Deposit $120.00: $215.00
// expect: Withdraw $85.00: $130.00
// expect: Deposit $82.00: $212.00

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 27.0);
    fx { println("Deposit $27.00: $", balance:0:2); }
    balance = withdraw(balance, 98.0);
    fx { println("Withdraw $98.00: $", balance:0:2); }
    balance = withdraw(balance, 272.0);
    fx { println("Withdraw $272.00: $", balance:0:2); }
    balance = withdraw(balance, 223.0);
    fx { println("Withdraw $223.00: $", balance:0:2); }
    balance = withdraw(balance, 62.0);
    fx { println("Withdraw $62.00: $", balance:0:2); }
    balance = deposit(balance, 120.0);
    fx { println("Deposit $120.00: $", balance:0:2); }
    balance = withdraw(balance, 85.0);
    fx { println("Withdraw $85.00: $", balance:0:2); }
    balance = deposit(balance, 82.0);
    fx { println("Deposit $82.00: $", balance:0:2); }
    ret;
}
