// 306_recursion_016
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(2, 3) = 8
// expect: digit_sum(145096) = 25
// expect: count_digits(8326497) = 7
// expect: sum_to(33) = 561
// expect: reverse_int(5256444) = 4446525

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(2, 3);
    let ds: Int = digitSum(145096);
    let cd: Int = countDigits(8326497);
    let st: Int = sumTo(33);
    let ri: Int = reverseInt(5256444, 0);
    fx {
        println("power(2, 3) = ", pw);
        println("digit_sum(145096) = ", ds);
        println("count_digits(8326497) = ", cd);
        println("sum_to(33) = ", st);
        println("reverse_int(5256444) = ", ri);
    }
    ret;
}
