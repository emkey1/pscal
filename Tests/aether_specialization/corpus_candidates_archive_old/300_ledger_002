fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 123.0);
    fx { println("Withdraw $123.00: $", balance:0:2); }
    balance = deposit(balance, 152.0);
    fx { println("Deposit $152.00: $", balance:0:2); }
    balance = withdraw(balance, 57.0);
    fx { println("Withdraw $57.00: $", balance:0:2); }
    balance = withdraw(balance, 232.0);
    fx { println("Withdraw $232.00: $", balance:0:2); }
    balance = withdraw(balance, 133.0);
    fx { println("Withdraw $133.00: $", balance:0:2); }
    balance = deposit(balance, 30.0);
    fx { println("Deposit $30.00: $", balance:0:2); }
    balance = withdraw(balance, 299.0);
    fx { println("Withdraw $299.00: $", balance:0:2); }
    balance = withdraw(balance, 76.0);
    fx { println("Withdraw $76.00: $", balance:0:2); }
    balance = withdraw(balance, 93.0);
    fx { println("Withdraw $93.00: $", balance:0:2); }
    balance = deposit(balance, 153.0);
    fx { println("Deposit $153.00: $", balance:0:2); }
    balance = deposit(balance, 278.0);
    fx { println("Deposit $278.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    ret;
}
