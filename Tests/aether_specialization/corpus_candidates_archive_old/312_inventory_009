// 312_inventory_009
// Concepts: parallel Text/Int/Real arrays, Int*Real line totals, running real grand total, threshold flag helper, formatted currency output, summary counts
// expect: Gear: 1 x $13.91 = $13.91 LOW
// expect: Cable: 30 x $8.90 = $267.00
// expect: Washer: 4 x $20.06 = $80.24 LOW
// expect: Seal: 7 x $22.08 = $154.56 LOW
// expect: Nut: 8 x $6.54 = $52.32
// expect: Screw: 23 x $37.89 = $871.47
// expect: Hinge: 21 x $1.41 = $29.61
// expect: Pump: 30 x $18.53 = $555.90
// expect: Bolt: 15 x $31.98 = $479.70
// expect: Bearing: 9 x $24.71 = $222.39
// expect: Rod: 38 x $21.69 = $824.22
// expect: grand total: $3551.32
// expect: low-stock items: 3

fn lowFlag(qty: Int, threshold: Int) -> Text {
    if qty < threshold { ret " LOW"; }
    ret "";
}

fn main() -> Void {
    let names: Text[] = ["Gear", "Cable", "Washer", "Seal", "Nut", "Screw", "Hinge", "Pump", "Bolt", "Bearing", "Rod"];
    let qtys: Int[] = [1, 30, 4, 7, 8, 23, 21, 30, 15, 9, 38];
    let prices: Real[] = [13.91, 8.90, 20.06, 22.08, 6.54, 37.89, 1.41, 18.53, 31.98, 24.71, 21.69];
    let threshold: Int = 8;
    let n: Int = length(qtys);
    let grand: Real = 0.0;
    let low: Int = 0;
    loop i in 0..n {
        let line: Real = qtys[i] * prices[i];
        grand = grand + line;
        let flag: Text = lowFlag(qtys[i], threshold);
        if qtys[i] < threshold { low = low + 1; }
        fx { println(names[i], ": ", qtys[i], " x $", prices[i]:0:2, " = $", line:0:2, flag); }
    }
    fx { println("grand total: $", grand:0:2); }
    fx { println("low-stock items: ", low); }
    ret;
}
