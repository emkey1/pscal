// 306_recursion_013
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(2, 9) = 512
// expect: digit_sum(926998) = 43
// expect: count_digits(6413972) = 7
// expect: sum_to(11) = 66
// expect: reverse_int(3295665) = 5665923

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(2, 9);
    let ds: Int = digitSum(926998);
    let cd: Int = countDigits(6413972);
    let st: Int = sumTo(11);
    let ri: Int = reverseInt(3295665, 0);
    fx {
        println("power(2, 9) = ", pw);
        println("digit_sum(926998) = ", ds);
        println("count_digits(6413972) = ", cd);
        println("sum_to(11) = ", st);
        println("reverse_int(3295665) = ", ri);
    }
    ret;
}
