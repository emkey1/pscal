// 300_ledger_021
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $500.00
// expect: Deposit $135.00: $635.00
// expect: Interest 5%: $666.75
// expect: Withdraw $230.00: $436.75
// expect: Withdraw $181.00: $255.75
// expect: Deposit $243.00: $498.75
// expect: Deposit $226.00: $724.75
// expect: Interest 5%: $760.99
// expect: Interest 1%: $768.60
// expect: Deposit $12.00: $780.60
// expect: Deposit $251.00: $1031.60
// expect: Deposit $59.00: $1090.60
// expect: Deposit $200.00: $1290.60

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 500.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 135.0);
    fx { println("Deposit $135.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 230.0);
    fx { println("Withdraw $230.00: $", balance:0:2); }
    balance = withdraw(balance, 181.0);
    fx { println("Withdraw $181.00: $", balance:0:2); }
    balance = deposit(balance, 243.0);
    fx { println("Deposit $243.00: $", balance:0:2); }
    balance = deposit(balance, 226.0);
    fx { println("Deposit $226.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 12.0);
    fx { println("Deposit $12.00: $", balance:0:2); }
    balance = deposit(balance, 251.0);
    fx { println("Deposit $251.00: $", balance:0:2); }
    balance = deposit(balance, 59.0);
    fx { println("Deposit $59.00: $", balance:0:2); }
    balance = deposit(balance, 200.0);
    fx { println("Deposit $200.00: $", balance:0:2); }
    ret;
}
