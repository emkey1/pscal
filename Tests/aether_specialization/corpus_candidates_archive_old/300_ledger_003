// expect: Withdraw $242.00: $255.00
// expect: Withdraw $181.00: $74.00
// expect: Deposit $267.00: $341.00
// expect: Withdraw $54.00: $287.00
// expect: Interest 2%: $292.74
// expect: Withdraw $269.00: $23.74
// expect: Withdraw $26.00: $23.74
// expect: Withdraw $285.00: $23.74
// expect: Withdraw $173.00: $23.74
