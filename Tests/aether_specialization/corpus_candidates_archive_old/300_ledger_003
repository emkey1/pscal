// expect: Withdraw $81.00: $238.74

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 247.0);
    fx { println("Deposit $247.00: $", balance:0:2); }
    balance = withdraw(balance, 242.0);
    fx { println("Withdraw $242.00: $", balance:0:2); }
    balance = withdraw(balance, 181.0);
    fx { println("Withdraw $181.00: $", balance:0:2); }
    balance = deposit(balance, 267.0);
    fx { println("Deposit $267.00: $", balance:0:2); }
    balance = withdraw(balance, 54.0);
    fx { println("Withdraw $54.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 269.0);
    fx { println("Withdraw $269.00: $", balance:0:2); }
    balance = withdraw(balance, 26.0);
    fx { println("Withdraw $26.00: $", balance:0:2); }
    balance = withdraw(balance, 285.0);
    fx { println("Withdraw $285.00: $", balance:0:2); }
    balance = withdraw(balance, 173.0);
    fx { println("Withdraw $173.00: $", balance:0:2); }
    balance = deposit(balance, 296.0);
    fx { println("Deposit $296.00: $", balance:0:2); }
    balance = withdraw(balance, 81.0);
    fx { println("Withdraw $81.00: $", balance:0:2); }
    ret;
}
