// 300_ledger_025
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Deposit $186.00: $286.00
// expect: Interest 5%: $300.30
// expect: Withdraw $206.00: $94.30
// expect: Withdraw $255.00: $94.30
// expect: Interest 1%: $95.24
// expect: Withdraw $45.00: $50.24
// expect: Withdraw $183.00: $50.24
// expect: Withdraw $115.00: $50.24

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 186.0);
    fx { println("Deposit $186.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 206.0);
    fx { println("Withdraw $206.00: $", balance:0:2); }
    balance = withdraw(balance, 255.0);
    fx { println("Withdraw $255.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 45.0);
    fx { println("Withdraw $45.00: $", balance:0:2); }
    balance = withdraw(balance, 183.0);
    fx { println("Withdraw $183.00: $", balance:0:2); }
    balance = withdraw(balance, 115.0);
    fx { println("Withdraw $115.00: $", balance:0:2); }
    ret;
}
