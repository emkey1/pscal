// 306_recursion_011
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(4, 9) = 262144
// expect: digit_sum(686565) = 36
// expect: count_digits(3540555) = 7
// expect: sum_to(16) = 136
// expect: reverse_int(3261684) = 4861623

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(4, 9);
    let ds: Int = digitSum(686565);
    let cd: Int = countDigits(3540555);
    let st: Int = sumTo(16);
    let ri: Int = reverseInt(3261684, 0);
    fx {
        println("power(4, 9) = ", pw);
        println("digit_sum(686565) = ", ds);
        println("count_digits(3540555) = ", cd);
        println("sum_to(16) = ", st);
        println("reverse_int(3261684) = ", ri);
    }
    ret;
}
