// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Withdraw $65.00: $35.00
// expect: Deposit $190.00: $225.00
// expect: Withdraw $137.00: $88.00
// expect: Withdraw $10.00: $78.00
// expect: Withdraw $158.00: $78.00
// expect: Deposit $46.00: $124.00
// expect: Deposit $206.00: $330.00
// expect: Withdraw $142.00: $188.00
// expect: Deposit $12.00: $200.00
// expect: Interest 2%: $204.00
// expect: Withdraw $135.00: $69.00

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 65.0);
    fx { println("Withdraw $65.00: $", balance:0:2); }
    balance = deposit(balance, 190.0);
    fx { println("Deposit $190.00: $", balance:0:2); }
    balance = withdraw(balance, 137.0);
    fx { println("Withdraw $137.00: $", balance:0:2); }
    balance = withdraw(balance, 10.0);
    fx { println("Withdraw $10.00: $", balance:0:2); }
    balance = withdraw(balance, 158.0);
    fx { println("Withdraw $158.00: $", balance:0:2); }
    balance = deposit(balance, 46.0);
    fx { println("Deposit $46.00: $", balance:0:2); }
    balance = deposit(balance, 206.0);
    fx { println("Deposit $206.00: $", balance:0:2); }
    balance = withdraw(balance, 142.0);
    fx { println("Withdraw $142.00: $", balance:0:2); }
    balance = deposit(balance, 12.0);
    fx { println("Deposit $12.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 135.0);
    fx { println("Withdraw $135.00: $", balance:0:2); }
    ret;
}
