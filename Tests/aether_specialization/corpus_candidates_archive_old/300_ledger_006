// 300_ledger_006
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Deposit $16.00: $266.00
// expect: Deposit $175.00: $441.00
// expect: Withdraw $117.00: $324.00
// expect: Interest 2%: $330.48
// expect: Withdraw $46.00: $284.48
// expect: Withdraw $25.00: $259.48
// expect: Deposit $149.00: $408.48
// expect: Deposit $162.00: $570.48

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 16.0);
    fx { println("Deposit $16.00: $", balance:0:2); }
    balance = deposit(balance, 175.0);
    fx { println("Deposit $175.00: $", balance:0:2); }
    balance = withdraw(balance, 117.0);
    fx { println("Withdraw $117.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 46.0);
    fx { println("Withdraw $46.00: $", balance:0:2); }
    balance = withdraw(balance, 25.0);
    fx { println("Withdraw $25.00: $", balance:0:2); }
    balance = deposit(balance, 149.0);
    fx { println("Deposit $149.00: $", balance:0:2); }
    balance = deposit(balance, 162.0);
    fx { println("Deposit $162.00: $", balance:0:2); }
    ret;
}
