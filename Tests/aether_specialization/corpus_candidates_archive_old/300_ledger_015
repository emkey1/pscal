// 300_ledger_015
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Interest 2%: $102.00
// expect: Withdraw $215.00: $102.00
// expect: Deposit $166.00: $268.00
// expect: Withdraw $14.00: $254.00
// expect: Withdraw $66.00: $188.00
// expect: Interest 2%: $191.76
// expect: Interest 5%: $201.35
// expect: Deposit $128.00: $329.35
// expect: Withdraw $165.00: $164.35
// expect: Deposit $204.00: $368.35

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = withdraw(balance, 215.0);
    fx { println("Withdraw $215.00: $", balance:0:2); }
    balance = deposit(balance, 166.0);
    fx { println("Deposit $166.00: $", balance:0:2); }
    balance = withdraw(balance, 14.0);
    fx { println("Withdraw $14.00: $", balance:0:2); }
    balance = withdraw(balance, 66.0);
    fx { println("Withdraw $66.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.02);
    fx { println("Interest 2%: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = deposit(balance, 128.0);
    fx { println("Deposit $128.00: $", balance:0:2); }
    balance = withdraw(balance, 165.0);
    fx { println("Withdraw $165.00: $", balance:0:2); }
    balance = deposit(balance, 204.0);
    fx { println("Deposit $204.00: $", balance:0:2); }
    ret;
}
