// 306_recursion_026
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(7, 8) = 5764801
// expect: digit_sum(349585) = 34
// expect: count_digits(5683046) = 7
// expect: sum_to(27) = 378
// expect: reverse_int(6143521) = 1253416

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(7, 8);
    let ds: Int = digitSum(349585);
    let cd: Int = countDigits(5683046);
    let st: Int = sumTo(27);
    let ri: Int = reverseInt(6143521, 0);
    fx {
        println("power(7, 8) = ", pw);
        println("digit_sum(349585) = ", ds);
        println("count_digits(5683046) = ", cd);
        println("sum_to(27) = ", st);
        println("reverse_int(6143521) = ", ri);
    }
    ret;
}
