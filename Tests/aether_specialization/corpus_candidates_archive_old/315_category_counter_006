// 315_category_counter_006
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: pea [veg]
// expect: item 1: apple [fruit]
// expect: item 2: butter [dairy]
// expect: item 3: kale [veg]
// expect: item 4: pea [veg]
// expect: item 5: apple [fruit]
// expect: item 6: bean [veg]
// expect: item 7: fig [fruit]
// expect: item 8: milk [dairy]
// expect: veg: 4
// expect: fruit: 3
// expect: dairy: 2
// expect: categories: 3

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["pea", "apple", "butter", "kale", "pea", "apple", "bean", "fig", "milk"];
    let tags: Text[] = ["veg", "fruit", "dairy", "veg", "veg", "fruit", "veg", "fruit", "dairy"];
    let cats: Text[] = ["veg", "fruit", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
