// 306_recursion_015
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(3, 8) = 6561
// expect: digit_sum(196503) = 24
// expect: count_digits(4400751) = 7
// expect: sum_to(25) = 325
// expect: reverse_int(9929382) = 2839299

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(3, 8);
    let ds: Int = digitSum(196503);
    let cd: Int = countDigits(4400751);
    let st: Int = sumTo(25);
    let ri: Int = reverseInt(9929382, 0);
    fx {
        println("power(3, 8) = ", pw);
        println("digit_sum(196503) = ", ds);
        println("count_digits(4400751) = ", cd);
        println("sum_to(25) = ", st);
        println("reverse_int(9929382) = ", ri);
    }
    ret;
}
