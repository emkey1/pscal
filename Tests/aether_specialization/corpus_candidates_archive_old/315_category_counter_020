// 315_category_counter_020
// Concepts: parallel Text arrays of items and category tags, per-category tally helper with string equality, first-appearance ordering, counted summary
// expect: item 0: barley [grain]
// expect: item 1: plum [fruit]
// expect: item 2: oat [grain]
// expect: item 3: rye [grain]
// expect: item 4: pork [meat]
// expect: item 5: beef [meat]
// expect: item 6: butter [dairy]
// expect: item 7: lime [fruit]
// expect: item 8: lime [fruit]
// expect: item 9: plum [fruit]
// expect: item 10: cream [dairy]
// expect: grain: 3
// expect: fruit: 4
// expect: meat: 2
// expect: dairy: 2
// expect: categories: 4

fn countTag(tags: Text[], cat: Text) -> Int {
    let total: Int = 0;
    loop i in 0..length(tags) {
        if tags[i] == cat { total = total + 1; }
    }
    ret total;
}

fn main() -> Void {
    let items: Text[] = ["barley", "plum", "oat", "rye", "pork", "beef", "butter", "lime", "lime", "plum", "cream"];
    let tags: Text[] = ["grain", "fruit", "grain", "grain", "meat", "meat", "dairy", "fruit", "fruit", "fruit", "dairy"];
    let cats: Text[] = ["grain", "fruit", "meat", "dairy"];
    let n: Int = length(tags);
    let c: Int = length(cats);
    loop i in 0..n {
        fx { println("item ", i, ": ", items[i], " [", tags[i], "]"); }
    }
    loop j in 0..c {
        let total: Int = countTag(tags, cats[j]);
        fx { println(cats[j], ": ", total); }
    }
    fx { println("categories: ", c); }
    ret;
}
