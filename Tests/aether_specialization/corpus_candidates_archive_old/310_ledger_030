// 310_ledger_030
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $250.00
// expect: Deposit $137.00: $387.00
// expect: Deposit $198.00: $585.00
// expect: Withdraw $271.00: $314.00
// expect: Deposit $156.00: $470.00
// expect: Withdraw $236.00: $234.00
// expect: Withdraw $47.00: $187.00
// expect: Interest 1%: $188.87
// expect: Withdraw $59.00: $129.87
// expect: Interest 5%: $136.36
// expect: Withdraw $210.00: $136.36

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 250.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = deposit(balance, 137.0);
    fx { println("Deposit $137.00: $", balance:0:2); }
    balance = deposit(balance, 198.0);
    fx { println("Deposit $198.00: $", balance:0:2); }
    balance = withdraw(balance, 271.0);
    fx { println("Withdraw $271.00: $", balance:0:2); }
    balance = deposit(balance, 156.0);
    fx { println("Deposit $156.00: $", balance:0:2); }
    balance = withdraw(balance, 236.0);
    fx { println("Withdraw $236.00: $", balance:0:2); }
    balance = withdraw(balance, 47.0);
    fx { println("Withdraw $47.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = withdraw(balance, 59.0);
    fx { println("Withdraw $59.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.05);
    fx { println("Interest 5%: $", balance:0:2); }
    balance = withdraw(balance, 210.0);
    fx { println("Withdraw $210.00: $", balance:0:2); }
    ret;
}
