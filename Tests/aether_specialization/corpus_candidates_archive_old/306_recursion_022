// 306_recursion_022
// Concepts: classic single-recursion drills (exponentiation, digit reduction, digit count, triangular sum, integer reversal with accumulator), Int %/ division, base cases
// expect: power(2, 5) = 32
// expect: digit_sum(629319) = 30
// expect: count_digits(1011575) = 7
// expect: sum_to(9) = 45
// expect: reverse_int(7859144) = 4419587

fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { ret 1; }
    ret base * power(base, exp - 1);
}

fn digitSum(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret (n % 10) + digitSum(n / 10);
}

fn countDigits(n: Int) -> Int {
    if n < 10 { ret 1; }
    ret 1 + countDigits(n / 10);
}

fn sumTo(n: Int) -> Int {
    if n == 0 { ret 0; }
    ret n + sumTo(n - 1);
}

fn reverseInt(n: Int, acc: Int) -> Int {
    if n == 0 { ret acc; }
    ret reverseInt(n / 10, acc * 10 + n % 10);
}

fn main() -> Void {
    let pw: Int = power(2, 5);
    let ds: Int = digitSum(629319);
    let cd: Int = countDigits(1011575);
    let st: Int = sumTo(9);
    let ri: Int = reverseInt(7859144, 0);
    fx {
        println("power(2, 5) = ", pw);
        println("digit_sum(629319) = ", ds);
        println("count_digits(1011575) = ", cd);
        println("sum_to(9) = ", st);
        println("reverse_int(7859144) = ", ri);
    }
    ret;
}
