// 310_ledger_012
// Concepts: Real arithmetic, helper functions, overdraft guard, percentage interest, fx formatted output, multi-step state
// expect: Starting balance: $100.00
// expect: Withdraw $265.00: $100.00
// expect: Withdraw $34.00: $66.00
// expect: Deposit $11.00: $77.00
// expect: Interest 1%: $77.77
// expect: Deposit $11.00: $88.77
// expect: Deposit $71.00: $159.77
// expect: Deposit $137.00: $296.77
// expect: Deposit $133.00: $429.77

fn deposit(balance: Real, amount: Real) -> Real {
    ret balance + amount;
}

fn withdraw(balance: Real, amount: Real) -> Real {
    if balance >= amount { ret balance - amount; }
    ret balance;
}

fn applyInterest(balance: Real, rate: Real) -> Real {
    ret balance * (1.0 + rate);
}

fn main() -> Void {
    let balance: Real = 100.0;
    fx { println("Starting balance: $", balance:0:2); }
    balance = withdraw(balance, 265.0);
    fx { println("Withdraw $265.00: $", balance:0:2); }
    balance = withdraw(balance, 34.0);
    fx { println("Withdraw $34.00: $", balance:0:2); }
    balance = deposit(balance, 11.0);
    fx { println("Deposit $11.00: $", balance:0:2); }
    balance = applyInterest(balance, 0.01);
    fx { println("Interest 1%: $", balance:0:2); }
    balance = deposit(balance, 11.0);
    fx { println("Deposit $11.00: $", balance:0:2); }
    balance = deposit(balance, 71.0);
    fx { println("Deposit $71.00: $", balance:0:2); }
    balance = deposit(balance, 137.0);
    fx { println("Deposit $137.00: $", balance:0:2); }
    balance = deposit(balance, 133.0);
    fx { println("Deposit $133.00: $", balance:0:2); }
    ret;
}
