// 309_dp1d_022
// Concepts: 1-D dynamic programming — Kadane's running max-subarray, climbing-stairs step counting (two-back recurrence), house-robber take/skip choice; rolling state, max() via if
// expect: array: 1 8 2 -1 -8 -1 -3 -2 2
// expect: max_subarray = 11
// expect: stairs(15) ways = 987
// expect: houses: 30 26 6 12 2 15 6 27 26
// expect: rob_max = 84

fn maxSubarray(xs: Int[]) -> Int {
    let best: Int = xs[0];
    let cur: Int = xs[0];
    let n: Int = length(xs);
    loop i in 1..n {
        if cur + xs[i] > xs[i] { cur = cur + xs[i]; }
        if cur + xs[i] <= xs[i] { cur = xs[i]; }
        if cur > best { best = cur; }
    }
    ret best;
}

fn climbStairs(n: Int) -> Int {
    let a: Int = 1;
    let b: Int = 1;
    loop i in 2..n + 1 {
        let next: Int = a + b;
        a = b;
        b = next;
    }
    ret b;
}

fn robHouses(xs: Int[]) -> Int {
    let prev2: Int = 0;
    let prev1: Int = 0;
    let n: Int = length(xs);
    loop i in 0..n {
        let take: Int = prev2 + xs[i];
        let best: Int = prev1;
        if take > best { best = take; }
        prev2 = prev1;
        prev1 = best;
    }
    ret prev1;
}

fn joinInts(xs: Int[]) -> Text {
    let out: Text = "";
    let n: Int = length(xs);
    loop i in 0..n {
        if i > 0 { out = out + " "; }
        out = out + int_to_text(xs[i]);
    }
    ret out;
}

fn main() -> Void {
    let arr: Int[] = [1, 8, 2, -1, -8, -1, -3, -2, 2];
    let houses: Int[] = [30, 26, 6, 12, 2, 15, 6, 27, 26];
    let stairs: Int = 15;
    let best: Int = maxSubarray(arr);
    let ways: Int = climbStairs(stairs);
    let rob: Int = robHouses(houses);
    fx {
        println("array: ", joinInts(arr));
        println("max_subarray = ", best);
        println("stairs(", stairs, ") ways = ", ways);
        println("houses: ", joinInts(houses));
        println("rob_max = ", rob);
    }
    ret;
}
