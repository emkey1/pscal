// Verified: place `@pure` on the line above `export fn` inside the module.

mod BenchMetrics {
    export const PassMark: Int = 70;

    @pure
    export fn isPass(score: Int) -> Bool {
        ret score >= PassMark;
    }

    @pure
    export fn band(score: Int) -> Text {
        if score >= 90 { ret "high"; }
        if score >= 70 { ret "mid"; }
        ret "low";
    }
}
