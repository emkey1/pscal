// 45_toon_users_object_root
// Concepts: object-shaped TOON root, array extraction with toon_key, typed field reads
// expect: Processing 2 users
// expect: User # 1 is Alice
// expect: User # 2 is Bob

fn main() -> Void {
    if !has_toon() { fx { println("TOON backend unavailable"); } ret; }

    let json: Text = "{\"users\":[{\"id\":1,\"name\":\"Alice\"},{\"id\":2,\"name\":\"Bob\"}]}";
    let doc: ToonDoc = toon_parse(json);
    let root: ToonNode = toon_root(doc);
    let users: ToonNode = toon_key(root, "users");
    let count: Int = toon_len(users);

    fx { println("Processing ", count, " users"); }

    loop i in 0..count {
        let user: ToonNode = toon_at(users, i);
        let id: Int = toon_get_int(user, "id");
        let name: Text = toon_get_text(user, "name");
        fx { println("User #", id, " is ", name); }
        toon_free(user);
    }

    toon_close(doc);
    ret;
}
