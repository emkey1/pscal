// n3_object_named_array_nested  (wishlist 8)
// Object root, array under data.items, each item may carry a nested info.v.
// expect: a -> 10
// expect: b -> 0
// expect: total = 10

fn main() -> Void {
    if !has_toon() { fx { println("yyjson unavailable"); } ret; }

    let doc: ToonDoc = toon_parse("{\"data\":{\"items\":[{\"label\":\"a\",\"info\":{\"v\":10}},{\"label\":\"b\"}]}}");
    let root: ToonNode = toon_root(doc);

    let total: Int = 0;
    if toon_has_key(root, "data") {
        let data: ToonNode = toon_key(root, "data");
        if toon_has_key(data, "items") {
            let items: ToonNode = toon_key(data, "items");
            loop i in 0..toon_len(items) {
                let item: ToonNode = toon_at(items, i);
                let label: Text = toon_get_text(item, "label");
                let v: Int = 0;
                if toon_has_key(item, "info") {
                    let info: ToonNode = toon_key(item, "info");
                    v = toon_get_int_or(info, "v", 0);
                }
                total = total + v;
                fx { println(label, " -> ", v); }
            }
        }
    }
    fx { println("total = ", total); }
    toon_close(doc);
    ret;
}
