fn main() -> Void {
    if !has_toon() { fx { println("yyjson unavailable"); } ret; }
    let doc: ToonDoc = toon_parse("{\"vals\":[7,\"hi\",false]}");
    let root: ToonNode = toon_root(doc);
    let vals: ToonNode = toon_key(root, "vals");
    loop i in 0..toon_len(vals) {
        let item: ToonNode = toon_at(vals, i);
        let label: Text = "other";
        if toon_is_int(item) { label = "int"; }
        if toon_is_text(item) { label = "text"; }
        if toon_is_bool(item) { label = "bool"; }
        fx { println("item ", i, ": ", label); }
    }
    toon_close(doc);
    ret;
}
