/* --------------------------------------------------------------
 * Example: Job Processor
 *
 * Reads a JSON payload of job objects, normalises scores,
 * classifies them, aggregates stats and prints a report.
 *
 * Demonstrates:
 *   - modules & imports (self‑contained, no external use)
 *   - @pure helpers
 *   - @pre / @post contracts
 *   - @cost annotation
 *   - type blocks with methods
 *   - TOON handling (parse, navigate, fallback)
 *   - fx blocks for all effectful work
 * -------------------------------------------------------------- */

/* --------------------------------------------------------------
 * Constants & configuration
 * -------------------------------------------------------------- */
const DefaultScore: Int = 0;
const MaxScore: Int    = 100;
const ReportWidth: Int = 30;

/* --------------------------------------------------------------
 * Pure helpers
 * -------------------------------------------------------------- */

/* Classification of a normalized score */
@pure
fn classify(score: Int) -> Text {
    if score >= 90 {
        ret "Excellent";
    }
    if score >= 70 {
        ret "Good";
    }
    if score >= 50 {
        ret "Average";
    }
    ret "Poor";
}

/* Normalisation with contracts and a cost budget */
@pre score >= 0
@post result >= 0 && result <= MaxScore
@cost 1ms
fn normalizeScore(score: Int) -> Int {
    if score > MaxScore {
        ret MaxScore;
    }
    ret score;
}

/* --------------------------------------------------------------
 * Data structure for a job summary
 * -------------------------------------------------------------- */
type JobSummary {
    name:     Text;
    rawScore: Int;
    score:    Int;
    status:   Text;
}

/* Method to compute a one‑line description */
fn description(self: JobSummary) -> Text {
    ret self.name + " => " + self.status + " (" + self.score + ")";
}

/* --------------------------------------------------------------
 * Aggregated statistics type
 * -------------------------------------------------------------- */
type Stats {
    count:        Int;
    sumScore:     Int;
    minScore:     Int;
    maxScore:     Int;
}

/* Initialise an empty Stats record */
fn emptyStats() -> Stats {
    let s: Stats = Stats {
        count:    0,
        sumScore: 0,
        minScore: MaxScore,
        maxScore: 0
    };
    ret s;
}

/* Update stats with a new score */
fn update(self: Stats, newScore: Int) -> Stats {
    self.count    = self.count + 1;
    self.sumScore = self.sumScore + newScore;
    if newScore < self.minScore {
        self.minScore = newScore;
    }
    if newScore > self.maxScore {
        self.maxScore = newScore;
    }
    ret self;
}

/* Compute average score (integer division) */
fn average(self: Stats) -> Int {
    if self.count == 0 {
        ret 0;
    }
    ret self.sumScore / self.count;
}

/* --------------------------------------------------------------
 * Helper to safely extract a Text field with fallback
 * -------------------------------------------------------------- */
@pure
fn getTextOr(node: ToonNode, key: Text, fallback: Text) -> Text {
    if toon_has_key(node, key) {
        ret toon_get_text(node, key);
    }
    ret fallback;
}

/* --------------------------------------------------------------
 * Main processing function – builds a list of JobSummary
 * -------------------------------------------------------------- */
fn processJobs(root: ToonNode) -> (JobSummary[], Stats) {
    let summaries: JobSummary[] = [];
    let stats: Stats = emptyStats();

    loop i in 0..toon_len(root) {
        let jobNode: ToonNode = toon_at(root, i);

        /* Extract fields – using fallbacks where appropriate */
        let name:  Text = getTextOr(jobNode, "name", "Unnamed");
        let raw:   Int  = toon_get_int_or(jobNode, "score", DefaultScore);
        let norm:  Int  = normalizeScore(raw);
        let clas:  Text = classify(norm);

        /* Build a summary record */
        let summary: JobSummary = JobSummary {
            name:     name,
            rawScore: raw,
            score:    norm,
            status:   clas
        };
        summaries = summaries + [summary];   // array concatenation

        /* Update aggregated stats */
        stats = update(stats, norm);
    }

    ret (summaries, stats);
}

/* --------------------------------------------------------------
 * Pretty‑print a report
 * -------------------------------------------------------------- */
fn printReport(summaries: JobSummary[], stats: Stats) -> Void {
    fx {
        println("=== Job Processing Report ===");
        println("Total jobs   : ", stats.count);
        println("Average score: ", average(stats));
        println("Min score    : ", stats.minScore);
        println("Max score    : ", stats.maxScore);
        println("------------------------------");
        loop i in 0..len(summaries) {
            let s: JobSummary = summaries[i];
            println(s.description());
        }
        println("------------------------------");
    }
    ret;
}

/* --------------------------------------------------------------
 * Entry point
 * -------------------------------------------------------------- */
fn main() -> Void {
    /* Verify TOON (yyjson) support */
    if !has_toon() {
        fx {
            println("Error: TOON/yyjson library not available.");
        }
        ret;
    }

    /* Load JSON payload – replace with real path when deployed */
    let path: Text = "jobs.json";
    let doc: ToonDoc = toon_parse_file(path);
    let root: ToonNode = toon_root(doc);

    /* Process jobs and collect stats */
    let (summaries, stats) = processJobs(root);

    /* Close the document to free resources */
    toon_close(doc);

    /* Print the final report */
    printReport(summaries, stats);
    ret;
}

