fn adapt_to_payload(json: Text) -> Void {
    if !has_toon() {
        fx { println("yyjson unavailable"); }
        ret;
    }

    let doc: ToonDoc = toon_parse(json);
    let root: ToonNode = toon_root(doc);

    fx {
        println("Root shape detection: ", toon_type(root));
    }

    if toon_is_arr(root) {
        let count: Int = toon_len(root);
        fx { println("Direct array iteration (", count, " items)"); }
        loop i in 0..count {
            let item: ToonNode = toon_at(root, i);
            fx { println("  Index ", i, ": ", toon_text_value(item)); }
        }
    } else {
        if toon_is_obj(root) {
            fx { println("Object root detected. Extracting records key."); }
            if toon_has_key(root, "records") {
                let records: ToonNode = toon_key(root, "records");
                loop i in 0..toon_len(records) {
                    let row: ToonNode = toon_at(records, i);
                    fx { println("  Row ", i, ": ", toon_get_text(row, "id")); }
                }
            }
        }
    }

    toon_close(doc);
    ret;
}

fn main() -> Void {
    let objPayload: Text = "{\"records\": [{\"id\": \"X1\"}, {\"id\": \"X2\"}]}";
    adapt_to_payload(objPayload);
    ret;
}
