type LogStats {
    totalProcessed: Int;
    criticalCount: Int;

    fn record(severity: Text) -> Int {
        self.totalProcessed = self.totalProcessed + 1;
        if severity == "critical" {
            self.criticalCount = self.criticalCount + 1;
        }
        ret self.totalProcessed;
    }
}

@pure
fn getSeverity(code: Int) -> Text {
    if code >= 500 {
        ret "critical";
    }
    if code >= 400 {
        ret "warning";
    }
    ret "info";
}

@pre code >= 0
@post result >= 0
@post result <= 599
fn normalizeCode(code: Int) -> Int {
    if code > 599 {
        ret 500;
    }
    ret code;
}

fn main() -> Void {
    // 1. Check for runtime capability
    if !has_toon() {
        fx {
            println("yyjson unavailable. Cannot parse logs.");
        }
        ret;
    }

    // 2. Initialize our stateful object
    let stats: LogStats = LogStats {
        totalProcessed: 0,
        criticalCount: 0
    };

    // 3. Mock JSON payload (a top-level array of log objects)
    let payload: Text = "[{\"service\":\"auth\",\"code\":401},{\"service\":\"db\",\"code\":503},{\"service\":\"web\",\"code\":200}]";
    
    // 4. Parse TOON data explicitly
    let doc: ToonDoc = toon_parse(payload);
    let root: ToonNode = toon_root(doc);

    fx {
        println("--- Starting Log Analysis ---");
    }

    // 5. Iterate through the top-level array
    let count: Int = toon_len(root);
    loop i in 0..count {
        let entry: ToonNode = toon_at(root, i);
        
        // Extract fields using fallbacks for safety
        let service: Text = toon_get_text_or(entry, "service", "unknown");
        let rawCode: Int = toon_get_int_or(entry, "code", 200);

        // Apply contract-bound and pure helpers
        let code: Int = normalizeCode(rawCode);
        let severity: Text = getSeverity(code);

        // Update our stateful tracker
        stats.record(severity);

        // Print effectful output
        fx {
            println("Service: ", service, " | Code: ", code, " | Severity: ", severity);
        }
    }

    // 6. Final report
    fx {
        println("-----------------------------");
        println("Total Logs Processed : ", stats.totalProcessed);
        println("Critical Alerts      : ", stats.criticalCount);
    }

    // 7. Clean up
    toon_close(doc);
    ret;
}
