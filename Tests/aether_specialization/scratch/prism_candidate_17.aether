fn main() -> Void {
    // This is fine — the array type is inferred from the literal
    let numbers: Int[] = [1, 2, 3, 4];
    
    // This needs an explicit annotation because of the conditional
    let value: Int = if length(numbers) > 0 { numbers[0] } else { 0 };
    
    fx {
        println("First element: ", value);
    }
    ret;
}
