#!/bin/sh
set -e

tmp="./exsh-bg-tool-simple-web.$$"
rm -f "$tmp"

echo "pipeline-bg-tool-simple-web:start"
Examples/clike/base/simple_web_server 1 > "$tmp" 2>&1 &
pid=$!
wait "$pid" 2>/dev/null || true

if grep "initFiles: RootDir=" "$tmp" >/dev/null 2>&1; then
    echo "pipeline-bg-tool-simple-web:file-ok"
else
    echo "pipeline-bg-tool-simple-web:file-missing"
fi
echo "pipeline-bg-tool-simple-web:end"

rm -f "$tmp"
exit 0
