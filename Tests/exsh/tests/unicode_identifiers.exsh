#!/bin/sh
printf 'unicode-ident:start\n'
雪=山
printf 'var=%s\n' "$雪"
printf 'len=%s\n' "${#雪}"
山() { printf 'fn=%s\n' "$1"; }
山 ok
function 海() { printf 'kw=%s\n' "$雪"; }
海
for 雲 in 一 二; do
    printf 'for=%s\n' "$雲"
done
export 空=海
printf 'export=%s\n' "$空"
((数=3))
printf 'arith=%s\n' "$数"
printf 'unicode-ident:end\n'
