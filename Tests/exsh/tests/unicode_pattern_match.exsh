#!/bin/sh
name="雪山"
printf 'unicode-pattern:start\n'
case "$name" in
    ?山) printf 'case=single-prefix\n' ;;
    *) printf 'case=miss\n' ;;
esac
if [[ "$name" = ?山 ]]; then
    printf 'test=match\n'
else
    printf 'test=miss\n'
fi
if [[ "$name" != ?海 ]]; then
    printf 'test-neg=match\n'
else
    printf 'test-neg=miss\n'
fi
case "$name" in
    [雪海]山) printf 'case=bracket-prefix\n' ;;
    *) printf 'case=bracket-miss\n' ;;
esac
if [[ "$name" = [雪海]山 ]]; then
    printf 'test-bracket=match\n'
else
    printf 'test-bracket=miss\n'
fi
if [[ "$name" = [!海]山 ]]; then
    printf 'test-bracket-neg=match\n'
else
    printf 'test-bracket-neg=miss\n'
fi
if [[ "$name" = [[:alpha:]][[:alpha:]] ]]; then
    printf 'test-class-alpha=match\n'
else
    printf 'test-class-alpha=miss\n'
fi
if [[ "9" = [[:digit:]] ]]; then
    printf 'test-class-digit=match\n'
else
    printf 'test-class-digit=miss\n'
fi
printf 'unicode-pattern:end\n'
