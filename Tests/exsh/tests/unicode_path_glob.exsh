#!/bin/sh
tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/exsh-unicode-glob.XXXXXX")" || exit 1
trap 'rm -rf "$tmpdir"' EXIT INT TERM
cd "$tmpdir" || exit 1
touch йӣӘ.txt еұұ.txt .йҡ гҒ—.txt
mkdir йӣӘdir
touch йӣӘdir/еұұ.log
rm -f .йҡ гҒ—.txt
touch .йӣӘ.txt
printf 'unicode-glob:start\n'
printf 'single=%s\n' ?.txt
printf 'nested=%s\n' ?dir/?.log
printf 'dot=%s\n' .?.txt
printf 'unicode-glob:end\n'
