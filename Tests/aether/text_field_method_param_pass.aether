type Item {
    name: Text;
    currentBid: Int;
    owner: Text;

    @pre newBid > self.currentBid
    @post self.currentBid == newBid
    fn placeBid(newBid: Int, bidder: Text) -> Bool {
        self.currentBid = newBid;
        self.owner = bidder;
        ret true;
    }
}

fn main() -> Void {
    let auctionItem: Item = Item {
        name: "Vintage Guitar",
        currentBid: 100,
        owner: "None"
    };

    fx {
        println(auctionItem.placeBid(150, "Alice"));
        println(auctionItem.owner);
        println(auctionItem.currentBid);
    }

    ret;
}
