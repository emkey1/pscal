type Stats {
    count: Int;
    sum: Int;
}

fn update(self: Stats, value: Int) -> Stats {
    self.count = self.count + 1;
    self.sum = self.sum + value;
    ret self;
}

fn average(self: Stats) -> Int {
    if self.count == 0 {
        ret 0;
    }
    ret self.sum / self.count;
}

fn main() -> Void {
    let stats: Stats = Stats {
        count: 0,
        sum: 0
    };

    stats = update(stats, 4);
    stats = update(stats, 6);

    fx {
        println(average(stats));
        println(len("tool"));
    }
    ret;
}
