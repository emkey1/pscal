type Counter {
    value: Int;

    fn current() -> Int {
        ret self.value;
    }

    fn bump() -> Int {
        ret self.value + 1;
    }
}

fn main() -> Void {
    let counter: Counter = Counter { value: 41 };

    fx {
        writeln(counter.current());
        writeln(counter.bump());
    }
    ret;
}
