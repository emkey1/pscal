type Inventory {
    currentStock: Int;
    maxCapacity: Int;

    fn roomLeft() -> Int {
        let remaining = self.maxCapacity - self.currentStock;
        ret remaining;
    }
}

fn main() -> Void {
    let inv = new Inventory();
    inv.currentStock = 7;
    inv.maxCapacity = 10;
    fx {
        writeln(inv.roomLeft());
    }
    ret;
}
