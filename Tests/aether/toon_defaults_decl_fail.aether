fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"enabled\":true}");
    let root: ToonNode = toon_root(doc);
    let fallbackText: Text = "zero";
    let fallbackBool: Bool = false;

    let wrongCount: Int = toon_get_int_or(root, "count", fallbackText);
    let wrongFlag: Text = toon_get_bool_or(root, "enabled", fallbackBool);

    fx {
        println(wrongCount, wrongFlag);
    }

    toon_close(doc);
    ret;
}
