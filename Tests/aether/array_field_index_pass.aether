type Box {
    values: Int[];
}

fn sumValues(self: Box) -> Int {
    let items: Int[] = self.values;
    let total: Int = 0;
    let size: Int = length(items);
    loop i in 0..size {
        total = total + items[i];
    }
    ret total;
}

fn main() -> Void {
    let box: Box = Box { values: [] };
    box.values = box.values + [5];
    box.values = box.values + [9];
    fx {
        println(sumValues(box));
    }
    ret;
}
