fn main() -> Void {
    if !has_toon() {
        fx {
            writeln("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"items\":[{\"name\":\"Ada\"},{\"name\":\"Bob\"}],\"count\":2}");
    let root: ToonNode = toon_root(doc);
    let items: ToonNode = toon_key(root, "items");
    let second: ToonNode = toon_at(items, 1);
    let name: ToonNode = toon_key(second, "name");

    fx {
        writeln(toon_len(items));
        writeln(toon_text_value(name));
        writeln(toon_int_value(toon_key(root, "count")));
    }

    toon_free(name);
    toon_free(second);
    toon_free(items);
    toon_close(doc);
    ret;
}
