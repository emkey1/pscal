const DefaultScore: Int = 50;

@pure
fn jobsLength(jobsNode: ToonNode) -> Int {
    ret toon_len(jobsNode);
}

fn main() -> Void {
    let doc: ToonDoc = toon_parse("{\"jobs\":[{\"name\":\"Ada\",\"score\":91}]}");
    let root: ToonNode = toon_root(doc);
    let jobs: ToonNode = toon_key(root, "jobs");

    let totalJobs: Int = jobsLength(jobs);
    let i: Int = 0;
    loop i < totalJobs {
        let name: Text = toon_get_text(toon_at(jobs, i), "name");
        let rawScore: Int = toon_get_int_or(toon_at(jobs, i), "score", DefaultScore);
        fx {
            println(name, " ", rawScore);
        }
        i = i + 1;
    }

    toon_close(doc);
    ret;
}
