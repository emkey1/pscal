type JobSummary {
    name: Text;
    score: Int;
    status: Text;
    priority: Int;

    fn isReady() -> Bool {
        ret self.priority == 3;
    }
}

fn main() -> Void {
    let priority_val: Int = 3;
    let is_ready = JobSummary { priority: priority_val }.isReady();
    fx {
        println(is_ready);
    }
    ret;
}
