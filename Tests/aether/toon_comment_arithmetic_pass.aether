fn main() -> Void {
    let doc: ToonDoc = toon_parse("{\"jobs\":[{\"name\":\"Ada\"}]}");
    let root: ToonNode = toon_root(doc);
    let jobs: ToonNode = toon_key(root, "jobs");

    /* iterate over every job ------------------------
       mention job and jobs in prose without treating
       either opaque handle as arithmetic. */
    let totalJobs: Int = toon_len(jobs);
    let i: Int = 0;
    loop i < totalJobs {
        /* opaque handle – forwarded only through helpers */
        let job: ToonNode = toon_at(jobs, i);
        let name: Text = toon_get_text(job, "name");
        fx {
            println(name);
        }
        i = i + 1;
    }

    toon_close(doc);
    ret;
}
