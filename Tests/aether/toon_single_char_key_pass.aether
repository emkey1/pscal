fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("[{\"v\": 3.5}, {\"broken\": true}]");
    let root: ToonNode = toon_root(doc);
    let first: ToonNode = toon_at(root, 0);
    let second: ToonNode = toon_at(root, 1);

    let firstHas: Bool = toon_has_key(first, "v");
    let secondHas: Bool = toon_has_key(second, "v");
    let firstValue: Real = toon_get_real_or(first, "v", 0.0);
    let secondValue: Real = toon_get_real_or(second, "v", 0.0);

    fx {
        println(firstHas);
        println(secondHas);
        println(firstValue:0:1);
        println(secondValue:0:1);
    }

    toon_close(doc);
    ret;
}
