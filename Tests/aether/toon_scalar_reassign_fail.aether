fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"enabled\":true}");
    let root: ToonNode = toon_root(doc);
    let enabled: Bool = false;

    enabled = toon_get_text(root, "enabled");

    fx {
        println(enabled);
    }

    toon_close(doc);
    ret;
}
