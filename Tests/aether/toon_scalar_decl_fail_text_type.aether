fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"name\":\"Aether\"}");
    let root: ToonNode = toon_root(doc);
    let wrong: Bool = toon_get_text(root, "name");

    fx {
        println(wrong);
    }
    toon_close(doc);
    ret;
}
