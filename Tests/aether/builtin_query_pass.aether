fn main() -> Void {
    let names: Text = builtins_json();
    let detailed: Text = builtins_json(true);
    let sleepInfo: Text = builtin_info("sleep");
    let toonInfo: Text = builtin_info("toon_len");

    fx {
        println(pos("sleep", names) > 0);
        println(pos("builtins_json", detailed) > 0);
        println(pos("\"backend_name\":\"delay\"", sleepInfo) > 0);
        println(pos("toon_len", toonInfo) > 0);
    }
    ret;
}
