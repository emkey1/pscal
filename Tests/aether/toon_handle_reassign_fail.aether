fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"user\":{\"name\":\"Ada\"}}");
    let current: ToonNode = toon_root(doc);
    current = toon_parse("{\"user\":{\"name\":\"Bob\"}}");

    fx {
        println(toon_text_value(current));
    }
    toon_close(doc);
    ret;
}
