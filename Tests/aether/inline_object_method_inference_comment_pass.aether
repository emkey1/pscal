type JobSummary {
    priority: Int;

    fn isReady() -> Bool {
        ret self.priority == 3;
    }
}

fn main() -> Void {
    let priority_val: Int = 3;
    let is_ready = JobSummary { priority: priority_val }.isReady(); // regression: trailing comment
    fx {
        println(is_ready);
    }
    ret;
}
