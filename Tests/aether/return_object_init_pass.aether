type JobInfo {
    index: Int;
    status: Text;
}

fn buildJob(idx: Int, ready: Bool) -> JobInfo {
    ret JobInfo { index: idx, status: if ready { "ready" } else { "blocked" } };
}

fn main() -> Void {
    let job: JobInfo = buildJob(7, true);
    fx {
        println(job.index);
        println(job.status);
    }
    ret;
}
