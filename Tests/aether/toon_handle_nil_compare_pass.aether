fn main() -> Void {
    if !has_toon() {
        fx {
            writeln("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"name\":\"Aether\"}");
    if doc == nil {
        fx {
            writeln("doc unexpectedly nil");
        }
        ret;
    }

    let root: ToonNode = toon_root(doc);
    if root == nil {
        fx {
            writeln("root unexpectedly nil");
        }
        toon_close(doc);
        ret;
    }

    let missing: ToonNode = toon_key(root, "missing");
    if missing != nil {
        fx {
            writeln("missing key unexpectedly resolved");
        }
    }

    fx {
        writeln("ok");
    }

    toon_close(doc);
    ret;
}
