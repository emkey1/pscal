fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"users\":[{\"name\":\"Ada\"}]}");
    let root: ToonNode = toon_root(doc);
    let badKey: Bool = true;
    let users: ToonNode = toon_key(root, badKey);

    fx {
        println(users);
    }

    toon_close(doc);
    ret;
}
