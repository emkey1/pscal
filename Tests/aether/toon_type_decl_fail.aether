fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"count\":2,\"items\":[1],\"maybe\":null}");
    let root: ToonNode = toon_root(doc);
    let countNode: ToonNode = toon_key(root, "count");
    let itemsNode: ToonNode = toon_key(root, "items");
    let maybeNode: ToonNode = toon_key(root, "maybe");

    let wrongType: Bool = toon_type(countNode);
    let wrongArr: Int = toon_is_arr(itemsNode);
    let wrongNull: Text = toon_is_null(maybeNode);

    fx {
        println(wrongType, wrongArr, wrongNull);
    }

    toon_free(maybeNode);
    toon_free(itemsNode);
    toon_free(countNode);
    toon_close(doc);
    ret;
}
