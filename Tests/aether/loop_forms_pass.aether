fn main() -> Void {
    let total: Int = 0;
    let idx: Int = 0;
    let spins: Int = 0;

    loop idx < 3 {
        total = total + idx;
        idx = idx + 1;
    }

    loop n in 1..4 {
        total = total + n;
    }

    loop {
        spins = spins + 1;
        if spins == 2 {
            break;
        }
    }

    fx {
        println("total = ", total);
        println("spins = ", spins);
    }
    ret;
}
