fn main() -> Void {
    if !has_toon() {
        fx {
            println("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"pi\":3.25}");
    let root: ToonNode = toon_root(doc);
    let wrong: Int = toon_get_real(root, "pi");

    fx {
        println(wrong);
    }

    toon_close(doc);
    ret;
}
