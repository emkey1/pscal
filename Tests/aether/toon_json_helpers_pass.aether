fn main() -> Void {
    if !has_toon() {
        fx {
            writeln("yyjson unavailable");
        }
        ret;
    }

    let doc: ToonDoc = toon_parse("{\"name\":\"Rea\",\"count\":3,\"enabled\":true}");
    let root: ToonNode = toon_root(doc);

    fx {
        println(toon_get_text(root, "name"));
        println(toon_get_int(root, "count"));
        println(toon_get_bool(root, "enabled"));
    }

    toon_close(doc);
    ret;
}
