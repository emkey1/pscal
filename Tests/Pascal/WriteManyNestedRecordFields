program WriteManyNestedRecordFields;

type
  TEnemy = record
    X, Y: Integer;
    HP, MaxHP: Integer;
    Damage: Integer;
    Name: String[15];
    Glyph: Char;
    Speed, Energy, Color: Integer;
    ResistPhysical, ResistMagic: Integer;
    Active: Boolean;
  end;

  TLevel = record
    Enemies: array[1..20] of TEnemy;
  end;

var
  F: Text;
  Levels: array[1..2] of TLevel;
  L, R: Integer;

begin
  for L := 1 to 2 do
    for R := 1 to 20 do
    begin
      Levels[L].Enemies[R].X := R;
      Levels[L].Enemies[R].Y := L;
      Levels[L].Enemies[R].HP := 50;
      Levels[L].Enemies[R].MaxHP := 60;
      Levels[L].Enemies[R].Damage := 7;
      Levels[L].Enemies[R].Name := 'Rat';
      Levels[L].Enemies[R].Glyph := 'r';
      Levels[L].Enemies[R].Speed := 125;
      Levels[L].Enemies[R].Energy := 75;
      Levels[L].Enemies[R].Color := 6;
      Levels[L].Enemies[R].ResistPhysical := 4;
      Levels[L].Enemies[R].ResistMagic := 2;
      Levels[L].Enemies[R].Active := True;
    end;

  Assign(F, 'write_many_nested_fields.sav');
  Rewrite(F);

  for L := 1 to 2 do
    for R := 1 to 20 do
      WriteLn(F,
        Levels[L].Enemies[R].X, ' ', Levels[L].Enemies[R].Y, ' ',
        Levels[L].Enemies[R].HP, ' ', Levels[L].Enemies[R].MaxHP, ' ',
        Levels[L].Enemies[R].Damage, ' ', Levels[L].Enemies[R].Name, ' ',
        Levels[L].Enemies[R].Glyph, ' ', Levels[L].Enemies[R].Speed, ' ',
        Levels[L].Enemies[R].Energy, ' ', Levels[L].Enemies[R].Color, ' ',
        Levels[L].Enemies[R].ResistPhysical, ' ', Levels[L].Enemies[R].ResistMagic, ' ',
        Ord(Levels[L].Enemies[R].Active));

  Close(F);
  WriteLn('ok');
end.
