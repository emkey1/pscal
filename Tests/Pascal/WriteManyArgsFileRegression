program WriteManyArgsFileRegression;

type
  TEnemy = record
    X, Y: Integer;
    HP: Integer;
    MaxHP: Integer;
    Damage: Integer;
    Glyph: Char;
    Active: Integer;
  end;

var
  f: Text;
  e: TEnemy;
  i: Integer;

begin
  e.X := 12;
  e.Y := 34;
  e.HP := 50;
  e.MaxHP := 75;
  e.Damage := 6;
  e.Glyph := 'r';
  e.Active := 1;

  Assign(f, 'write_many_args_test.sav');
  Rewrite(f);

  { Force a large mixed-argument writeln payload similar to save serialization paths. }
  for i := 1 to 5 do
    Writeln(f,
      i, ' ',
      e.X, ' ',
      e.Y, ' ',
      e.HP, ' ',
      e.MaxHP, ' ',
      e.Damage, ' ',
      e.Glyph, ' ',
      e.Active, ' ',
      i * 10, ' ',
      i * 100, ' ',
      i * 1000, ' ',
      i * 10000, ' ',
      i * 100000);

  Close(f);
  Writeln('ok');
end.
